        }, Row)

        local PctLbl = New("TextLabel", {
            Name                   = "Pct",
            Text                   = "0%",
            Font                   = Enum.Font.GothamMedium,
            TextSize               = 12,
            TextColor3             = Theme.Description,
            BackgroundTransparency = 1,
            TextXAlignment         = Enum.TextXAlignment.Right,
            Size                   = UDim2.new(0.3, 0, 1, 0),
            Position               = UDim2.new(0.7, 0, 0, 0),
            BorderSizePixel        = 0,
        }, Row)

        local TrackFrame = New("Frame", {
            Name             = "Track",
            Size             = UDim2.new(1, -20, 0, 6),
            Position         = UDim2.new(0, 10, 1, -10),
            AnchorPoint      = Vector2.new(0, 1),
            BackgroundColor3 = Theme.ProgressBg,
            BorderSizePixel  = 0,
            ClipsDescendants = true,
        }, Wrapper)
        New("UICorner", { CornerRadius = UDim.new(1, 0) }, TrackFrame)

        local FillFrame = New("Frame", {
            Name             = "Fill",
            Size             = UDim2.fromScale(0, 1),
            BackgroundColor3 = Cfg.Color or Theme.ProgressFill,
            BorderSizePixel  = 0,
        }, TrackFrame)
        New("UICorner", { CornerRadius = UDim.new(1, 0) }, FillFrame)

        -- Animated shimmer on the fill (subtle)
        local Shimmer = New("Frame", {
            Size             = UDim2.new(0, 40, 1, 0),
            Position         = UDim2.new(-0.2, 0, 0, 0),
            BackgroundColor3 = Color3.new(1,1,1),
            BackgroundTransparency = 0.78,
            BorderSizePixel  = 0,
        }, FillFrame)
        New("UICorner", { CornerRadius = UDim.new(1, 0) }, Shimmer)
        New("UIGradient", {
            Transparency = NumberSequence.new({
                NumberSequenceKeypoint.new(0, 1),
                NumberSequenceKeypoint.new(0.5, 0),
                NumberSequenceKeypoint.new(1, 1),
            })
        }, Shimmer)

        local Current = math.clamp(Cfg.Default or 0, 0, 1)
        local shimmerConn = nil

        local function StartShimmer()
            if shimmerConn then return end
            shimmerConn = Svc.Run.Heartbeat:Connect(function()
                if not Shimmer.Parent then shimmerConn:Disconnect(); shimmerConn = nil; return end
                local t = tick() % 1.4 / 1.4
                Shimmer.Position = UDim2.new(t - 0.15, 0, 0, 0)
            end)
        end

        local function SetProgress(pct)
            pct     = math.clamp(pct, 0, 1)
            Current = pct
            Tween(FillFrame, Ease.Slow, { Size = UDim2.fromScale(pct, 1) })
            PctLbl.Text = math.floor(pct * 100) .. "%"
            if pct > 0 and pct < 1 then StartShimmer()
            elseif shimmerConn then shimmerConn:Disconnect(); shimmerConn = nil end
        end

        cMaid:Add(function()
            if shimmerConn then shimmerConn:Disconnect(); shimmerConn = nil end
        end)

        SetProgress(Current)

        Registry:Register(function(T)
            if not Wrapper.Parent then return end
            Wrapper.BackgroundColor3    = T.Component
            TitleLbl.TextColor3         = T.Title
            PctLbl.TextColor3           = T.Description
            TrackFrame.BackgroundColor3 = T.ProgressBg
            if not Cfg.Color then FillFrame.BackgroundColor3 = T.ProgressFill end
        end, cMaid)

        local Ctrl = {}
        function Ctrl:Set(pct) SetProgress(pct) end
        function Ctrl:Get()    return Current    end
        function Ctrl:Destroy() Destroy(Wrapper); cMaid:Destroy() end
        return Ctrl
    end


