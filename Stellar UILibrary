local Animations = {}

--- Standard open (scale-in + fade)
function Animations:Open(Win, Transparency, UseCurrentSize)
    local Original   = (UseCurrentSize and Win.Size) or Setup.Size
    local Multiplied = Multiply(Original, 1.06)
    local Shadow     = Win:FindFirstChildOfClass("UIStroke")

    if Shadow then Shadow.Transparency = 1 end
    SetProperty(Win, { Size = Multiplied, GroupTransparency = 1, Visible = true })

    if Shadow then Tween(Shadow, Ease.Quart, { Transparency = 0.55 }) end
    Tween(Win, Ease.Quart, { Size = Original, GroupTransparency = Transparency or 0 })
end

--- Standard close (scale-out + fade)
function Animations:Close(Win)
    local Original   = Win.Size
    local Multiplied = Multiply(Original, 1.06)
    local Shadow     = Win:FindFirstChildOfClass("UIStroke")

    if Shadow then Tween(Shadow, Ease.Quart, { Transparency = 1 }) end
    Tween(Win, Ease.Quart, { Size = Multiplied, GroupTransparency = 1 })

    task.wait(0.2)
    Win.Size    = Original
    Win.Visible = false
end

--- Hover highlight for any interactive component
function Animations:Hover(Component, IsImage, Maid_)
    local base
    local c1 = Connect(Component.InputBegan, function(Input)
        local t = Input.UserInputType
        if t == Enum.UserInputType.MouseMovement or t == Enum.UserInputType.Touch then
            if IsImage then
                Tween(Component, Ease.Fast, { ImageTransparency = 0.25 })
            else
                base = Component.BackgroundColor3
                Tween(Component, Ease.Fast, {
                    BackgroundColor3 = base:Lerp(Theme.Accent, 0.07)
                })
            end
        end
    end)
    local c2 = Connect(Component.InputEnded, function(Input)
        local t = Input.UserInputType
        if t == Enum.UserInputType.MouseMovement or t == Enum.UserInputType.Touch then
            if IsImage then
                Tween(Component, Ease.Fast, { ImageTransparency = 0 })
            elseif base then
                Tween(Component, Ease.Fast, { BackgroundColor3 = base })
            end
        end
    end)
    if Maid_ then Maid_:Add(c1); Maid_:Add(c2) end
end

--- Ink-ripple on button press (programmatic, no assets)
function Animations:Ripple(Button, maid_)
    local conn = Connect(Button.MouseButton1Down, function(x, y)
        local Ripple = New("Frame", {
            Size                   = UDim2.new(0, 0, 0, 0),
            AnchorPoint            = Vector2.new(0.5, 0.5),
            Position               = UDim2.new(0, x - Button.AbsolutePosition.X,
                                                0, y - Button.AbsolutePosition.Y),
            BackgroundColor3       = Theme.Accent,
            BackgroundTransparency = 0.65,
            BorderSizePixel        = 0,
            ZIndex                 = Button.ZIndex + 5,
            ClipsDescendants       = false,
        }, Button)
        New("UICorner", { CornerRadius = UDim.new(1, 0) }, Ripple)

        local target = math.max(Button.AbsoluteSize.X, Button.AbsoluteSize.Y) * 2.2
        Tween(Ripple, TweenInfo.new(0.45, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            Size                   = UDim2.new(0, target, 0, target),
            BackgroundTransparency = 1,
        })
        task.delay(0.5, function() Destroy(Ripple) end)
    end)
    if maid_ then maid_:Add(conn) end
end

--- Accent-glow pulse on a UIStroke (one-shot)
function Animations:PulseGlow(inst, maid_)
    local stroke = inst:FindFirstChildOfClass("UIStroke")
        or New("UIStroke", { Color = Theme.AccentGlow, Thickness = 1.5, Transparency = 0.6 }, inst)
    Tween(stroke, TweenInfo.new(0.15, Enum.EasingStyle.Sine, Enum.EasingDirection.Out),
        { Thickness = 3, Transparency = 0.1, Color = Theme.AccentGlow })
    task.delay(0.15, function()
        Tween(stroke, TweenInfo.new(0.4, Enum.EasingStyle.Sine, Enum.EasingDirection.Out),
            { Thickness = 1.5, Transparency = 0.6, Color = Theme.Outline })
    end)
end


-- ═══════════════════════════════════════════════════
--  Library.CreateWindow
-- ═══════════════════════════════════════════════════
--[[
    Settings = {
        Title:             string          — Window title
        Subtitle:          string?         — Subtext below title
        Icon:              string?         — rbxassetid for icon
        Size:              UDim2           — Initial window size
        Transparency:      number?         — 0 = opaque (default)
        Theme:             string?         — "Dark"|"Light"|"Midnight"|"Sakura"
        MinimizeKeybind:   Enum.KeyCode?
        Blurring:          boolean?
        MinSize:           Vector2?
        MaxSize:           Vector2?
    }
]]

function Library.CreateWindow(Settings)
    ValidateCfg("CreateWindow", Settings, { "Title", "Size" })

    local WinMaid    = Maid.new()
    local WinState   = { DragType = nil }

    local Window     = Clone(Screen.Main)
    local Examples   = Screen:FindFirstChild("Examples")
    local Sidebar    = Window:FindFirstChild("Sidebar")
    local Holder     = Window:FindFirstChild("Holder")
    local TabList    = Sidebar and Sidebar:FindFirstChild("List")
    local BG         = Window:FindFirstChild("BG")
    local StoredInfo = { Tabs = {}, Sections = {} }

    local Options        = {}
    local Opened         = true
    local Maximized      = false
    local BlurEnabled    = false
    local PreMaxPos      = nil
    local ThemeCallbacks = {}
    local ActiveNotifs   = {}

    -- Active theme (local reference for this window — theme switch fires Registry:Apply globally)
    local _Theme = Themes[Settings.Theme or Setup.ThemeMode] or Themes.Dark

    -- ── Config ─────────────────────────────────────────────────────
    Setup.Transparency = Settings.Transparency or 0
    Setup.Size         = Settings.Size
    Setup.ThemeMode    = Settings.Theme or "Dark"
    if Settings.MinimizeKeybind then Setup.Keybind = Settings.MinimizeKeybind end


    -- ══════════════════════════════════════════
    --  DRAG SYSTEM  (per-window)
    -- ══════════════════════════════════════════

    local function MakeDraggable(Canvas, Handle)
        if not Canvas then return end
        Handle = Handle or Canvas
        local Dragging, DragInput, Start, StartPos

        WinMaid:Add(Connect(Handle.InputBegan, function(Input)
            local t = Input.UserInputType
            if (t == Enum.UserInputType.MouseButton1 or t == Enum.UserInputType.Touch)
                and not WinState.DragType then
                Dragging = true
                Start    = Input.Position
                StartPos = Canvas.Position
                WinMaid:Add(Connect(Input.Changed, function()
                    if Input.UserInputState == Enum.UserInputState.End then
                        Dragging = false
                    end
                end))
            end
        end))

        WinMaid:Add(Connect(Handle.InputChanged, function(Input)
            local t = Input.UserInputType
            if t == Enum.UserInputType.MouseMovement or t == Enum.UserInputType.Touch then
                DragInput = Input
            end
        end))

        WinMaid:Add(Connect(Svc.Input.InputChanged, function(Input)
            if Input == DragInput and Dragging and not WinState.DragType then
                local delta = Input.Position - Start
                Canvas.Position = UDim2.new(
                    StartPos.X.Scale, StartPos.X.Offset + delta.X,
                    StartPos.Y.Scale, StartPos.Y.Offset + delta.Y
                )
            end
        end))
    end

    -- ── Resize grip (bottom-right) ────────────────────────────────

    local function AddResizeGrip(Tab, Minimum, Maximum)
        if not Tab then return end
        Minimum = Minimum or Vector2.new(320, 240)
        Maximum = Maximum or Vector2.new(1800, 1200)

        local Grip = New("Frame", {
            Name                   = "ResizeGrip",
            Size                   = UDim2.new(0, 20, 0, 20),
            Position               = UDim2.new(1, -2, 1, -2),
            AnchorPoint            = Vector2.new(1, 1),
            BackgroundColor3       = Theme.Accent,
            BackgroundTransparency = 0.55,
            ZIndex                 = 20,
            BorderSizePixel        = 0,
        }, Tab)
        New("UICorner", { CornerRadius = UDim.new(0, 5) }, Grip)

        for _, d in ipairs({ {11,3}, {3,11}, {11,11} }) do
            New("Frame", {
                Size             = UDim2.new(0, 3, 0, 3),
                Position         = UDim2.new(0, d[1], 0, d[2]),
                BackgroundColor3 = Color3.fromRGB(210, 220, 255),
                BorderSizePixel  = 0,
                ZIndex           = 21,
                Parent           = Grip,
            })
        end

        local Resizing, StartMouse, StartSize, ActiveTouch = false, nil, nil, nil

        local function BeginResize(pos)
            WinState.DragType = "BottomRight"
            Resizing   = true; StartMouse = pos
            StartSize  = Vector2.new(Tab.AbsoluteSize.X, Tab.AbsoluteSize.Y)
        end
        local function EndResize()
            WinState.DragType = nil; Resizing = false
            StartMouse = nil; StartSize = nil; ActiveTouch = nil
            Tween(Grip, Ease.Quart, { BackgroundTransparency = 0.55 })
        end
        local function DoResize(pos)
            if not (Resizing and StartMouse and StartSize) then return end
            local D = pos - StartMouse
            Tab.Size = UDim2.new(0,
                math.clamp(StartSize.X + D.X, Minimum.X, Maximum.X), 0,
                math.clamp(StartSize.Y + D.Y, Minimum.Y, Maximum.Y))
        end

        WinMaid:Add(Connect(Grip.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 then
                BeginResize(Vector2.new(Input.Position.X, Input.Position.Y))
                Tween(Grip, Ease.Fast, { BackgroundTransparency = 0.15 })
            elseif Input.UserInputType == Enum.UserInputType.Touch then
                ActiveTouch = Input
                BeginResize(Vector2.new(Input.Position.X, Input.Position.Y))
                Tween(Grip, Ease.Fast, { BackgroundTransparency = 0.15 })
                WinMaid:Add(Connect(Input.Changed, function()
                    if Input.UserInputState == Enum.UserInputState.End then
                        if Resizing and ActiveTouch == Input then EndResize() end
                    elseif Resizing and ActiveTouch == Input then
                        DoResize(Vector2.new(Input.Position.X, Input.Position.Y))
                    end
                end))
            end
        end))
        WinMaid:Add(Connect(Svc.Input.InputChanged, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseMovement and Resizing then
                DoResize(Vector2.new(Input.Position.X, Input.Position.Y))
            end
        end))
        WinMaid:Add(Connect(Svc.Input.InputEnded, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 and Resizing then
                EndResize()
            end
        end))
        WinMaid:Add(Connect(Grip.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseMovement then
                Tween(Grip, Ease.Fast, { BackgroundTransparency = 0.3 })
            end
        end))
        WinMaid:Add(Connect(Grip.InputEnded, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseMovement then
                Tween(Grip, Ease.Fast, { BackgroundTransparency = 0.55 })
            end
        end))
    end

    local DragHandle = Window:FindFirstChild("TitleBar") or Window
    MakeDraggable(Window, DragHandle)
    AddResizeGrip(Window,
        Settings.MinSize or Vector2.new(380, 260),
        Settings.MaxSize or Vector2.new(1800, 1200))


    -- ── Blur ───────────────────────────────────────────────────────

    if Settings.Blurring then
        xpcall(function()
            Blurs[Settings.Title] = Blur.new(Window, 5)
            BlurEnabled = true
        end, function(err)
            warn("[Stellar] Blur init failed: " .. tostring(err))
        end)
    end


    -- ── Title bar wiring ───────────────────────────────────────────

    local TitleBar = Window:FindFirstChild("TitleBar")
    if TitleBar then
        local TL = TitleBar:FindFirstChild("Title")
        local SL = TitleBar:FindFirstChild("Subtitle") or TitleBar:FindFirstChild("Description")
        local IL = TitleBar:FindFirstChild("Icon")

        if TL then TL.Text = Settings.Title    or "Window" end
        if SL then SL.Text = Settings.Subtitle or ""       end
        if IL and Settings.Icon then IL.Image = Settings.Icon end

        -- Live-update helpers
        function Options:SetTitle(str)    if TL then TL.Text = str end end
        function Options:SetSubtitle(str) if SL then SL.Text = str end end

        -- Theme toggle button
        local ThemeBtn   = TitleBar:FindFirstChild("ThemeSelect")
        if ThemeBtn then
            local ThemeLabel = ThemeBtn:FindFirstChild("Label") or ThemeBtn:FindFirstChild("TextLabel")
            if ThemeLabel then ThemeLabel.Text = Setup.ThemeMode end

            WinMaid:Add(Connect(ThemeBtn.MouseButton1Click, function()
                local order = { "Dark", "Light", "Midnight", "Sakura" }
                local cur = Setup.ThemeMode
                local idx = table.find(order, cur) or 1
                local newMode = order[(idx % #order) + 1]

                Setup.ThemeMode = newMode
                if ThemeLabel then ThemeLabel.Text = newMode end
                Options:SetSetting("Theme", newMode)
            end))
            Animations:Hover(ThemeBtn, false, WinMaid)
        end
    end


    -- ── Toggle visibility ──────────────────────────────────────────

    local function ToggleWindow()
        if Opened then
            Opened = false
            if BlurEnabled and Blurs[Settings.Title] then
                pcall(function() Blurs[Settings.Title].root.Parent = nil end)
            end
            Animations:Close(Window)
        else
            Opened = true
            Animations:Open(Window, Setup.Transparency)
            if BlurEnabled and Blurs[Settings.Title] then
                pcall(function() Blurs[Settings.Title].root.Parent = workspace.CurrentCamera end)
            end
        end
    end


    -- ── Window control buttons ─────────────────────────────────────

    local ButtonsFrame = (TitleBar and TitleBar:FindFirstChild("Buttons"))
        or (Sidebar and Sidebar:FindFirstChild("Top") and Sidebar.Top:FindFirstChild("Buttons"))

    if ButtonsFrame then
        for _, Btn in next, ButtonsFrame:GetChildren() do
            if Btn:IsA("TextButton") or Btn:IsA("ImageButton") then
                Animations:Hover(Btn, Btn:IsA("ImageButton"), WinMaid)
                WinMaid:Add(Connect(Btn.MouseButton1Click, function()
                    local n = Btn.Name
                    if n == "Close" then
                        ToggleWindow()
                    elseif n == "Maximize" then
                        if Maximized then
                            Maximized = false
                            Tween(Window, Ease.Quart, { Size = Setup.Size, Position = PreMaxPos })
                        else
                            Maximized = true
                            PreMaxPos = Window.Position
                            Tween(Window, Ease.Quart, {
                                Size     = UDim2.fromScale(1, 1),
                                Position = UDim2.fromScale(0.5, 0.5),
                            })
                        end
                    elseif n == "Minimize" then
                        Opened         = false
                        Window.Visible = false
                        if BlurEnabled and Blurs[Settings.Title] then
                            pcall(function() Blurs[Settings.Title].root.Parent = nil end)
                        end
                    end
                end))
            end
        end
    end


    -- ── Keybind toggle ─────────────────────────────────────────────

    WinMaid:Add(Connect(Svc.Input.InputBegan, function(Input, GameFocused)
        if GameFocused then return end
        if Input == Setup.Keybind or Input.KeyCode == Setup.Keybind then
            ToggleWindow()
        end
    end))


    -- ── Mobile swipe (left/right = change tab) ─────────────────────

    if IsMobile and TabList then
        local SwipeStart, SwipeStartT = nil, nil
        WinMaid:Add(Connect(Window.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.Touch then
                SwipeStart  = Input.Position
                SwipeStartT = tick()
            end
        end))
        WinMaid:Add(Connect(Window.InputEnded, function(Input)
            if Input.UserInputType ~= Enum.UserInputType.Touch then return end
            if not (SwipeStart and SwipeStartT) then return end
            local dt  = tick() - SwipeStartT
            local dx  = Input.Position.X - SwipeStart.X
            local adx = math.abs(dx)
            local ady = math.abs(Input.Position.Y - SwipeStart.Y)
            if dt < 0.35 and adx > 80 and adx > ady * 1.5 then
                local tabs = {}
                for _, Btn in next, TabList:GetChildren() do
                    if Btn:IsA("TextButton") and Btn.Visible then
                        tabs[#tabs + 1] = Btn
                    end
                end
                table.sort(tabs, function(a, b) return a.LayoutOrder < b.LayoutOrder end)
                local activeIdx = 1
                for i, Btn in ipairs(tabs) do
                    local Val = Btn:FindFirstChild("Value")
                    if Val and Val.Value then activeIdx = i; break end
                end
                local newIdx = (dx < 0)
                    and math.min(activeIdx + 1, #tabs)
                    or  math.max(activeIdx - 1, 1)
                if newIdx ~= activeIdx then Options:SetTab(tabs[newIdx].Name) end
            end
            SwipeStart = nil; SwipeStartT = nil
        end))
    end


    -- ══════════════════════════════════════════
    --  TAB SYSTEM
    -- ══════════════════════════════════════════

    function Options:SetTab(Name)
        if not TabList then return end
        for _, Button in next, TabList:GetChildren() do
            if Button:IsA("TextButton") then
                local isTarget = (Button.Name == Name)
                local Val      = Button:FindFirstChild("Value")
                local Pad      = Button:FindFirstChildOfClass("UIPadding")
                local ICO      = Button:FindFirstChild("ICO")

                if isTarget and not (Val and Val.Value) then
                    if Pad then Tween(Pad, Ease.Quart, { PaddingLeft = UDim.new(0, 22) }) end
                    Tween(Button, Ease.Quart, {
                        BackgroundTransparency = 0.88,
                        BackgroundColor3       = Theme.Accent,
                    })
                    if ICO then Tween(ICO, Ease.Quart, { ImageColor3 = Theme.Accent }) end
                    local TL = Button:FindFirstChild("TextLabel")
                    if TL then Tween(TL, Ease.Quart, { TextColor3 = Theme.TabActive }) end
                    if Val then Val.Value = true end

                elseif not isTarget and (Val and Val.Value) then
                    if Pad then Tween(Pad, Ease.Quart, { PaddingLeft = UDim.new(0, 16) }) end
                    Tween(Button, Ease.Quart, {
                        BackgroundTransparency = 1,
                        BackgroundColor3       = Theme.Component,
                    })
                    if ICO then Tween(ICO, Ease.Quart, { ImageColor3 = Theme.Icon }) end
                    local TL = Button:FindFirstChild("TextLabel")
                    if TL then Tween(TL, Ease.Quart, { TextColor3 = Theme.Tab }) end
                    if Val then Val.Value = false end
                end
            end
        end

        if not Holder then return end
        for _, Main in next, Holder:GetChildren() do
            if Main:IsA("CanvasGroup") then
                local isTarget = (Main.Name == Name)
                local Val      = Main:FindFirstChild("Value")
                local Scroll   = Main:FindFirstChild("ScrollingFrame")
                local Pad      = Scroll and Scroll:FindFirstChild("UIPadding")

                if isTarget and not (Val and Val.Value) then
                    if Val then Val.Value = true end
                    Main.Visible = true
                    Tween(Main, Ease.Sine, { GroupTransparency = 0 })
                    if Pad then Tween(Pad, Ease.Sine, { PaddingTop = UDim.new(0, 8) }) end

                elseif not isTarget and (Val and Val.Value) then
                    if Val then Val.Value = false end
                    Tween(Main, Ease.Fast, { GroupTransparency = 1 })
                    if Pad then Tween(Pad, Ease.Fast, { PaddingTop = UDim.new(0, 18) }) end
                    task.delay(0.18, function() if Main then Main.Visible = false end end)
                end
            end
        end
    end


    function Options:AddTabSection(Cfg)
        ValidateCfg("AddTabSection", Cfg, { "Name" })
        local Example = Examples and Examples["SectionExample"]
        if not Example then return end
        local Section = Clone(Example)
        StoredInfo.Sections[Cfg.Name] = Cfg.Order
        SetProperty(Section, {
            Parent      = Example.Parent,
            Text        = Cfg.Name,
            Name        = Cfg.Name,
            LayoutOrder = Cfg.Order,
            Visible     = true,
        })
    end


    function Options:AddTab(Cfg)
        ValidateCfg("AddTab", Cfg, { "Title" })
        if StoredInfo.Tabs[Cfg.Title] then
            error("[Stellar] Duplicate tab: " .. Cfg.Title)
        end

        local BtnExample  = Examples and Examples["TabButtonExample"]
        local MainExample = Examples and Examples["MainExample"]
        if not (BtnExample and MainExample) then return end

        local Main = Clone(MainExample)
        local Tab  = Clone(BtnExample)

        local ICO = Tab:FindFirstChild("ICO")
        if Cfg.Icon and ICO then ICO.Image = Cfg.Icon
        elseif ICO then Destroy(ICO) end

        local TL = Tab:FindFirstChild("TextLabel")
        if TL then TL.Text = Cfg.Title end

        local Order = Cfg.Order or (StoredInfo.Tabs._count or 0) + 1
        StoredInfo.Tabs._count = Order

        SetProperty(Tab, {
            Parent      = TabList,
            Name        = Cfg.Title,
            LayoutOrder = Order,
            Visible     = true,
        })
        SetProperty(Main, {
            Parent      = Holder,
            Name        = Cfg.Title,
            Visible     = false,
        })

        if Cfg.Section and StoredInfo.Sections[Cfg.Section] then
            Tab.LayoutOrder = StoredInfo.Sections[Cfg.Section] + (Order * 0.01)
        end

        Animations:Hover(Tab, false, WinMaid)

        WinMaid:Add(Connect(Tab.MouseButton1Click, function()
            Options:SetTab(Cfg.Title)
        end))

        StoredInfo.Tabs[Cfg.Title] = { Tab = Tab, Main = Main }

        -- First tab auto-selects
        if Order == 1 then Options:SetTab(Cfg.Title) end

        -- Return the scroll container so components can be parented to it
        local Scroll = Main:FindFirstChild("ScrollingFrame") or Main
        return Scroll
    end


    -- ════════════════════════════════════════
    --  TAB BADGE  (new)
    -- ════════════════════════════════════════

    function Options:AddTabBadge(tabName, text)
        local entry = StoredInfo.Tabs[tabName]
        if not entry then return end
        local Tab = entry.Tab

        local existing = Tab:FindFirstChild("_Badge")
        if existing then existing:Destroy() end

        if not text or text == "" or text == 0 then return end

        local badge = New("Frame", {
            Name             = "_Badge",
            Size             = UDim2.new(0, 18, 0, 18),
            Position         = UDim2.new(1, -6, 0, 6),
            AnchorPoint      = Vector2.new(1, 0),
            BackgroundColor3 = Theme.BadgeBg,
            BorderSizePixel  = 0,
            ZIndex           = Tab.ZIndex + 3,
        }, Tab)
        New("UICorner", { CornerRadius = UDim.new(1, 0) }, badge)
        New("TextLabel", {
            Text                   = tostring(text),
            Font                   = Enum.Font.GothamBold,
            TextSize               = 10,
            TextColor3             = Theme.BadgeText,
            BackgroundTransparency = 1,
            Size                   = UDim2.fromScale(1, 1),
            TextXAlignment         = Enum.TextXAlignment.Center,
            TextYAlignment         = Enum.TextYAlignment.Center,
            ZIndex                 = Tab.ZIndex + 4,
        }, badge)

        -- Register badge for theme
        Registry:Register(function(T)
            if badge and badge.Parent then
                badge.BackgroundColor3 = T.BadgeBg
                local lbl = badge:FindFirstChildOfClass("TextLabel")
                if lbl then lbl.TextColor3 = T.BadgeText end
            end
        end, WinMaid)
    end

    function Options:ClearTabBadge(tabName)
        Options:AddTabBadge(tabName, nil)
    end


    -- ════════════════════════════════════════
    --  NOTIFICATION  (enhanced v3 — typed)
    -- ════════════════════════════════════════
    --[[
        Cfg = {
            Title:       string
            Description: string?
            Duration:    number?   (default 5 s)
            Type:        "info"|"success"|"warning"|"error"  (default "info")
            Action:      { Label: string, Callback: function }?
            Progress:    boolean?  — show animated progress bar draining to 0
        }
    ]]

    local TypeIcon = {
        info    = "ℹ",
        success = "✓",
        warning = "⚠",
        error   = "✕",
    }

    local function RepositionNotifs()
        local yOffset = 16
        for _, N in ipairs(ActiveNotifs) do
            if N and N.Parent then
                Tween(N, Ease.Quart, { Position = UDim2.new(1, -16, 1, -(yOffset + N.AbsoluteSize.Y)) })
                yOffset = yOffset + N.AbsoluteSize.Y + 8
            end
        end
    end

    function Options:Notify(Cfg)
        ValidateCfg("Notify", Cfg, { "Title" })
        local Duration = Cfg.Duration or 5
        local NType    = Cfg.Type or "info"
        local Accent   = Theme["Note" .. (NType:sub(1,1):upper() .. NType:sub(2))] or Theme.NoteInfo

        local Height   = 68 + (Cfg.Description and 16 or 0) + (Cfg.Action and 28 or 0) + (Cfg.Progress and 8 or 0)

        local Notif = New("CanvasGroup", {
            Name                   = "Notification",
            Size                   = UDim2.new(0, IsMobile and 260 or 290, 0, Height),
            Position               = UDim2.new(1, 320, 1, -100),
            AnchorPoint            = Vector2.new(1, 1),
            BackgroundColor3       = Theme.Primary,
            GroupTransparency      = 1,
            BorderSizePixel        = 0,
            ZIndex                 = 50,
        }, Screen)
        New("UICorner", { CornerRadius = UDim.new(0, 10) }, Notif)

        local Stroke = New("UIStroke", { Color = Theme.Outline, Thickness = 1.2 }, Notif)

        -- Accent left bar
        New("Frame", {
            Size             = UDim2.new(0, 3, 1, -16),
            Position         = UDim2.new(0, 10, 0, 8),
            AnchorPoint      = Vector2.new(0, 0),
            BackgroundColor3 = Accent,
            BorderSizePixel  = 0,
        }, Notif)

