--  UTILITY
-- ═══════════════════════════════════════════════════

local function Clone(obj)       return obj:Clone()                                end
local function Destroy(obj)     pcall(function() obj:Destroy() end)               end
local function Connect(sig, fn) return sig:Connect(fn)                            end

local function Tween(obj, info, props)
    if not (obj and obj.Parent) then return end
    Svc.Tween:Create(obj, info or Ease.Quart, props):Play()
end

local function SetProperty(obj, props)
    for k, v in next, props do obj[k] = v end
    return obj
end

local function Multiply(value, amount)
    return UDim2.new(
        value.X.Scale  * amount, value.X.Offset * amount,
        value.Y.Scale  * amount, value.Y.Offset * amount
    )
end

local function LerpColor(a, b, t) return a:Lerp(b, t) end

local function ShiftColor(color, factor)
    local f = (Setup.ThemeMode == "Light" or Setup.ThemeMode == "Sakura")
        and -math.abs(factor) or math.abs(factor)
    return Color3.fromRGB(
        math.clamp((color.R * 255) + f, 0, 255),
        math.clamp((color.G * 255) + f, 0, 255),
        math.clamp((color.B * 255) + f, 0, 255))
end

local function Color3ToHex(c)
    return string.format("#%02X%02X%02X",
        math.round(c.R * 255), math.round(c.G * 255), math.round(c.B * 255))
end

local function HexToColor3(hex)
    hex = hex:gsub("^#", "")
    if #hex ~= 6 then return nil end
    local r = tonumber(hex:sub(1,2), 16)
    local g = tonumber(hex:sub(3,4), 16)
    local b = tonumber(hex:sub(5,6), 16)
    if not (r and g and b) then return nil end
    return Color3.fromRGB(r, g, b)
end

--- Validate a Cfg table and warn on missing required keys
local function ValidateCfg(caller, cfg, required)
    for _, key in ipairs(required) do
        if cfg[key] == nil then
            warn(string.format("[Stellar:%s] missing required Cfg.%s", caller, key))
        end
    end
end

--- Make an instance of a given class with a single property table call
local function New(class, props, parent)
    local inst = Instance.new(class)
    if parent then inst.Parent = parent end
    for k, v in next, props do inst[k] = v end
    return inst
end


