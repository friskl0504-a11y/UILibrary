    function Options:AddNumberInput(Cfg)
        ValidateCfg("AddNumberInput", Cfg, { "Title", "Tab" })
        local cMaid  = WinMaid:Child()
        local Changed = Signal.new()
        cMaid:Add(Changed)

        local Min    = Cfg.Min    or 0
        local Max    = Cfg.Max    or math.huge
        local Step   = Cfg.Step   or 1
        local Value  = math.clamp(Cfg.Default or Min, Min, Max)

        local H = TouchH
        local Wrapper = New("Frame", {
            Name             = "NumberInput_" .. Cfg.Title,
            Size             = UDim2.new(1, 0, 0, H),
            BackgroundColor3 = Theme.Component,
            BorderSizePixel  = 0,
            Parent           = Cfg.Tab,
            Visible          = true,
        })
        New("UICorner", { CornerRadius = CORNER }, Wrapper)

        -- Labels
        local LblTitle = New("TextLabel", {
            Text                   = Cfg.Title or "",
            Font                   = Enum.Font.GothamSemibold,
            TextSize               = 13,
            TextColor3             = Theme.Title,
            BackgroundTransparency = 1,
            TextXAlignment         = Enum.TextXAlignment.Left,
            Size                   = UDim2.new(0.55, 0, 0.5, 0),
            Position               = UDim2.new(0, 12, 0, 0),
        }, Wrapper)
        if Cfg.Description then
            New("TextLabel", {
                Text                   = Cfg.Description,
                Font                   = Enum.Font.Gotham,
                TextSize               = 11,
                TextColor3             = Theme.Description,
                BackgroundTransparency = 1,
                TextXAlignment         = Enum.TextXAlignment.Left,
                Size                   = UDim2.new(0.55, 0, 0.5, 0),
                Position               = UDim2.new(0, 12, 0.5, 0),
            }, Wrapper)
        end

        -- Right side: [−] [textbox] [+]
        local BtnW  = H - 8
        local BoxW  = 52

        local MinusBtn = New("TextButton", {
            Text             = "−",
            Font             = Enum.Font.GothamBold,
            TextSize         = 16,
            TextColor3       = Theme.Accent,
            BackgroundColor3 = Theme.Interactable,
            BorderSizePixel  = 0,
            AutoButtonColor  = false,
            Size             = UDim2.new(0, BtnW, 0, BtnW),
            Position         = UDim2.new(1, -(BtnW * 2 + BoxW + 8), 0.5, 0),
            AnchorPoint      = Vector2.new(0, 0.5),
        }, Wrapper)
        New("UICorner", { CornerRadius = UDim.new(0, 6) }, MinusBtn)

        local BoxFrame = New("Frame", {
            Size             = UDim2.new(0, BoxW, 0, BtnW),
            Position         = UDim2.new(1, -(BtnW + BoxW + 4), 0.5, 0),
            AnchorPoint      = Vector2.new(0, 0.5),
            BackgroundColor3 = Theme.Interactable,
            BorderSizePixel  = 0,
        }, Wrapper)
        New("UICorner", { CornerRadius = UDim.new(0, 6) }, BoxFrame)

        local TB = New("TextBox", {
            Text                   = tostring(Value) .. (Cfg.Suffix or ""),
            Font                   = Enum.Font.GothamSemibold,
            TextSize               = 13,
            TextColor3             = Theme.Title,
            BackgroundTransparency = 1,
            TextXAlignment         = Enum.TextXAlignment.Center,
            PlaceholderText        = "0",
            Size                   = UDim2.fromScale(1, 1),
            ClearTextOnFocus       = true,
        }, BoxFrame)

        local PlusBtn = New("TextButton", {
            Text             = "+",
            Font             = Enum.Font.GothamBold,
            TextSize         = 16,
            TextColor3       = Theme.Accent,
            BackgroundColor3 = Theme.Interactable,
            BorderSizePixel  = 0,
            AutoButtonColor  = false,
            Size             = UDim2.new(0, BtnW, 0, BtnW),
            Position         = UDim2.new(1, -BtnW - 4, 0.5, 0),
            AnchorPoint      = Vector2.new(0, 0.5),
        }, Wrapper)
        New("UICorner", { CornerRadius = UDim.new(0, 6) }, PlusBtn)

        local function SetValue(n)
            Value = math.clamp(n, Min, Max)
            TB.Text = tostring(Value) .. (Cfg.Suffix or "")
            Changed:Fire(Value)
            if Cfg.Callback then task.spawn(Cfg.Callback, Value) end
        end

        cMaid:Add(Connect(MinusBtn.MouseButton1Click, function()
            local s = Svc.Input:IsKeyDown(Enum.KeyCode.LeftShift) and Step * 10 or Step
            SetValue(Value - s)
            Tween(MinusBtn, Ease.Fast, { BackgroundColor3 = LerpColor(Theme.Interactable, Theme.Accent, 0.2) })
            task.delay(0.12, function() Tween(MinusBtn, Ease.Quart, { BackgroundColor3 = Theme.Interactable }) end)
        end))

        cMaid:Add(Connect(PlusBtn.MouseButton1Click, function()
            local s = Svc.Input:IsKeyDown(Enum.KeyCode.LeftShift) and Step * 10 or Step
            SetValue(Value + s)
            Tween(PlusBtn, Ease.Fast, { BackgroundColor3 = LerpColor(Theme.Interactable, Theme.Accent, 0.2) })
            task.delay(0.12, function() Tween(PlusBtn, Ease.Quart, { BackgroundColor3 = Theme.Interactable }) end)
        end))

        cMaid:Add(Connect(TB.FocusLost, function()
            local n = tonumber(TB.Text:gsub(Cfg.Suffix or "", ""))
            if n then SetValue(n) else TB.Text = tostring(Value) .. (Cfg.Suffix or "") end
        end))

        -- Scroll wheel on the whole wrapper
        cMaid:Add(Connect(Wrapper.InputChanged, function(Inp)
            if Inp.UserInputType == Enum.UserInputType.MouseWheel then
                local s = Svc.Input:IsKeyDown(Enum.KeyCode.LeftShift) and Step * 10 or Step
                SetValue(Value + Inp.Position.Z * s)
            end
        end))

        Animations:Hover(MinusBtn, false, cMaid)
        Animations:Hover(PlusBtn,  false, cMaid)

        Registry:Register(function(T)
            if not Wrapper.Parent then return end
            Wrapper.BackgroundColor3 = T.Component
            BoxFrame.BackgroundColor3 = T.Interactable
            MinusBtn.BackgroundColor3 = T.Interactable
            PlusBtn.BackgroundColor3  = T.Interactable
            LblTitle.TextColor3       = T.Title
            TB.TextColor3             = T.Title
            MinusBtn.TextColor3       = T.Accent
            PlusBtn.TextColor3        = T.Accent
        end, cMaid)

        local Ctrl = {}
        function Ctrl:Set(n)        SetValue(n) end
        function Ctrl:Get()         return Value end
        function Ctrl:OnChanged(fn) return Changed:Connect(fn) end
        function Ctrl:Destroy()     Destroy(Wrapper); cMaid:Destroy() end
        return Ctrl
    end


    -- ════════════════════════════════════════
    --  KEYBIND
    -- ════════════════════════════════════════

    function Options:AddKeybind(Cfg)
        ValidateCfg("AddKeybind", Cfg, { "Title", "Tab" })
        local Keybind = Components and Clone(Components["Keybind"])
        if not Keybind then return end

        local cMaid   = WinMaid:Child()
        local Title, Desc = Options:GetLabels(Keybind)
        local Main    = Keybind:FindFirstChild("Main")
        local KeyLbl  = Main and (Main:FindFirstChild("Options") or Main:FindFirstChild("Key"))
        local CurrentKey = Cfg.Default
        local Listening  = false
        local ListenDebounce = false
        local Changed = Signal.new()
        cMaid:Add(Changed)

        local function UpdateLabel()
            if not KeyLbl then return end
            if Listening then
                KeyLbl.Text = "..."
            elseif CurrentKey then
                KeyLbl.Text = tostring(CurrentKey.Name or CurrentKey):gsub("Enum.KeyCode.", "")
            else
                KeyLbl.Text = "None"
            end
        end
        UpdateLabel()

        cMaid:Add(Connect(Keybind.MouseButton1Click, function()
            if ListenDebounce then return end
            ListenDebounce = true
            Listening = true
            UpdateLabel()
            Tween(Keybind, Ease.Quart, {
                BackgroundColor3 = LerpColor(Theme.Component, Theme.Accent, 0.15)
            })

            local conn
            conn = Connect(Svc.Input.InputBegan, function(Input, GameFocused)
                if GameFocused then return end
                local t = Input.UserInputType
                if t == Enum.UserInputType.Keyboard then
                    CurrentKey = Input.KeyCode
                    Changed:Fire(CurrentKey)
                    if Cfg.Callback then task.spawn(Cfg.Callback, CurrentKey) end
                elseif Cfg.AllowMouse and t == Enum.UserInputType.MouseButton1 then
                    CurrentKey = Enum.KeyCode.Unknown  -- placeholder for mouse
                    Changed:Fire(CurrentKey)
                    if Cfg.Callback then task.spawn(Cfg.Callback, CurrentKey) end
                end
                Listening = false
                UpdateLabel()
                Tween(Keybind, Ease.Quart, { BackgroundColor3 = Theme.Component })
                conn:Disconnect()
                task.delay(0.3, function() ListenDebounce = false end)
            end)
            cMaid:Add(conn)
        end))

        Animations:Hover(Keybind, false, cMaid)
        if Title then Title.Text = Cfg.Title       or "" end
        if Desc  then Desc.Text  = Cfg.Description or "" end
        SetProperty(Keybind, { Name = Cfg.Title, Parent = Cfg.Tab, Visible = true })

        local Ctrl = {}
        function Ctrl:Set(kc)       CurrentKey = kc; UpdateLabel() end
        function Ctrl:Get()         return CurrentKey end
        function Ctrl:OnChanged(fn) return Changed:Connect(fn) end
        function Ctrl:Destroy()     Destroy(Keybind); cMaid:Destroy() end
        return Ctrl
    end


    -- ════════════════════════════════════════
    --  DROPDOWN  (improved — auto close on outside click, optional search)
    -- ════════════════════════════════════════

    function Options:AddDropdown(Cfg)
        ValidateCfg("AddDropdown", Cfg, { "Title", "Tab", "Options" })
        local Dropdown = Components and Clone(Components["Dropdown"])
        if not Dropdown then return end

        local cMaid = WinMaid:Child()
        local Title, Desc  = Options:GetLabels(Dropdown)
        local OptionsLabel = Dropdown:FindFirstChild("Main") and Dropdown.Main:FindFirstChild("Options")
        local CurrentValue = Cfg.Default
        local Changed = Signal.new()
        cMaid:Add(Changed)

        if OptionsLabel and CurrentValue then
            for k, v in next, Cfg.Options do
                if v == CurrentValue then OptionsLabel.Text = tostring(k); break end
            end
        end

        local OpenDD = nil  -- reference to open dropdown frame

        local function CloseDropdown()
            if not OpenDD then return end
            if BG then Tween(BG, Ease.Quart, { BackgroundTransparency = 1 }) end
            Animations:Close(OpenDD)
            task.delay(0.25, function() if OpenDD then Destroy(OpenDD) end; OpenDD = nil end)
        end

        cMaid:Add(Connect(Dropdown.MouseButton1Click, function()
            if OpenDD then CloseDropdown(); return end

            local Example = Examples and Clone(Examples["DropdownExample"])
            if not Example then return end

            OpenDD = Example
            local CloseButtons = Example:FindFirstChild("Top") and Example.Top:FindFirstChild("Buttons")
            local ScrollFrame  = Example:FindFirstChild("ScrollingFrame") or Example

            -- Optional search box
            local FilterText = ""
            local ItemBtns   = {}

            if Cfg.Searchable then
                local SearchRow = New("Frame", {
                    Size             = UDim2.new(1, 0, 0, 32),
                    BackgroundColor3 = Theme.Secondary,
                    BorderSizePixel  = 0,
                    LayoutOrder      = -999,
                }, ScrollFrame)
                New("UIPadding", { PaddingLeft = UDim.new(0, 8), PaddingRight = UDim.new(0, 8),
                                   PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 4) }, SearchRow)
                local SearchBox = New("TextBox", {
                    Text                   = "",
                    PlaceholderText        = "Search...",
                    Font                   = Enum.Font.Gotham,
                    TextSize               = 12,
                    TextColor3             = Theme.Title,
                    PlaceholderColor3      = Theme.Muted,
                    BackgroundTransparency = 1,
                    Size                   = UDim2.fromScale(1, 1),
                    ClearTextOnFocus       = false,
                }, SearchRow)
                Connect(SearchBox:GetPropertyChangedSignal("Text"), function()
                    FilterText = SearchBox.Text:lower()
                    for _, pair in ipairs(ItemBtns) do
                        pair.btn.Visible = (FilterText == "" or pair.key:lower():find(FilterText, 1, true) ~= nil)
                    end
                end)
            end

            if BG then Tween(BG, Ease.Quart, { BackgroundTransparency = 0.5 }) end
            Example.Parent = Window
            Animations:Open(Example, 0, true)

            if CloseButtons then
                for _, Btn in next, CloseButtons:GetChildren() do
                    if Btn:IsA("TextButton") then
                        Animations:Hover(Btn)
                        Connect(Btn.MouseButton1Click, CloseDropdown)
                    end
                end
            end

            for Index, Option in next, Cfg.Options do
                local Btn = Clone(Examples["DropdownButtonExample"])
                if not Btn then continue end
                local BTitle, _ = Options:GetLabels(Btn)
                if BTitle then BTitle.Text = tostring(Index) end
                if Option == CurrentValue then
                    Btn.BackgroundColor3 = LerpColor(Theme.Component, Theme.Accent, 0.15)
                end
                SetProperty(Btn, { Parent = ScrollFrame, Visible = true })
                Animations:Hover(Btn)
                table.insert(ItemBtns, { btn = Btn, key = tostring(Index) })

                Connect(Btn.MouseButton1Click, function()
                    CurrentValue = Option
                    if OptionsLabel then OptionsLabel.Text = tostring(Index) end
                    Changed:Fire(CurrentValue)
                    if Cfg.Callback then task.spawn(Cfg.Callback, CurrentValue) end
                    CloseDropdown()
                end)
            end

            -- Close on outside click
            local globalConn
            globalConn = Connect(Svc.Input.InputBegan, function(Input)
                if Input.UserInputType == Enum.UserInputType.MouseButton1 then
                    -- Check if clicked outside the dropdown
                    local mPos = Svc.Input:GetMouseLocation()
                    local ddPos  = Example.AbsolutePosition
                    local ddSize = Example.AbsoluteSize
                    if mPos.X < ddPos.X or mPos.X > ddPos.X + ddSize.X
                    or mPos.Y < ddPos.Y or mPos.Y > ddPos.Y + ddSize.Y then
                        CloseDropdown()
                        globalConn:Disconnect()
                    end
                end
            end)
        end))

        Animations:Hover(Dropdown, false, cMaid)
        if Title then Title.Text = Cfg.Title       or "" end
        if Desc  then Desc.Text  = Cfg.Description or "" end
        SetProperty(Dropdown, { Name = Cfg.Title, Parent = Cfg.Tab, Visible = true })

        local Ctrl = {}
        function Ctrl:Set(value)
            CurrentValue = value
            if OptionsLabel then
                for k, v in next, Cfg.Options do
                    if v == value then OptionsLabel.Text = tostring(k); break end
                end
            end
        end
        function Ctrl:Get()         return CurrentValue end
        function Ctrl:OnChanged(fn) return Changed:Connect(fn) end
        function Ctrl:Destroy()     CloseDropdown(); Destroy(Dropdown); cMaid:Destroy() end
        return Ctrl
    end


    -- ════════════════════════════════════════
    --  MULTI-DROPDOWN  (improved — searchable)
    -- ════════════════════════════════════════

    function Options:AddMultiDropdown(Cfg)
        ValidateCfg("AddMultiDropdown", Cfg, { "Title", "Tab", "Options" })
