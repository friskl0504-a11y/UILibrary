-- ═════════════════════════════════════════════════════════════
--  Window Animations  (stateless — no module-level Setup reads)
-- ═════════════════════════════════════════════════════════════

local Animations = {}

function Animations:Open(Window, Transparency, FromSize)
    local Original   = FromSize or Window.Size
    local Multiplied = Multiply(Original, 1.07)
    local Shadow     = Window:FindFirstChildOfClass("UIStroke")

    if Shadow then Shadow.Transparency = 1 end
    SetProperty(Window, {
        Size              = Multiplied,
        GroupTransparency = 1,
        Visible           = true,
    })

    if Shadow then Tween(Shadow, 0.18, { Transparency = 0.6 }) end
    Tween(Window, 0.18, {
        Size              = Original,
        GroupTransparency = Transparency or 0,
    })
end

function Animations:Close(Window)
    local Original   = Window.Size
    local Multiplied = Multiply(Original, 1.07)
    local Shadow     = Window:FindFirstChildOfClass("UIStroke")

    if Shadow then Tween(Shadow, 0.18, { Transparency = 1 }) end
    Tween(Window, 0.18, { Size = Multiplied, GroupTransparency = 1 })

    task.wait(0.2)
    Window.Size    = Original
    Window.Visible = false
end

--- Hover highlight; pass a Maid to track for cleanup.
function Animations:Hover(Component, IsImage, Maid_, accent)
    if not Component then return end
    accent = accent or Color3.fromRGB(108, 130, 255)
    local base
    local c1 = Connect(Component.InputBegan, function(Input)
        local t = Input.UserInputType
        if t == Enum.UserInputType.MouseMovement
           or (IsMobile and t == Enum.UserInputType.Touch) then
            if IsImage then
                Tween(Component, 0.12, { ImageTransparency = 0.25 })
            else
                base = Component.BackgroundColor3
                Tween(Component, 0.12, {
                    BackgroundColor3 = base:Lerp(accent, 0.08),
                })
            end
        end
    end)
    local c2 = Connect(Component.InputEnded, function(Input)
        local t = Input.UserInputType
        if t == Enum.UserInputType.MouseMovement
           or (IsMobile and t == Enum.UserInputType.Touch) then
            if IsImage then
                Tween(Component, 0.12, { ImageTransparency = 0 })
            else
                if base then Tween(Component, 0.12, { BackgroundColor3 = base }) end
            end
        end
    end)
    if Maid_ then
        Maid_:Add(c1)
        Maid_:Add(c2)
    end
end



-- ═════════════════════════════════════════════════════════════
--  Library.CreateWindow
-- ═════════════════════════════════════════════════════════════
--[[
    Settings = {
        Title:           string          — Window title
        Subtitle:        string?         — Small text below title
        Icon:            string?         — rbxassetid for icon
        Size:            UDim2           — Initial window size
        Transparency:    number?         — 0 = opaque (default)
        MinimizeKeybind: Enum.KeyCode?
        Blurring:        boolean?
        Theme:           string?         — "Dark" (default) | "Light"
        ConfigName:      string?         — auto-save flag for components
    }
    Returns: Options table
]]

function Library:CreateWindow(Settings)
    Settings = Settings or {}

    -- ── Per-window state (FIXED: was module-level) ───────────────────────
    local WinMaid     = Maid.new()
    local WinState    = { DragType = nil }
    local StoredInfo  = { Sections = {}, Tabs = {} }
    local WinSetup    = {
        Keybind      = Settings.MinimizeKeybind or Enum.KeyCode.LeftControl,
        Transparency = Settings.Transparency    or 0,
        ThemeMode    = (Themes[Settings.Theme] and Settings.Theme) or "Dark",
        Size         = Settings.Size,
    }
    local Theme = Themes[WinSetup.ThemeMode]

    -- Per-window flags for save/load
    local Flags          = {}        -- flag → {Get, Set}
    local Components     = {}        -- list of component controllers (for :Destroy all)
    local ThemeCallbacks = {}
    local ActiveNotifs   = {}

    -- Per-window ShiftColor (uses per-window ThemeMode)
    local function ShiftColor(color, factor)
        local f = (WinSetup.ThemeMode == "Light") and -math.abs(factor) or math.abs(factor)
        return Color3.fromRGB(
            math.clamp((color.R * 255) + f, 0, 255),
            math.clamp((color.G * 255) + f, 0, 255),
            math.clamp((color.B * 255) + f, 0, 255)
        )
    end

    -- ── Clone window template ────────────────────────────────────────────
    local Window  = Clone(Screen:WaitForChild("Main"))
    local Sidebar = Window:FindFirstChild("Sidebar")
    local Holder  = Window:FindFirstChild("Main")
    local BG      = Window:FindFirstChild("BackgroundShadow")
    local TabList = Sidebar and Sidebar:FindFirstChild("Tab")

    -- ── Collect example templates ────────────────────────────────────────
    local Examples = {}
    for _, ex in next, Window:GetDescendants() do
        if ex.Name:find("Example") and not Examples[ex.Name] then
            Examples[ex.Name] = ex
        end
    end

    -- ── Internal state ───────────────────────────────────────────────────
    local Options     = {}
    local Opened      = true
    local Maximized   = false
    local BlurEnabled = false
    local PreMaxPos   = nil
    local FAB         = nil   -- mobile floating-action-button


    -- ═══════════════════════════════════════════════════════════════════
    --  DRAG SYSTEM  (FIXED: no per-mousedown listener leak)
    -- ═══════════════════════════════════════════════════════════════════

    local function MakeDraggable(Canvas, Handle)
        if not Canvas then return end
        Handle = Handle or Canvas

        local Dragging, DragInput, Start, StartPos

        WinMaid:Add(Connect(Handle.InputBegan, function(Input)
            local t = Input.UserInputType
            if (t == Enum.UserInputType.MouseButton1 or t == Enum.UserInputType.Touch)
               and not WinState.DragType then
                Dragging = true
                Start    = Input.Position
                StartPos = Canvas.Position
            end
        end))

        WinMaid:Add(Connect(Handle.InputChanged, function(Input)
            local t = Input.UserInputType
            if t == Enum.UserInputType.MouseMovement or t == Enum.UserInputType.Touch then
                DragInput = Input
            end
        end))

        -- Use shared InputHub (no per-mousedown listener spawn)
        WinMaid:Add(InputHub:OnChanged(function(Input)
            if Input == DragInput and Dragging and not WinState.DragType then
                local delta = Input.Position - Start
                Canvas.Position = UDim2.new(
                    StartPos.X.Scale, StartPos.X.Offset + delta.X,
                    StartPos.Y.Scale, StartPos.Y.Offset + delta.Y
                )
            end
        end))

        WinMaid:Add(InputHub:OnEnded(function(Input)
            local t = Input.UserInputType
            if (t == Enum.UserInputType.MouseButton1 or t == Enum.UserInputType.Touch)
               and Dragging then
                Dragging = false
            end
        end))
    end


    -- ── Bottom-right resize grip (Mouse + Touch) ─────────────────────────

    local function AddResizeGrip(Tab, Minimum, Maximum)
        if not Tab then return end
        Minimum = Minimum or Vector2.new(280,  200)
        Maximum = Maximum or Vector2.new(1800, 1200)

        local GripSize = IsMobile and 28 or 20

        local Grip = Instance.new("Frame")
        SetProperty(Grip, {
            Name                   = "ResizeGrip",
            Size                   = UDim2.new(0, GripSize, 0, GripSize),
            Position               = UDim2.new(1, -2, 1, -2),
            AnchorPoint            = Vector2.new(1, 1),
            BackgroundColor3       = Theme.Accent,
            BackgroundTransparency = 0.55,
            ZIndex                 = 20,
            BorderSizePixel        = 0,
            ClipsDescendants       = false,
            Parent                 = Tab,
        })
        Instance.new("UICorner", Grip).CornerRadius = UDim.new(0, 5)

        local DotDefs = IsMobile
            and { {15, 5}, {5, 15}, {15, 15} }
            or  { {11, 3}, {3, 11}, {11, 11} }
        for _, d in ipairs(DotDefs) do
            local Dot = Instance.new("Frame")
            SetProperty(Dot, {
                Size             = UDim2.new(0, 3, 0, 3),
                Position         = UDim2.new(0, d[1], 0, d[2]),
                BackgroundColor3 = Color3.fromRGB(200, 210, 255),
                BorderSizePixel  = 0,
                ZIndex           = 21,
                Parent           = Grip,
            })
            Instance.new("UICorner", Dot).CornerRadius = UDim.new(1, 0)
        end

        Animations:Hover(Grip, false, WinMaid, Theme.Accent)

        local Resizing, StartMouse, StartSize, ActiveTouch = false, nil, nil, nil

        local function BeginResize(pos)
            WinState.DragType = "BottomRight"
            Resizing   = true
            StartMouse = pos
            StartSize  = Vector2.new(Tab.AbsoluteSize.X, Tab.AbsoluteSize.Y)
            Tween(Grip, 0.1, { BackgroundTransparency = 0.15 })
        end

        local function EndResize()
            WinState.DragType = nil
            Resizing, StartMouse, StartSize, ActiveTouch = false, nil, nil, nil
            Tween(Grip, 0.12, { BackgroundTransparency = 0.55 })
        end

        local function DoResize(pos)
            if not (Resizing and StartMouse and StartSize) then return end
            local Delta = pos - StartMouse
            Tab.Size = UDim2.new(0,
                math.clamp(StartSize.X + Delta.X, Minimum.X, Maximum.X),
                0,
                math.clamp(StartSize.Y + Delta.Y, Minimum.Y, Maximum.Y)
            )
        end

        WinMaid:Add(Connect(Grip.InputBegan, function(Input)
            local t = Input.UserInputType
            if t == Enum.UserInputType.MouseButton1 then
                BeginResize(Vector2.new(Input.Position.X, Input.Position.Y))
            elseif t == Enum.UserInputType.Touch then
                ActiveTouch = Input
                BeginResize(Vector2.new(Input.Position.X, Input.Position.Y))
            end
        end))

        WinMaid:Add(InputHub:OnChanged(function(Input)
            if not Resizing then return end
            local t = Input.UserInputType
            if t == Enum.UserInputType.MouseMovement then
                DoResize(Vector2.new(Input.Position.X, Input.Position.Y))
            elseif t == Enum.UserInputType.Touch and Input == ActiveTouch then
                DoResize(Vector2.new(Input.Position.X, Input.Position.Y))
            end
        end))

        WinMaid:Add(InputHub:OnEnded(function(Input)
            local t = Input.UserInputType
            if (t == Enum.UserInputType.MouseButton1
                or (t == Enum.UserInputType.Touch and Input == ActiveTouch))
               and Resizing then
                EndResize()
            end
        end))
    end


    -- ── Attach drag & resize ─────────────────────────────────────────────
    local DragHandle = Window:FindFirstChild("TitleBar") or Window
    MakeDraggable(Window, DragHandle)
    AddResizeGrip(Window, Vector2.new(380, 260), Vector2.new(1800, 1200))


    -- ── Blur ─────────────────────────────────────────────────────────────
    if Settings.Blurring and Blur then
        xpcall(function()
            Blurs[Settings.Title] = Blur.new(Window, 5)
            BlurEnabled = true
        end, function(err)
            warn("[UILib] Blur init failed: " .. tostring(err))
        end)
    end


    -- ── Titlebar ─────────────────────────────────────────────────────────
    local TitleBar = Window:FindFirstChild("TitleBar")
    if TitleBar then
        local TL = TitleBar:FindFirstChild("Title")
        local SL = TitleBar:FindFirstChild("Subtitle") or TitleBar:FindFirstChild("Description")
        local IL = TitleBar:FindFirstChild("Icon")

        if TL then TL.Text = Settings.Title    or "Window" end
        if SL then SL.Text = Settings.Subtitle or ""       end
        if IL and Settings.Icon then IL.Image = Settings.Icon end

        local ThemeBtn   = TitleBar:FindFirstChild("ThemeSelect")
        if ThemeBtn then
            local ThemeLabel = ThemeBtn:FindFirstChild("Label") or ThemeBtn:FindFirstChild("TextLabel")
            if ThemeLabel then ThemeLabel.Text = WinSetup.ThemeMode end

            WinMaid:Add(Connect(ThemeBtn.MouseButton1Click, function()
                local newMode = (WinSetup.ThemeMode == "Dark") and "Light" or "Dark"
                WinSetup.ThemeMode = newMode
                Theme = Themes[newMode]
                if ThemeLabel then ThemeLabel.Text = newMode end
                Options:SetTheme()
                for _, fn in ipairs(ThemeCallbacks) do
                    task.spawn(fn, newMode, Theme)
                end
                Buzz(0.3)
            end))

            Animations:Hover(ThemeBtn, false, WinMaid, Theme.Accent)
        end
    end


    -- ── Toggle visibility ────────────────────────────────────────────────
    local function ToggleWindow()
        if Opened then
            Opened = false
            if BlurEnabled and Blurs[Settings.Title] then
                pcall(function() Blurs[Settings.Title].root.Parent = nil end)
            end
            Animations:Close(Window)
            if IsMobile and FAB then FAB:Show() end
        else
            Opened = true
            Animations:Open(Window, WinSetup.Transparency, WinSetup.Size)
            if BlurEnabled and Blurs[Settings.Title] then
                pcall(function() Blurs[Settings.Title].root.Parent = workspace.CurrentCamera end)
            end
            if IsMobile and FAB then FAB:Hide() end
        end
    end


    -- ── Window control buttons ───────────────────────────────────────────
    local ButtonsFrame = (TitleBar and TitleBar:FindFirstChild("Buttons"))
        or (Sidebar and Sidebar:FindFirstChild("Top") and Sidebar.Top:FindFirstChild("Buttons"))

    if ButtonsFrame then
        for _, Btn in next, ButtonsFrame:GetChildren() do
            if Btn:IsA("TextButton") or Btn:IsA("ImageButton") then
                Animations:Hover(Btn, Btn:IsA("ImageButton"), WinMaid, Theme.Accent)

                WinMaid:Add(Connect(Btn.MouseButton1Click, function()
                    local n = Btn.Name
                    if n == "Close" then
                        ToggleWindow()
                    elseif n == "Maximize" then
                        if Maximized then
                            Maximized = false
                            Tween(Window, 0.14, {
                                Size     = WinSetup.Size,
                                Position = PreMaxPos,
                            })
                        else
                            Maximized = true
                            PreMaxPos = Window.Position
                            Tween(Window, 0.14, {
                                Size     = UDim2.fromScale(1, 1),
                                Position = UDim2.fromScale(0.5, 0.5),
                            })
                        end
                    elseif n == "Minimize" then
                        Opened = false
                        Window.Visible = false
                        if BlurEnabled and Blurs[Settings.Title] then
                            pcall(function() Blurs[Settings.Title].root.Parent = nil end)
                        end
                        if IsMobile and FAB then FAB:Show() end
                    end
                end))
            end
        end
    end


    -- ── Keybind toggle ───────────────────────────────────────────────────
    WinMaid:Add(Connect(Services.Input.InputBegan, function(Input, GameFocused)
        if GameFocused then return end
        if Input == WinSetup.Keybind or Input.KeyCode == WinSetup.Keybind then
            ToggleWindow()
        end
    end))


    -- ── Mobile swipe gesture — left/right to change tabs ─────────────────
    if IsMobile and TabList then
        local SwipeStart, SwipeStartT = nil, nil

        WinMaid:Add(Connect(Window.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.Touch then
                SwipeStart  = Input.Position
                SwipeStartT = tick()
            end
        end))

        WinMaid:Add(Connect(Window.InputEnded, function(Input)
            if Input.UserInputType ~= Enum.UserInputType.Touch then return end
            if not (SwipeStart and SwipeStartT) then return end

            local dt    = tick() - SwipeStartT
            local dx    = Input.Position.X - SwipeStart.X
            local absDx = math.abs(dx)
            local absDy = math.abs(Input.Position.Y - SwipeStart.Y)

            if dt < 0.35 and absDx > 80 and absDx > absDy * 1.5 then
                local tabs = {}
                for _, Btn in next, TabList:GetChildren() do
                    if Btn:IsA("TextButton") and Btn.Visible then
                        tabs[#tabs + 1] = Btn
                    end
                end
                table.sort(tabs, function(a, b) return a.LayoutOrder < b.LayoutOrder end)

                local activeIdx = 1
                for i, Btn in ipairs(tabs) do
                    local Val = Btn:FindFirstChild("Value")
                    if Val and Val.Value then activeIdx = i; break end
                end

                local newIdx = (dx < 0)
                    and math.min(activeIdx + 1, #tabs)
                    or  math.max(activeIdx - 1, 1)

                if newIdx ~= activeIdx and tabs[newIdx] then
                    Options:SetTab(tabs[newIdx].Name)
                    Buzz(0.25)
                end
            end

            SwipeStart, SwipeStartT = nil, nil
        end))
    end


    -- ═══════════════════════════════════════════════════════════════════
    --  FLOATING ACTION BUTTON  (mobile-only, NEW in v3.0)
    -- ═══════════════════════════════════════════════════════════════════
    --[[
        Mobile users have no physical keyboard, so a hidden window is
        gone forever unless they re-launch the script. The FAB is a
        draggable, dismissable icon that re-opens the window in one tap.
    ]]
    if IsMobile then
        local FabBtn = Instance.new("TextButton")
        SetProperty(FabBtn, {
            Name                   = "FAB_" .. (Settings.Title or "Window"),
            Size                   = UDim2.new(0, 52, 0, 52),
            Position               = UDim2.new(1, -78, 1, -78),
            AnchorPoint            = Vector2.new(0, 0),
            BackgroundColor3       = Theme.Accent,
            BorderSizePixel        = 0,
            AutoButtonColor        = false,
            Text                   = "",
            Visible                = false,
            ZIndex                 = 50,
            Parent                 = Screen,
        })
        Instance.new("UICorner", FabBtn).CornerRadius = UDim.new(1, 0)
        local FabStroke = Instance.new("UIStroke", FabBtn)
        FabStroke.Color = Theme.Outline
        FabStroke.Thickness = 1
        FabStroke.Transparency = 0.5

        local FabIcon = Instance.new("TextLabel", FabBtn)
        SetProperty(FabIcon, {
            Text                   = (Settings.Title or "S"):sub(1, 1):upper(),
            Font                   = Enum.Font.GothamBold,
            TextSize               = 22,
            TextColor3             = Color3.new(1, 1, 1),
            BackgroundTransparency = 1,
            Size                   = UDim2.fromScale(1, 1),
            BorderSizePixel        = 0,
            ZIndex                 = 51,
        })

        -- Subtle pulse animation when shown
        FAB = {}
        function FAB:Show()
            FabBtn.Size = UDim2.new(0, 0, 0, 0)
            FabBtn.Visible = true
            Spring(FabBtn, 0.25, { Size = UDim2.new(0, 52, 0, 52) })
        end
        function FAB:Hide()
            Tween(FabBtn, 0.18, { Size = UDim2.new(0, 0, 0, 0) })
            task.delay(0.2, function() FabBtn.Visible = false end)
        end

        -- Drag the FAB itself
        local FabDragging, FabStart, FabStartPos, FabMoved = false, nil, nil, false
        local FabTouch

        WinMaid:Add(Connect(FabBtn.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.Touch then
                FabDragging = true
                FabStart    = Input.Position
                FabStartPos = FabBtn.Position
                FabMoved    = false
                FabTouch    = Input
            end
        end))

        WinMaid:Add(InputHub:OnChanged(function(Input)
            if FabDragging and Input == FabTouch then
                local delta = Input.Position - FabStart
                if math.abs(delta.X) + math.abs(delta.Y) > 6 then
                    FabMoved = true
                end
                FabBtn.Position = UDim2.new(
                    FabStartPos.X.Scale, FabStartPos.X.Offset + delta.X,
                    FabStartPos.Y.Scale, FabStartPos.Y.Offset + delta.Y
                )
            end
        end))

        WinMaid:Add(InputHub:OnEnded(function(Input)
            if FabDragging and Input == FabTouch then
                FabDragging = false
                if not FabMoved then
                    -- Tap (not drag) → reopen the window
                    ToggleWindow()
                    Buzz(0.3)
                end
                FabTouch = nil
            end
        end))

        WinMaid:Add(FabBtn)
    end


    -- ═══════════════════════════════════════════════════════════════════
    --  TAB SYSTEM
    -- ═══════════════════════════════════════════════════════════════════

    function Options:SetTab(Name)
        if not TabList then return end

        for _, Button in next, TabList:GetChildren() do
            if Button:IsA("TextButton") then
                local isTarget = (Button.Name == Name)
                local Val      = Button:FindFirstChild("Value")
                local Pad      = Button:FindFirstChildOfClass("UIPadding")
                local ICO      = Button:FindFirstChild("ICO")

                if isTarget and not (Val and Val.Value) then
                    if Pad then Tween(Pad, 0.18, { PaddingLeft = UDim.new(0, 22) }) end
                    Tween(Button, 0.18, {
                        BackgroundTransparency = 0.88,
                        BackgroundColor3       = Theme.Accent,
                    })
                    if ICO then Tween(ICO, 0.18, { ImageColor3 = Theme.Accent }) end
                    local TL = Button:FindFirstChild("TextLabel")
                    if TL then Tween(TL, 0.18, { TextColor3 = Theme.TabActive }) end
                    if Val then Val.Value = true end

                elseif not isTarget and (Val and Val.Value) then
                    if Pad then Tween(Pad, 0.18, { PaddingLeft = UDim.new(0, 16) }) end
                    Tween(Button, 0.18, {
                        BackgroundTransparency = 1,
                        BackgroundColor3       = Theme.Component,
                    })
                    if ICO then Tween(ICO, 0.18, { ImageColor3 = Theme.Icon }) end
                    local TL = Button:FindFirstChild("TextLabel")
                    if TL then Tween(TL, 0.18, { TextColor3 = Theme.Tab }) end
                    if Val then Val.Value = false end
                end
            end
        end

        if not Holder then return end
        for _, Main in next, Holder:GetChildren() do
            if Main:IsA("CanvasGroup") then
                local isTarget = (Main.Name == Name)
                local Val      = Main:FindFirstChild("Value")
                local Scroll   = Main:FindFirstChild("ScrollingFrame")
                local Pad      = Scroll and Scroll:FindFirstChild("UIPadding")

                if isTarget and not (Val and Val.Value) then
                    if Val then Val.Value = true end
                    Main.Visible = true
                    Tween(Main, 0.22, { GroupTransparency = 0 })
                    if Pad then Tween(Pad, 0.22, { PaddingTop = UDim.new(0, 8) }) end

                elseif not isTarget and (Val and Val.Value) then
                    if Val then Val.Value = false end
                    Tween(Main, 0.14, { GroupTransparency = 1 })
                    if Pad then Tween(Pad, 0.14, { PaddingTop = UDim.new(0, 18) }) end
                    task.delay(0.18, function() Main.Visible = false end)
                end
            end
        end
    end


    function Options:AddTabSection(Cfg)
