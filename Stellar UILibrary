            TextColor3             = Theme.Title,
            BackgroundTransparency = 1,
            TextXAlignment         = Enum.TextXAlignment.Left,
            Size                   = UDim2.new(1, -36, 0, 26),
            Position               = UDim2.new(0, 20, 0, 20),
            ZIndex                 = 202,
            BorderSizePixel        = 0,
        })

        local CDesc = Instance.new("TextLabel", Card)
        SetProperty(CDesc, {
            Text                   = Cfg.Description or "",
            Font                   = Enum.Font.GothamMedium,
            TextSize               = 13,
            TextColor3             = Theme.Description,
            BackgroundTransparency = 1,
            TextXAlignment         = Enum.TextXAlignment.Left,
            TextYAlignment         = Enum.TextYAlignment.Top,
            TextWrapped            = true,
            Size                   = UDim2.new(1, -36, 0, 78),
            Position               = UDim2.new(0, 20, 0, 52),
            ZIndex                 = 202,
            BorderSizePixel        = 0,
        })

        local BtnRow = Instance.new("Frame", Card)
        SetProperty(BtnRow, {
            Size                   = UDim2.new(1, -36, 0, 40),
            Position               = UDim2.new(0, 18, 1, -58),
            BackgroundTransparency = 1,
            BorderSizePixel        = 0,
            ZIndex                 = 202,
        })
        local Lay = Instance.new("UIListLayout", BtnRow)
        Lay.FillDirection      = Enum.FillDirection.Horizontal
        Lay.HorizontalAlignment = Enum.HorizontalAlignment.Right
        Lay.Padding            = UDim.new(0, 10)
        Lay.VerticalAlignment  = Enum.VerticalAlignment.Center

        local PanelMaid = Maid.new()

        local function MakeBtn(label, isPrimary)
            local B = Instance.new("TextButton", BtnRow)
            SetProperty(B, {
                Text                   = label,
                Font                   = Enum.Font.GothamSemibold,
                TextSize               = 13,
                TextColor3             = isPrimary and Color3.new(1,1,1) or Theme.Title,
                BackgroundColor3       = isPrimary and Theme.Accent or Theme.Component,
                AutoButtonColor        = false,
                BorderSizePixel        = 0,
                Size                   = UDim2.new(0, 104, 1, 0),
                ZIndex                 = 203,
            })
            Instance.new("UICorner", B).CornerRadius = UDim.new(0, 8)
            Animations:Hover(B, false, PanelMaid, Theme.Accent)
            Animations:Press(B, PanelMaid)
            return B
        end

        local CancelBtn  = MakeBtn(Cfg.CancelText  or "Cancel",  false)
        local ConfirmBtn = MakeBtn(Cfg.ConfirmText or "Confirm", true)

        local function CloseModal(result)
            Tween(Modal, 0.16, { BackgroundTransparency = 1 }, Ease.Snap)
            Tween(Card, 0.16, { Size = UDim2.new(0, TargetW - 30, 0, TargetH - 30) }, Ease.Snap)
            task.delay(0.2, function()
                PanelMaid:Destroy()
                Destroy(Modal)
            end)
            if Cfg.Callback then task.spawn(Cfg.Callback, result) end
        end

        PanelMaid:Add(Connect(CancelBtn.MouseButton1Click,  function() Buzz(0.2); CloseModal(false) end))
        PanelMaid:Add(Connect(ConfirmBtn.MouseButton1Click, function() Buzz(0.35); CloseModal(true)  end))

        -- v4: ESC / outside tap = cancel (modern modal convention)
        PanelMaid:Add(Connect(Modal.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1
               or Input.UserInputType == Enum.UserInputType.Touch then
                local mx, my = Input.Position.X, Input.Position.Y
                local p, s = Card.AbsolutePosition, Card.AbsoluteSize
                local inside = mx >= p.X and mx <= p.X + s.X
                           and my >= p.Y and my <= p.Y + s.Y
                if not inside then
                    CloseModal(false)
                end
            end
        end))

        -- v4: smoother spring-in (Back/Out)
        Card.Size = UDim2.new(0, TargetW - 40, 0, TargetH - 40)
        PresetTween(Card, "Spring", { Size = UDim2.new(0, TargetW, 0, TargetH) })
    end


    -- ═══════════════════════════════════════════════════════════════════
    --  THEME ENGINE
    -- ═══════════════════════════════════════════════════════════════════
    -- v4: per-window descendant cache for fast SetTheme. Walking the full
    -- Screen:GetDescendants() on every theme change was O(other windows +
    -- global Components template). The cache scopes the walk to JUST this
    -- window and rebuilds only when descendants change.
    local _themeCache      = nil
    local _themeCacheDirty = true

    local function _rebuildThemeCache()
        local cache = {}
        local i = 0
        i += 1; cache[i] = Window
        for _, D in next, Window:GetDescendants() do
            i += 1; cache[i] = D
        end
        _themeCache      = cache
        _themeCacheDirty = false
    end

    WinMaid:Add(Connect(Window.DescendantAdded, function()
        _themeCacheDirty = true
    end))
    WinMaid:Add(Connect(Window.DescendantRemoving, function()
        _themeCacheDirty = true
    end))

    function Options:SetTheme(NewTheme)
        if NewTheme then Theme = NewTheme end

        Window.BackgroundColor3 = Theme.Primary
        if Holder  then Holder.BackgroundColor3  = Theme.Secondary end
        if Sidebar then Sidebar.BackgroundColor3 = Theme.Sidebar   end

        local WS = Window:FindFirstChildOfClass("UIStroke")
        if WS then WS.Color = Theme.Shadow end

        if _themeCacheDirty or not _themeCache then
            _rebuildThemeCache()
        end

        -- Walk our cached descendants; rule-table lookup is O(1) per node.
        for i = 1, #_themeCache do
            local D = _themeCache[i]
            if D and D.Parent then  -- guard against just-destroyed nodes
                local nr = NameRules[D.Name]
                local cr = ClassRules[D.ClassName]
                if     nr then pcall(nr, D)
                elseif cr then pcall(cr, D)
                end
            end
        end

        -- Notifications live under Screen, not Window — recolour them here.
        for _, N in ipairs(ActiveNotifs) do
            if N and N.Parent and N:IsA("CanvasGroup") then
                N.BackgroundColor3 = Theme.Primary
                local NS = N:FindFirstChildOfClass("UIStroke")
                if NS then NS.Color = Theme.Outline end
            end
        end

        -- Update the per-window FAB (lives under Screen directly).
        local fabName = "FAB_" .. (Settings.Title or "Window")
        local fab = Screen:FindFirstChild(fabName)
        if fab then
            fab.BackgroundColor3 = Theme.Accent
            local S = fab:FindFirstChildOfClass("UIStroke")
            if S then S.Color = Theme.Outline end
        end
    end


    -- ═══════════════════════════════════════════════════════════════════
    --  SETTINGS CONTROL
    -- ═══════════════════════════════════════════════════════════════════
    --[[
        Runtime control over per-window settings:
            Options:SetSetting("Size",         UDim2)
            Options:SetSetting("Transparency", number 0-1)
            Options:SetSetting("Blur",         boolean)
            Options:SetSetting("Theme",        "Dark" | "Light" | table)
            Options:SetSetting("Keybind",      Enum.KeyCode)
    ]]

    function Options:SetSetting(Setting, Value)
        if Setting == "Size" then
            Window.Size    = Value
            WinSetup.Size  = Value

        elseif Setting == "Transparency" then
            Window.GroupTransparency = Value
            WinSetup.Transparency    = Value
            -- propagate to notifications belonging to this window
            for _, N in ipairs(ActiveNotifs) do
                if N and N.Parent then N.GroupTransparency = Value end
            end

        elseif Setting == "Blur" then
            local stored = Blurs[Settings.Title]
            if Value then
                BlurEnabled = true
                if not stored then
                    pcall(function() Blurs[Settings.Title] = Blur.new(Window, 5) end)
                elseif stored.root and not stored.root.Parent then
                    stored.root.Parent = workspace.CurrentCamera
                end
            else
                if stored and stored.root and stored.root.Parent then
                    stored.root.Parent = nil
                end
                BlurEnabled = false
            end

        elseif Setting == "Theme" then
            -- v5: only preset names accepted (custom table mode removed)
            local mode = tostring(Value)
            if Themes[mode] then
                Theme              = Themes[mode]
                WinSetup.ThemeMode = mode
                Options:SetTheme()
                for _, fn in ipairs(ThemeCallbacks) do task.spawn(fn, mode, Theme) end
            else
                warn("[StellarUI] Unknown theme: " .. mode
                     .. " (available: Default, Midnight, Tokyo, Mocha)")
            end

        elseif Setting == "Keybind" then
            WinSetup.Keybind = Value

        else
            warn("[StellarUI] Unknown setting: " .. tostring(Setting))
        end
    end


    -- ═══════════════════════════════════════════════════════════════════
    --  LIFECYCLE METHODS
    -- ═══════════════════════════════════════════════════════════════════

    --- Register a callback invoked whenever the theme changes.
    ---   fn(modeName: string, themeTable: table)
    function Options:OnThemeChanged(fn)
        if type(fn) == "function" then
            ThemeCallbacks[#ThemeCallbacks + 1] = fn
        end
    end

    --- Programmatically show or hide the window (animated).
    function Options:SetVisible(visible)
        if visible and not Opened then
            Opened = true
            Animations:Open(Window, WinSetup.Transparency, WinSetup.Size)
            if BlurEnabled and Blurs[Settings.Title] then
                pcall(function() Blurs[Settings.Title].root.Parent = workspace.CurrentCamera end)
            end
            -- Hide FAB while window is open
            if IsMobile then
                for _, child in ipairs(Screen:GetChildren()) do
                    if child.Name == "FAB_" .. (Settings.Title or "Window") then
                        child.Visible = false
                    end
                end
            end
        elseif not visible and Opened then
            Opened = false
            if BlurEnabled and Blurs[Settings.Title] then
                pcall(function() Blurs[Settings.Title].root.Parent = nil end)
            end
            Animations:Close(Window)
            -- Show FAB so the user can reopen
            if IsMobile then
                for _, child in ipairs(Screen:GetChildren()) do
                    if child.Name == "FAB_" .. (Settings.Title or "Window") then
                        child.Size    = UDim2.new(0, 0, 0, 0)
                        child.Visible = true
                        Spring(child, 0.25, { Size = UDim2.new(0, 52, 0, 52) })
                    end
                end
            end
        end
    end

    --- Returns whether the window is currently shown.
    function Options:IsVisible() return Opened end

    --- Full teardown: disconnects every connection and destroys the window.
    function Options:Destroy()
        -- Destroy all child component controllers first
        for _, ctrl in ipairs(Components) do
            if ctrl and ctrl.Destroy then pcall(ctrl.Destroy, ctrl) end
        end
        table.clear(Components)
        table.clear(ThemeCallbacks)
        table.clear(Flags)

        -- WinMaid contains: drag listeners, FAB, swipe, keybind, hover anims,
        -- tab buttons, etc. — one call cleans every per-window connection.
        WinMaid:Destroy()

        -- Per-window blur instance
        if Blurs[Settings.Title] then
            pcall(function()
                local b = Blurs[Settings.Title]
                if b and b.root then b.root:Destroy() end
            end)
            Blurs[Settings.Title] = nil
        end

        -- Finally the window itself
        if Window and Window.Parent then
            pcall(function() Window:Destroy() end)
        end

        -- Clear active notifs
        for _, N in ipairs(ActiveNotifs) do
            pcall(function() if N then N:Destroy() end end)
        end
        table.clear(ActiveNotifs)
    end


    -- ═══════════════════════════════════════════════════════════════════
    --  CONFIG SAVE / LOAD  (NEW in v3.0)
    -- ═══════════════════════════════════════════════════════════════════
    --[[
        Every component that received a Cfg.Flag is auto-registered in the
        Flags table via RegisterFlag(flag, getFn, setFn).

        Usage:
            local cfg = Window:GetConfig()       -- {Speed=80, Theme="Dark", ...}
            HttpService:JSONEncode(cfg)          -- persist somewhere

            -- later:
            Window:LoadConfig(decodedTable)
    ]]

    --- Serialise every flagged value to a plain Lua table.
    function Options:GetConfig()
        local out = {}
        for flag, fns in pairs(Flags) do
            local ok, val = pcall(fns.Get)
            if ok then
                -- Skip non-serialisable values (Color3, Vector3, EnumItem all
                -- become strings so JSON round-trips work). Callers that want
                -- raw values can read from Flags directly.
                local t = typeof(val)
                if t == "Color3" then
                    out[flag] = { _type = "Color3", hex = Color3ToHex(val) }
                elseif t == "EnumItem" then
                    out[flag] = { _type = "EnumItem", value = tostring(val) }
                elseif t == "table" then
                    -- For multidropdowns: shallow copy of {[k]=true,...}
                    local copy = {}
                    for k, v in pairs(val) do copy[k] = v end
                    out[flag] = copy
                else
                    out[flag] = val
                end
            end
        end
        return out
    end

    --- Apply a previously-saved config table back to the components.
    function Options:LoadConfig(config)
        if type(config) ~= "table" then return end
        for flag, val in pairs(config) do
            local fns = Flags[flag]
            if fns and fns.Set then
                local actual = val
                -- Reverse the serialisation done in GetConfig
                if type(val) == "table" and val._type == "Color3" then
                    actual = HexToColor3(val.hex)
                elseif type(val) == "table" and val._type == "EnumItem" then
                    -- "Enum.KeyCode.LeftControl" → Enum.KeyCode.LeftControl
                    local ok, parsed = pcall(function()
                        local parts = string.split(val.value, ".")
                        local cursor = _G
                        for _, p in ipairs(parts) do cursor = cursor[p] end
                        return cursor
                    end)
                    actual = ok and parsed or val.value
                end
                pcall(fns.Set, actual)
            end
        end
    end


    -- ═══════════════════════════════════════════════════════════════════
    --  SET ACCENT  (v5.0)
    -- ═══════════════════════════════════════════════════════════════════
    --[[
        Overrides the current theme's accent colour without changing any
        other palette entry. Useful for letting end-users pick "their"
        colour while keeping the rest of the dark theme intact.

            window:SetAccent(Color3.fromRGB(255, 100, 100))
            window:SetAccent("#FF6464")
            window:SetAccent(nil)  -- reverts to the theme default
    ]]

    -- Snapshot the theme's original accent so SetAccent(nil) can restore.
    local _accentSnapshot = {
        Accent       = Theme.Accent,
        AccentLight  = Theme.AccentLight,
        AccentDark   = Theme.AccentDark,
        ToggleOn     = Theme.ToggleOn,
        SliderFill   = Theme.SliderFill,
        ProgressFill = Theme.ProgressFill,
        IconActive   = Theme.IconActive,
        BadgeBg      = Theme.BadgeBg,
        FocusRing    = Theme.FocusRing,
    }

    function Options:SetAccent(color)
        -- Accept hex string, Color3, or nil (reset)
        local target
        if color == nil then
            for k, v in pairs(_accentSnapshot) do Theme[k] = v end
            Options:SetTheme()
            return
        end
        if type(color) == "string" then
            target = HexToColor3(color)
            if not target then
                warn("[StellarUI] SetAccent: invalid hex '" .. color .. "'")
                return
            end
        elseif typeof(color) == "Color3" then
            target = color
        else
            warn("[StellarUI] SetAccent: expected Color3 or hex string")
            return
        end

        local light = target:Lerp(Color3.new(1, 1, 1), 0.18)
        local dark  = target:Lerp(Color3.new(0, 0, 0), 0.18)

        Theme.Accent       = target
        Theme.AccentLight  = light
        Theme.AccentDark   = dark
        Theme.ToggleOn     = target
        Theme.SliderFill   = target
        Theme.ProgressFill = target
        Theme.IconActive   = target
        Theme.BadgeBg      = target
        Theme.FocusRing    = target

        Options:SetTheme()
        for _, fn in ipairs(ThemeCallbacks) do task.spawn(fn, WinSetup.ThemeMode, Theme) end
    end


    -- ═══════════════════════════════════════════════════════════════════
    --  DENSITY MODE  (v5.0)
    -- ═══════════════════════════════════════════════════════════════════
    --[[
        Compact     — power-user density, tighter rows (~32 px each)
        Comfortable — mobile-first / default, generous touch zones (~44 px+)

        Adjusts all child component heights + the holder scroll padding.
        Persists in WinSetup so it survives SetTheme.
    ]]
    WinSetup.Density = "Comfortable"

    function Options:SetDensity(d)
        d = (d == "Compact") and "Compact" or "Comfortable"
        WinSetup.Density = d
        local scale = (d == "Compact") and 0.82 or 1.0
        -- Apply to all component rows we control (anything inside Holder
        -- that has Size in Offset on the Y axis).
        if not Holder then return end
        for _, tab in next, Holder:GetChildren() do
            if tab:IsA("CanvasGroup") then
                local sf = tab:FindFirstChild("ScrollingFrame") or tab
                for _, child in next, sf:GetChildren() do
                    if child:IsA("GuiObject") and not child:IsA("UIListLayout")
                       and not child:IsA("UIPadding") then
                        local sz = child.Size
                        local origAttr = child:GetAttribute("__OrigY")
                        if not origAttr then
                            origAttr = sz.Y.Offset
                            child:SetAttribute("__OrigY", origAttr)
                        end
                        Tween(child, 0.18, {
                            Size = UDim2.new(sz.X.Scale, sz.X.Offset,
                                             sz.Y.Scale, math.floor(origAttr * scale)),
                        }, Ease.Smooth)
                    end
                end
            end
        end
    end


    -- ═══════════════════════════════════════════════════════════════════
    --  PROFILE SYSTEM  (v5.0)
    -- ═══════════════════════════════════════════════════════════════════
    --[[
        Profiles let users save multiple named configs and switch between
        them. Internally each profile is just a GetConfig() snapshot.
        With executor `writefile`, profiles persist to disk.

            window:SaveProfile("PvP")
            window:LoadProfile("PvP")
            window:ListProfiles()  → { "Default", "PvP", "Farm" }
            window:DeleteProfile("Farm")

        AUTO-SAVE: debounced 0.5 s after the last change.
            window:SetAutoSave(true, "MyScript")   -- writes to "MyScript.json"
    ]]
    local Profiles       = { Default = {} }
    local ActiveProfile  = "Default"
    local AutoSaveOn     = false
    local AutoSaveKey    = nil       -- filename without extension
    local _autoSaveTimer = nil

    local function _readProfilesFromDisk()
        if not AutoSaveKey then return end
        local ok, raw = pcall(function() return readfile(AutoSaveKey .. ".json") end)
        if not ok or not raw then return end
        local ok2, decoded = pcall(function() return Services.Http:JSONDecode(raw) end)
        if ok2 and type(decoded) == "table" then
            Profiles = decoded.profiles or { Default = {} }
            ActiveProfile = decoded.active or "Default"
        end
    end

    local function _writeProfilesToDisk()
        if not AutoSaveKey then return end
        local ok = pcall(function()
            writefile(AutoSaveKey .. ".json", Services.Http:JSONEncode({
                profiles = Profiles,
                active   = ActiveProfile,
            }))
        end)
        if not ok then warn("[StellarUI] Auto-save write failed") end
    end

    function Options:SaveProfile(name)
        name = tostring(name or ActiveProfile)
        Profiles[name] = Options:GetConfig()
        ActiveProfile  = name
        _writeProfilesToDisk()
        return true
    end

    function Options:LoadProfile(name)
        name = tostring(name)
        local p = Profiles[name]
        if not p then
            warn("[StellarUI] Profile not found: " .. name)
            return false
        end
        ActiveProfile = name
        Options:LoadConfig(p)
        _writeProfilesToDisk()
        return true
    end

    function Options:DeleteProfile(name)
        name = tostring(name)
        if name == "Default" then
            warn("[StellarUI] Cannot delete Default profile")
            return false
        end
        Profiles[name] = nil
        if ActiveProfile == name then ActiveProfile = "Default" end
        _writeProfilesToDisk()
        return true
    end

    function Options:ListProfiles()
        local out = {}
        for n in pairs(Profiles) do out[#out + 1] = n end
        table.sort(out)
        return out
    end

    function Options:GetActiveProfile() return ActiveProfile end

    function Options:SetAutoSave(enabled, key)
        AutoSaveOn  = enabled and true or false
        AutoSaveKey = key
        if AutoSaveOn then
            _readProfilesFromDisk()
            -- Apply the active profile on load
            local p = Profiles[ActiveProfile]
            if p then Options:LoadConfig(p) end
        end
    end

    -- Hook auto-save: every flag change schedules a debounced write.
    local _origRegisterFlag = RegisterFlag
    RegisterFlag = function(flag, getFn, setFn)
        if not flag then return end
        Flags[flag] = {
            Get = getFn,
            Set = function(v)
                setFn(v)
                if AutoSaveOn then
                    if _autoSaveTimer then task.cancel(_autoSaveTimer) end
                    _autoSaveTimer = task.delay(0.5, function()
                        Profiles[ActiveProfile] = Options:GetConfig()
                        _writeProfilesToDisk()
                    end)
                end
            end,
        }
    end


    -- ═══════════════════════════════════════════════════════════════════
    --  RADIO GROUP  (v5.0)
    -- ═══════════════════════════════════════════════════════════════════
    --[[
        1-of-N picker, rendered as horizontal segmented buttons.
        Better than Dropdown when there are 2-4 options.

            section:RadioGroup{
                Title   = "Mode",
                Options = { "Off", "On", "Auto" },
                Default = "Off",
                Callback = function(value, index) ... end,
            }
    ]]
    function Options:AddRadioGroup(Cfg)
        if not Cfg.Tab then warn("[UILib] AddRadioGroup: missing Cfg.Tab"); return end
        local opts = Cfg.Options or {}
        if #opts < 2 then warn("[UILib] RadioGroup needs ≥2 options"); return end

        local ROW_H = IsMobile and 56 or 44

        local Wrapper = Instance.new("Frame")
        SetProperty(Wrapper, {
            Name             = "RadioGroup_" .. (Cfg.Title or ""),
            Size             = UDim2.new(1, 0, 0, ROW_H),
            BackgroundColor3 = Theme.Component,
            BorderSizePixel  = 0,
            Parent           = Cfg.Tab,
            Visible          = true,
        })
        Instance.new("UICorner", Wrapper).CornerRadius = UDim.new(0, 8)
        local Pad = Instance.new("UIPadding", Wrapper)
        Pad.PaddingLeft  = UDim.new(0, 12)
        Pad.PaddingRight = UDim.new(0, 12)

        local TitleLbl
        if Cfg.Title then
            TitleLbl = Instance.new("TextLabel", Wrapper)
            SetProperty(TitleLbl, {
                Name                   = "Title",
                Text                   = Cfg.Title,
                Font                   = Enum.Font.GothamSemibold,
                TextSize               = 13,
                TextColor3             = Theme.Title,
                BackgroundTransparency = 1,
                TextXAlignment         = Enum.TextXAlignment.Left,
                Size                   = UDim2.new(0.4, 0, 1, 0),
                BorderSizePixel        = 0,
            })
        end

        -- The segmented control itself sits on the right
        local SegWidth = 240
        local Seg = Instance.new("Frame", Wrapper)
        SetProperty(Seg, {
            Name             = "Segments",
            Size             = UDim2.new(0, SegWidth, 0, ROW_H - 16),
            Position         = UDim2.new(1, 0, 0.5, 0),
            AnchorPoint      = Vector2.new(1, 0.5),
            BackgroundColor3 = Theme.Interactable,
            BorderSizePixel  = 0,
        })
        Instance.new("UICorner", Seg).CornerRadius = UDim.new(0, 7)

        local Hl = Instance.new("UIListLayout", Seg)
        Hl.FillDirection         = Enum.FillDirection.Horizontal
        Hl.SortOrder             = Enum.SortOrder.LayoutOrder
        Hl.HorizontalAlignment   = Enum.HorizontalAlignment.Center
        Hl.VerticalAlignment     = Enum.VerticalAlignment.Center
        Hl.Padding               = UDim.new(0, 2)
        local SegPad = Instance.new("UIPadding", Seg)
        SegPad.PaddingLeft  = UDim.new(0, 2)
        SegPad.PaddingRight = UDim.new(0, 2)
        SegPad.PaddingTop    = UDim.new(0, 2)
        SegPad.PaddingBottom = UDim.new(0, 2)

        local Current   = Cfg.Default or opts[1]
        local Listeners = {}
        local SegBtns   = {}

        local function PaintSelection()
            for _, info in ipairs(SegBtns) do
                local selected = (info.value == Current)
                Tween(info.btn, 0.18, {
                    BackgroundColor3 = selected and Theme.Accent or Theme.Interactable,
                }, Ease.Smooth)
                if info.lbl then
                    Tween(info.lbl, 0.18, {
                        TextColor3 = selected and Color3.new(1,1,1) or Theme.Description,
                    }, Ease.Smooth)
                end
            end
        end

        for i, opt in ipairs(opts) do
            local btn = Instance.new("TextButton", Seg)
            SetProperty(btn, {
                Name                   = "Seg_" .. tostring(i),
                Text                   = "",
                AutoButtonColor        = false,
                Size                   = UDim2.new(1 / #opts, -2, 1, 0),
                BackgroundColor3       = Theme.Interactable,
                BorderSizePixel        = 0,
                LayoutOrder            = i,
            })
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

            local lbl = Instance.new("TextLabel", btn)
            SetProperty(lbl, {
                Text                   = tostring(opt),
                Font                   = Enum.Font.GothamSemibold,
                TextSize               = 12,
                TextColor3             = Theme.Description,
                BackgroundTransparency = 1,
                Size                   = UDim2.fromScale(1, 1),
                BorderSizePixel        = 0,
            })

            SegBtns[#SegBtns + 1] = { btn = btn, lbl = lbl, value = opt, index = i }

            WinMaid:Add(Connect(btn.MouseButton1Click, function()
                if Current == opt then return end
                Current = opt
                PaintSelection()
                Buzz(0.25)
                if Cfg.Callback then task.spawn(Cfg.Callback, opt, i) end
                for _, fn in ipairs(Listeners) do task.spawn(fn, opt, i) end
            end))
            Animations:Press(btn, WinMaid)
        end

        PaintSelection()

        local Ctrl = {}
        function Ctrl:Get()              return Current end
        function Ctrl:Set(v)
            for _, info in ipairs(SegBtns) do
                if info.value == v then
                    Current = v
                    PaintSelection()
                    for _, fn in ipairs(Listeners) do task.spawn(fn, v, info.index) end
                    return
                end
            end
        end
        function Ctrl:OnChanged(fn)      Listeners[#Listeners + 1] = fn end
        function Ctrl:SetTitle(t)        if TitleLbl then TitleLbl.Text = t end end
        function Ctrl:SetDescription()   end
        function Ctrl:SetVisible(v)      Wrapper.Visible = v end
        function Ctrl:Destroy()          Destroy(Wrapper) end

        RegisterFlag(Cfg.Flag, function() return Ctrl:Get() end, function(v) Ctrl:Set(v) end)
        BindState(Ctrl, Cfg.State)
        Components[#Components + 1] = Ctrl
        return Ctrl
    end
    Options.AddSegmentedControl = Options.AddRadioGroup  -- alias


    -- ═══════════════════════════════════════════════════════════════════
    --  NUMBER STEPPER  (v5.0)
    -- ═══════════════════════════════════════════════════════════════════
    --[[
        Compact +/- stepper for small integer ranges. Less space-greedy
        than a slider when range is short (e.g. "Lives: 1-5").

            section:Stepper{
                Title   = "Lives",
                Min = 1, Max = 5, Step = 1, Default = 3,
                Callback = function(value) ... end,
            }
    ]]
    function Options:AddStepper(Cfg)
        if not Cfg.Tab then warn("[UILib] AddStepper: missing Cfg.Tab"); return end
        local Min     = Cfg.Min or 0
        local Max     = Cfg.Max or 10
        local Step    = Cfg.Step or 1
        local Current = math.clamp(Cfg.Default or Min, Min, Max)
        local ROW_H   = IsMobile and 56 or 44

        local Wrapper = Instance.new("Frame")
        SetProperty(Wrapper, {
            Name             = "Stepper_" .. (Cfg.Title or ""),
            Size             = UDim2.new(1, 0, 0, ROW_H),
            BackgroundColor3 = Theme.Component,
            BorderSizePixel  = 0,
            Parent           = Cfg.Tab,
            Visible          = true,
        })
        Instance.new("UICorner", Wrapper).CornerRadius = UDim.new(0, 8)
        local Pad = Instance.new("UIPadding", Wrapper)
        Pad.PaddingLeft  = UDim.new(0, 12)
        Pad.PaddingRight = UDim.new(0, 12)

        local TitleLbl = Instance.new("TextLabel", Wrapper)
        SetProperty(TitleLbl, {
            Name                   = "Title",
            Text                   = Cfg.Title or "Number",
            Font                   = Enum.Font.GothamSemibold,
            TextSize               = 13,
            TextColor3             = Theme.Title,
            BackgroundTransparency = 1,
            TextXAlignment         = Enum.TextXAlignment.Left,
            Size                   = UDim2.new(1, -140, 1, 0),
            BorderSizePixel        = 0,
        })

        -- Stepper assembly on the right
        local Box = Instance.new("Frame", Wrapper)
        SetProperty(Box, {
            Name             = "Box",
            Size             = UDim2.new(0, 124, 0, ROW_H - 16),
            Position         = UDim2.new(1, 0, 0.5, 0),
            AnchorPoint      = Vector2.new(1, 0.5),
            BackgroundColor3 = Theme.Interactable,
            BorderSizePixel  = 0,
        })
        Instance.new("UICorner", Box).CornerRadius = UDim.new(0, 7)

        local function MakeBtn(text, posX, ax)
            local b = Instance.new("TextButton", Box)
            SetProperty(b, {
                Text                   = text,
                Font                   = Enum.Font.GothamBold,
                TextSize               = 18,
                TextColor3             = Theme.Title,
                BackgroundTransparency = 1,
                AutoButtonColor        = false,
                Size                   = UDim2.new(0, 36, 1, 0),
                Position               = UDim2.new(posX, 0, 0, 0),
                AnchorPoint            = Vector2.new(ax, 0),
                BorderSizePixel        = 0,
            })
            return b
        end
        local Minus = MakeBtn("−", 0, 0)
        local Plus  = MakeBtn("+", 1, 1)

        local NumLbl = Instance.new("TextLabel", Box)
        SetProperty(NumLbl, {
            Text                   = tostring(Current),
            Font                   = Enum.Font.GothamBold,
            TextSize               = 14,
            TextColor3             = Theme.Title,
            BackgroundTransparency = 1,
            Size                   = UDim2.new(0, 52, 1, 0),
            Position               = UDim2.fromScale(0.5, 0.5),
            AnchorPoint            = Vector2.new(0.5, 0.5),
            BorderSizePixel        = 0,
        })

        local Listeners = {}
        local function SetValue(v, silent)
            v = math.clamp(v, Min, Max)
            if v == Current then return end
            Current = v
            NumLbl.Text = tostring(v)
            if not silent then
                if Cfg.Callback then task.spawn(Cfg.Callback, v) end
                for _, fn in ipairs(Listeners) do task.spawn(fn, v) end
            end
            -- Visual feedback on edge-hit
            local atMin = (v == Min)
            local atMax = (v == Max)
            Tween(Minus, 0.12, { TextTransparency = atMin and 0.6 or 0 }, Ease.Smooth)
            Tween(Plus,  0.12, { TextTransparency = atMax and 0.6 or 0 }, Ease.Smooth)
        end

        WinMaid:Add(Connect(Minus.MouseButton1Click, function()
            SetValue(Current - Step); Buzz(0.2)
        end))
        WinMaid:Add(Connect(Plus.MouseButton1Click, function()
            SetValue(Current + Step); Buzz(0.2)
        end))
        Animations:Press(Minus, WinMaid)
        Animations:Press(Plus,  WinMaid)
        Animations:Hover(Wrapper, false, WinMaid, Theme.Accent)
        SetValue(Current, true)

        local Ctrl = {}
        function Ctrl:Get()              return Current end
        function Ctrl:Set(v)             SetValue(tonumber(v) or Min) end
        function Ctrl:OnChanged(fn)      Listeners[#Listeners + 1] = fn end
        function Ctrl:SetTitle(t)        TitleLbl.Text = t end
        function Ctrl:SetDescription()   end
        function Ctrl:SetRange(mn, mx)   Min = mn; Max = mx; SetValue(Current) end
        function Ctrl:SetVisible(v)      Wrapper.Visible = v end
        function Ctrl:Destroy()          Destroy(Wrapper) end

        RegisterFlag(Cfg.Flag, function() return Ctrl:Get() end, function(v) Ctrl:Set(v) end)
        BindState(Ctrl, Cfg.State)
        Components[#Components + 1] = Ctrl
        return Ctrl
    end


    -- ═══════════════════════════════════════════════════════════════════
    --  BUILDER API  (v5.0)
    -- ═══════════════════════════════════════════════════════════════════
    --[[
        Chainable, declarative API on top of the imperative Add* methods.

            local window = Library:CreateWindow{ ... }
            local main   = window:Tab{ Title = "Main", Icon = "rbxassetid://..." }
            local combat = main:Section{ Title = "Combat" }
            combat:Toggle{ Title = "Auto-aim",  Default = false }
                  :Slider{ Title = "FOV", Min = 0, Max = 360, Default = 90 }
                  :RadioGroup{ Title = "Mode", Options = {"Off","On","Auto"} }

        Each method returns the SECTION (not the component) to enable
        chaining. Use the underlying Options:AddXxx if you need the
        controller object.
    ]]

    -- Window: build a tab object
    function Options:Tab(Cfg)
        Cfg = Cfg or {}
        local tabFrame = Options:AddTab(Cfg)
        if not tabFrame then return nil end

        local TabAPI = {}
        TabAPI._frame = tabFrame

        function TabAPI:Section(secCfg)
            secCfg = secCfg or {}
            secCfg.Tab  = tabFrame
            secCfg.Name = secCfg.Title or secCfg.Name or "Section"
            local secCtrl = Options:AddSection(secCfg)

            local SecAPI = {}
            SecAPI._ctrl = secCtrl

            -- Component shortcuts that auto-set Cfg.Tab
            local function wrap(method)
                return function(_, c)
                    c = c or {}
                    c.Tab = tabFrame
                    Options[method](Options, c)
                    return SecAPI
                end
            end
            SecAPI.Toggle       = wrap("AddToggle")
            SecAPI.Button       = wrap("AddButton")
            SecAPI.Input        = wrap("AddInput")
            SecAPI.Slider       = wrap("AddSlider")
            SecAPI.Keybind      = wrap("AddKeybind")
            SecAPI.Dropdown     = wrap("AddDropdown")
            SecAPI.MultiDropdown= wrap("AddMultiDropdown")
            SecAPI.ProgressBar  = wrap("AddProgressBar")
            SecAPI.ColorPicker  = wrap("AddColorPicker")
            SecAPI.RadioGroup   = wrap("AddRadioGroup")
            SecAPI.Stepper      = wrap("AddStepper")
            SecAPI.Label        = wrap("AddLabel")
            SecAPI.Divider      = wrap("AddDivider")
            -- Chain back to parent tab
            SecAPI.Tab          = function() return TabAPI end
            SecAPI._getSection  = function() return secCtrl end
            return SecAPI
        end

        function TabAPI:Show() Options:SetTab(tabFrame.Name) end
        return TabAPI
    end


    -- ═══════════════════════════════════════════════════════════════════
    --  FINALISE & OPEN
    -- ═══════════════════════════════════════════════════════════════════

    Options:SetTheme()
    SetProperty(Window, {
        Size    = Settings.Size,
        Visible = true,
        Parent  = Screen,
    })
    Animations:Open(Window, Settings.Transparency or 0, Settings.Size)

    return Options
end


return Library
