    -- ════════════════════════════════════════════════════════════

    function Options:AddSection(Cfg)
        local Section = Components and Clone(Components["Section"])
        if not Section then return end
        SetProperty(Section, { Text = Cfg.Name, Parent = Cfg.Tab, Visible = true })
    end


    -- ════════════════════════════════════════════════════════════
    --  DIVIDER
    -- ════════════════════════════════════════════════════════════

    function Options:AddDivider(Cfg)
        local Pad     = (Cfg and Cfg.Padding) or 4
        local Wrapper = Instance.new("Frame")
        SetProperty(Wrapper, {
            Name                   = "Divider",
            Size                   = UDim2.new(1, 0, 0, Pad * 2 + 1),
            BackgroundTransparency = 1,
            BorderSizePixel        = 0,
            Parent                 = Cfg and Cfg.Tab,
            Visible                = true,
        })
        local Line = Instance.new("Frame", Wrapper)
        SetProperty(Line, {
            Name             = "Line",
            Size             = UDim2.new(1, -24, 0, 1),
            Position         = UDim2.new(0, 12, 0.5, 0),
            AnchorPoint      = Vector2.new(0, 0.5),
            BackgroundColor3 = Theme.Divider,
            BorderSizePixel  = 0,
        })

        -- v3.0: optional centre label on divider
        if Cfg and Cfg.Label then
            local CL = Instance.new("TextLabel", Wrapper)
            SetProperty(CL, {
                Text                   = " " .. Cfg.Label .. " ",
                Font                   = Enum.Font.GothamMedium,
                TextSize               = 10,
                TextColor3             = Theme.Muted,
                BackgroundColor3       = Theme.Primary,
                BorderSizePixel        = 0,
                Size                   = UDim2.new(0, 0, 1, 0),
                AutomaticSize          = Enum.AutomaticSize.X,
                Position               = UDim2.new(0.5, 0, 0, 0),
                AnchorPoint            = Vector2.new(0.5, 0),
                ZIndex                 = Line.ZIndex + 1,
            })
        end
    end


    -- ════════════════════════════════════════════════════════════
    --  LABEL
    -- ════════════════════════════════════════════════════════════

    function Options:AddLabel(Cfg)
        --[[
            Cfg = { Text: string, Tab: Instance, Color: Color3? }
            Returns: { Set(str), Get() }
        ]]
        local Lbl = Instance.new("TextLabel")
        SetProperty(Lbl, {
            Name                   = "Label",
            Text                   = Cfg.Text or "",
            Font                   = Enum.Font.GothamMedium,
            TextSize               = 13,
            TextColor3             = Cfg.Color or Theme.Description,
            BackgroundTransparency = 1,
            TextXAlignment         = Enum.TextXAlignment.Left,
            Size                   = UDim2.new(1, -24, 0, 22),
            BorderSizePixel        = 0,
            Parent                 = Cfg.Tab,
            Visible                = true,
        })
        local P = Instance.new("UIPadding", Lbl)
        P.PaddingLeft = UDim.new(0, 12)

        local Ctrl = {}
        function Ctrl:Set(text) Lbl.Text = text end
        function Ctrl:Get()     return Lbl.Text end
        return Ctrl
    end


    -- ════════════════════════════════════════════════════════════
    --  TOGGLE  (v3.0 — spring Back-easing + accent glow pulse)
    -- ════════════════════════════════════════════════════════════

    function Options:AddToggle(Cfg)
        --[[
            Cfg = {
                Title: string, Description: string,
                Default: boolean?, Tab: Instance, Callback: function(bool)
            }
            Returns: { Set(bool), Get(), OnChanged(fn) }
        ]]
        local Toggle = Components and Clone(Components["Toggle"])
        if not Toggle then return {} end

        local Title, Desc = Options:GetLabels(Toggle)
        local On     = Toggle:FindFirstChild("Value")
        local Main   = Toggle:FindFirstChild("Main")
        local Circle = Main and Main:FindFirstChild("Circle")

        local Changed = Signal.new()

        local function Set(Value)
            if Main then
                Tween(Main, 0.18, { BackgroundColor3 = Value and Theme.ToggleOn or Theme.ToggleOff })
            end
            if Circle then
                -- v3.0: Back easing for spring feel on knob
                Tween(Circle, 0.22, {
                    BackgroundColor3 = Theme.ToggleKnob,
                    Position = Value
                        and UDim2.new(1, -16, 0.5, 0)
                        or  UDim2.new(0,   3, 0.5, 0),
                }, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
            end
            if On then On.Value = Value end
            -- v3.0: glow pulse on activation
            if Value and Main then
                task.spawn(function() Animations:Pulse(Main, WinMaid) end)
            end
            Changed:Fire(Value)
        end

        WinMaid:Add(Connect(Toggle.MouseButton1Click, function()
            local Value = not (On and On.Value)
            Set(Value)
            if Cfg.Callback then task.spawn(Cfg.Callback, Value) end
        end))

        Animations:Hover(Toggle, false, WinMaid)
        Set(Cfg.Default or false)
        if Title then Title.Text = Cfg.Title       or "" end
        if Desc  then Desc.Text  = Cfg.Description or "" end
        SetProperty(Toggle, { Name = Cfg.Title, Parent = Cfg.Tab, Visible = true })

        local Ctrl = {}
        function Ctrl:Set(v)        Set(v) end
        function Ctrl:Get()         return On and On.Value or false end
        function Ctrl:OnChanged(fn) return Changed:Connect(fn) end
        return Ctrl
    end


