    function Options:AddCodeBlock(Cfg)
        ValidateCfg("AddCodeBlock", Cfg, { "Title", "Tab" })
        local cMaid = WinMaid:Child()
        local Template = Components and (Components:FindFirstChild("Code") or Components["Paragraph"])
        if not Template then return end

        local Block = Clone(Template)
        local Title, Desc = Options:GetLabels(Block)
        local CopyBtn = Block:FindFirstChild("Copy") or Block:FindFirstChild("CopyButton")

        local Dots = Block:FindFirstChild("Dots")
        if Dots then
            local DR = Dots:FindFirstChild("Red")
            local DY = Dots:FindFirstChild("Yellow")
            local DG = Dots:FindFirstChild("Green")
            if DR then DR.BackgroundColor3 = Theme.CodeDotRed    end
            if DY then DY.BackgroundColor3 = Theme.CodeDotYellow end
            if DG then DG.BackgroundColor3 = Theme.CodeDotGreen  end
        end

        if Title then Title.Text = Cfg.Title or "Code" end
        if Desc  then Desc.Text  = Cfg.Code  or ""    end

        if CopyBtn then
            local BtnLabel = CopyBtn:FindFirstChild("TextLabel") or CopyBtn:FindFirstChild("Label")
            cMaid:Add(Connect(CopyBtn.MouseButton1Click, function()
                pcall(function()
                    if setclipboard then setclipboard(Cfg.Code or "") end
                end)
                if BtnLabel then
                    local Original = BtnLabel.Text
                    BtnLabel.Text  = "✓ Copied!"
                    Tween(CopyBtn, Ease.Quart, {
                        BackgroundColor3 = LerpColor(Theme.Component, Theme.NoteSuccess, 0.25)
                    })
                    task.delay(1.8, function()
                        BtnLabel.Text = Original
                        Tween(CopyBtn, Ease.Quart, { BackgroundColor3 = Theme.Component })
                    end)
                end
                if Cfg.Callback then task.spawn(Cfg.Callback) end
            end))
            Animations:Hover(CopyBtn, false, cMaid)
        end

        SetProperty(Block, { Parent = Cfg.Tab, Visible = true })
    end


    -- ════════════════════════════════════════
    --  TOOLTIP  (new — hover tooltip)
    -- ════════════════════════════════════════
    --[[
        Cfg = {
            Target:  GuiObject   — the element to attach to
            Text:    string
        }
        Destroys itself when the target is destroyed.
    ]]

    function Options:AddTooltip(Cfg)
        if not (Cfg and Cfg.Target and Cfg.Text) then return end

        local TipFrame = nil

        local function ShowTip()
            if TipFrame then return end
            TipFrame = New("Frame", {
                Name             = "_Tooltip",
                BackgroundColor3 = Theme.Secondary,
                BorderSizePixel  = 0,
                Size             = UDim2.new(0, 0, 0, 24),
                ZIndex           = 100,
                AutomaticSize    = Enum.AutomaticSize.X,
            }, Screen)
            New("UICorner", { CornerRadius = UDim.new(0, 5) }, TipFrame)
            New("UIStroke", { Color = Theme.Outline, Thickness = 1 }, TipFrame)
            New("UIPadding", {
                PaddingLeft  = UDim.new(0, 8), PaddingRight  = UDim.new(0, 8),
                PaddingTop   = UDim.new(0, 4), PaddingBottom = UDim.new(0, 4),
            }, TipFrame)
            New("TextLabel", {
                Text                   = Cfg.Text,
                Font                   = Enum.Font.Gotham,
                TextSize               = 11,
                TextColor3             = Theme.Description,
                BackgroundTransparency = 1,
                Size                   = UDim2.fromScale(1, 1),
                AutomaticSize          = Enum.AutomaticSize.X,
            }, TipFrame)

            -- Position near target
            local abs = Cfg.Target.AbsolutePosition
            local sz  = Cfg.Target.AbsoluteSize
            TipFrame.Position = UDim2.new(0, abs.X + sz.X / 2, 0, abs.Y - 30)
            TipFrame.AnchorPoint = Vector2.new(0.5, 1)
            TipFrame.GroupTransparency = 1

            -- Track mouse position for tooltip follow
            local conn
            conn = Svc.Run.Heartbeat:Connect(function()
                if not TipFrame or not TipFrame.Parent then conn:Disconnect(); return end
                local mp = Svc.Input:GetMouseLocation()
                TipFrame.Position = UDim2.new(0, mp.X, 0, mp.Y - 34)
            end)

            TipFrame.GroupTransparency = 0
        end

        local function HideTip()
            if TipFrame then Destroy(TipFrame); TipFrame = nil end
        end

        local c1 = Connect(Cfg.Target.MouseEnter, ShowTip)
        local c2 = Connect(Cfg.Target.MouseLeave, HideTip)
        WinMaid:Add(c1); WinMaid:Add(c2)
        WinMaid:Add(HideTip)
    end


    -- ════════════════════════════════════════
    --  TAG ROW  (new — chip/tag strip)
    -- ════════════════════════════════════════
    --[[
        Cfg = {
            Tags:       { string }    — initial tags
            MaxTags:    number?
            Tab:        Instance
            Callback:   function({ string })
        }
        Returns: { AddTag(str), RemoveTag(str), Get(), Destroy() }
    ]]

    function Options:AddTagRow(Cfg)
        ValidateCfg("AddTagRow", Cfg, { "Tab" })
        local cMaid = WinMaid:Child()
        local Tags  = {}
        local MaxTags = Cfg.MaxTags or 10

        local Wrapper = New("Frame", {
            Name             = "TagRow",
            Size             = UDim2.new(1, 0, 0, 36),
            BackgroundTransparency = 1,
            BorderSizePixel  = 0,
            AutomaticSize    = Enum.AutomaticSize.Y,
            Parent           = Cfg.Tab,
            Visible          = true,
        })
        New("UIListLayout", {
            FillDirection  = Enum.FillDirection.Horizontal,
            Wraps          = true,
            SortOrder      = Enum.SortOrder.LayoutOrder,
            Padding        = UDim.new(0, 4),
        }, Wrapper)
        New("UIPadding", { PaddingLeft = UDim.new(0, 12), PaddingBottom = UDim.new(0, 4) }, Wrapper)

        local function FireCallback()
            if Cfg.Callback then task.spawn(Cfg.Callback, table.clone(Tags)) end
        end

        local function RebuildChips()
            for _, ch in ipairs(Wrapper:GetChildren()) do
                if ch.Name == "_Chip" then ch:Destroy() end
            end
            for i, tag in ipairs(Tags) do
                local chip = New("Frame", {
                    Name             = "_Chip",
                    Size             = UDim2.new(0, 0, 0, 24),
                    AutomaticSize    = Enum.AutomaticSize.X,
                    BackgroundColor3 = Theme.Accent:Lerp(Theme.Component, 0.6),
                    BorderSizePixel  = 0,
                    LayoutOrder      = i,
                }, Wrapper)
                New("UICorner", { CornerRadius = UDim.new(1, 0) }, chip)
                New("UIPadding", { PaddingLeft = UDim.new(0, 8), PaddingRight = UDim.new(0, 6) }, chip)
                New("UIListLayout", { FillDirection = Enum.FillDirection.Horizontal,
                    VerticalAlignment = Enum.VerticalAlignment.Center, Padding = UDim.new(0, 4) }, chip)

                New("TextLabel", {
                    Text                   = tag,
                    Font                   = Enum.Font.GothamMedium,
                    TextSize               = 11,
                    TextColor3             = Theme.TabActive,
                    BackgroundTransparency = 1,
                    AutomaticSize          = Enum.AutomaticSize.XY,
                }, chip)

                local closeBtn = New("TextButton", {
                    Text             = "×",
                    Font             = Enum.Font.GothamBold,
                    TextSize         = 13,
                    TextColor3       = Theme.Muted,
                    BackgroundTransparency = 1,
                    AutoButtonColor  = false,
                    Size             = UDim2.new(0, 14, 0, 14),
                }, chip)

                Connect(closeBtn.MouseButton1Click, function()
                    table.remove(Tags, i)
                    RebuildChips()
                    FireCallback()
                end)
            end
        end

        -- Pre-fill
        for _, tag in ipairs(Cfg.Tags or {}) do
            if #Tags < MaxTags then table.insert(Tags, tag) end
        end
        RebuildChips()

        local Ctrl = {}
        function Ctrl:AddTag(str)
            if #Tags >= MaxTags then return end
            table.insert(Tags, str)
            RebuildChips()
            FireCallback()
        end
        function Ctrl:RemoveTag(str)
            for i, t in ipairs(Tags) do
                if t == str then table.remove(Tags, i); break end
            end
            RebuildChips()
            FireCallback()
        end
        function Ctrl:Get()      return table.clone(Tags) end
        function Ctrl:Destroy()  Destroy(Wrapper); cMaid:Destroy() end
        return Ctrl
    end


    -- ════════════════════════════════════════
    --  THEME ENGINE  (ComponentRegistry-backed)
    -- ════════════════════════════════════════

    function Options:SetTheme(NewTheme)
        if NewTheme then Theme = NewTheme end
        Registry:Apply(Theme)

        -- Also apply to any legacy components that pre-date the registry
        Window.BackgroundColor3 = Theme.Primary
        if Holder  then Holder.BackgroundColor3  = Theme.Secondary end
        if Sidebar then Sidebar.BackgroundColor3 = Theme.Sidebar   end
        local WS = Window:FindFirstChildOfClass("UIStroke")
        if WS then WS.Color = Theme.Shadow end
    end


    -- ════════════════════════════════════════
    --  SETTINGS CONTROL
    -- ════════════════════════════════════════

    function Options:SetSetting(Setting, Value)
        if Setting == "Size" then
            Window.Size = Value
            Setup.Size  = Value

        elseif Setting == "Transparency" then
            Window.GroupTransparency = Value
            Setup.Transparency = Value
            for _, D in next, Screen:GetDescendants() do
                if D:IsA("CanvasGroup") and D.Name == "Notification" then
                    D.GroupTransparency = Value
                end
            end

        elseif Setting == "Blur" then
            local stored = Blurs[Settings.Title]
            if Value then
                BlurEnabled = true
                if not stored then
                    pcall(function()
                        Blurs[Settings.Title] = Blur.new(Window, 5)
                    end)
                elseif stored.root and not stored.root.Parent then
                    stored.root.Parent = workspace.CurrentCamera
                end
            else
                if stored and stored.root and stored.root.Parent then
                    stored.root.Parent = nil
                end
                BlurEnabled = false
            end

        elseif Setting == "Theme" then
            local mode = (type(Value) == "string") and Value or nil
            if mode and Themes[mode] then
                Theme           = Themes[mode]
                Setup.ThemeMode = mode
                Options:SetTheme()
                for _, fn in ipairs(ThemeCallbacks) do task.spawn(fn, mode, Theme) end
            elseif type(Value) == "table" then
                Options:SetTheme(Value)
            end

        elseif Setting == "Keybind" then
            Setup.Keybind = Value

        else
            warn("[Stellar] Unknown setting: " .. tostring(Setting))
        end
    end


    -- ════════════════════════════════════════
    --  WINDOW CONTROL METHODS
    -- ════════════════════════════════════════

    function Options:OnThemeChanged(fn)
        ThemeCallbacks[#ThemeCallbacks + 1] = fn
    end

    function Options:SetVisible(visible)
        if visible and not Opened then
            Opened = true
            Animations:Open(Window, Setup.Transparency)
            if BlurEnabled and Blurs[Settings.Title] then
                pcall(function() Blurs[Settings.Title].root.Parent = workspace.CurrentCamera end)
            end
        elseif not visible and Opened then
            Opened = false
            if BlurEnabled and Blurs[Settings.Title] then
                pcall(function() Blurs[Settings.Title].root.Parent = nil end)
            end
            Animations:Close(Window)
        end
    end

    function Options:Destroy()
        WinMaid:Destroy()
        if Blurs[Settings.Title] then
            pcall(function()
                local b = Blurs[Settings.Title]
                if b and b.root then b.root:Destroy() end
            end)
            Blurs[Settings.Title] = nil
        end
        if Window and Window.Parent then
            pcall(function() Window:Destroy() end)
        end
    end


    -- ════════════════════════════════════════
    --  FINALISE & OPEN
    -- ════════════════════════════════════════

    Options:SetTheme()
    SetProperty(Window, { Size = Settings.Size, Visible = true, Parent = Screen })
    Animations:Open(Window, Settings.Transparency or 0)

    return Options
end


-- ═══════════════════════════════════════════════════
--  PUBLIC API EXPORTS
-- ═══════════════════════════════════════════════════

Library.Themes    = Themes
Library.Signal    = Signal
Library.Maid      = Maid
Library.Registry  = Registry
Library.Ease      = Ease

return Library
