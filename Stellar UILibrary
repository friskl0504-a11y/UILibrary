            BackgroundTransparency = 1,
            BorderSizePixel        = 0,
            Parent                 = Cfg.Tab,
            Visible                = true,
        })
        local Line = Instance.new("Frame", Wrapper)
        SetProperty(Line, {
            Name             = "Line",
            Size             = UDim2.new(1, -24, 0, 1),
            Position         = UDim2.new(0, 12, 0.5, 0),
            AnchorPoint      = Vector2.new(0, 0.5),
            BackgroundColor3 = Theme.Divider,
            BorderSizePixel  = 0,
        })

        local Ctrl = {}
        function Ctrl:Destroy()              Destroy(Wrapper) end
        function Ctrl:SetVisible(v)          Wrapper.Visible = v end
        function Ctrl:Set()                  end
        function Ctrl:Get()                  end
        function Ctrl:OnChanged()            end
        function Ctrl:SetTitle()             end
        function Ctrl:SetDescription()       end
        return Ctrl
