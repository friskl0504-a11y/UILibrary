--  Mobile Detection  (v4: GuiService fallback + screen-size check)
-- ─────────────────────────────────────────────────────────────────

local IsMobile = (function()
    -- Primary: TouchEnabled and no physical keyboard
    local ok1, res1 = pcall(function()
        return Services.Input.TouchEnabled and not Services.Input.KeyboardEnabled
    end)
    if ok1 and res1 then return true end

    -- Fallback 1: GuiService.TouchControlsEnabled
    local ok2, res2 = pcall(function()
        return Services.Gui.TouchControlsEnabled
    end)
    if ok2 and res2 then return true end

    -- Fallback 2: small screen (likely phone/tablet executor)
    local ok3, res3 = pcall(function()
        local cam = workspace.CurrentCamera
        return cam and cam.ViewportSize.X < 800
    end)
    if ok3 and res3 then return true end

    return false
end)()

