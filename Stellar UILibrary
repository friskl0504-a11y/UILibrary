    -- ═══════════════════════════════════════════════════════════════════
    --  TOGGLE
    -- ═══════════════════════════════════════════════════════════════════

    function Options:AddToggle(Cfg)
        if not Cfg.Tab then warn("[UILib] AddToggle: missing Cfg.Tab"); return end
        local Toggle = _GlobalComponents and Clone(_GlobalComponents["Toggle"])
        if not Toggle then return end

        local Title, Desc = Options:GetLabels(Toggle)
        local On     = Toggle:FindFirstChild("Value")
        local Main   = Toggle:FindFirstChild("Main")
        local Circle = Main and Main:FindFirstChild("Circle")

        local Listeners = {}

        local function Set(Value)
            if Main then
                Tween(Main, 0.16, {
                    BackgroundColor3 = Value and Theme.ToggleOn or Theme.ToggleOff,
                })
            end
            if Circle then
                Tween(Circle, 0.16, {
                    BackgroundColor3 = Theme.ToggleKnob,
                    Position = Value
                        and UDim2.new(1, -16, 0.5, 0)
                        or  UDim2.new(0,   3, 0.5, 0),
                })
            end
            if On then On.Value = Value end
            for _, fn in ipairs(Listeners) do task.spawn(fn, Value) end
        end

        WinMaid:Add(Connect(Toggle.MouseButton1Click, function()
            local Value = not (On and On.Value)
            Set(Value)
            Buzz(0.3)
            if Cfg.Callback then task.spawn(Cfg.Callback, Value) end
        end))

        Animations:Hover(Toggle, false, WinMaid, Theme.Accent)
        Set(Cfg.Default or false)
        if Title then Title.Text = Cfg.Title       or "" end
        if Desc  then Desc.Text  = Cfg.Description or "" end
        SetProperty(Toggle, { Name = Cfg.Title or "Toggle", Parent = Cfg.Tab, Visible = true })

        -- Bigger touch target on mobile
        if IsMobile then
            Toggle.Size = UDim2.new(Toggle.Size.X.Scale, Toggle.Size.X.Offset,
                                    Toggle.Size.Y.Scale, math.max(Toggle.Size.Y.Offset, 52))
        end

        local Ctrl = {}
        function Ctrl:Set(v)             Set(v) end
        function Ctrl:Get()              return On and On.Value or false end
        function Ctrl:OnChanged(fn)      Listeners[#Listeners + 1] = fn end
        function Ctrl:SetTitle(t)        if Title then Title.Text = t end end
        function Ctrl:SetDescription(t)  if Desc  then Desc.Text  = t end end
        function Ctrl:SetVisible(v)      Toggle.Visible = v end
        function Ctrl:Destroy()          Destroy(Toggle) end

        RegisterFlag(Cfg.Flag, function() return Ctrl:Get() end, function(v) Ctrl:Set(v) end)
        Components[#Components + 1] = Ctrl
        return Ctrl
    end


