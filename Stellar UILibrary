    -- ════════════════════════════════════════
    --  TOGGLE
    -- ════════════════════════════════════════

    function Options:AddToggle(Cfg)
        ValidateCfg("AddToggle", Cfg, { "Title", "Tab" })
        local Toggle = Components and Clone(Components["Toggle"])
        if not Toggle then return end

        local cMaid  = WinMaid:Child()
        local Title, Desc = Options:GetLabels(Toggle)
        local On     = Toggle:FindFirstChild("Value")
        local Main   = Toggle:FindFirstChild("Main")
        local Circle = Main and Main:FindFirstChild("Circle")
        local Changed = Signal.new()
        cMaid:Add(Changed)

        local function Set(Value)
            if Main then
                Tween(Main, Ease.Quart, {
                    BackgroundColor3 = Value and Theme.ToggleOn or Theme.ToggleOff
                })
            end
            if Circle then
                Tween(Circle, Ease.Back, {
                    BackgroundColor3 = Theme.ToggleKnob,
                    Position = Value
                        and UDim2.new(1, -16, 0.5, 0)
                        or  UDim2.new(0,   3, 0.5, 0),
                })
            end
            if On then On.Value = Value end
            Changed:Fire(Value)
        end

        cMaid:Add(Connect(Toggle.MouseButton1Click, function()
            local Value = not (On and On.Value)
            Set(Value)
            if Cfg.Callback then task.spawn(Cfg.Callback, Value) end
        end))

        -- Long-press (mobile vibration hook)
        if IsMobile then
            local pressStart = nil
            cMaid:Add(Connect(Toggle.InputBegan, function(Input)
                if Input.UserInputType == Enum.UserInputType.Touch then
                    pressStart = tick()
                end
            end))
            cMaid:Add(Connect(Toggle.InputEnded, function(Input)
                if Input.UserInputType == Enum.UserInputType.Touch and pressStart then
                    if (tick() - pressStart) >= 0.5 then
                        -- Long press: could hook haptic here
                        Animations:PulseGlow(Toggle)
                    end
                    pressStart = nil
                end
            end))
        end

        Animations:Hover(Toggle, false, cMaid)
        Set(Cfg.Default or false)
        if Title then Title.Text = Cfg.Title       or "" end
        if Desc  then Desc.Text  = Cfg.Description or "" end
        SetProperty(Toggle, { Name = Cfg.Title, Parent = Cfg.Tab, Visible = true })

        Registry:Register(function(T)
            if not Toggle.Parent then return end
            if Main then
                Main.BackgroundColor3 = (On and On.Value) and T.ToggleOn or T.ToggleOff
            end
            if Circle then Circle.BackgroundColor3 = T.ToggleKnob end
        end, cMaid)

        local Ctrl = {}
        function Ctrl:Set(v)         Set(v) end
        function Ctrl:Get()          return On and On.Value or false end
        function Ctrl:OnChanged(fn)  return Changed:Connect(fn) end
        function Ctrl:Destroy()      Destroy(Toggle); cMaid:Destroy() end
        return Ctrl
    end


