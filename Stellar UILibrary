-- ═════════════════════════════════════════════════════════════
--  TweenManager  (v4.0)
-- ═════════════════════════════════════════════════════════════
--[[
    Tracks the most-recent active tween per (instance, property-set
    signature) and cancels it before starting a new one. Without
    this, rapid state changes (e.g. user mashing a toggle) stack
    tweens — each fights for the same property and the visual goes
    janky. With it, only the latest tween survives.

    Implementation uses weak keys so an instance being garbage-
    collected doesn't pin its tween record.
]]
local TweenManager = {
    _active = setmetatable({}, { __mode = "k" }),  -- weak keys
}

--- Stop any in-flight tween on `inst` with the same property signature.
function TweenManager:CancelPrevious(inst, sig)
    local bucket = self._active[inst]
    if not bucket then return end
    local prev = bucket[sig]
    if prev then
        pcall(function() prev:Cancel() end)
        bucket[sig] = nil
    end
end

function TweenManager:Register(inst, sig, tween)
    local bucket = self._active[inst]
    if not bucket then
        bucket = {}
        self._active[inst] = bucket
    end
    bucket[sig] = tween
    -- Auto-clear on completion so we don't keep references alive forever.
    tween.Completed:Connect(function()
        local b = self._active[inst]
        if b and b[sig] == tween then b[sig] = nil end
    end)
end

--- Build a stable signature string from a property table.
--- Sorted keys → identical prop-sets produce identical sigs.
local function _propSig(props)
    local keys = {}
    for k in pairs(props) do keys[#keys + 1] = k end
    table.sort(keys)
    return table.concat(keys, ",")
end

--- Smooth tween helper — modern Cubic/Out default, with auto-cancel.
local function Tween(obj, speed, props, info)
    if not obj then return end
    local tinfo
    if info then
        tinfo = info
    elseif speed then
        tinfo = TweenInfo.new(speed, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out)
    else
        tinfo = Ease.Smooth
    end
    local sig = _propSig(props)
    TweenManager:CancelPrevious(obj, sig)
    local t = Services.Tween:Create(obj, tinfo, props)
    TweenManager:Register(obj, sig, t)
    t:Play()
    return t
end

--- Spring tween (Back/Out — slight overshoot for tactile arrivals).
local function Spring(obj, speed, props)
    if not obj then return end
    local tinfo = TweenInfo.new(speed or 0.32,
        Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    local sig = _propSig(props)
    TweenManager:CancelPrevious(obj, sig)
    local t = Services.Tween:Create(obj, tinfo, props)
    TweenManager:Register(obj, sig, t)
    t:Play()
    return t
end

--- Apply a preset Ease directly (e.g. PresetTween(obj, "Snap", {...}))
local function PresetTween(obj, presetName, props)
    if not obj then return end
    local tinfo = Ease[presetName] or Ease.Smooth
    local sig = _propSig(props)
    TweenManager:CancelPrevious(obj, sig)
    local t = Services.Tween:Create(obj, tinfo, props)
    TweenManager:Register(obj, sig, t)
    t:Play()
    return t
end

--- Batch-set object properties (no animation)
local function SetProperty(obj, props)
    for k, v in next, props do obj[k] = v end
    return obj
end

--- Scale a UDim2 by a factor
local function Multiply(value, amount)
    return UDim2.new(
        value.X.Scale  * amount, value.X.Offset * amount,
        value.Y.Scale  * amount, value.Y.Offset * amount
    )
end

--- Lerp between two Color3 values — uses native Color3:Lerp
local function LerpColor(a, b, t)
    return a:Lerp(b, t)
end

--- Color3 → "#RRGGBB"
local function Color3ToHex(c)
    return string.format("#%02X%02X%02X",
        math.round(c.R * 255),
        math.round(c.G * 255),
        math.round(c.B * 255))
end

--- "#RRGGBB" or "RRGGBB" → Color3 (nil on bad input)
local function HexToColor3(hex)
    if type(hex) ~= "string" then return nil end
    hex = hex:gsub("^#", "")
    if #hex ~= 6 then return nil end
    local r = tonumber(hex:sub(1, 2), 16)
    local g = tonumber(hex:sub(3, 4), 16)
    local b = tonumber(hex:sub(5, 6), 16)
    if not (r and g and b) then return nil end
    return Color3.fromRGB(r, g, b)
end

--- Best-effort haptic pulse (silent fail on platforms that block it)
local function Buzz(intensity)
    if not IsMobile then return end
    pcall(function()
        if Services.Haptic and Services.Haptic.IsVibrationSupported
           and Services.Haptic:IsVibrationSupported(Enum.UserInputType.Touch) then
            Services.Haptic:SetMotor(Enum.UserInputType.Touch,
                Enum.VibrationMotor.Small, intensity or 0.4)
            task.delay(0.05, function()
                pcall(function()
                    Services.Haptic:SetMotor(Enum.UserInputType.Touch,
                        Enum.VibrationMotor.Small, 0)
                end)
            end)
        end
    end)
end


