    -- ════════════════════════════════════════
    --  INPUT  (TextBox) — with validator & mask
    -- ════════════════════════════════════════

    function Options:AddInput(Cfg)
        ValidateCfg("AddInput", Cfg, { "Title", "Tab" })
        local Input = Components and Clone(Components["Input"])
        if not Input then return end

        local cMaid  = WinMaid:Child()
        local Title, Desc = Options:GetLabels(Input)
        local Main    = Input:FindFirstChild("Main")
        local TextBox = Main and Main:FindFirstChild("Input")
        local ErrLbl  = nil

        if TextBox then
            if Cfg.Placeholder then TextBox.PlaceholderText = Cfg.Placeholder end

            -- Mask: strip invalid characters on each keystroke
            if Cfg.Mask then
                cMaid:Add(Connect(TextBox:GetPropertyChangedSignal("Text"), function()
                    local filtered = TextBox.Text:gsub(Cfg.Mask, "")
                    if filtered ~= TextBox.Text then
                        TextBox.Text = filtered
                    end
                end))
            end

            cMaid:Add(Connect(Input.MouseButton1Click, function()
                TextBox:CaptureFocus()
            end))

            if IsMobile then
                cMaid:Add(Connect(Input.InputBegan, function(Inp)
                    if Inp.UserInputType == Enum.UserInputType.Touch then
                        TextBox:CaptureFocus()
                    end
                end))
            end

            cMaid:Add(Connect(TextBox.Focused, function()
                if Main then
                    Tween(Main, Ease.Quart, {
                        BackgroundColor3 = LerpColor(Theme.Interactable, Theme.Accent, 0.12)
                    })
                end
                local Outline = Input:FindFirstChildOfClass("UIStroke")
                    or (Main and Main:FindFirstChildOfClass("UIStroke"))
                if Outline then Tween(Outline, Ease.Quart, { Color = Theme.Accent }) end
            end))

            cMaid:Add(Connect(TextBox.FocusLost, function()
                local text = TextBox.Text
                local valid = true
                local msg   = nil

                -- Validator
                if Cfg.Validator then
                    local result = Cfg.Validator(text)
                    if result == false then
                        valid = false
                    elseif type(result) == "string" then
                        valid = false
                        msg   = result
                    end
                end

                if not valid then
                    -- Show error outline
                    local Outline = Input:FindFirstChildOfClass("UIStroke")
                        or (Main and Main:FindFirstChildOfClass("UIStroke"))
                    if Outline then Tween(Outline, Ease.Quart, { Color = Theme.NoteError }) end
                    if Main    then Tween(Main,    Ease.Quart, {
                        BackgroundColor3 = LerpColor(Theme.Interactable, Theme.NoteError, 0.10)
                    }) end
                    if msg then
                        if not ErrLbl then
                            ErrLbl = New("TextLabel", {
                                Text                   = msg,
                                Font                   = Enum.Font.Gotham,
                                TextSize               = 10,
                                TextColor3             = Theme.NoteError,
                                BackgroundTransparency = 1,
                                TextXAlignment         = Enum.TextXAlignment.Left,
                                Size                   = UDim2.new(1, -12, 0, 14),
                                Position               = UDim2.new(0, 12, 1, 2),
                                ZIndex                 = Input.ZIndex + 1,
                            }, Input)
                        else
                            ErrLbl.Text    = msg
                            ErrLbl.Visible = true
                        end
                    end
                    return
                end

                -- Valid: reset visuals
                if ErrLbl then ErrLbl.Visible = false end
                if Main    then Tween(Main,    Ease.Quart, { BackgroundColor3 = Theme.Interactable }) end
                local Outline = Input:FindFirstChildOfClass("UIStroke")
                    or (Main and Main:FindFirstChildOfClass("UIStroke"))
                if Outline then Tween(Outline, Ease.Quart, { Color = Theme.Outline }) end
                if Cfg.Callback then task.spawn(Cfg.Callback, text) end
            end))
        end

        Animations:Hover(Input, false, cMaid)
        if Title then Title.Text = Cfg.Title       or "" end
        if Desc  then Desc.Text  = Cfg.Description or "" end
        SetProperty(Input, { Name = Cfg.Title, Parent = Cfg.Tab, Visible = true })

        local Ctrl = {}
        function Ctrl:Set(text)  if TextBox then TextBox.Text = text end end
        function Ctrl:Get()      return TextBox and TextBox.Text or "" end
        function Ctrl:Focus()    if TextBox then TextBox:CaptureFocus() end end
        function Ctrl:Destroy()  Destroy(Input); cMaid:Destroy() end
        return Ctrl
    end


    -- ════════════════════════════════════════
    --  SLIDER  (improved — click-to-jump, scroll wheel, prefix/suffix)
    -- ════════════════════════════════════════

    function Options:AddSlider(Cfg)
        ValidateCfg("AddSlider", Cfg, { "Title", "Tab", "MaxValue" })
        local Slider = Components and Clone(Components["Slider"])
        if not Slider then return end

        local cMaid  = WinMaid:Child()
        local Title, Desc = Options:GetLabels(Slider)
        local SliderFrame = Slider:FindFirstChild("Slider")
        local AmountBox   = SliderFrame and SliderFrame:FindFirstChild("Main")
                         and SliderFrame.Main:FindFirstChild("Input")
        local Slide       = SliderFrame and SliderFrame:FindFirstChild("Slide")
        local Fire        = Slide and Slide:FindFirstChild("Fire")
        local Fill        = Slide and Slide:FindFirstChild("Highlight")

        local MinVal = Cfg.MinValue  or 0
        local MaxVal = Cfg.MaxValue  or 100
        local Step   = Cfg.Step      or nil
        local Value  = math.clamp(Cfg.Default or MinVal, MinVal, MaxVal)
        local Changed = Signal.new()
        cMaid:Add(Changed)

        local Active = false
        local HBConn = nil
        local TchConn = nil

        local function Round(n)
            if Step then
                n = math.floor((n - MinVal) / Step + 0.5) * Step + MinVal
            elseif Cfg.AllowDecimals then
                local p = 10 ^ (Cfg.DecimalAmount or 2)
                return math.floor(n * p + 0.5) / p
            else
                return math.round(n)
            end
            return n
        end

        local function FormatValue(n)
            local s = tostring(n)
            if Cfg.Prefix then s = Cfg.Prefix .. s end
            if Cfg.Suffix then s = s .. Cfg.Suffix end
            return s
        end

        local function UpdateFromScale(scale)
            scale  = math.clamp(scale, 0, 1)
            Value  = Round(MinVal + scale * (MaxVal - MinVal))
            if AmountBox then AmountBox.Text = FormatValue(Value) end
            if Fill      then Fill.Size = UDim2.fromScale(scale, 1) end
            Changed:Fire(Value)
            if Cfg.Callback then task.spawn(Cfg.Callback, Value) end
        end

        local function UpdateFromX(posX)
            if not Slide then return end
            local slideX = Slide.AbsolutePosition.X
            local slideW = math.max(Slide.AbsoluteSize.X, 1)
            UpdateFromScale((posX - slideX) / slideW)
        end

        local function SetValue(n)
            n = math.clamp(n, MinVal, MaxVal)
            UpdateFromScale((n - MinVal) / (MaxVal - MinVal))
        end

        local function StopSliding()
            Active = false
            if HBConn  then HBConn:Disconnect();  HBConn  = nil end
            if TchConn then TchConn:Disconnect(); TchConn = nil end
        end
        cMaid:Add(StopSliding)

        local function StartMouse()
            if Active then return end
            Active = true
            HBConn = Svc.Run.Heartbeat:Connect(function()
                if not Active then StopSliding(); return end
                UpdateFromX(Mouse.X)
            end)
        end

        local function StartTouch(touchInput)
            if Active then return end
            Active = true
            TchConn = Svc.Input.InputChanged:Connect(function(changed)
                if not Active then return end
                if changed.UserInputType == Enum.UserInputType.Touch
                    and changed == touchInput then
                    UpdateFromX(changed.Position.X)
                end
            end)
        end

        -- Click anywhere on Slide track to jump
        if Slide then
            cMaid:Add(Connect(Slide.InputBegan, function(Input)
                if Input.UserInputType == Enum.UserInputType.MouseButton1 then
                    UpdateFromX(Input.Position.X)
                    StartMouse()
                elseif Input.UserInputType == Enum.UserInputType.Touch then
                    UpdateFromX(Input.Position.X)
                    StartTouch(Input)
                end
            end))
        end

        if Fire then
            cMaid:Add(Connect(Fire.MouseButton1Down, StartMouse))
            cMaid:Add(Connect(Fire.InputBegan, function(Inp)
                if Inp.UserInputType == Enum.UserInputType.Touch then StartTouch(Inp) end
            end))
        end

        cMaid:Add(Connect(Svc.Input.InputEnded, function(Inp)
            local t = Inp.UserInputType
            if (t == Enum.UserInputType.MouseButton1 or t == Enum.UserInputType.Touch) and Active then
                StopSliding()
            end
        end))

        -- Scroll-wheel support
        cMaid:Add(Connect(Slider.InputChanged, function(Inp)
            if Inp.UserInputType == Enum.UserInputType.MouseWheel then
                local delta = Inp.Position.Z
                local step  = Step or ((MaxVal - MinVal) / 20)
                SetValue(Value + delta * step)
            end
        end))

        -- Manual text entry in the amount box
        if AmountBox then
            cMaid:Add(Connect(AmountBox.FocusLost, function()
                local raw = AmountBox.Text:gsub(Cfg.Prefix or "", ""):gsub(Cfg.Suffix or "", "")
                SetValue(tonumber(raw) or MinVal)
            end))
        end

        SetValue(Value)
        Animations:Hover(Slider, false, cMaid)
        if Title then Title.Text = Cfg.Title       or "" end
        if Desc  then Desc.Text  = Cfg.Description or "" end
        SetProperty(Slider, { Name = Cfg.Title, Parent = Cfg.Tab, Visible = true })

        Registry:Register(function(T)
            if not Slider.Parent then return end
            if Slide then Slide.BackgroundColor3 = T.SliderTrack end
            if Fill  then Fill.BackgroundColor3  = T.SliderFill  end
        end, cMaid)

        local Ctrl = {}
        function Ctrl:Set(n)        SetValue(n) end
        function Ctrl:Get()         return Value end
        function Ctrl:OnChanged(fn) return Changed:Connect(fn) end
        function Ctrl:Destroy()     Destroy(Slider); cMaid:Destroy() end
        return Ctrl
    end


    -- ════════════════════════════════════════
    --  NUMBER INPUT  (new — ± stepper + scrollwheel)
