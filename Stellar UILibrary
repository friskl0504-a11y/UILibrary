-- ─────────────────────────────────────────────────────────────────
--  Maid  (connection / instance cleanup)
-- ─────────────────────────────────────────────────────────────────
--[[
    m = Maid.new()
    m:Add(connection)    → RBXScriptConnection:Disconnect()
    m:Add(instance)      → Instance:Destroy()
    m:Add(function()end) → called as cleanup fn
    m:Remove(task)       → remove individual entry (v3.0 new)
    m:Destroy()          → runs all, clears list
]]

local Maid = {}
Maid.__index = Maid

function Maid.new()
    return setmetatable({ _tasks = {} }, Maid)
end

function Maid:Add(task_)
    self._tasks[#self._tasks + 1] = task_
    return task_
end

--- Remove a single task without triggering it.
function Maid:Remove(task_)
    for i = #self._tasks, 1, -1 do
        if self._tasks[i] == task_ then
            table.remove(self._tasks, i)
            return
        end
    end
end

function Maid:Destroy()
    for i = #self._tasks, 1, -1 do
        local t  = self._tasks[i]
        local tt = type(t)
        if tt == "function" then
            pcall(t)
        elseif tt == "table" and t.Destroy then
            pcall(function() t:Destroy() end)
        elseif tt == "userdata" then
            if t.Disconnect then
                pcall(function() t:Disconnect() end)
            elseif t.Destroy then
                pcall(function() t:Destroy() end)
            end
        end
        self._tasks[i] = nil
    end
end


-- ─────────────────────────────────────────────────────────────────
--  Signal  (v3.0 — proper typed event emitter)
-- ─────────────────────────────────────────────────────────────────
--[[
    sig = Signal.new()
    conn = sig:Connect(function(...) end)
    conn:Disconnect()
    sig:Fire(...)
    sig:DisconnectAll()
]]

local Signal = {}
Signal.__index = Signal

function Signal.new()
    return setmetatable({ _conns = {} }, Signal)
end

function Signal:Connect(fn)
    local conn = { _fn = fn, _sig = self, _active = true }
    self._conns[#self._conns + 1] = conn
    function conn:Disconnect()
        self._active = false
        local list = self._sig._conns
        for i = #list, 1, -1 do
            if list[i] == self then
                table.remove(list, i)
                break
            end
        end
    end
    return conn
end

function Signal:Fire(...)
    local args = { ... }
    for i = #self._conns, 1, -1 do
        local c = self._conns[i]
        if c._active then task.spawn(c._fn, table.unpack(args)) end
    end
end

function Signal:DisconnectAll()
    for _, c in ipairs(self._conns) do c._active = false end
    self._conns = {}
end


