        local OpenDD = nil
        local function CloseDD()
            if not OpenDD then return end
            if BG then Tween(BG, Ease.Quart, { BackgroundTransparency = 1 }) end
            Animations:Close(OpenDD)
            task.delay(0.25, function() if OpenDD then Destroy(OpenDD) end; OpenDD = nil end)
        end

        cMaid:Add(Connect(Dropdown.MouseButton1Click, function()
            if OpenDD then CloseDD(); return end
            local Example = Examples and Clone(Examples["DropdownExample"])
            if not Example then return end
            OpenDD = Example

            local CloseButtons = Example:FindFirstChild("Top") and Example.Top:FindFirstChild("Buttons")
            local ScrollFrame  = Example:FindFirstChild("ScrollingFrame") or Example
            local ItemBtns     = {}

            if Cfg.Searchable then
                local SearchRow = New("Frame", {
                    Size             = UDim2.new(1, 0, 0, 32),
                    BackgroundColor3 = Theme.Secondary,
                    BorderSizePixel  = 0,
                    LayoutOrder      = -999,
                }, ScrollFrame)
                New("UIPadding", { PaddingLeft = UDim.new(0, 8), PaddingRight = UDim.new(0, 8),
                                   PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 4) }, SearchRow)
                local SearchBox = New("TextBox", {
                    Text = "", PlaceholderText = "Search...",
                    Font = Enum.Font.Gotham, TextSize = 12,
                    TextColor3 = Theme.Title, PlaceholderColor3 = Theme.Muted,
                    BackgroundTransparency = 1,
                    Size = UDim2.fromScale(1, 1),
                    ClearTextOnFocus = false,
                }, SearchRow)
                Connect(SearchBox:GetPropertyChangedSignal("Text"), function()
                    local f = SearchBox.Text:lower()
                    for _, pair in ipairs(ItemBtns) do
                        pair.btn.Visible = (f == "" or pair.key:lower():find(f, 1, true) ~= nil)
                    end
                end)
            end

            if BG then Tween(BG, Ease.Quart, { BackgroundTransparency = 0.5 }) end
            Example.Parent = Window
            Animations:Open(Example, 0, true)

            if CloseButtons then
                for _, Btn in next, CloseButtons:GetChildren() do
                    if Btn:IsA("TextButton") then
                        Animations:Hover(Btn)
                        Connect(Btn.MouseButton1Click, CloseDD)
                    end
                end
            end

            for Index, Option in next, Cfg.Options do
                local Btn = Clone(Examples["DropdownButtonExample"])
                if not Btn then continue end
                local BTitle, _ = Options:GetLabels(Btn)
                if BTitle then BTitle.Text = tostring(Index) end

                local Chk = New("TextLabel", {
                    Name                   = "CheckMark",
                    Text                   = Selected[Option] and "✓" or "",
                    Font                   = Enum.Font.GothamBold,
                    TextSize               = 13,
                    TextColor3             = Theme.Accent,
                    BackgroundTransparency = 1,
                    Size                   = UDim2.new(0, 20, 1, 0),
                    Position               = UDim2.new(1, -24, 0, 0),
                    AnchorPoint            = Vector2.new(1, 0),
                    ZIndex                 = Btn.ZIndex + 1,
                }, Btn)

                if Selected[Option] then
                    Btn.BackgroundColor3 = LerpColor(Theme.Component, Theme.Accent, 0.12)
                end

                SetProperty(Btn, { Parent = ScrollFrame, Visible = true })
                Animations:Hover(Btn)
                table.insert(ItemBtns, { btn = Btn, key = tostring(Index) })

                Connect(Btn.MouseButton1Click, function()
                    Selected[Option] = not Selected[Option]
                    Chk.Text = Selected[Option] and "✓" or ""
                    Tween(Btn, Ease.Quart, {
                        BackgroundColor3 = Selected[Option]
                            and LerpColor(Theme.Component, Theme.Accent, 0.12)
                            or  Theme.Component
                    })
                    UpdateLabel()
                    local arr = {}
                    for v in pairs(Selected) do arr[#arr + 1] = v end
                    Changed:Fire(arr)
                    if Cfg.Callback then task.spawn(Cfg.Callback, arr) end
                end)
            end

            -- Close on outside click
            local globalConn
            globalConn = Connect(Svc.Input.InputBegan, function(Input)
                if Input.UserInputType == Enum.UserInputType.MouseButton1 then
                    local mPos   = Svc.Input:GetMouseLocation()
                    local ddPos  = Example.AbsolutePosition
                    local ddSize = Example.AbsoluteSize
                    if mPos.X < ddPos.X or mPos.X > ddPos.X + ddSize.X
                    or mPos.Y < ddPos.Y or mPos.Y > ddPos.Y + ddSize.Y then
                        CloseDD()
                        globalConn:Disconnect()
                    end
                end
            end)
        end))

        Animations:Hover(Dropdown, false, cMaid)
        if Title then Title.Text = Cfg.Title       or "" end
        if Desc  then Desc.Text  = Cfg.Description or "" end
        SetProperty(Dropdown, { Name = Cfg.Title, Parent = Cfg.Tab, Visible = true })

        local Ctrl = {}
        function Ctrl:Get()
            local arr = {}
            for v in pairs(Selected) do arr[#arr + 1] = v end
            return arr
        end
        function Ctrl:Set(values)
            Selected = {}
            for _, v in ipairs(values) do Selected[v] = true end
            UpdateLabel()
        end
        function Ctrl:OnChanged(fn) return Changed:Connect(fn) end
        function Ctrl:Destroy()     CloseDD(); Destroy(Dropdown); cMaid:Destroy() end
        return Ctrl
    end


    -- ════════════════════════════════════════
    --  RADIO GROUP  (new — mutually exclusive)
    -- ════════════════════════════════════════
    --[[
        Cfg = {
            Title:       string
            Description: string?
            Options:     { string }   — ordered list of option labels
            Default:     string?      — selected option label
            Tab:         Instance
            Callback:    function(selectedLabel: string)
        }
        Returns: { Get(), Set(label), OnChanged(fn), Destroy() }
    ]]

    function Options:AddRadioGroup(Cfg)
        ValidateCfg("AddRadioGroup", Cfg, { "Title", "Tab", "Options" })
        local cMaid  = WinMaid:Child()
        local Changed = Signal.new()
        cMaid:Add(Changed)

        local Selected = Cfg.Default or (Cfg.Options[1])

        local H_header = 32
        local H_item   = TouchH - 4
        local TotalH   = H_header + (#Cfg.Options * (H_item + 4)) + 8

        local Wrapper = New("Frame", {
            Name             = "RadioGroup_" .. Cfg.Title,
            Size             = UDim2.new(1, 0, 0, TotalH),
            BackgroundColor3 = Theme.Component,
            BorderSizePixel  = 0,
            Parent           = Cfg.Tab,
            Visible          = true,
        })
        New("UICorner", { CornerRadius = CORNER }, Wrapper)
        New("UIPadding", { PaddingLeft = UDim.new(0, 12), PaddingRight = UDim.new(0, 12),
                           PaddingTop = UDim.new(0, 6), PaddingBottom = UDim.new(0, 6) }, Wrapper)
        New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 4) }, Wrapper)

        -- Title row
        local Header = New("TextLabel", {
            Text                   = Cfg.Title,
            Font                   = Enum.Font.GothamSemibold,
            TextSize               = 13,
            TextColor3             = Theme.Title,
            BackgroundTransparency = 1,
            TextXAlignment         = Enum.TextXAlignment.Left,
            Size                   = UDim2.new(1, 0, 0, H_header - 6),
            LayoutOrder            = 0,
        }, Wrapper)

        local ItemFrames = {}

        local function Refresh()
            for label, pair in pairs(ItemFrames) do
                local active = (label == Selected)
                Tween(pair.outer, Ease.Quart, {
                    BackgroundColor3 = active and Theme.RadioActive or Theme.RadioInactive
                })
                if active then
                    Tween(pair.inner, Ease.Back, {
                        Size    = UDim2.new(0, 8, 0, 8),
                        BackgroundColor3 = Color3.new(1,1,1),
                    })
                else
                    Tween(pair.inner, Ease.Quart, {
                        Size    = UDim2.new(0, 0, 0, 0),
                    })
                end
            end
        end

        for i, label in ipairs(Cfg.Options) do
            local Row = New("TextButton", {
                Text             = "",
                AutoButtonColor  = false,
                BackgroundColor3 = Theme.Secondary,
                BorderSizePixel  = 0,
                Size             = UDim2.new(1, 0, 0, H_item),
                LayoutOrder      = i,
            }, Wrapper)
            New("UICorner", { CornerRadius = UDim.new(0, 6) }, Row)

            -- Radio circle
            local Outer = New("Frame", {
                Size             = UDim2.new(0, 16, 0, 16),
                Position         = UDim2.new(0, 8, 0.5, 0),
                AnchorPoint      = Vector2.new(0, 0.5),
                BackgroundColor3 = (label == Selected) and Theme.RadioActive or Theme.RadioInactive,
                BorderSizePixel  = 0,
            }, Row)
            New("UICorner", { CornerRadius = UDim.new(1, 0) }, Outer)

            local Inner = New("Frame", {
                Size             = (label == Selected) and UDim2.new(0, 8, 0, 8) or UDim2.new(0, 0, 0, 0),
                AnchorPoint      = Vector2.new(0.5, 0.5),
                Position         = UDim2.fromScale(0.5, 0.5),
                BackgroundColor3 = Color3.new(1, 1, 1),
                BorderSizePixel  = 0,
            }, Outer)
            New("UICorner", { CornerRadius = UDim.new(1, 0) }, Inner)

            -- Label
            New("TextLabel", {
                Text                   = label,
                Font                   = Enum.Font.GothamMedium,
                TextSize               = 13,
                TextColor3             = Theme.Title,
                BackgroundTransparency = 1,
                TextXAlignment         = Enum.TextXAlignment.Left,
                Size                   = UDim2.new(1, -36, 1, 0),
                Position               = UDim2.new(0, 32, 0, 0),
            }, Row)

            ItemFrames[label] = { outer = Outer, inner = Inner, row = Row }
            Animations:Hover(Row, false, cMaid)

            cMaid:Add(Connect(Row.MouseButton1Click, function()
                if Selected == label then return end
                Selected = label
                Refresh()
                Changed:Fire(Selected)
                if Cfg.Callback then task.spawn(Cfg.Callback, Selected) end
            end))
        end

        Registry:Register(function(T)
            if not Wrapper.Parent then return end
            Wrapper.BackgroundColor3 = T.Component
            Header.TextColor3        = T.Title
            for label, pair in pairs(ItemFrames) do
                pair.outer.BackgroundColor3 = (label == Selected) and T.RadioActive or T.RadioInactive
                pair.row.BackgroundColor3   = T.Secondary
            end
        end, cMaid)

        local Ctrl = {}
        function Ctrl:Get()         return Selected end
        function Ctrl:Set(label)    Selected = label; Refresh() end
        function Ctrl:OnChanged(fn) return Changed:Connect(fn) end
        function Ctrl:Destroy()     Destroy(Wrapper); cMaid:Destroy() end
        return Ctrl
    end


