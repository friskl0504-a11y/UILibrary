-- ─────────────────────────────────────────────
--  Maid  (connection / instance cleanup)
-- ─────────────────────────────────────────────
--[[
    Usage:
        local m = Maid.new()
        m:Add(someSignal:Connect(fn))  -- RBXScriptConnection
        m:Add(someInstance)            -- Instance (will be :Destroyed)
        m:Add(function() ... end)      -- arbitrary cleanup fn
        m:Destroy()                    -- runs all, clears list
]]

local Maid = {}
Maid.__index = Maid

function Maid.new()
    return setmetatable({ _tasks = {} }, Maid)
end

function Maid:Add(task_)
    self._tasks[#self._tasks + 1] = task_
    return task_
end

function Maid:Destroy()
    for i = #self._tasks, 1, -1 do
        local t  = self._tasks[i]
        local tt = type(t)
        if tt == "function" then
            pcall(t)
        elseif tt == "table" and t.Destroy then
            pcall(function() t:Destroy() end)
        elseif tt == "userdata" then
            if t.Disconnect then
                pcall(function() t:Disconnect() end)
            elseif t.Destroy then
                pcall(function() t:Destroy() end)
            end
        end
        self._tasks[i] = nil
    end
end


-- ─────────────────────────────────────────────
--  Utility Functions
-- ─────────────────────────────────────────────

local function Clone(obj)       return obj:Clone()              end
local function Destroy(obj)     pcall(function() obj:Destroy() end) end
local function Connect(sig, fn) return sig:Connect(fn)          end

--- Smooth tween helper (defaults to Quart/Out)
local function Tween(obj, speed, props, info)
    local style = (info and info.EasingStyle)     or Enum.EasingStyle.Quart
    local dir   = (info and info.EasingDirection) or Enum.EasingDirection.Out
    Services.Tween:Create(obj, TweenInfo.new(speed, style, dir), props):Play()
end

--- Batch-set object properties
local function SetProperty(obj, props)
    for k, v in next, props do obj[k] = v end
    return obj
end

--- Scale a UDim2 by a factor
local function Multiply(value, amount)
    return UDim2.new(
        value.X.Scale  * amount, value.X.Offset * amount,
        value.Y.Scale  * amount, value.Y.Offset * amount
    )
end

--- Lerp between two Color3 values — uses native Color3:Lerp
local function LerpColor(a, b, t)
    return a:Lerp(b, t)
end

--- Brighten/darken a Color3 in a theme-aware direction
local function ShiftColor(color, factor)
    local mode = Setup.ThemeMode
    local f = (mode == "Light") and -math.abs(factor) or math.abs(factor)
    return Color3.fromRGB(
        math.clamp((color.R * 255) + f, 0, 255),
        math.clamp((color.G * 255) + f, 0, 255),
        math.clamp((color.B * 255) + f, 0, 255)
    )
end

--- Color3 → "#RRGGBB"
local function Color3ToHex(c)
    return string.format("#%02X%02X%02X",
        math.round(c.R * 255),
        math.round(c.G * 255),
        math.round(c.B * 255))
end

--- "#RRGGBB" or "RRGGBB" → Color3 (nil on bad input)
local function HexToColor3(hex)
    hex = hex:gsub("^#", "")
    if #hex ~= 6 then return nil end
    local r = tonumber(hex:sub(1, 2), 16)
    local g = tonumber(hex:sub(3, 4), 16)
    local b = tonumber(hex:sub(5, 6), 16)
    if not (r and g and b) then return nil end
    return Color3.fromRGB(r, g, b)
end


