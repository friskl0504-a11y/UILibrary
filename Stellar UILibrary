    function Options:AddColorPicker(Cfg)
        --[[
            Cfg = {
                Title:    string
                Default:  Color3?
                Tab:      Instance
                Callback: function(Color3)
            }
            Returns: { Set(Color3), Get() }
        ]]

        -- ── Collapsed row ────────────────────────────────────────────────
        local Row = Instance.new("TextButton")
        SetProperty(Row, {
            Name             = "ColorPicker_" .. (Cfg.Title or ""),
            Size             = UDim2.new(1, 0, 0, IsMobile and 48 or 40),
            BackgroundColor3 = Theme.Component,
            BorderSizePixel  = 0,
            Text             = "",
            AutoButtonColor  = false,
            Parent           = Cfg.Tab,
            Visible          = true,
        })
        Instance.new("UICorner", Row).CornerRadius = UDim.new(0, 8)
        local RowPad = Instance.new("UIPadding", Row)
        RowPad.PaddingLeft  = UDim.new(0, 12)
        RowPad.PaddingRight = UDim.new(0, 12)

        local RowTitle = Instance.new("TextLabel", Row)
        SetProperty(RowTitle, {
            Text                   = Cfg.Title or "Color",
            Font                   = Enum.Font.GothamSemibold,
            TextSize               = 13,
            TextColor3             = Theme.Title,
            BackgroundTransparency = 1,
            TextXAlignment         = Enum.TextXAlignment.Left,
            Size                   = UDim2.new(1, -50, 1, 0),
            BorderSizePixel        = 0,
        })

        local Swatch = Instance.new("Frame", Row)
        SetProperty(Swatch, {
            Name             = "Swatch",
            Size             = UDim2.new(0, IsMobile and 36 or 28, 0, IsMobile and 22 or 18),
            Position         = UDim2.new(1, 0, 0.5, 0),
            AnchorPoint      = Vector2.new(1, 0.5),
            BorderSizePixel  = 0,
            BackgroundColor3 = Cfg.Default or Color3.fromRGB(108, 130, 255),
        })
        Instance.new("UICorner", Swatch).CornerRadius = UDim.new(0, 5)
        local SwatchStroke = Instance.new("UIStroke", Swatch)
        SwatchStroke.Color = Theme.Outline

        -- ── Expanded picker panel ─────────────────────────────────────────
        local SV_H    = IsMobile and 130 or 110
        local HUE_H   = IsMobile and 18  or 14
        local HEX_H   = IsMobile and 32  or 26
        local PANEL_H = 16 + SV_H + 8 + HUE_H + 8 + HEX_H + 10

        local Picker = Instance.new("Frame")
        SetProperty(Picker, {
            Name             = "Picker",
            Size             = UDim2.new(1, 0, 0, 0),
            BackgroundColor3 = Theme.CPBackground,
            BorderSizePixel  = 0,
            ClipsDescendants = true,
            Visible          = false,
            Parent           = Cfg.Tab,
        })
        Instance.new("UICorner", Picker).CornerRadius = UDim.new(0, 8)
        local PickerStroke = Instance.new("UIStroke", Picker)
        PickerStroke.Color = Theme.CPBorder

        -- SV canvas: base hue colour + white-gradient (sat) + black-gradient (val)
        local SVCanvas = Instance.new("Frame", Picker)
        SetProperty(SVCanvas, {
            Name             = "SVCanvas",
            Size             = UDim2.new(1, -16, 0, SV_H),
            Position         = UDim2.new(0, 8, 0, 8),
            BackgroundColor3 = Color3.fromHSV(0, 1, 1),
            BorderSizePixel  = 0,
            ClipsDescendants = false,
        })
        Instance.new("UICorner", SVCanvas).CornerRadius = UDim.new(0, 6)

        -- White overlay (saturation — left opaque, right transparent)
        local WhiteOverlay = Instance.new("Frame", SVCanvas)
        SetProperty(WhiteOverlay, {
            Size             = UDim2.fromScale(1, 1),
            BackgroundColor3 = Color3.new(1, 1, 1),
            BorderSizePixel  = 0,
            ZIndex           = SVCanvas.ZIndex + 1,
        })
        Instance.new("UICorner", WhiteOverlay).CornerRadius = UDim.new(0, 6)
        local WhiteGrad = Instance.new("UIGradient", WhiteOverlay)
        WhiteGrad.Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0),
            NumberSequenceKeypoint.new(1, 1),
        })

        -- Black overlay (value — top transparent, bottom opaque)
        local BlackOverlay = Instance.new("Frame", SVCanvas)
        SetProperty(BlackOverlay, {
            Size             = UDim2.fromScale(1, 1),
            BackgroundColor3 = Color3.new(0, 0, 0),
            BorderSizePixel  = 0,
            ZIndex           = SVCanvas.ZIndex + 2,
        })
        Instance.new("UICorner", BlackOverlay).CornerRadius = UDim.new(0, 6)
        local BlackGrad = Instance.new("UIGradient", BlackOverlay)
        BlackGrad.Rotation     = 90
        BlackGrad.Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 1),
            NumberSequenceKeypoint.new(1, 0),
        })

        -- SV thumb
        local SVThumb = Instance.new("Frame", SVCanvas)
        SetProperty(SVThumb, {
            Size             = UDim2.new(0, 12, 0, 12),
            AnchorPoint      = Vector2.new(0.5, 0.5),
            Position         = UDim2.new(1, 0, 0, 0),
            BackgroundColor3 = Color3.new(1, 1, 1),
            BorderSizePixel  = 0,
            ZIndex           = SVCanvas.ZIndex + 5,
        })
        Instance.new("UICorner", SVThumb).CornerRadius = UDim.new(1, 0)
        local SVStroke = Instance.new("UIStroke", SVThumb)
        SVStroke.Color = Color3.new(0.15, 0.15, 0.15); SVStroke.Thickness = 1.5

        -- Hue track (rainbow gradient)
        local HueTrack = Instance.new("Frame", Picker)
        SetProperty(HueTrack, {
            Name             = "HueTrack",
            Size             = UDim2.new(1, -16, 0, HUE_H),
            Position         = UDim2.new(0, 8, 0, 8 + SV_H + 8),
            BackgroundColor3 = Color3.new(1, 0, 0),
            BorderSizePixel  = 0,
            ClipsDescendants = true,
        })
        Instance.new("UICorner", HueTrack).CornerRadius = UDim.new(1, 0)
        local HueGrad = Instance.new("UIGradient", HueTrack)
        HueGrad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0/6,   Color3.fromHSV(0/6,   1, 1)),
            ColorSequenceKeypoint.new(1/6,   Color3.fromHSV(1/6,   1, 1)),
            ColorSequenceKeypoint.new(2/6,   Color3.fromHSV(2/6,   1, 1)),
            ColorSequenceKeypoint.new(3/6,   Color3.fromHSV(3/6,   1, 1)),
            ColorSequenceKeypoint.new(4/6,   Color3.fromHSV(4/6,   1, 1)),
            ColorSequenceKeypoint.new(5/6,   Color3.fromHSV(5/6,   1, 1)),
            ColorSequenceKeypoint.new(1,     Color3.fromHSV(1,     1, 1)),
        })

        local HueThumb = Instance.new("Frame", HueTrack)
        SetProperty(HueThumb, {
            Size             = UDim2.new(0, IsMobile and 16 or 12, 1, 4),
            AnchorPoint      = Vector2.new(0.5, 0.5),
            Position         = UDim2.new(0, 0, 0.5, 0),
            BackgroundColor3 = Color3.new(1, 1, 1),
            BorderSizePixel  = 0,
            ZIndex           = HueTrack.ZIndex + 2,
        })
        Instance.new("UICorner", HueThumb).CornerRadius = UDim.new(0, 4)
        local HueStroke = Instance.new("UIStroke", HueThumb)
        HueStroke.Color = Color3.new(0.15, 0.15, 0.15); HueStroke.Thickness = 1.5

        -- Hex input
        local HexRow = Instance.new("Frame", Picker)
        SetProperty(HexRow, {
            Name             = "HexRow",
            Size             = UDim2.new(1, -16, 0, HEX_H),
            Position         = UDim2.new(0, 8, 0, 8 + SV_H + 8 + HUE_H + 8),
            BackgroundColor3 = Theme.CPHexBg,
            BorderSizePixel  = 0,
        })
        Instance.new("UICorner", HexRow).CornerRadius = UDim.new(0, 6)

        local HexInput = Instance.new("TextBox", HexRow)
        SetProperty(HexInput, {
            Name              = "HexInput",
            Text              = "",
            PlaceholderText   = "#RRGGBB",
            Font              = Enum.Font.Code,
            TextSize          = 12,
            TextColor3        = Theme.Title,
            BackgroundTransparency = 1,
            Size              = UDim2.new(1, -12, 1, 0),
            Position          = UDim2.new(0, 6, 0, 0),
            ClearTextOnFocus  = false,
            BorderSizePixel   = 0,
        })

        -- ── HSV state ─────────────────────────────────────────────────────
        local H, S, V = Color3.toHSV(Cfg.Default or Color3.fromRGB(108, 130, 255))
        local PickerOpen = false

        local function GetC3() return Color3.fromHSV(H, S, V) end

        local function UpdateVisuals()
            local c3 = GetC3()
            Swatch.BackgroundColor3 = c3
            SVCanvas.BackgroundColor3 = Color3.fromHSV(H, 1, 1)
            SVThumb.Position = UDim2.new(S, 0, 1 - V, 0)
            HueThumb.Position = UDim2.new(H, 0, 0.5, 0)
            HexInput.Text = Color3ToHex(c3)
            if Cfg.Callback then task.spawn(Cfg.Callback, c3) end
        end

        -- Toggle open/close
        WinMaid:Add(Connect(Row.MouseButton1Click, function()
            PickerOpen = not PickerOpen
            if PickerOpen then
                Picker.Visible = true
                Tween(Picker, 0.2, { Size = UDim2.new(1, 0, 0, PANEL_H) })
            else
                Tween(Picker, 0.18, { Size = UDim2.new(1, 0, 0, 0) })
                task.delay(0.2, function() Picker.Visible = false end)
            end
        end))

        -- SV drag
        local SVDragging = false
        local function UpdateSV(px, py)
            local ax, ay = SVCanvas.AbsolutePosition.X, SVCanvas.AbsolutePosition.Y
            local aw, ah = math.max(SVCanvas.AbsoluteSize.X, 1), math.max(SVCanvas.AbsoluteSize.Y, 1)
            S = math.clamp((px - ax) / aw, 0, 1)
            V = 1 - math.clamp((py - ay) / ah, 0, 1)
            UpdateVisuals()
        end
        WinMaid:Add(Connect(SVCanvas.InputBegan, function(Inp)
            if Inp.UserInputType == Enum.UserInputType.MouseButton1
                or Inp.UserInputType == Enum.UserInputType.Touch then
                SVDragging = true
                UpdateSV(Inp.Position.X, Inp.Position.Y)
            end
        end))
        WinMaid:Add(Connect(Services.Input.InputChanged, function(Inp)
            if not SVDragging then return end
            if Inp.UserInputType == Enum.UserInputType.MouseMovement
                or Inp.UserInputType == Enum.UserInputType.Touch then
                UpdateSV(Inp.Position.X, Inp.Position.Y)
            end
        end))
        WinMaid:Add(Connect(Services.Input.InputEnded, function(Inp)
            if Inp.UserInputType == Enum.UserInputType.MouseButton1
                or Inp.UserInputType == Enum.UserInputType.Touch then
                SVDragging = false
            end
        end))

        -- Hue drag
        local HueDragging = false
        local function UpdateHue(px)
            local ax = HueTrack.AbsolutePosition.X
            local aw = math.max(HueTrack.AbsoluteSize.X, 1)
            H = math.clamp((px - ax) / aw, 0, 1)
            UpdateVisuals()
        end
        WinMaid:Add(Connect(HueTrack.InputBegan, function(Inp)
            if Inp.UserInputType == Enum.UserInputType.MouseButton1
                or Inp.UserInputType == Enum.UserInputType.Touch then
                HueDragging = true
                UpdateHue(Inp.Position.X)
            end
        end))
        WinMaid:Add(Connect(Services.Input.InputChanged, function(Inp)
            if not HueDragging then return end
            if Inp.UserInputType == Enum.UserInputType.MouseMovement
                or Inp.UserInputType == Enum.UserInputType.Touch then
                UpdateHue(Inp.Position.X)
            end
        end))
        WinMaid:Add(Connect(Services.Input.InputEnded, function(Inp)
            if Inp.UserInputType == Enum.UserInputType.MouseButton1
                or Inp.UserInputType == Enum.UserInputType.Touch then
                HueDragging = false
            end
        end))

        -- Hex input
        WinMaid:Add(Connect(HexInput.FocusLost, function()
            local c3 = HexToColor3(HexInput.Text)
            if c3 then
                H, S, V = Color3.toHSV(c3)
                UpdateVisuals()
            else
                HexInput.Text = Color3ToHex(GetC3())
            end
        end))

        UpdateVisuals()
        Animations:Hover(Row, false, WinMaid)

        local Ctrl = {}
        function Ctrl:Set(c3) H, S, V = Color3.toHSV(c3); UpdateVisuals() end
        function Ctrl:Get()   return GetC3() end
        return Ctrl
    end


    -- ════════════════════════════════════════
    --  CODE BLOCK
    -- ════════════════════════════════════════

    function Options:AddCodeBlock(Cfg)
        --[[
            Cfg = {
                Title:    string
                Code:     string
                Tab:      Instance
                Callback: function()?   — called after copy
            }
        ]]
        local Template = Components and (Components:FindFirstChild("Code") or Components["Paragraph"])
        if not Template then return end

        local Block   = Clone(Template)
        local Title, Desc = Options:GetLabels(Block)
        local CopyBtn = Block:FindFirstChild("Copy") or Block:FindFirstChild("CopyButton")

        -- Traffic-light dots
        local Dots = Block:FindFirstChild("Dots")
        if Dots then
            local DR = Dots:FindFirstChild("Red")
            local DY = Dots:FindFirstChild("Yellow")
            local DG = Dots:FindFirstChild("Green")
            if DR then DR.BackgroundColor3 = Theme.CodeDotRed    end
            if DY then DY.BackgroundColor3 = Theme.CodeDotYellow end
            if DG then DG.BackgroundColor3 = Theme.CodeDotGreen  end
        end

        if Title then Title.Text = Cfg.Title or "Code" end
        if Desc  then Desc.Text  = Cfg.Code  or ""    end

        if CopyBtn then
            local BtnLabel = CopyBtn:FindFirstChild("TextLabel") or CopyBtn:FindFirstChild("Label")

            WinMaid:Add(Connect(CopyBtn.MouseButton1Click, function()
                pcall(function()
                    if setclipboard then setclipboard(Cfg.Code or "") end
                end)

                if BtnLabel then
                    local Original = BtnLabel.Text
                    BtnLabel.Text  = "Copied!"
                    Tween(CopyBtn, 0.1, {
                        BackgroundColor3 = LerpColor(Theme.Component, Theme.Accent, 0.25),
                    })
                    task.delay(1.5, function()
                        BtnLabel.Text = Original
                        Tween(CopyBtn, 0.15, { BackgroundColor3 = Theme.Component })
                    end)
                end

                if Cfg.Callback then task.spawn(Cfg.Callback) end
            end))

            Animations:Hover(CopyBtn, false, WinMaid)
        end

        SetProperty(Block, { Parent = Cfg.Tab, Visible = true })
    end


    -- ════════════════════════════════════════
    --  THEME ENGINE
    -- ════════════════════════════════════════

    local NameRules = {
        ["Paragraph"]       = function(L) if L:IsA("TextButton") then L.BackgroundColor3 = Theme.Component end end,
        ["Title"]           = function(L) if L:IsA("TextLabel")  then L.TextColor3 = Theme.Title          end end,
        ["Description"]     = function(L) if L:IsA("TextLabel")  then L.TextColor3 = Theme.Description    end end,
        ["Section"]         = function(L) if L:IsA("TextLabel")  then L.TextColor3 = Theme.SectionText    end end,
        ["Options"]         = function(L)
            if L:IsA("TextLabel") and L.Parent.Name == "Main" then L.TextColor3 = Theme.Title end
        end,
        ["Notification"]    = function(L)
            if L:IsA("CanvasGroup") then
                L.BackgroundColor3 = Theme.Primary
                local S = L:FindFirstChildOfClass("UIStroke")
                if S then S.Color = Theme.Outline end
            end
        end,
        ["TextLabel"]       = function(L)
            if L:IsA("TextLabel") and L.Parent:FindFirstChild("List") then L.TextColor3 = Theme.Tab end
        end,
        ["Main"]            = function(L)
            if L:IsA("Frame") then
                if L.Parent == Window then
                    L.BackgroundColor3 = Theme.Secondary
                elseif L.Parent:FindFirstChild("Value") then
                    local V = L.Parent.Value
                    if not V.Value then
                        L.BackgroundColor3 = Theme.ToggleOff
                        local C = L:FindFirstChild("Circle")
                        if C then C.BackgroundColor3 = Theme.Primary end
                    end
                else
                    L.BackgroundColor3 = Theme.Interactable
                end
            elseif L:FindFirstChild("Padding") then
                L.TextColor3 = Theme.Title
            end
        end,
        ["Amount"]          = function(L) if L:IsA("Frame") then L.BackgroundColor3 = Theme.Interactable end end,
        ["Slide"]           = function(L) if L:IsA("Frame") then L.BackgroundColor3 = Theme.SliderTrack  end end,
        ["Highlight"]       = function(L) if L:IsA("Frame") then L.BackgroundColor3 = Theme.SliderFill   end end,
        ["Input"]           = function(L)
            if L:IsA("TextLabel") then
                L.TextColor3 = Theme.Title
            elseif L:FindFirstChild("Labels") then
                L.BackgroundColor3 = Theme.Component
            elseif L:IsA("TextBox") and L.Parent.Name == "Main" then
                L.TextColor3 = Theme.Title
            end
        end,
        ["Outline"]         = function(L) if L:IsA("UIStroke") then L.Color = Theme.Outline end end,
        ["DropdownExample"] = function(L) if L:IsA("Frame")    then L.BackgroundColor3 = Theme.Secondary end end,
        ["Underline"]       = function(L) if L:IsA("Frame")    then L.BackgroundColor3 = Theme.Divider   end end,
        -- New component rules
        ["Line"]            = function(L) if L:IsA("Frame")    then L.BackgroundColor3 = Theme.Divider   end end,
        ["Track"]           = function(L) if L:IsA("Frame")    then L.BackgroundColor3 = Theme.ProgressBg end end,
        ["Fill"]            = function(L)
            if L:IsA("Frame") and L.Parent and L.Parent.Name == "Track" then
                L.BackgroundColor3 = Theme.ProgressFill
            end
        end,
        ["Picker"]          = function(L)
            if L:IsA("Frame") then
                L.BackgroundColor3 = Theme.CPBackground
                local S = L:FindFirstChildOfClass("UIStroke")
                if S then S.Color = Theme.CPBorder end
            end
        end,
        ["HexRow"]          = function(L) if L:IsA("Frame") then L.BackgroundColor3 = Theme.CPHexBg end end,
        ["HexInput"]        = function(L) if L:IsA("TextBox") then L.TextColor3 = Theme.Title end end,
        ["CheckMark"]       = function(L) if L:IsA("TextLabel") then L.TextColor3 = Theme.Accent end end,
        ["Swatch"]          = function(L)
            if L:IsA("Frame") then
                local S = L:FindFirstChildOfClass("UIStroke")
                if S then S.Color = Theme.Outline end
            end
        end,
    }

    local ClassRules = {
        ["ImageLabel"]     = function(L)
            if L.Image ~= "rbxassetid://6644618143" then L.ImageColor3 = Theme.Icon end
        end,
        ["TextLabel"]      = function(L)
            if L:FindFirstChild("Padding") then L.TextColor3 = Theme.Title end
        end,
        ["TextButton"]     = function(L)
            if L:FindFirstChild("Labels") then L.BackgroundColor3 = Theme.Component end
        end,
        ["ScrollingFrame"] = function(L) L.ScrollBarImageColor3 = Theme.Interactable end,
    }

    function Options:SetTheme(NewTheme)
        if NewTheme then Theme = NewTheme end

        Window.BackgroundColor3 = Theme.Primary
        if Holder  then Holder.BackgroundColor3  = Theme.Secondary end
        if Sidebar then Sidebar.BackgroundColor3 = Theme.Sidebar   end

        local WS = Window:FindFirstChildOfClass("UIStroke")
        if WS then WS.Color = Theme.Shadow end

        for _, D in next, Screen:GetDescendants() do
            local nr = NameRules[D.Name]
            local cr = ClassRules[D.ClassName]
            if     nr then pcall(nr, D)
            elseif cr then pcall(cr, D)
            end
        end
    end


    -- ════════════════════════════════════════
    --  SETTINGS CONTROL
    -- ════════════════════════════════════════

    function Options:SetSetting(Setting, Value)
        if Setting == "Size" then
            Window.Size = Value
            Setup.Size  = Value

        elseif Setting == "Transparency" then
            Window.GroupTransparency = Value
            Setup.Transparency = Value
            for _, D in next, Screen:GetDescendants() do
                if D:IsA("CanvasGroup") and D.Name == "Notification" then
                    D.GroupTransparency = Value
                end
            end

        elseif Setting == "Blur" then
            local stored = Blurs[Settings.Title]
            if Value then
                BlurEnabled = true
                if not stored then
                    pcall(function()
                        Blurs[Settings.Title] = Blur.new(Window, 5)
                    end)
                elseif stored.root and not stored.root.Parent then
                    stored.root.Parent = workspace.CurrentCamera
                end
            else
                if stored and stored.root and stored.root.Parent then
                    stored.root.Parent = nil
                end
                BlurEnabled = false
            end

        elseif Setting == "Theme" then
            local mode = (type(Value) == "string") and Value or nil
            if mode and Themes[mode] then
                Theme = Themes[mode]
                Setup.ThemeMode = mode
                Options:SetTheme()
                for _, fn in ipairs(ThemeCallbacks) do task.spawn(fn, mode, Theme) end
            elseif type(Value) == "table" then
                Options:SetTheme(Value)
            end

        elseif Setting == "Keybind" then
            Setup.Keybind = Value

        else
            warn("[UILib] Unknown setting: " .. tostring(Setting))
        end
    end


    -- ════════════════════════════════════════
    --  WINDOW CONTROL METHODS
    -- ════════════════════════════════════════

    --- Register a callback invoked whenever the theme changes.
    ---   fn(modeName: string, themeTable: table)
    function Options:OnThemeChanged(fn)
        ThemeCallbacks[#ThemeCallbacks + 1] = fn
    end

    --- Programmatically show or hide the window (animated).
    function Options:SetVisible(visible)
        if visible and not Opened then
            Opened = true
            Animations:Open(Window, Setup.Transparency)
            if BlurEnabled and Blurs[Settings.Title] then
                pcall(function() Blurs[Settings.Title].root.Parent = workspace.CurrentCamera end)
            end
        elseif not visible and Opened then
            Opened = false
            if BlurEnabled and Blurs[Settings.Title] then
                pcall(function() Blurs[Settings.Title].root.Parent = nil end)
            end
            Animations:Close(Window)
        end
    end

    --- Full teardown: disconnects every connection and destroys the window.
    function Options:Destroy()
        WinMaid:Destroy()
        if Blurs[Settings.Title] then
            pcall(function()
                local b = Blurs[Settings.Title]
                if b and b.root then b.root:Destroy() end
            end)
            Blurs[Settings.Title] = nil
        end
        if Window and Window.Parent then
            pcall(function() Window:Destroy() end)
        end
    end


    -- ════════════════════════════════════════
    --  FINALISE & OPEN
    -- ════════════════════════════════════════

    Options:SetTheme()
    SetProperty(Window, { Size = Settings.Size, Visible = true, Parent = Screen })
    Animations:Open(Window, Settings.Transparency or 0)

    return Options
end


return Library
