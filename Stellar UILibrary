-- ═════════════════════════════════════════════════════════════
--  Maid  (connection / instance cleanup)
-- ═════════════════════════════════════════════════════════════

local Maid = {}
Maid.__index = Maid

function Maid.new()
    return setmetatable({ _tasks = {} }, Maid)
end

function Maid:Add(task_)
    self._tasks[#self._tasks + 1] = task_
    return task_
end

-- Remove a specific task without destroying it.
function Maid:Remove(task_)
    for i, t in ipairs(self._tasks) do
        if t == task_ then table.remove(self._tasks, i); return end
    end
end

function Maid:Destroy()
    for i = #self._tasks, 1, -1 do
        local t  = self._tasks[i]
        local tt = type(t)
        if tt == "function" then
            pcall(t)
        elseif tt == "table" and t.Destroy then
            pcall(function() t:Destroy() end)
        elseif tt == "userdata" then
            -- RBXScriptConnection or Instance
            if t.Disconnect then
                pcall(function() t:Disconnect() end)
            elseif t.Destroy then
                pcall(function() t:Destroy() end)
            end
        end
        self._tasks[i] = nil
    end
end


-- ═════════════════════════════════════════════════════════════
--  State  (observable value, v5.0)
-- ═════════════════════════════════════════════════════════════
--[[
    A State is an observable value. Multiple components can bind to
    the same State and stay synchronised.

        local power = State.new(50)
        section:Slider{ State = power, Min = 0, Max = 100 }
        section:Label { Text = "" }:Bind(power)
        power:OnChanged(function(v) print("changed", v) end)
        power:Set(80)    -- both slider AND label update

    Internally just a table with `:Get / :Set / :OnChanged / :Destroy`,
    plus a `_listeners` array. Equality check before notifying avoids
    re-fires when the value didn't actually change.
]]
local State = {}
State.__index = State

function State.new(initial)
    return setmetatable({
        _value     = initial,
        _listeners = {},
        _destroyed = false,
    }, State)
end

function State:Get() return self._value end

function State:Set(value)
    if self._destroyed then return end
    if self._value == value then return end       -- no-op on same value
    self._value = value
    -- Snapshot to allow listeners to disconnect mid-fire
    local snap = {}
    local n = #self._listeners
    for i = 1, n do snap[i] = self._listeners[i] end
    for i = 1, n do
        local fn = snap[i]
        if fn then pcall(fn, value) end
    end
end

--- Subscribe to changes. Returns a disconnect closure.
function State:OnChanged(fn)
    if type(fn) ~= "function" then return function() end end
    table.insert(self._listeners, fn)
    return function()
        local i = table.find(self._listeners, fn)
        if i then table.remove(self._listeners, i) end
    end
end

--- Forcibly notify all listeners with the current value (no equality skip).
function State:Notify()
    if self._destroyed then return end
    local v = self._value
    for _, fn in ipairs(self._listeners) do pcall(fn, v) end
end

function State:Destroy()
    self._destroyed = true
    table.clear(self._listeners)
end


