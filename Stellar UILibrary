    -- ═══════════════════════════════════════════════════════════════════
    --  SEARCHABLE DROPDOWN  (NEW — dropdown + filter)
    -- ═══════════════════════════════════════════════════════════════════

    function Options:AddSearchableDropdown(Cfg)
        if not Cfg.Tab then warn("[UILib] AddSearchableDropdown: missing Cfg.Tab"); return end
        local Dropdown = _GlobalComponents and Clone(_GlobalComponents["Dropdown"])
        if not Dropdown then return end

        local Title, Desc  = Options:GetLabels(Dropdown)
        local OptionsLabel = Dropdown:FindFirstChild("Main")
            and Dropdown.Main:FindFirstChild("Options")

        local CurrentValue = Cfg.Default
        local Listeners    = {}

        local function FindIndex(value)
            for idx, opt in pairs(Cfg.Options or {}) do
                if opt == value then return idx end
            end
        end

        if OptionsLabel and CurrentValue ~= nil then
            local idx = FindIndex(CurrentValue)
            if idx then OptionsLabel.Text = tostring(idx) end
        end

        WinMaid:Add(Connect(Dropdown.MouseButton1Click, function()
            local Example = Clone(Examples["DropdownExample"])
            if not Example then return end

            local PanelMaid = Maid.new()
            local Top        = Example:FindFirstChild("Top")
            local CloseBtns  = Top and Top:FindFirstChild("Buttons")
            local ScrollFrame= Example:FindFirstChild("ScrollingFrame") or Example

            -- Inject a search input bar at the top of the panel
            local SearchBar = Instance.new("Frame")
            SetProperty(SearchBar, {
                Name             = "SearchBar",
                Size             = UDim2.new(1, -16, 0, 32),
                Position         = UDim2.new(0, 8, 0, Top and (Top.Size.Y.Offset + 8) or 8),
                BackgroundColor3 = Theme.Interactable,
                BorderSizePixel  = 0,
                Parent           = Example,
                ZIndex           = (ScrollFrame.ZIndex or 1) + 2,
            })
            Instance.new("UICorner", SearchBar).CornerRadius = UDim.new(0, 6)

            local SearchBox = Instance.new("TextBox", SearchBar)
            SetProperty(SearchBox, {
                Text                   = "",
                PlaceholderText        = "Search…",
                Font                   = Enum.Font.GothamMedium,
                TextSize               = 13,
                TextColor3             = Theme.Title,
                PlaceholderColor3      = Theme.Muted,
                BackgroundTransparency = 1,
                Size                   = UDim2.new(1, -16, 1, 0),
                Position               = UDim2.new(0, 8, 0, 0),
                ClearTextOnFocus       = false,
                BorderSizePixel        = 0,
                ZIndex                 = SearchBar.ZIndex + 1,
            })

            -- Push the scroll frame down so it doesn't overlap the search
            if ScrollFrame ~= Example then
                ScrollFrame.Position = UDim2.new(
                    ScrollFrame.Position.X.Scale, ScrollFrame.Position.X.Offset,
                    ScrollFrame.Position.Y.Scale, ScrollFrame.Position.Y.Offset + 40
                )
                ScrollFrame.Size = UDim2.new(
                    ScrollFrame.Size.X.Scale, ScrollFrame.Size.X.Offset,
                    ScrollFrame.Size.Y.Scale, ScrollFrame.Size.Y.Offset - 40
                )
            end

            if BG then Tween(BG, 0.18, { BackgroundTransparency = 0.5 }) end
            Example.Parent = Window
            Animations:Open(Example, 0, Example.Size)

            local function CloseDropdown()
                if BG then Tween(BG, 0.18, { BackgroundTransparency = 1 }) end
                Animations:Close(Example)
                task.delay(0.3, function()
                    PanelMaid:Destroy()
                    Destroy(Example)
                end)
            end

            if CloseBtns then
                for _, Btn in next, CloseBtns:GetChildren() do
                    if Btn:IsA("TextButton") then
                        Animations:Hover(Btn, false, PanelMaid, Theme.Accent)
                        PanelMaid:Add(Connect(Btn.MouseButton1Click, CloseDropdown))
                    end
                end
            end

            -- Build option buttons and a lookup for filtering
            local OptionBtns = {}
            for Index, Option in next, Cfg.Options do
                local Btn = Clone(Examples["DropdownButtonExample"])
                if Btn then
                    local BTitle, _ = Options:GetLabels(Btn)
                    if BTitle then BTitle.Text = tostring(Index) end

                    if CurrentValue == Option then
                        Btn.BackgroundColor3 = Theme.Interactable
                    end

                    SetProperty(Btn, { Parent = ScrollFrame, Visible = true })
                    Animations:Hover(Btn, false, PanelMaid, Theme.Accent)

                    OptionBtns[#OptionBtns + 1] = { btn = Btn, key = tostring(Index):lower(), value = Option, index = Index }

                    PanelMaid:Add(Connect(Btn.MouseButton1Click, function()
                        CurrentValue = Option
                        if OptionsLabel then OptionsLabel.Text = tostring(Index) end
                        if Cfg.Callback then task.spawn(Cfg.Callback, Option, Index) end
                        for _, fn in ipairs(Listeners) do task.spawn(fn, Option, Index) end
                        Buzz(0.25)
                        CloseDropdown()
                    end))
                end
            end

            -- Filter as user types
            PanelMaid:Add(Connect(SearchBox:GetPropertyChangedSignal("Text"), function()
                local q = SearchBox.Text:lower()
                for _, info in ipairs(OptionBtns) do
                    info.btn.Visible = (q == "" or info.key:find(q, 1, true) ~= nil)
                end
            end))
        end))

        Animations:Hover(Dropdown, false, WinMaid, Theme.Accent)
        if Title then Title.Text = Cfg.Title       or "" end
        if Desc  then Desc.Text  = Cfg.Description or "" end
        SetProperty(Dropdown, { Name = Cfg.Title or "SearchableDropdown", Parent = Cfg.Tab, Visible = true })

        if IsMobile then
            Dropdown.Size = UDim2.new(Dropdown.Size.X.Scale, Dropdown.Size.X.Offset,
                                      Dropdown.Size.Y.Scale, math.max(Dropdown.Size.Y.Offset, 56))
        end

        local Ctrl = {}
        function Ctrl:Get()             return CurrentValue end
        function Ctrl:Set(value)
            local idx = FindIndex(value)
            if idx then
                CurrentValue = value
                if OptionsLabel then OptionsLabel.Text = tostring(idx) end
                for _, fn in ipairs(Listeners) do task.spawn(fn, value, idx) end
            end
        end
        function Ctrl:OnChanged(fn)     Listeners[#Listeners + 1] = fn end
        function Ctrl:SetTitle(t)       if Title then Title.Text = t end end
        function Ctrl:SetDescription(t) if Desc  then Desc.Text  = t end end
        function Ctrl:SetVisible(v)     Dropdown.Visible = v end
        function Ctrl:Destroy()         Destroy(Dropdown) end

        Components[#Components + 1] = Ctrl
        return Ctrl
    end


    -- ═══════════════════════════════════════════════════════════════════
    --  THEME ENGINE
    -- ═══════════════════════════════════════════════════════════════════
    --[[
        SetTheme walks Screen:GetDescendants() once and applies the right
        recolouring rule for each instance, matching either by Name or by
        ClassName. New v3.0 components (Tooltip, Badge, Confirm) get their
        own NameRules so a single SetTheme call covers everything.
    ]]

    local NameRules = {
        ["Paragraph"]       = function(L) if L:IsA("TextButton") then L.BackgroundColor3 = Theme.Component end end,
        ["Title"]           = function(L) if L:IsA("TextLabel")  then L.TextColor3 = Theme.Title          end end,
        ["Description"]     = function(L) if L:IsA("TextLabel")  then L.TextColor3 = Theme.Description    end end,
        ["Section"]         = function(L) if L:IsA("TextLabel")  then L.TextColor3 = Theme.SectionText    end end,
        ["Options"]         = function(L)
            if L:IsA("TextLabel") and L.Parent.Name == "Main" then L.TextColor3 = Theme.Title end
        end,
        ["Notification"]    = function(L)
            if L:IsA("CanvasGroup") then
                L.BackgroundColor3 = Theme.Primary
                local S = L:FindFirstChildOfClass("UIStroke")
                if S then S.Color = Theme.Outline end
            end
        end,
        ["TextLabel"]       = function(L)
            if L:IsA("TextLabel") and L.Parent:FindFirstChild("List") then L.TextColor3 = Theme.Tab end
        end,
        ["Main"]            = function(L)
            if L:IsA("Frame") then
                if L.Parent == Window then
                    L.BackgroundColor3 = Theme.Secondary
                elseif L.Parent:FindFirstChild("Value") then
                    local V = L.Parent.Value
                    if not V.Value then
                        L.BackgroundColor3 = Theme.ToggleOff
                        local C = L:FindFirstChild("Circle")
                        if C then C.BackgroundColor3 = Theme.Primary end
                    end
                else
                    L.BackgroundColor3 = Theme.Interactable
                end
            elseif L:FindFirstChild("Padding") then
                L.TextColor3 = Theme.Title
            end
        end,
        ["Amount"]          = function(L) if L:IsA("Frame") then L.BackgroundColor3 = Theme.Interactable end end,
        ["Slide"]           = function(L) if L:IsA("Frame") then L.BackgroundColor3 = Theme.SliderTrack  end end,
        ["Highlight"]       = function(L) if L:IsA("Frame") then L.BackgroundColor3 = Theme.SliderFill   end end,
        ["Input"]           = function(L)
            if L:IsA("TextLabel") then
                L.TextColor3 = Theme.Title
            elseif L:FindFirstChild("Labels") then
                L.BackgroundColor3 = Theme.Component
            elseif L:IsA("TextBox") and L.Parent.Name == "Main" then
                L.TextColor3 = Theme.Title
            end
        end,
        ["Outline"]         = function(L) if L:IsA("UIStroke") then L.Color = Theme.Outline end end,
        ["DropdownExample"] = function(L) if L:IsA("Frame")    then L.BackgroundColor3 = Theme.Secondary end end,
        ["Underline"]       = function(L) if L:IsA("Frame")    then L.BackgroundColor3 = Theme.Divider   end end,
        ["Line"]            = function(L) if L:IsA("Frame")    then L.BackgroundColor3 = Theme.Divider   end end,
        ["Track"]           = function(L) if L:IsA("Frame")    then L.BackgroundColor3 = Theme.ProgressBg end end,
        ["Fill"]            = function(L)
            if L:IsA("Frame") and L.Parent and L.Parent.Name == "Track" then
                L.BackgroundColor3 = Theme.ProgressFill
            end
        end,
        ["Picker"]          = function(L)
            if L:IsA("Frame") then
                L.BackgroundColor3 = Theme.CPBackground
                local S = L:FindFirstChildOfClass("UIStroke")
                if S then S.Color = Theme.CPBorder end
            end
        end,
        ["HexRow"]          = function(L) if L:IsA("Frame")   then L.BackgroundColor3 = Theme.CPHexBg end end,
        ["HexInput"]        = function(L) if L:IsA("TextBox") then L.TextColor3       = Theme.Title  end end,
        ["CheckMark"]       = function(L) if L:IsA("TextLabel") then L.TextColor3     = Theme.Accent end end,
        ["Swatch"]          = function(L)
            if L:IsA("Frame") then
                local S = L:FindFirstChildOfClass("UIStroke")
                if S then S.Color = Theme.Outline end
            end
        end,
        -- v3.0 additions
        ["Tooltip"]         = function(L)
            if L:IsA("Frame") then
                L.BackgroundColor3 = Theme.TooltipBg
                local S = L:FindFirstChildOfClass("UIStroke")
                if S then S.Color = Theme.Outline end
                local Lbl = L:FindFirstChildOfClass("TextLabel")
                if Lbl then Lbl.TextColor3 = Theme.TooltipText end
            end
        end,
        ["Badge"]           = function(L)
            if L:IsA("TextLabel") then
                L.BackgroundColor3 = Theme.BadgeBg
                L.TextColor3       = Theme.BadgeText
            end
        end,
        ["ConfirmModal"]    = function(L)
            if L:IsA("Frame") then
                L.BackgroundColor3 = Theme.Primary
                local S = L:FindFirstChildOfClass("UIStroke")
                if S then S.Color = Theme.Outline end
            end
        end,
        ["SearchBox"]       = function(L)
            if L:IsA("TextBox") then
                L.BackgroundColor3 = Theme.Component
                L.TextColor3       = Theme.Title
                L.PlaceholderColor3 = Theme.Description
            end
        end,
    }

    local ClassRules = {
        ["ImageLabel"]     = function(L)
            if L.Image ~= "rbxassetid://6644618143" then L.ImageColor3 = Theme.Icon end
        end,
        ["TextLabel"]      = function(L)
            if L:FindFirstChild("Padding") then L.TextColor3 = Theme.Title end
        end,
        ["TextButton"]     = function(L)
            if L:FindFirstChild("Labels") then L.BackgroundColor3 = Theme.Component end
        end,
        ["ScrollingFrame"] = function(L) L.ScrollBarImageColor3 = Theme.Interactable end,
    }

    function Options:SetTheme(NewTheme)
        if NewTheme then Theme = NewTheme end

        Window.BackgroundColor3 = Theme.Primary
        if Holder  then Holder.BackgroundColor3  = Theme.Secondary end
        if Sidebar then Sidebar.BackgroundColor3 = Theme.Sidebar   end

        local WS = Window:FindFirstChildOfClass("UIStroke")
        if WS then WS.Color = Theme.Shadow end

        -- Walk the entire screen tree once; rule-table lookup is O(1) per node.
        for _, D in next, Screen:GetDescendants() do
            local nr = NameRules[D.Name]
            local cr = ClassRules[D.ClassName]
            if     nr then pcall(nr, D)
            elseif cr then pcall(cr, D)
            end
        end

        -- Update the FAB if it exists (it lives directly under Screen so the
        -- name-rule walk above might not catch its Accent colour).
        for _, child in ipairs(Screen:GetChildren()) do
            if child.Name:match("^FAB_") then
                child.BackgroundColor3 = Theme.Accent
                local S = child:FindFirstChildOfClass("UIStroke")
                if S then S.Color = Theme.Outline end
            end
        end
    end


    -- ═══════════════════════════════════════════════════════════════════
    --  SETTINGS CONTROL
    -- ═══════════════════════════════════════════════════════════════════
    --[[
        Runtime control over per-window settings:
            Options:SetSetting("Size",         UDim2)
            Options:SetSetting("Transparency", number 0-1)
            Options:SetSetting("Blur",         boolean)
            Options:SetSetting("Theme",        "Dark" | "Light" | table)
            Options:SetSetting("Keybind",      Enum.KeyCode)
    ]]

    function Options:SetSetting(Setting, Value)
        if Setting == "Size" then
            Window.Size    = Value
            WinSetup.Size  = Value

        elseif Setting == "Transparency" then
            Window.GroupTransparency = Value
            WinSetup.Transparency    = Value
            -- propagate to notifications belonging to this window
            for _, N in ipairs(ActiveNotifs) do
                if N and N.Parent then N.GroupTransparency = Value end
            end

        elseif Setting == "Blur" then
            local stored = Blurs[Settings.Title]
            if Value then
                BlurEnabled = true
                if not stored then
                    pcall(function() Blurs[Settings.Title] = Blur.new(Window, 5) end)
                elseif stored.root and not stored.root.Parent then
                    stored.root.Parent = workspace.CurrentCamera
                end
            else
                if stored and stored.root and stored.root.Parent then
                    stored.root.Parent = nil
                end
                BlurEnabled = false
            end

        elseif Setting == "Theme" then
            local mode = (type(Value) == "string") and Value or nil
            if mode and Themes[mode] then
                Theme              = Themes[mode]
                WinSetup.ThemeMode = mode
                Options:SetTheme()
                for _, fn in ipairs(ThemeCallbacks) do task.spawn(fn, mode, Theme) end
            elseif type(Value) == "table" then
                Options:SetTheme(Value)
                for _, fn in ipairs(ThemeCallbacks) do task.spawn(fn, "Custom", Value) end
            end

        elseif Setting == "Keybind" then
            WinSetup.Keybind = Value

        else
            warn("[StellarUI] Unknown setting: " .. tostring(Setting))
        end
    end


    -- ═══════════════════════════════════════════════════════════════════
    --  LIFECYCLE METHODS
    -- ═══════════════════════════════════════════════════════════════════

    --- Register a callback invoked whenever the theme changes.
    ---   fn(modeName: string, themeTable: table)
    function Options:OnThemeChanged(fn)
        if type(fn) == "function" then
            ThemeCallbacks[#ThemeCallbacks + 1] = fn
        end
    end

    --- Programmatically show or hide the window (animated).
    function Options:SetVisible(visible)
        if visible and not Opened then
            Opened = true
            Animations:Open(Window, WinSetup.Transparency, WinSetup.Size)
            if BlurEnabled and Blurs[Settings.Title] then
                pcall(function() Blurs[Settings.Title].root.Parent = workspace.CurrentCamera end)
            end
            -- Hide FAB while window is open
            if IsMobile then
                for _, child in ipairs(Screen:GetChildren()) do
                    if child.Name == "FAB_" .. (Settings.Title or "Window") then
                        child.Visible = false
                    end
                end
            end
        elseif not visible and Opened then
            Opened = false
            if BlurEnabled and Blurs[Settings.Title] then
                pcall(function() Blurs[Settings.Title].root.Parent = nil end)
            end
            Animations:Close(Window)
            -- Show FAB so the user can reopen
            if IsMobile then
                for _, child in ipairs(Screen:GetChildren()) do
                    if child.Name == "FAB_" .. (Settings.Title or "Window") then
                        child.Size    = UDim2.new(0, 0, 0, 0)
                        child.Visible = true
                        Spring(child, 0.25, { Size = UDim2.new(0, 52, 0, 52) })
                    end
                end
            end
        end
    end

    --- Returns whether the window is currently shown.
    function Options:IsVisible() return Opened end

    --- Full teardown: disconnects every connection and destroys the window.
    function Options:Destroy()
        -- Destroy all child component controllers first
        for _, ctrl in ipairs(Components) do
            if ctrl and ctrl.Destroy then pcall(ctrl.Destroy, ctrl) end
        end
        table.clear(Components)
        table.clear(ThemeCallbacks)
        table.clear(Flags)

        -- WinMaid contains: drag listeners, FAB, swipe, keybind, hover anims,
        -- tab buttons, etc. — one call cleans every per-window connection.
        WinMaid:Destroy()

        -- Per-window blur instance
        if Blurs[Settings.Title] then
            pcall(function()
                local b = Blurs[Settings.Title]
                if b and b.root then b.root:Destroy() end
            end)
            Blurs[Settings.Title] = nil
        end

        -- Finally the window itself
        if Window and Window.Parent then
            pcall(function() Window:Destroy() end)
        end

        -- Clear active notifs
        for _, N in ipairs(ActiveNotifs) do
            pcall(function() if N then N:Destroy() end end)
        end
        table.clear(ActiveNotifs)
    end


    -- ═══════════════════════════════════════════════════════════════════
    --  CONFIG SAVE / LOAD  (NEW in v3.0)
    -- ═══════════════════════════════════════════════════════════════════
    --[[
        Every component that received a Cfg.Flag is auto-registered in the
        Flags table via RegisterFlag(flag, getFn, setFn).

        Usage:
            local cfg = Window:GetConfig()       -- {Speed=80, Theme="Dark", ...}
            HttpService:JSONEncode(cfg)          -- persist somewhere

            -- later:
            Window:LoadConfig(decodedTable)
    ]]

    --- Serialise every flagged value to a plain Lua table.
    function Options:GetConfig()
        local out = {}
        for flag, fns in pairs(Flags) do
            local ok, val = pcall(fns.Get)
            if ok then
                -- Skip non-serialisable values (Color3, Vector3, EnumItem all
                -- become strings so JSON round-trips work). Callers that want
                -- raw values can read from Flags directly.
                local t = typeof(val)
                if t == "Color3" then
                    out[flag] = { _type = "Color3", hex = Color3ToHex(val) }
                elseif t == "EnumItem" then
                    out[flag] = { _type = "EnumItem", value = tostring(val) }
                elseif t == "table" then
                    -- For multidropdowns: shallow copy of {[k]=true,...}
                    local copy = {}
                    for k, v in pairs(val) do copy[k] = v end
                    out[flag] = copy
                else
                    out[flag] = val
                end
            end
        end
        return out
    end

    --- Apply a previously-saved config table back to the components.
    function Options:LoadConfig(config)
        if type(config) ~= "table" then return end
        for flag, val in pairs(config) do
            local fns = Flags[flag]
            if fns and fns.Set then
                local actual = val
                -- Reverse the serialisation done in GetConfig
                if type(val) == "table" and val._type == "Color3" then
                    actual = HexToColor3(val.hex)
                elseif type(val) == "table" and val._type == "EnumItem" then
                    -- "Enum.KeyCode.LeftControl" → Enum.KeyCode.LeftControl
                    local ok, parsed = pcall(function()
                        local parts = string.split(val.value, ".")
                        local cursor = _G
                        for _, p in ipairs(parts) do cursor = cursor[p] end
                        return cursor
                    end)
                    actual = ok and parsed or val.value
                end
                pcall(fns.Set, actual)
            end
        end
    end

    --- Returns the list of registered flag names (handy for debugging).
    function Options:GetFlags()
        local list = {}
        for f in pairs(Flags) do list[#list + 1] = f end
        table.sort(list)
        return list
    end


    -- ═══════════════════════════════════════════════════════════════════
    --  FINALISE & OPEN
    -- ═══════════════════════════════════════════════════════════════════

    Options:SetTheme()
    SetProperty(Window, {
        Size    = Settings.Size,
        Visible = true,
        Parent  = Screen,
    })
    Animations:Open(Window, Settings.Transparency or 0, Settings.Size)

    return Options
end


return Library
