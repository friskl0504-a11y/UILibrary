-- ─────────────────────────────────────────────────────────────────
--  Window Animations  (improved — spring-like, scale press)
-- ─────────────────────────────────────────────────────────────────

local Animations = {}

function Animations:Open(Window, Transparency, UseCurrentSize)
    local Original   = (UseCurrentSize and Window.Size) or Setup.Size
    local Multiplied = Multiply(Original, 1.06)
    local Shadow     = Window:FindFirstChildOfClass("UIStroke")

    if Shadow then Shadow.Transparency = 1 end
    SetProperty(Window, { Size = Multiplied, GroupTransparency = 1, Visible = true })

    if Shadow then Tween(Shadow, 0.2, { Transparency = 0.55 }) end
    Tween(Window, 0.2, { Size = Original, GroupTransparency = Transparency or 0 },
        Enum.EasingStyle.Back, Enum.EasingDirection.Out)
end

function Animations:Close(Window)
    local Original   = Window.Size
    local Multiplied = Multiply(Original, 1.05)
    local Shadow     = Window:FindFirstChildOfClass("UIStroke")

    if Shadow then Tween(Shadow, 0.16, { Transparency = 1 }) end
    Tween(Window, 0.16, { Size = Multiplied, GroupTransparency = 1 })

    task.wait(0.18)
    Window.Size    = Original
    Window.Visible = false
end

--- Hover highlight for interactive components.
function Animations:Hover(Component, IsImage, Maid_)
    local base
    local c1 = Connect(Component.InputBegan, function(Input)
        local t = Input.UserInputType
        if t == Enum.UserInputType.MouseMovement or t == Enum.UserInputType.Touch then
            if IsImage then
                Tween(Component, 0.1, { ImageTransparency = 0.28 })
            else
                base = Component.BackgroundColor3
                Tween(Component, 0.1, {
                    BackgroundColor3 = base:Lerp(Theme.Accent, 0.07)
                })
            end
        end
    end)
    local c2 = Connect(Component.InputEnded, function(Input)
        local t = Input.UserInputType
        if t == Enum.UserInputType.MouseMovement or t == Enum.UserInputType.Touch then
            if IsImage then
                Tween(Component, 0.1, { ImageTransparency = 0 })
            else
                if base then Tween(Component, 0.12, { BackgroundColor3 = base }) end
            end
        end
    end)
    if Maid_ then Maid_:Add(c1); Maid_:Add(c2) end
end

--- Press effect: brief scale-down then restore (v3.0 new)
function Animations:Press(Component, Maid_)
    local c = Connect(Component.MouseButton1Down, function()
        Tween(Component, 0.07, { Size = Multiply(Component.Size, 0.97) })
        task.delay(0.12, function()
            Tween(Component, 0.12, { Size = Multiply(Component.Size, 1/0.97) })
        end)
    end)
    if Maid_ then Maid_:Add(c) end
end

--- Accent glow pulse on activation (v3.0 new)
function Animations:Pulse(Component, Maid_)
    local stroke = Component:FindFirstChildOfClass("UIStroke")
    if not stroke then
        stroke = MakeStroke(Component, Theme.Accent, 1.5, 0)
    end
    Tween(stroke, 0.12, { Transparency = 0.3 })
    task.delay(0.35, function()
        Tween(stroke, 0.3, { Transparency = 1 })
    end)
end


