-- ═════════════════════════════════════════════════════════════
--  Maid  (connection / instance cleanup)
-- ═════════════════════════════════════════════════════════════

local Maid = {}
Maid.__index = Maid

function Maid.new()
    return setmetatable({ _tasks = {} }, Maid)
end

function Maid:Add(task_)
    self._tasks[#self._tasks + 1] = task_
    return task_
end

-- Remove a specific task without destroying it.
function Maid:Remove(task_)
    for i, t in ipairs(self._tasks) do
        if t == task_ then table.remove(self._tasks, i); return end
    end
end

function Maid:Destroy()
    for i = #self._tasks, 1, -1 do
        local t  = self._tasks[i]
        local tt = type(t)
        if tt == "function" then
            pcall(t)
        elseif tt == "table" and t.Destroy then
            pcall(function() t:Destroy() end)
        elseif tt == "userdata" then
            -- RBXScriptConnection or Instance
            if t.Disconnect then
                pcall(function() t:Disconnect() end)
            elseif t.Destroy then
                pcall(function() t:Destroy() end)
            end
        end
        self._tasks[i] = nil
    end
end


-- ═════════════════════════════════════════════════════════════
--  Utility Functions
-- ═════════════════════════════════════════════════════════════

local function Clone(obj)       return obj:Clone()              end
local function Destroy(obj)     pcall(function() obj:Destroy() end) end
local function Connect(sig, fn) return sig:Connect(fn)          end

--- Smooth tween helper (defaults to Quart/Out)
local function Tween(obj, speed, props, info)
    local style = (info and info.EasingStyle)     or Enum.EasingStyle.Quart
    local dir   = (info and info.EasingDirection) or Enum.EasingDirection.Out
    Services.Tween:Create(obj, TweenInfo.new(speed, style, dir), props):Play()
end

--- Spring-style tween (Quint/InOut) — slightly bouncier feel
local function Spring(obj, speed, props)
    Services.Tween:Create(obj,
        TweenInfo.new(speed, Enum.EasingStyle.Quint, Enum.EasingDirection.InOut),
        props
    ):Play()
end

--- Batch-set object properties
local function SetProperty(obj, props)
    for k, v in next, props do obj[k] = v end
    return obj
end

--- Scale a UDim2 by a factor
local function Multiply(value, amount)
    return UDim2.new(
        value.X.Scale  * amount, value.X.Offset * amount,
        value.Y.Scale  * amount, value.Y.Offset * amount
    )
end

--- Lerp between two Color3 values — uses native Color3:Lerp
local function LerpColor(a, b, t)
    return a:Lerp(b, t)
end

--- Color3 → "#RRGGBB"
local function Color3ToHex(c)
    return string.format("#%02X%02X%02X",
        math.round(c.R * 255),
        math.round(c.G * 255),
        math.round(c.B * 255))
end

--- "#RRGGBB" or "RRGGBB" → Color3 (nil on bad input)
local function HexToColor3(hex)
    if type(hex) ~= "string" then return nil end
    hex = hex:gsub("^#", "")
    if #hex ~= 6 then return nil end
    local r = tonumber(hex:sub(1, 2), 16)
    local g = tonumber(hex:sub(3, 4), 16)
    local b = tonumber(hex:sub(5, 6), 16)
    if not (r and g and b) then return nil end
    return Color3.fromRGB(r, g, b)
end

--- Best-effort haptic pulse (silent fail on platforms that block it)
local function Buzz(intensity)
    if not IsMobile then return end
    pcall(function()
        if Services.Haptic and Services.Haptic.IsVibrationSupported
           and Services.Haptic:IsVibrationSupported(Enum.UserInputType.Touch) then
            Services.Haptic:SetMotor(Enum.UserInputType.Touch,
                Enum.VibrationMotor.Small, intensity or 0.4)
            task.delay(0.05, function()
                pcall(function()
                    Services.Haptic:SetMotor(Enum.UserInputType.Touch,
                        Enum.VibrationMotor.Small, 0)
                end)
            end)
        end
    end)
end


-- ═════════════════════════════════════════════════════════════
--  InputHub  — single shared global input listener
-- ═════════════════════════════════════════════════════════════
--[[
    Many components needed `Connect(Services.Input.InputChanged, ...)`.
    Each one added a global listener, so 5 colour-pickers + 3 sliders
    fired ~13 listeners on every mouse move.

    InputHub is one InputChanged + one InputEnded subscription
    that fans out to per-component handlers, kept in a list.
]]
local InputHub = {}
InputHub._changed = {}
InputHub._ended   = {}

local function _runFanout(list, input)
    for _, fn in ipairs(list) do
        pcall(fn, input)
    end
end

Connect(Services.Input.InputChanged, function(input)
    _runFanout(InputHub._changed, input)
end)
Connect(Services.Input.InputEnded, function(input)
    _runFanout(InputHub._ended, input)
end)

function InputHub:OnChanged(fn)
    table.insert(self._changed, fn)
    return function()
        local i = table.find(self._changed, fn)
        if i then table.remove(self._changed, i) end
    end
end

function InputHub:OnEnded(fn)
    table.insert(self._ended, fn)
    return function()
        local i = table.find(self._ended, fn)
        if i then table.remove(self._ended, i) end
    end
end


