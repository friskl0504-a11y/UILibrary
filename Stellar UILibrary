    -- ═══════════════════════════════════════════════════════════════════
    --  NOTIFICATIONS  (queued / stacked — portrait-aware)
    -- ═══════════════════════════════════════════════════════════════════

    local NOTIF_PADDING = 8

    local function RepositionNotifs()
        local portrait = IsMobile and IsPortrait()
        if portrait then
            -- Top-down stack
            local baseY = NOTIF_PADDING
            for i = 1, #ActiveNotifs do
                local n = ActiveNotifs[i]
                PresetTween(n, "Spring", {
                    Position = UDim2.new(1, -(n.AbsoluteSize.X + 10), 0, baseY),
                })
                baseY = baseY + n.AbsoluteSize.Y + NOTIF_PADDING
            end
        else
            -- Bottom-up stack
            local baseY = -NOTIF_PADDING
            for i = #ActiveNotifs, 1, -1 do
                local n = ActiveNotifs[i]
                local h = n.AbsoluteSize.Y
                PresetTween(n, "Spring", {
                    Position = UDim2.new(1, -(n.AbsoluteSize.X + 10), 1, baseY - h),
                })
                baseY = baseY - h - NOTIF_PADDING
            end
        end
    end

    function Options:Notify(Cfg)
        local TmplFolder = _GlobalComponents
        if not TmplFolder then return end
        local Notif = Clone(TmplFolder["Notification"])
        if not Notif then return end

        local Title, Desc = Options:GetLabels(Notif)
        local Timer = Notif:FindFirstChild("Timer")

        if Title then Title.Text = Cfg.Title       or "Notification" end
        if Desc  then Desc.Text  = Cfg.Description or ""             end

        Notif.BackgroundColor3 = Theme.Primary
        local NS = Notif:FindFirstChildOfClass("UIStroke")
        if NS then NS.Color = Theme.Outline end

        -- v4: resolve the type colour once and use it for BOTH the timer AND
        -- a new left accent strip — a much more modern notification design.
        local TypeColor = Theme.Accent
        if Cfg.Type then
            local colors = {
                success = Theme.Success,
                warning = Theme.Warning,
                error   = Theme.Danger,
                info    = Theme.Info or Theme.Accent,
            }
            TypeColor = colors[string.lower(Cfg.Type)] or Theme.Accent
        end
        if Timer then Timer.BackgroundColor3 = TypeColor end

        -- v4: left side accent strip (4 px wide, full height, rounded)
        local Accent = Instance.new("Frame", Notif)
        SetProperty(Accent, {
            Name             = "AccentStrip",
            Size             = UDim2.new(0, 3, 1, -8),
            Position         = UDim2.new(0, 4, 0.5, 0),
            AnchorPoint      = Vector2.new(0, 0.5),
            BackgroundColor3 = TypeColor,
            BorderSizePixel  = 0,
            ZIndex           = (Notif.ZIndex or 1) + 1,
        })
        Instance.new("UICorner", Accent).CornerRadius = UDim.new(1, 0)

        local Parent = Screen:FindFirstChild("Frame") or Screen
        SetProperty(Notif, { GroupTransparency = 1, Visible = true, Parent = Parent })

        table.insert(ActiveNotifs, Notif)
        RepositionNotifs()

        task.spawn(function()
            local Duration = Cfg.Duration or 3
            Animations:Open(Notif, WinSetup.Transparency, Notif.Size)
            -- v4: timer drains linearly (the visible countdown should be linear)
            if Timer then
                Tween(Timer, Duration, { Size = UDim2.new(0, 0, 0, 3) },
                    TweenInfo.new(Duration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out))
            end
            task.wait(Duration)
            Animations:Close(Notif)
            task.wait(0.25)

            local idx = table.find(ActiveNotifs, Notif)
            if idx then table.remove(ActiveNotifs, idx) end
            RepositionNotifs()

            task.wait(0.05)
            Destroy(Notif)
        end)
    end


    function Options:GetLabels(Component)
        if not Component then return nil, nil end
        local Labels = Component:FindFirstChild("Labels")
        if Labels then
            return Labels:FindFirstChild("Title"), Labels:FindFirstChild("Description")
        end
        return Component:FindFirstChild("Title"), Component:FindFirstChild("Description")
    end


