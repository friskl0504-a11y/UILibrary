    -- ════════════════════════════════════════════════════════════
    --  INPUT  (v4: TOUCH_MIN height)
    -- ════════════════════════════════════════════════════════════

    function Options:AddInput(Cfg)
        return ErrorBoundary("AddInput", function()
            local Input = Components and Clone(Components["Input"])
            if not Input then return {} end

            if Input.AbsoluteSize.Y < TOUCH_MIN then
                Input.Size = UDim2.new(1, 0, 0, TOUCH_MIN)
            end

            local Title, Desc = Options:GetLabels(Input)
            local Main    = Input:FindFirstChild("Main")
            local TextBox = Main and Main:FindFirstChild("Input")

            if TextBox then
                if Cfg.Placeholder then TextBox.PlaceholderText = Cfg.Placeholder end

                WinMaid:Add(Connect(Input.MouseButton1Click, function()
                    TextBox:CaptureFocus()
                end))

                if IsMobile then
                    WinMaid:Add(Connect(Input.InputBegan, function(Inp)
                        if Inp.UserInputType == Enum.UserInputType.Touch then
                            TextBox:CaptureFocus()
                        end
                    end))
                end

                WinMaid:Add(Connect(TextBox.Focused, function()
                    if Main then
                        Tween(Main, 0.14, {
                            BackgroundColor3 = LerpColor(Theme.Interactable, Theme.Accent, 0.12)
                        })
                    end
                    local Outline = Input:FindFirstChildOfClass("UIStroke")
                        or (Main and Main:FindFirstChildOfClass("UIStroke"))
                    if Outline then Tween(Outline, 0.14, { Color = Theme.Accent }) end
                end))

                WinMaid:Add(Connect(TextBox.FocusLost, function()
                    if Main then Tween(Main, 0.14, { BackgroundColor3 = Theme.Interactable }) end
                    local Outline = Input:FindFirstChildOfClass("UIStroke")
                        or (Main and Main:FindFirstChildOfClass("UIStroke"))
                    if Outline then Tween(Outline, 0.14, { Color = Theme.Outline }) end
                    if Cfg.Callback then task.spawn(Cfg.Callback, TextBox.Text) end
                end))
            end

            Animations:Hover(Input, false, WinMaid)
            if Title then Title.Text = Cfg.Title       or "" end
            if Desc  then Desc.Text  = Cfg.Description or "" end
            SetProperty(Input, { Name = Cfg.Title, Parent = Cfg.Tab, Visible = true })

            local Ctrl = {}
            function Ctrl:Set(text) if TextBox then TextBox.Text = text end end
            function Ctrl:Get()     return TextBox and TextBox.Text or "" end
            return Ctrl
        end)
    end


    -- ════════════════════════════════════════════════════════════
    --  SLIDER  (v4: nil-guard + mobile touch target ขยาย)
    -- ════════════════════════════════════════════════════════════

    function Options:AddSlider(Cfg)
        return ErrorBoundary("AddSlider", function()
            local Slider = Components and Clone(Components["Slider"])
            if not Slider then return {} end

            -- v4: ขยาย Slide frame บน mobile เพื่อ touch target ใหญ่ขึ้น
            if IsMobile then
                local SlideFrame = Slider:FindFirstChild("Slider")
                local SlideInner = SlideFrame and SlideFrame:FindFirstChild("Slide")
                if SlideInner and SlideInner.AbsoluteSize.Y < 20 then
                    SlideInner.Size = UDim2.new(1, 0, 0, 20)
                end
            end

            local Title, Desc = Options:GetLabels(Slider)
            local SliderFrame = Slider:FindFirstChild("Slider")
            local Amount = SliderFrame and SliderFrame:FindFirstChild("Main")
                        and SliderFrame.Main:FindFirstChild("Input")
            local Slide = SliderFrame and SliderFrame:FindFirstChild("Slide")
            local Fire  = Slide and Slide:FindFirstChild("Fire")
            local Fill  = Slide and Slide:FindFirstChild("Highlight")

            local MinVal = Cfg.MinValue or 0
            local MaxVal = Cfg.MaxValue or 100
            local Value  = math.clamp(Cfg.Default or MinVal, MinVal, MaxVal)

            local Changed  = Signal.new()
            local Active   = false
            local DragConn = nil

            -- Floating bubble
            local Bubble, BubbleLbl
            if Slide then
                Bubble = Instance.new("Frame")
                SetProperty(Bubble, {
                    Name             = "ValueBubble",
                    Size             = UDim2.new(0, 38, 0, 22),
                    AnchorPoint      = Vector2.new(0.5, 1),
                    Position         = UDim2.new(0, 0, 0, -6),
                    BackgroundColor3 = Theme.Accent,
                    BorderSizePixel  = 0,
                    Visible          = false,
                    ZIndex           = 25,
                    Parent           = Slide,
                })
                MakeCorner(Bubble, 5)

                BubbleLbl = Instance.new("TextLabel", Bubble)
                SetProperty(BubbleLbl, {
                    Size                   = UDim2.fromScale(1, 1),
                    Text                   = tostring(Value),
                    Font                   = Enum.Font.GothamBold,
                    TextSize               = 11,
                    TextColor3             = Color3.new(1, 1, 1),
                    BackgroundTransparency = 1,
                    BorderSizePixel        = 0,
                })

                local Tri = Instance.new("Frame", Bubble)
                SetProperty(Tri, {
                    Size             = UDim2.new(0, 7, 0, 5),
                    Position         = UDim2.new(0.5, 0, 1, 0),
                    AnchorPoint      = Vector2.new(0.5, 0),
                    BackgroundColor3 = Theme.Accent,
                    BorderSizePixel  = 0,
                    ZIndex           = 24,
                })
                MakeCorner(Tri, 2)
            end

            local function Round(n)
                if Cfg.AllowDecimals then
                    local p = 10 ^ (Cfg.DecimalAmount or 2)
                    return math.floor(n * p + 0.5) / p
                end
                return math.round(n)
            end

            local function UpdateFromScale(scale)
                scale = math.clamp(scale, 0, 1)
                Value = Round(MinVal + scale * (MaxVal - MinVal))
                if Amount then Amount.Text = tostring(Value) end
                if Fill   then Fill.Size   = UDim2.fromScale(scale, 1) end
                if Bubble and BubbleLbl then
                    Bubble.Position  = UDim2.new(scale, 0, 0, -6)
                    BubbleLbl.Text   = tostring(Value)
                end
                if Cfg.Callback then task.spawn(Cfg.Callback, Value) end
                Changed:Fire(Value)
            end

            local function UpdateFromPositionX(posX)
                if not Slide then return end
                local slideX = Slide.AbsolutePosition.X
                local slideW = math.max(Slide.AbsoluteSize.X, 1)
                UpdateFromScale((posX - slideX) / slideW)
            end

            local function SetValue(n)
                -- v4: nil-guard
                n = tonumber(n)
                if not n then n = MinVal end
                n = math.clamp(n, MinVal, MaxVal)
                UpdateFromScale((n - MinVal) / (MaxVal - MinVal))
            end

            local function StopSliding()
                if not Active then return end  -- v4: idempotent
                Active = false
                if DragConn then DragConn:Disconnect(); DragConn = nil end
                if Bubble then
                    Tween(Bubble, 0.1, { Size = UDim2.new(0, 38, 0, 0) })
                    task.delay(0.12, function()
                        if Bubble then
                            Bubble.Visible = false
                            Bubble.Size    = UDim2.new(0, 38, 0, 22)
                        end
                    end)
                end
            end
            WinMaid:Add(StopSliding)

            local function StartDragging(getX)
                if Active then return end
                Active = true
                if Bubble then
                    Bubble.Visible = true
                    Bubble.Size    = UDim2.new(0, 38, 0, 0)
                    Tween(Bubble, 0.12, { Size = UDim2.new(0, 38, 0, 22) })
                end
                DragConn = Services.Run.Heartbeat:Connect(function()
                    if not Active then StopSliding(); return end
                    UpdateFromPositionX(getX())
                end)
            end

            if Fire then
                WinMaid:Add(Connect(Fire.MouseButton1Down, function()
                    StartDragging(function() return Player.Mouse.X end)
                end))
                WinMaid:Add(Connect(Fire.InputBegan, function(Inp)
                    if Inp.UserInputType == Enum.UserInputType.Touch then
                        local touchRef = Inp
                        StartDragging(function()
                            return touchRef.Position.X
                        end)
                    end
                end))
            end

            WinMaid:Add(Connect(Services.Input.InputEnded, function(Inp)
                local t = Inp.UserInputType
                if (t == Enum.UserInputType.MouseButton1 or t == Enum.UserInputType.Touch)
                    and Active then
                    StopSliding()
                end
            end))

            if Amount then
                WinMaid:Add(Connect(Amount.FocusLost, function()
                    -- v4: nil-guard via SetValue
                    SetValue(tonumber(Amount.Text))
                end))
            end

            SetValue(Value)
            Animations:Hover(Slider, false, WinMaid)
            if Title then Title.Text = Cfg.Title       or "" end
            if Desc  then Desc.Text  = Cfg.Description or "" end
            SetProperty(Slider, { Name = Cfg.Title, Parent = Cfg.Tab, Visible = true })

            local Ctrl = {}
            function Ctrl:Set(n)        SetValue(n) end
            function Ctrl:Get()         return Value end
            function Ctrl:OnChanged(fn) return Changed:Connect(fn) end
            return Ctrl
        end)
    end


    -- ════════════════════════════════════════════════════════════
    --  KEYBIND  (v4: DetectConn deduplication + mobile guard)
    -- ════════════════════════════════════════════════════════════

    function Options:AddKeybind(Cfg)
        return ErrorBoundary("AddKeybind", function()
            local KBC = Components and Clone(Components["Keybind"])
            if not KBC then return {} end

            -- v4: ซ่อนบน mobile (ไม่มี physical keyboard)
            if IsMobile then
                KBC.Visible = false
                local MobileHint = Instance.new("TextLabel")
                SetProperty(MobileHint, {
                    Text                   = "⌨  Keybind (PC only)",
                    Font                   = Enum.Font.GothamMedium,
                    TextSize               = 11,
                    TextColor3             = Theme.Muted,
                    BackgroundTransparency = 1,
                    TextXAlignment         = Enum.TextXAlignment.Left,
                    Size                   = UDim2.new(1, -24, 0, 24),
                    BorderSizePixel        = 0,
                    Parent                 = Cfg.Tab,
                    Visible                = true,
                })
                local Ctrl = {}
                function Ctrl:Set()         end
                function Ctrl:Get()         return nil end
                function Ctrl:OnChanged()   return { Disconnect = function() end } end
                return Ctrl
            end

            local Title, Desc = Options:GetLabels(KBC)
            local Bind = KBC:FindFirstChild("Main") and KBC.Main:FindFirstChild("Options")

            local CurrentKey = Cfg.Default
            local Listening  = false
            local Changed    = Signal.new()
            -- v4: dedup — DetectConn เก็บเป็น local ไม่ add เข้า WinMaid ซ้ำ
            local DetectConn = nil

            local MouseTypes = {
                Enum.UserInputType.MouseButton1,
                Enum.UserInputType.MouseButton2,
                Enum.UserInputType.MouseButton3,
            }

            local function FormatKey(Key)
                local t = Key.UserInputType
                if table.find(MouseTypes, t) then
                    return tostring(t):gsub("Enum.UserInputType.MouseButton", "MB")
                elseif t == Enum.UserInputType.Keyboard then
                    return tostring(Key.KeyCode):gsub("Enum.KeyCode.", "")
                end
                return "?"
            end

            local function SetBind(Key)
                CurrentKey = Key
                if Bind then Bind.Text = FormatKey(Key) end
                Changed:Fire(Key)
            end

            if CurrentKey and Bind then
                if typeof(CurrentKey) == "EnumItem" then
                    Bind.Text = tostring(CurrentKey):gsub("Enum.KeyCode.", "")
                end
            end

            local function CancelListening()
                Listening = false
                if Bind then
                    Bind.Text = CurrentKey
                        and (typeof(CurrentKey) == "EnumItem"
                            and tostring(CurrentKey):gsub("Enum.KeyCode.", "")
                            or FormatKey(CurrentKey))
                        or "None"
                end
                -- v4: disconnect DetectConn โดยไม่ผ่าน WinMaid (ป้องกัน leak)
                if DetectConn then
                    DetectConn:Disconnect()
                    DetectConn = nil
                end
            end

            WinMaid:Add(Connect(KBC.MouseButton1Click, function()
                if Listening then
                    -- v4: click อีกครั้งเพื่อยกเลิก
                    CancelListening()
                    return
                end
                Listening = true
                if Bind then Bind.Text = "..." end

                -- v4: disconnect DetectConn เก่าก่อนสร้างใหม่
                if DetectConn then DetectConn:Disconnect(); DetectConn = nil end

                DetectConn = Connect(Services.Input.InputBegan, function(Key, GameFocused)
                    if not Listening or GameFocused then return end
                    if Key.KeyCode == Enum.KeyCode.Escape then
                        CancelListening(); return
                    end
                    Listening = false
                    SetBind(Key)
                    if Cfg.Callback then task.spawn(Cfg.Callback, Key) end
                    if DetectConn then DetectConn:Disconnect(); DetectConn = nil end
                end)
                -- เพิ่มเข้า WinMaid เพื่อ cleanup เมื่อ destroy (ปลอดภัย)
                WinMaid:Add(DetectConn)
            end))

            Animations:Hover(KBC, false, WinMaid)
            if Title then Title.Text = Cfg.Title       or "" end
            if Desc  then Desc.Text  = Cfg.Description or "" end
            SetProperty(KBC, { Name = Cfg.Title, Parent = Cfg.Tab, Visible = true })

            local Ctrl = {}
            function Ctrl:Set(key)
                SetBind({ UserInputType = Enum.UserInputType.Keyboard, KeyCode = key })
            end
            function Ctrl:Get()         return CurrentKey end
            function Ctrl:OnChanged(fn) return Changed:Connect(fn) end
            return Ctrl
        end)
    end


    -- ════════════════════════════════════════════════════════════
    --  DROPDOWN  ★ v4 FULL REWRITE ★  (inline accordion)
    -- ════════════════════════════════════════════════════════════
    --[[
        Cfg = {
            Title:           string
            Description:     string?
            Options:         {string} หรือ {[string]=any}  ← รองรับทั้งคู่
            Default:         any?     — ค่า default (Value หรือ Label ก็ได้)
            Tab:             Instance
            MaxVisible:      number?  — จำนวน item สูงสุดที่แสดง (default 5)
            SearchThreshold: number?  — แสดง search เมื่อ options >= N (default 4)
            Callback:        function(value)
        }
        Returns: {
            Get()            → currentValue
            GetLabel()       → currentLabel (string)
            Set(value, silent?)   — set value, fire callback ถ้าไม่ silent
            SetOptions(opts) — rebuild options dynamically
            OnChanged(fn)    → Connection
            Close()          — ปิด dropdown
        }
    ]]

    function Options:AddDropdown(Cfg)
        return ErrorBoundary("AddDropdown", function()

            -- Normalize options เป็น {Label, Value} array
            local OptionsList = NormalizeOptions(Cfg.Options or {})
            local SearchThreshold = Cfg.SearchThreshold or 4
            local MaxVisible      = Cfg.MaxVisible or 5
            local ItemH           = IsMobile and 44 or 36
            local SearchH         = IsMobile and 44 or 32

            -- ── Row (header button) ───────────────────────────────
            local Row = Components and Clone(Components["Dropdown"])
            if not Row then return {} end

            local Title, Desc = Options:GetLabels(Row)
            local OptionsLabel = Row:FindFirstChild("Main") and Row.Main:FindFirstChild("Options")

            if Row.AbsoluteSize.Y < TOUCH_MIN then
                Row.Size = UDim2.new(1, 0, 0, TOUCH_MIN)
            end

            -- Arrow indicator (v4 เพิ่ม)
            local ArrowLbl = Instance.new("TextLabel")
            SetProperty(ArrowLbl, {
                Name                   = "_Arrow",
                Text                   = "▾",
                Font                   = Enum.Font.GothamBold,
                TextSize               = IsMobile and 16 or 13,
                TextColor3             = Theme.DropArrow,
                BackgroundTransparency = 1,
                Size                   = UDim2.new(0, 20, 1, 0),
                Position               = UDim2.new(1, -22, 0, 0),
                AnchorPoint            = Vector2.new(0, 0),
                BorderSizePixel        = 0,
                ZIndex                 = Row.ZIndex + 2,
                Parent                 = Row,
            })

            -- ── DropList (inline, starts collapsed) ──────────────
            local function CalcListHeight(count)
                local visCount = math.min(count, MaxVisible)
                local hasSearch = count >= SearchThreshold
                return visCount * ItemH
                     + (hasSearch and (SearchH + 6) or 0)
                     + 10  -- top+bottom padding
            end

            local DropList = Instance.new("Frame")
            SetProperty(DropList, {
                Name             = "DropList_" .. (Cfg.Title or ""),
                Size             = UDim2.new(1, 0, 0, 0),
                BackgroundColor3 = Theme.DropListBg,
                BorderSizePixel  = 0,
                ClipsDescendants = true,
                Visible          = false,
                ZIndex           = Row.ZIndex + 1,
                Parent           = Cfg.Tab,
            })
            MakeCorner(DropList, 8)
            MakeStroke(DropList, Theme.Outline, 1)

            -- DropList เก็บ reference ไว้ใน _Arrow เพื่อ CloseActiveDropdown ใช้
            DropList:SetAttribute("_DropName", Cfg.Title or "")

            -- ── SearchBox (ถ้า options มากพอ) ─────────────────────
            local SearchBox
            local SearchWrapper
            if #OptionsList >= SearchThreshold then
                SearchWrapper = Instance.new("Frame", DropList)
                SetProperty(SearchWrapper, {
                    Name             = "SearchWrapper",
                    Size             = UDim2.new(1, -12, 0, SearchH),
                    Position         = UDim2.new(0, 6, 0, 5),
                    BackgroundColor3 = Theme.Interactable,
                    BorderSizePixel  = 0,
                    ZIndex           = DropList.ZIndex + 2,
                })
                MakeCorner(SearchWrapper, 6)
                MakeStroke(SearchWrapper, Theme.Outline, 1)

                -- search icon
                local SIcon = Instance.new("TextLabel", SearchWrapper)
                SetProperty(SIcon, {
                    Text                   = "🔍",
                    TextSize               = IsMobile and 14 or 11,
                    Font                   = Enum.Font.Gotham,
                    BackgroundTransparency = 1,
                    TextColor3             = Theme.Muted,
                    Size                   = UDim2.new(0, 24, 1, 0),
                    Position               = UDim2.new(0, 4, 0, 0),
                    BorderSizePixel        = 0,
                    ZIndex                 = SearchWrapper.ZIndex + 1,
                })

                SearchBox = Instance.new("TextBox", SearchWrapper)
                SetProperty(SearchBox, {
                    Size              = UDim2.new(1, -32, 1, 0),
                    Position          = UDim2.new(0, 28, 0, 0),
                    BackgroundTransparency = 1,
                    BorderSizePixel   = 0,
                    Text              = "",
                    PlaceholderText   = "ค้นหา...",
                    Font              = Enum.Font.GothamMedium,
                    TextSize          = IsMobile and 14 or 12,
                    TextColor3        = Theme.Title,
                    PlaceholderColor3 = Theme.Muted,
                    ClearTextOnFocus  = false,
                    ZIndex            = SearchWrapper.ZIndex + 1,
                })
            end

            -- ── ScrollingFrame สำหรับ option items ───────────────
            local scrollOffsetY = (#OptionsList >= SearchThreshold) and (SearchH + 10) or 5
            local Scroll = Instance.new("ScrollingFrame", DropList)
            SetProperty(Scroll, {
                Name                   = "DropScroll",
                Size                   = UDim2.new(1, -4, 1, -scrollOffsetY),
                Position               = UDim2.new(0, 2, 0, scrollOffsetY),
                BackgroundTransparency = 1,
                BorderSizePixel        = 0,
                ScrollBarThickness     = IsMobile and 0 or 3,
                ScrollBarImageColor3   = Theme.Accent,
                CanvasSize             = UDim2.new(0, 0, 0, 0),
                AutomaticCanvasSize    = Enum.AutomaticSize.Y,
                ElasticScrollingEnabled = IsMobile,
                ZIndex                 = DropList.ZIndex + 1,
            })

            local Layout = Instance.new("UIListLayout", Scroll)
            Layout.SortOrder = Enum.SortOrder.LayoutOrder
            Layout.Padding   = UDim.new(0, 2)

            local Pad = Instance.new("UIPadding", Scroll)
            Pad.PaddingTop    = UDim.new(0, 2)
            Pad.PaddingBottom = UDim.new(0, 4)
            Pad.PaddingLeft   = UDim.new(0, 4)
            Pad.PaddingRight  = UDim.new(0, 4)

            -- ── State ─────────────────────────────────────────────
            local CurrentValue = nil
            local CurrentLabel = "None"
            local Changed      = Signal.new()
            local IsOpen       = false
            local BtnInstances = {}

            -- Helper: อัพเดท visual ทุก button
            local function RefreshButtons(selValue)
                for _, b in ipairs(BtnInstances) do
                    local isThis = (b.Value == selValue)
                    b.Btn.BackgroundColor3 = isThis
                        and Theme.DropItemSel
                        or  Theme.Component
                    b.Lbl.TextColor3 = isThis and Theme.Accent or Theme.Title
                    b.Lbl.Font = isThis and Enum.Font.GothamBold or Enum.Font.GothamMedium
                    b.Check.Text = isThis and "✓" or ""
                end
            end

            -- Helper: สร้าง button สำหรับแต่ละ option
            local function BuildButton(opt, order)
                local Btn = Instance.new("TextButton", Scroll)
                SetProperty(Btn, {
                    Name             = "Item_" .. opt.Label,
                    Size             = UDim2.new(1, 0, 0, ItemH),
                    BackgroundColor3 = Theme.Component,
                    BorderSizePixel  = 0,
                    Text             = "",
                    AutoButtonColor  = false,
                    LayoutOrder      = order,
                    ZIndex           = Scroll.ZIndex + 1,
                })
                MakeCorner(Btn, 6)

                local Lbl = Instance.new("TextLabel", Btn)
                SetProperty(Lbl, {
                    Text             = opt.Label,
                    Font             = Enum.Font.GothamMedium,
                    TextSize         = IsMobile and 14 or 12,
                    TextColor3       = Theme.Title,
                    BackgroundTransparency = 1,
                    TextXAlignment   = Enum.TextXAlignment.Left,
                    Size             = UDim2.new(1, -36, 1, 0),
                    Position         = UDim2.new(0, 10, 0, 0),
                    BorderSizePixel  = 0,
                    ZIndex           = Btn.ZIndex + 1,
                })

                local Check = Instance.new("TextLabel", Btn)
                SetProperty(Check, {
                    Name             = "Check",
                    Text             = "",
                    Font             = Enum.Font.GothamBold,
                    TextSize         = IsMobile and 14 or 12,
                    TextColor3       = Theme.Accent,
                    BackgroundTransparency = 1,
                    Size             = UDim2.new(0, 24, 1, 0),
                    Position         = UDim2.new(1, -26, 0, 0),
                    BorderSizePixel  = 0,
                    ZIndex           = Btn.ZIndex + 1,
                })

                Animations:Hover(Btn, false, WinMaid)

                WinMaid:Add(Connect(Btn.MouseButton1Click, function()
                    CurrentValue = opt.Value
                    CurrentLabel = opt.Label
                    if OptionsLabel then OptionsLabel.Text = opt.Label end
                    RefreshButtons(opt.Value)

                    -- ปิด list
                    CloseList()

                    Changed:Fire(opt.Value)
                    if Cfg.Callback then task.spawn(Cfg.Callback, opt.Value) end
                end))

                return { Btn = Btn, Lbl = Lbl, Check = Check,
                         Label = opt.Label, Value = opt.Value }
            end

            -- สร้าง buttons ทั้งหมด
            for i, opt in ipairs(OptionsList) do
                BtnInstances[i] = BuildButton(opt, i)
            end

            -- ── Open / Close ──────────────────────────────────────

            -- CloseList เป็น local สำหรับใช้ภายใน AddDropdown
            function CloseList()
                IsOpen = false
                if ActiveDropdown == DropList then
                    ActiveDropdown = nil
                    ActiveDropName = nil
                end
                Tween(DropList, 0.18, { Size = UDim2.new(1, 0, 0, 0) }, Enum.EasingStyle.Quart)
                Tween(ArrowLbl, 0.18, { Rotation = 0 })
                task.delay(0.2, function()
                    if not IsOpen and DropList then DropList.Visible = false end
                end)
                -- ล้าง search
                if SearchBox then SearchBox.Text = "" end
                for _, b in ipairs(BtnInstances) do
                    if b.Btn then b.Btn.Visible = true end
                end
            end

            local function OpenList()
                -- ปิด dropdown อื่นก่อน (per-window guard)
                if ActiveDropdown and ActiveDropdown ~= DropList then
                    CloseActiveDropdown()
                end

                ActiveDropdown = DropList
                ActiveDropName = Cfg.Title

                IsOpen = true
                DropList.Visible = true

                local visCount  = 0
                for _, b in ipairs(BtnInstances) do
                    if b.Btn.Visible then visCount += 1 end
                end

                local fullH = CalcListHeight(#OptionsList)
                Tween(DropList, 0.2, { Size = UDim2.new(1, 0, 0, fullH) }, Enum.EasingStyle.Quart)
                Tween(ArrowLbl, 0.2, { Rotation = 180 })

                -- focus search บน mobile
                if SearchBox and IsMobile then
                    task.delay(0.25, function()
                        pcall(function() SearchBox:CaptureFocus() end)
                    end)
                end
            end

            -- Toggle on row click
            WinMaid:Add(Connect(Row.MouseButton1Click, function()
                if IsOpen then CloseList() else OpenList() end
            end))

            -- Search filter
            if SearchBox then
                WinMaid:Add(Connect(SearchBox:GetPropertyChangedSignal("Text"), function()
                    local query = SearchBox.Text:lower()
                    local visCount = 0
                    for _, b in ipairs(BtnInstances) do
                        local show = (query == "" or b.Label:lower():find(query, 1, true) ~= nil)
                        b.Btn.Visible = show
                        if show then visCount += 1 end
                    end
                    -- อัพเดท height ตาม filter result
                    if IsOpen then
                        local newH = CalcListHeight(visCount)
                        Tween(DropList, 0.12, { Size = UDim2.new(1, 0, 0, newH) })
                    end
                end))
            end

            -- Set default
            if Cfg.Default ~= nil then
                for _, opt in ipairs(OptionsList) do
                    if opt.Value == Cfg.Default or opt.Label == Cfg.Default then
                        CurrentValue = opt.Value
                        CurrentLabel = opt.Label
                        if OptionsLabel then OptionsLabel.Text = opt.Label end
                        RefreshButtons(opt.Value)
                        break
                    end
                end
            end

            if Title then Title.Text = Cfg.Title       or "" end
            if Desc  then Desc.Text  = Cfg.Description or "" end
            SetProperty(Row, { Name = Cfg.Title, Parent = Cfg.Tab, Visible = true })
            Animations:Hover(Row, false, WinMaid)

            -- ── Control Object ────────────────────────────────────
            local Ctrl = {}

            function Ctrl:Get()       return CurrentValue end
            function Ctrl:GetLabel()  return CurrentLabel end

            function Ctrl:Set(value, silent)
                for _, opt in ipairs(OptionsList) do
                    if opt.Value == value or opt.Label == value then
                        CurrentValue = opt.Value
                        CurrentLabel = opt.Label
                        if OptionsLabel then OptionsLabel.Text = opt.Label end
                        RefreshButtons(opt.Value)
                        if not silent then
                            Changed:Fire(opt.Value)
                            if Cfg.Callback then task.spawn(Cfg.Callback, opt.Value) end
                        end
                        return
                    end
                end
            end

            function Ctrl:SetOptions(newOpts)
                -- ลบ buttons เก่า
                for _, b in ipairs(BtnInstances) do
                    if b.Btn then Destroy(b.Btn) end
                end
                BtnInstances = {}
                OptionsList  = NormalizeOptions(newOpts or {})
                CurrentValue = nil
                CurrentLabel = "None"
                if OptionsLabel then OptionsLabel.Text = "None" end
                -- สร้าง buttons ใหม่
                for i, opt in ipairs(OptionsList) do
                    BtnInstances[i] = BuildButton(opt, i)
                end
                -- ปิด list
                if IsOpen then CloseList() end
            end

            function Ctrl:OnChanged(fn) return Changed:Connect(fn) end
            function Ctrl:Close()       CloseList() end
            function Ctrl:IsOpen()      return IsOpen end

            return Ctrl
        end)
    end


    -- ════════════════════════════════════════════════════════════
    --  MULTI-DROPDOWN  ★ v4 FULL REWRITE ★  (inline accordion)
    -- ════════════════════════════════════════════════════════════
    --[[
        Cfg = {
            Title, Description, Options, Default: {any}?,
            Tab, MaxVisible, SearchThreshold, Callback: fn({values})
        }
        Returns: { Get(), Set({values}), OnChanged(fn), Close(), SelectAll(), ClearAll() }
    ]]

    function Options:AddMultiDropdown(Cfg)
        return ErrorBoundary("AddMultiDropdown", function()

            local OptionsList     = NormalizeOptions(Cfg.Options or {})
            local SearchThreshold = Cfg.SearchThreshold or 4
            local MaxVisible      = Cfg.MaxVisible or 5
            local ItemH           = IsMobile and 44 or 36
            local SearchH         = IsMobile and 44 or 32

            -- ── Row ───────────────────────────────────────────────
            local Row = Components and Clone(Components["Dropdown"])
            if not Row then return {} end

            local Title, Desc  = Options:GetLabels(Row)
            local OptionsLabel = Row:FindFirstChild("Main") and Row.Main:FindFirstChild("Options")

            if Row.AbsoluteSize.Y < TOUCH_MIN then
                Row.Size = UDim2.new(1, 0, 0, TOUCH_MIN)
            end

            local ArrowLbl = Instance.new("TextLabel")
            SetProperty(ArrowLbl, {
                Name                   = "_Arrow",
                Text                   = "▾",
                Font                   = Enum.Font.GothamBold,
                TextSize               = IsMobile and 16 or 13,
                TextColor3             = Theme.DropArrow,
                BackgroundTransparency = 1,
                Size                   = UDim2.new(0, 20, 1, 0),
                Position               = UDim2.new(1, -22, 0, 0),
                AnchorPoint            = Vector2.new(0, 0),
                BorderSizePixel        = 0,
                ZIndex                 = Row.ZIndex + 2,
                Parent                 = Row,
            })

            -- ── DropList ──────────────────────────────────────────
            local function CalcH(count)
                local visCount = math.min(count, MaxVisible)
                local hasSearch = count >= SearchThreshold
                return visCount * ItemH
                     + (hasSearch and (SearchH + 6) or 0)
                     + (IsMobile and 54 or 44)  -- extra: Select/Clear row
                     + 10
            end

            local DropList = Instance.new("Frame")
            SetProperty(DropList, {
                Name             = "MultiDrop_" .. (Cfg.Title or ""),
                Size             = UDim2.new(1, 0, 0, 0),
                BackgroundColor3 = Theme.DropListBg,
                BorderSizePixel  = 0,
                ClipsDescendants = true,
                Visible          = false,
                ZIndex           = Row.ZIndex + 1,
                Parent           = Cfg.Tab,
            })
            MakeCorner(DropList, 8)
            MakeStroke(DropList, Theme.Outline, 1)

            -- ── Select All / Clear All pills ──────────────────────
            local ActionH   = IsMobile and 36 or 28
            local ActionRow = Instance.new("Frame", DropList)
            SetProperty(ActionRow, {
                Name             = "ActionRow",
                Size             = UDim2.new(1, -12, 0, ActionH),
                Position         = UDim2.new(0, 6, 0, 5),
                BackgroundTransparency = 1,
                BorderSizePixel  = 0,
                ZIndex           = DropList.ZIndex + 2,
            })
            local ActLayout = Instance.new("UIListLayout", ActionRow)
            ActLayout.FillDirection = Enum.FillDirection.Horizontal
            ActLayout.Padding       = UDim.new(0, 6)
            ActLayout.VerticalAlignment = Enum.VerticalAlignment.Center

            local function MakePill(label, callback)
                local Pill = Instance.new("TextButton", ActionRow)
                SetProperty(Pill, {
                    Text             = label,
                    Font             = Enum.Font.GothamMedium,
                    TextSize         = IsMobile and 12 or 10,
                    TextColor3       = Theme.Accent,
                    BackgroundColor3 = Theme.Interactable,
                    Size             = UDim2.new(0, 0, 1, 0),
                    AutomaticSize    = Enum.AutomaticSize.X,
                    BorderSizePixel  = 0,
                    AutoButtonColor  = false,
                    ZIndex           = ActionRow.ZIndex + 1,
                })
                MakeCorner(Pill, 5)
                local PP = Instance.new("UIPadding", Pill)
                PP.PaddingLeft  = UDim.new(0, 8)
                PP.PaddingRight = UDim.new(0, 8)
                WinMaid:Add(Connect(Pill.MouseButton1Click, callback))
                Animations:Hover(Pill, false, WinMaid)
                return Pill
            end

            -- ── SearchBox ─────────────────────────────────────────
            local SearchBox
            local topOffset = ActionH + 10
            if #OptionsList >= SearchThreshold then
                local SW = Instance.new("Frame", DropList)
                SetProperty(SW, {
                    Name             = "SW",
                    Size             = UDim2.new(1, -12, 0, SearchH),
                    Position         = UDim2.new(0, 6, 0, topOffset),
                    BackgroundColor3 = Theme.Interactable,
                    BorderSizePixel  = 0,
                    ZIndex           = DropList.ZIndex + 2,
                })
                MakeCorner(SW, 6)
                MakeStroke(SW, Theme.Outline, 1)
                local SIco = Instance.new("TextLabel", SW)
                SetProperty(SIco, {
                    Text = "🔍", TextSize = IsMobile and 14 or 11,
                    Font = Enum.Font.Gotham, BackgroundTransparency = 1,
                    TextColor3 = Theme.Muted,
                    Size = UDim2.new(0,24,1,0), Position = UDim2.new(0,4,0,0),
                    BorderSizePixel = 0, ZIndex = SW.ZIndex+1,
                })
                SearchBox = Instance.new("TextBox", SW)
                SetProperty(SearchBox, {
                    Size = UDim2.new(1,-32,1,0), Position = UDim2.new(0,28,0,0),
                    BackgroundTransparency = 1, BorderSizePixel = 0,
                    Text = "", PlaceholderText = "ค้นหา...",
                    Font = Enum.Font.GothamMedium,
                    TextSize = IsMobile and 14 or 12,
                    TextColor3 = Theme.Title, PlaceholderColor3 = Theme.Muted,
                    ClearTextOnFocus = false, ZIndex = SW.ZIndex+1,
                })
                topOffset = topOffset + SearchH + 6
            end

            -- ── ScrollingFrame ────────────────────────────────────
            local Scroll = Instance.new("ScrollingFrame", DropList)
            SetProperty(Scroll, {
                Name                   = "MDropScroll",
                Size                   = UDim2.new(1, -4, 1, -topOffset),
                Position               = UDim2.new(0, 2, 0, topOffset),
                BackgroundTransparency = 1,
                BorderSizePixel        = 0,
                ScrollBarThickness     = IsMobile and 0 or 3,
                ScrollBarImageColor3   = Theme.Accent,
                CanvasSize             = UDim2.new(0,0,0,0),
                AutomaticCanvasSize    = Enum.AutomaticSize.Y,
                ElasticScrollingEnabled = IsMobile,
                ZIndex                 = DropList.ZIndex + 1,
            })
            local Layout = Instance.new("UIListLayout", Scroll)
            Layout.SortOrder = Enum.SortOrder.LayoutOrder
            Layout.Padding   = UDim.new(0, 2)
            local ScrollPad = Instance.new("UIPadding", Scroll)
            ScrollPad.PaddingTop    = UDim.new(0, 2)
            ScrollPad.PaddingBottom = UDim.new(0, 4)
            ScrollPad.PaddingLeft   = UDim.new(0, 4)
            ScrollPad.PaddingRight  = UDim.new(0, 4)

            -- ── State ─────────────────────────────────────────────
            local Selected   = {}  -- { [value] = true }
            local Changed    = Signal.new()
            local IsOpen     = false
            local BtnInstances = {}

            if Cfg.Default then
                for _, v in ipairs(Cfg.Default) do Selected[v] = true end
            end

            local function GetSelectedArray()
                local arr = {}
                for v in pairs(Selected) do arr[#arr + 1] = v end
                return arr
            end

            local function UpdateLabel()
                if not OptionsLabel then return end
                local count = 0
                for _ in pairs(Selected) do count += 1 end
                OptionsLabel.Text = (count == 0) and "None"
                    or (count == #OptionsList) and "All selected"
                    or (count .. " selected")
            end
            UpdateLabel()

            local function FireChanged()
                local arr = GetSelectedArray()
                Changed:Fire(arr)
                if Cfg.Callback then task.spawn(Cfg.Callback, arr) end
            end

            -- Build item buttons
            local function BuildItem(opt, order)
                local Btn = Instance.new("TextButton", Scroll)
                SetProperty(Btn, {
                    Name             = "MItem_" .. opt.Label,
                    Size             = UDim2.new(1, 0, 0, ItemH),
                    BackgroundColor3 = Selected[opt.Value]
                        and LerpColor(Theme.Component, Theme.Accent, 0.12) or Theme.Component,
                    BorderSizePixel  = 0,
                    Text             = "",
                    AutoButtonColor  = false,
                    LayoutOrder      = order,
                    ZIndex           = Scroll.ZIndex + 1,
                })
                MakeCorner(Btn, 6)

                local Lbl = Instance.new("TextLabel", Btn)
                SetProperty(Lbl, {
                    Text = opt.Label,
                    Font = Selected[opt.Value] and Enum.Font.GothamBold or Enum.Font.GothamMedium,
                    TextSize = IsMobile and 14 or 12,
                    TextColor3 = Selected[opt.Value] and Theme.Accent or Theme.Title,
                    BackgroundTransparency = 1,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Size = UDim2.new(1,-34,1,0), Position = UDim2.new(0,10,0,0),
                    BorderSizePixel = 0, ZIndex = Btn.ZIndex+1,
                })

                local Chk = Instance.new("TextLabel", Btn)
                SetProperty(Chk, {
                    Name = "Chk",
                    Text = Selected[opt.Value] and "✓" or "",
                    Font = Enum.Font.GothamBold,
                    TextSize = IsMobile and 14 or 12,
                    TextColor3 = Theme.Accent,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(0,24,1,0), Position = UDim2.new(1,-26,0,0),
                    BorderSizePixel = 0, ZIndex = Btn.ZIndex+1,
                })

                Animations:Hover(Btn, false, WinMaid)
                WinMaid:Add(Connect(Btn.MouseButton1Click, function()
                    Selected[opt.Value] = not Selected[opt.Value]
                    local isSel = Selected[opt.Value]
                    Chk.Text = isSel and "✓" or ""
                    Lbl.TextColor3 = isSel and Theme.Accent or Theme.Title
                    Lbl.Font = isSel and Enum.Font.GothamBold or Enum.Font.GothamMedium
                    Tween(Btn, 0.15, {
                        BackgroundColor3 = isSel
                            and LerpColor(Theme.Component, Theme.Accent, 0.12)
                            or  Theme.Component
                    })
                    UpdateLabel()
                    FireChanged()
                end))

                return { Btn = Btn, Lbl = Lbl, Chk = Chk,
                         Label = opt.Label, Value = opt.Value }
            end

            for i, opt in ipairs(OptionsList) do
                BtnInstances[i] = BuildItem(opt, i)
            end

            -- Select All / Clear All pills (สร้างหลัง BtnInstances พร้อม)
            MakePill("Select All", function()
                for _, b in ipairs(BtnInstances) do
                    Selected[b.Value] = true
                    b.Chk.Text = "✓"
                    b.Lbl.TextColor3 = Theme.Accent
                    b.Lbl.Font = Enum.Font.GothamBold
                    b.Btn.BackgroundColor3 = LerpColor(Theme.Component, Theme.Accent, 0.12)
                end
                UpdateLabel(); FireChanged()
            end)
            MakePill("Clear All", function()
                for _, b in ipairs(BtnInstances) do
                    Selected[b.Value] = nil
                    b.Chk.Text = ""
                    b.Lbl.TextColor3 = Theme.Title
                    b.Lbl.Font = Enum.Font.GothamMedium
                    b.Btn.BackgroundColor3 = Theme.Component
                end
                UpdateLabel(); FireChanged()
            end)

            -- ── Open / Close ──────────────────────────────────────

            local function CloseMultiList()
                IsOpen = false
                if ActiveDropdown == DropList then
                    ActiveDropdown = nil; ActiveDropName = nil
                end
                Tween(DropList, 0.18, { Size = UDim2.new(1,0,0,0) }, Enum.EasingStyle.Quart)
                Tween(ArrowLbl, 0.18, { Rotation = 0 })
                task.delay(0.2, function()
                    if not IsOpen and DropList then DropList.Visible = false end
                end)
                if SearchBox then SearchBox.Text = "" end
                for _, b in ipairs(BtnInstances) do
                    if b.Btn then b.Btn.Visible = true end
                end
            end

            local function OpenMultiList()
                if ActiveDropdown and ActiveDropdown ~= DropList then
                    CloseActiveDropdown()
                end
                ActiveDropdown = DropList; ActiveDropName = Cfg.Title
                IsOpen = true
                DropList.Visible = true
                local fullH = CalcH(#OptionsList)
                Tween(DropList, 0.2, { Size = UDim2.new(1,0,0,fullH) }, Enum.EasingStyle.Quart)
                Tween(ArrowLbl, 0.2, { Rotation = 180 })
            end

            WinMaid:Add(Connect(Row.MouseButton1Click, function()
                if IsOpen then CloseMultiList() else OpenMultiList() end
            end))

            if SearchBox then
                WinMaid:Add(Connect(SearchBox:GetPropertyChangedSignal("Text"), function()
                    local query = SearchBox.Text:lower()
                    local vis = 0
                    for _, b in ipairs(BtnInstances) do
                        local show = (query == "" or b.Label:lower():find(query, 1, true) ~= nil)
                        b.Btn.Visible = show
                        if show then vis += 1 end
                    end
                    if IsOpen then
                        Tween(DropList, 0.12, { Size = UDim2.new(1,0,0,CalcH(vis)) })
                    end
                end))
            end

            if Title then Title.Text = Cfg.Title       or "" end
            if Desc  then Desc.Text  = Cfg.Description or "" end
            SetProperty(Row, { Name = Cfg.Title, Parent = Cfg.Tab, Visible = true })
            Animations:Hover(Row, false, WinMaid)

            -- ── Control ───────────────────────────────────────────
            local Ctrl = {}

            function Ctrl:Get() return GetSelectedArray() end

            function Ctrl:Set(values)
                Selected = {}
                local lookup = {}
                for _, v in ipairs(values) do lookup[v] = true end
                for _, b in ipairs(BtnInstances) do
                    local isSel = lookup[b.Value] == true
                    Selected[b.Value] = isSel or nil
                    b.Chk.Text = isSel and "✓" or ""
                    b.Lbl.TextColor3 = isSel and Theme.Accent or Theme.Title
                    b.Lbl.Font = isSel and Enum.Font.GothamBold or Enum.Font.GothamMedium
                    b.Btn.BackgroundColor3 = isSel
                        and LerpColor(Theme.Component, Theme.Accent, 0.12) or Theme.Component
                end
                UpdateLabel()
            end

            function Ctrl:SelectAll()
                for _, b in ipairs(BtnInstances) do Selected[b.Value] = true end
                for _, b in ipairs(BtnInstances) do
                    b.Chk.Text = "✓"
                    b.Lbl.TextColor3 = Theme.Accent
                    b.Btn.BackgroundColor3 = LerpColor(Theme.Component, Theme.Accent, 0.12)
                end
                UpdateLabel(); FireChanged()
            end

            function Ctrl:ClearAll()
                Selected = {}
                for _, b in ipairs(BtnInstances) do
                    b.Chk.Text = ""; b.Lbl.TextColor3 = Theme.Title
                    b.Btn.BackgroundColor3 = Theme.Component
                end
                UpdateLabel(); FireChanged()
            end

            function Ctrl:OnChanged(fn) return Changed:Connect(fn) end
            function Ctrl:Close()       CloseMultiList() end

            return Ctrl
        end)
    end


    -- ════════════════════════════════════════════════════════════
    --  PARAGRAPH
    -- ════════════════════════════════════════════════════════════

    function Options:AddParagraph(Cfg)
        local Para = Components and Clone(Components["Paragraph"])
        if not Para then return {} end
        local Title, Desc = Options:GetLabels(Para)
        if Title then Title.Text = Cfg.Title       or "" end
        if Desc  then Desc.Text  = Cfg.Description or "" end
        SetProperty(Para, { Parent = Cfg.Tab, Visible = true })
        local Ctrl = {}
        function Ctrl:SetTitle(text)       if Title then Title.Text = text end end
        function Ctrl:SetDescription(text) if Desc  then Desc.Text  = text end end
        return Ctrl
    end


    -- ════════════════════════════════════════════════════════════
    --  PROGRESS BAR  (shimmer)
    -- ════════════════════════════════════════════════════════════

    function Options:AddProgressBar(Cfg)
        return ErrorBoundary("AddProgressBar", function()
            local Wrapper = Instance.new("Frame")
            SetProperty(Wrapper, {
                Name             = "ProgressBar_" .. (Cfg.Title or ""),
                Size             = UDim2.new(1, 0, 0, IsMobile and 56 or 48),
                BackgroundColor3 = Theme.Component,
                BorderSizePixel  = 0,
                Parent           = Cfg.Tab,
                Visible          = true,
            })
            MakeCorner(Wrapper, 8)

            local Row = Instance.new("Frame", Wrapper)
            SetProperty(Row, {
                Name                   = "LabelRow",
                Size                   = UDim2.new(1,-16,0,18),
                Position               = UDim2.new(0,10,0,8),
                BackgroundTransparency = 1, BorderSizePixel = 0,
            })
            local TitleLbl = Instance.new("TextLabel", Row)
            SetProperty(TitleLbl, {
                Text = Cfg.Title or "", Font = Enum.Font.GothamSemibold,
                TextSize = 13, TextColor3 = Theme.Title,
                BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Left,
                Size = UDim2.new(0.7,0,1,0), BorderSizePixel = 0,
            })
            local PctLbl = Instance.new("TextLabel", Row)
            SetProperty(PctLbl, {
                Name = "Pct", Text = "0%", Font = Enum.Font.GothamBold,
                TextSize = 12, TextColor3 = Theme.Accent,
                BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Right,
                Size = UDim2.new(0.3,0,1,0), Position = UDim2.new(0.7,0,0,0),
                BorderSizePixel = 0,
            })

            local Track = Instance.new("Frame", Wrapper)
            SetProperty(Track, {
                Name = "Track",
                Size = UDim2.new(1,-20,0, IsMobile and 8 or 6),
                Position = UDim2.new(0,10,1,-14), AnchorPoint = Vector2.new(0,1),
                BackgroundColor3 = Theme.ProgressBg, BorderSizePixel = 0,
                ClipsDescendants = true,
            })
            MakeCorner(Track, 10)

            local Fill = Instance.new("Frame", Track)
            SetProperty(Fill, {
                Name = "Fill", Size = UDim2.fromScale(0,1),
                BackgroundColor3 = Theme.ProgressFill, BorderSizePixel = 0,
            })
            MakeCorner(Fill, 10)

            local Shimmer = Instance.new("Frame", Fill)
            SetProperty(Shimmer, {
                Size = UDim2.new(0,40,1,0), Position = UDim2.new(-0.5,0,0,0),
                BackgroundColor3 = Color3.new(1,1,1), BackgroundTransparency = 0.7,
                BorderSizePixel = 0, ZIndex = Fill.ZIndex+1, ClipsDescendants = false,
            })
            MakeCorner(Shimmer, 4)

            local Current = math.clamp(Cfg.Default or 0, 0, 1)
            task.spawn(function()
                while Fill and Fill.Parent do
                    Shimmer.Position = UDim2.new(-0.4,0,0,0)
                    Tween(Shimmer, 0.9, { Position = UDim2.new(1.4,0,0,0) })
                    task.wait(1.8)
                end
            end)

            local function SetProgress(pct)
                pct = math.clamp(pct, 0, 1); Current = pct
                Tween(Fill, 0.35, { Size = UDim2.fromScale(pct,1) })
                PctLbl.Text = math.floor(pct * 100) .. "%"
            end
            SetProgress(Current)

            local Ctrl = {}
            function Ctrl:Set(pct) SetProgress(pct) end
            function Ctrl:Get()    return Current    end
            return Ctrl
        end)
    end


    -- ════════════════════════════════════════════════════════════
