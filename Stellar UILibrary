            Position               = UDim2.new(0, 22, 0, 0),
        }, HexRow)

        -- ── HSV state ─────────────────────────────────────────────

        local H, S, V = Color3.toHSV(Cfg.Default or Color3.fromRGB(108, 130, 255))
        local PickerOpen = false

        local function GetC3() return Color3.fromHSV(H, S, V) end

        local function UpdateVisuals()
            local c3 = GetC3()
            Swatch.BackgroundColor3  = c3
            SVCanvas.BackgroundColor3 = Color3.fromHSV(H, 1, 1)
            SVThumb.Position  = UDim2.new(S, 0, 1 - V, 0)
            HueThumb.Position = UDim2.new(H, 0, 0.5, 0)
            HexInput.Text     = Color3ToHex(c3)
            if Cfg.Callback then task.spawn(Cfg.Callback, c3) end
        end

        cMaid:Add(Connect(Row.MouseButton1Click, function()
            PickerOpen = not PickerOpen
            if PickerOpen then
                Picker.Visible = true
                Tween(Picker, Ease.Quart, { Size = UDim2.new(1, 0, 0, PANEL_H) })
            else
                Tween(Picker, Ease.Quart, { Size = UDim2.new(1, 0, 0, 0) })
                task.delay(0.2, function() if Picker.Parent then Picker.Visible = false end end)
            end
        end))

        local SVDragging, HueDragging = false, false

        local function UpdateSV(px, py)
            local ax, ay = SVCanvas.AbsolutePosition.X, SVCanvas.AbsolutePosition.Y
            local aw, ah = math.max(SVCanvas.AbsoluteSize.X, 1), math.max(SVCanvas.AbsoluteSize.Y, 1)
            S = math.clamp((px - ax) / aw, 0, 1)
            V = 1 - math.clamp((py - ay) / ah, 0, 1)
            UpdateVisuals()
        end

        local function UpdateHue(px)
            local ax = HueTrack.AbsolutePosition.X
            local aw = math.max(HueTrack.AbsoluteSize.X, 1)
            H = math.clamp((px - ax) / aw, 0, 1)
            UpdateVisuals()
        end

        cMaid:Add(Connect(SVCanvas.InputBegan, function(Inp)
            if Inp.UserInputType == Enum.UserInputType.MouseButton1
            or Inp.UserInputType == Enum.UserInputType.Touch then
                SVDragging = true
                UpdateSV(Inp.Position.X, Inp.Position.Y)
            end
        end))
        cMaid:Add(Connect(Svc.Input.InputChanged, function(Inp)
            if SVDragging and (Inp.UserInputType == Enum.UserInputType.MouseMovement
                or Inp.UserInputType == Enum.UserInputType.Touch) then
                UpdateSV(Inp.Position.X, Inp.Position.Y)
            end
            if HueDragging and (Inp.UserInputType == Enum.UserInputType.MouseMovement
                or Inp.UserInputType == Enum.UserInputType.Touch) then
                UpdateHue(Inp.Position.X)
            end
        end))
        cMaid:Add(Connect(Svc.Input.InputEnded, function(Inp)
            if Inp.UserInputType == Enum.UserInputType.MouseButton1
            or Inp.UserInputType == Enum.UserInputType.Touch then
                SVDragging = false; HueDragging = false
            end
        end))
        cMaid:Add(Connect(HueTrack.InputBegan, function(Inp)
            if Inp.UserInputType == Enum.UserInputType.MouseButton1
            or Inp.UserInputType == Enum.UserInputType.Touch then
                HueDragging = true
                UpdateHue(Inp.Position.X)
            end
        end))

        cMaid:Add(Connect(HexInput.FocusLost, function()
            local c3 = HexToColor3(HexInput.Text)
            if c3 then H, S, V = Color3.toHSV(c3); UpdateVisuals()
            else HexInput.Text = Color3ToHex(GetC3()) end
        end))

        UpdateVisuals()
        Animations:Hover(Row, false, cMaid)

        Registry:Register(function(T)
            if not Row.Parent then return end
            Row.BackgroundColor3    = T.Component
            Picker.BackgroundColor3 = T.CPBackground
            HexRow.BackgroundColor3 = T.CPHexBg
            HexInput.TextColor3     = T.Title
            local stroke = Picker:FindFirstChildOfClass("UIStroke")
            if stroke then stroke.Color = T.CPBorder end
            local swatchStroke = Swatch:FindFirstChildOfClass("UIStroke")
            if swatchStroke then swatchStroke.Color = T.Outline end
        end, cMaid)

        local Ctrl = {}
        function Ctrl:Set(c3) H, S, V = Color3.toHSV(c3); UpdateVisuals() end
        function Ctrl:Get()   return GetC3() end
        function Ctrl:Destroy() Destroy(Row); Destroy(Picker); cMaid:Destroy() end
        return Ctrl
    end


