        local HueStroke = Instance.new("UIStroke", HueThumb)
        HueStroke.Color = Color3.new(0.10, 0.10, 0.12); HueStroke.Thickness = 2

        local HexRow = Instance.new("Frame", Picker)
        SetProperty(HexRow, {
            Name             = "HexRow",
            Size             = UDim2.new(1, -16, 0, HEX_H),
            Position         = UDim2.new(0, 8, 0, 8 + SV_H + 8 + HUE_H + 8),
            BackgroundColor3 = Theme.CPHexBg,
            BorderSizePixel  = 0,
        })
        Instance.new("UICorner", HexRow).CornerRadius = UDim.new(0, 6)

        local HexInput = Instance.new("TextBox", HexRow)
        SetProperty(HexInput, {
            Name                   = "HexInput",
            Text                   = "",
            PlaceholderText        = "#RRGGBB",
            Font                   = Enum.Font.Code,
            TextSize               = IsMobile and 14 or 12,
            TextColor3             = Theme.Title,
            BackgroundTransparency = 1,
            Size                   = UDim2.new(1, -12, 1, 0),
            Position               = UDim2.new(0, 6, 0, 0),
            ClearTextOnFocus       = false,
            BorderSizePixel        = 0,
        })

        local H, S, V = Color3.toHSV(Cfg.Default or Color3.fromRGB(108, 130, 255))
        local PickerOpen = false
        local Listeners  = {}

        local function GetC3() return Color3.fromHSV(H, S, V) end

        local function UpdateVisuals(emit)
            local c3 = GetC3()
            Swatch.BackgroundColor3 = c3
            SVCanvas.BackgroundColor3 = Color3.fromHSV(H, 1, 1)
            SVThumb.Position  = UDim2.new(S, 0, 1 - V, 0)
            HueThumb.Position = UDim2.new(H, 0, 0.5, 0)
            HexInput.Text     = Color3ToHex(c3)
            if emit ~= false then
                if Cfg.Callback then task.spawn(Cfg.Callback, c3) end
                for _, fn in ipairs(Listeners) do task.spawn(fn, c3) end
            end
        end

        WinMaid:Add(Connect(Row.MouseButton1Click, function()
            PickerOpen = not PickerOpen
            if PickerOpen then
                Picker.Visible = true
                Spring(Picker, 0.25, { Size = UDim2.new(1, 0, 0, PANEL_H) })
            else
                Tween(Picker, 0.18, { Size = UDim2.new(1, 0, 0, 0) })
                task.delay(0.2, function() Picker.Visible = false end)
            end
        end))

        local SVDragging, HueDragging = false, false
        local SVTouch, HueTouch       = nil, nil

        local function UpdateSV(px, py)
            local ax, ay = SVCanvas.AbsolutePosition.X, SVCanvas.AbsolutePosition.Y
            local aw, ah = math.max(SVCanvas.AbsoluteSize.X, 1), math.max(SVCanvas.AbsoluteSize.Y, 1)
            S = math.clamp((px - ax) / aw, 0, 1)
            V = 1 - math.clamp((py - ay) / ah, 0, 1)
            UpdateVisuals()
        end

        local function UpdateHue(px)
            local ax = HueTrack.AbsolutePosition.X
            local aw = math.max(HueTrack.AbsoluteSize.X, 1)
            H = math.clamp((px - ax) / aw, 0, 1)
            UpdateVisuals()
        end

        WinMaid:Add(Connect(SVCanvas.InputBegan, function(Inp)
            local t = Inp.UserInputType
            if t == Enum.UserInputType.MouseButton1 then
                SVDragging = true
                UpdateSV(Inp.Position.X, Inp.Position.Y)
            elseif t == Enum.UserInputType.Touch then
                SVDragging = true; SVTouch = Inp
                UpdateSV(Inp.Position.X, Inp.Position.Y)
            end
        end))

        WinMaid:Add(Connect(HueTrack.InputBegan, function(Inp)
            local t = Inp.UserInputType
            if t == Enum.UserInputType.MouseButton1 then
                HueDragging = true
                UpdateHue(Inp.Position.X)
            elseif t == Enum.UserInputType.Touch then
                HueDragging = true; HueTouch = Inp
                UpdateHue(Inp.Position.X)
            end
        end))

        -- SINGLE shared InputHub callback (was 6 separate per-picker)
        WinMaid:Add(InputHub:OnChanged(function(Inp)
            local t = Inp.UserInputType
            if SVDragging then
                if t == Enum.UserInputType.MouseMovement then
                    UpdateSV(Inp.Position.X, Inp.Position.Y)
                elseif t == Enum.UserInputType.Touch and Inp == SVTouch then
                    UpdateSV(Inp.Position.X, Inp.Position.Y)
                end
            end
            if HueDragging then
                if t == Enum.UserInputType.MouseMovement then
                    UpdateHue(Inp.Position.X)
                elseif t == Enum.UserInputType.Touch and Inp == HueTouch then
                    UpdateHue(Inp.Position.X)
                end
            end
        end))

        WinMaid:Add(InputHub:OnEnded(function(Inp)
            local t = Inp.UserInputType
            if t == Enum.UserInputType.MouseButton1 then
                SVDragging  = false
                HueDragging = false
            elseif t == Enum.UserInputType.Touch then
                if Inp == SVTouch  then SVDragging  = false; SVTouch  = nil end
                if Inp == HueTouch then HueDragging = false; HueTouch = nil end
            end
        end))

        WinMaid:Add(Connect(HexInput.FocusLost, function()
            local c3 = HexToColor3(HexInput.Text)
            if c3 then
                H, S, V = Color3.toHSV(c3)
                UpdateVisuals()
            else
                HexInput.Text = Color3ToHex(GetC3())
            end
        end))

        UpdateVisuals(false)
        Animations:Hover(Row, false, WinMaid, Theme.Accent)

        local Ctrl = {}
        function Ctrl:Set(c3)
            H, S, V = Color3.toHSV(c3)
            UpdateVisuals()
        end
        function Ctrl:Get()              return GetC3() end
        function Ctrl:OnChanged(fn)      Listeners[#Listeners + 1] = fn end
        function Ctrl:SetTitle(t)        RowTitle.Text = t end
        function Ctrl:SetDescription(_)  end
        function Ctrl:SetVisible(v)      Row.Visible = v; if not v then Picker.Visible = false end end
        function Ctrl:Destroy()
            Destroy(Row); Destroy(Picker)
        end

        RegisterFlag(Cfg.Flag,
            function()
                local c = Ctrl:Get()
                return { c.R, c.G, c.B }
            end,
            function(v)
                if type(v) == "table" and #v == 3 then
                    Ctrl:Set(Color3.new(v[1], v[2], v[3]))
                end
            end
        )
        Components[#Components + 1] = Ctrl
        return Ctrl
    end


    -- ═══════════════════════════════════════════════════════════════════
    --  CODE BLOCK
    -- ═══════════════════════════════════════════════════════════════════

    function Options:AddCodeBlock(Cfg)
        if not Cfg.Tab then warn("[UILib] AddCodeBlock: missing Cfg.Tab"); return end
        local Template = _GlobalComponents and (_GlobalComponents:FindFirstChild("Code")
                       or _GlobalComponents["Paragraph"])
        if not Template then return end

        local Block       = Clone(Template)
        local Title, Desc = Options:GetLabels(Block)
        local CopyBtn     = Block:FindFirstChild("Copy") or Block:FindFirstChild("CopyButton")

        local Dots = Block:FindFirstChild("Dots")
        if Dots then
            local DR = Dots:FindFirstChild("Red")
            local DY = Dots:FindFirstChild("Yellow")
            local DG = Dots:FindFirstChild("Green")
            if DR then DR.BackgroundColor3 = Theme.CodeDotRed    end
            if DY then DY.BackgroundColor3 = Theme.CodeDotYellow end
            if DG then DG.BackgroundColor3 = Theme.CodeDotGreen  end
        end

        if Title then Title.Text = Cfg.Title or "Code" end
        if Desc  then Desc.Text  = Cfg.Code  or ""    end

        local CurrentCode = Cfg.Code or ""

        if CopyBtn then
            local BtnLabel = CopyBtn:FindFirstChild("TextLabel") or CopyBtn:FindFirstChild("Label")

            WinMaid:Add(Connect(CopyBtn.MouseButton1Click, function()
                pcall(function()
                    if setclipboard then setclipboard(CurrentCode) end
                end)

                if BtnLabel then
                    local Original = BtnLabel.Text
                    BtnLabel.Text  = "Copied!"
                    Tween(CopyBtn, 0.1, {
                        BackgroundColor3 = LerpColor(Theme.Component, Theme.Accent, 0.25),
                    })
                    task.delay(1.5, function()
                        BtnLabel.Text = Original
                        Tween(CopyBtn, 0.15, { BackgroundColor3 = Theme.Component })
                    end)
                end
                Buzz(0.25)

                if Cfg.Callback then task.spawn(Cfg.Callback) end
            end))

            Animations:Hover(CopyBtn, false, WinMaid, Theme.Accent)
        end

        SetProperty(Block, { Parent = Cfg.Tab, Visible = true })

        local Ctrl = {}
        function Ctrl:Set(code)
            CurrentCode = code
            if Desc then Desc.Text = code end
        end
        function Ctrl:Get()              return CurrentCode end
        function Ctrl:OnChanged()        end
        function Ctrl:SetTitle(t)        if Title then Title.Text = t end end
        function Ctrl:SetDescription(t)  if Desc  then Desc.Text  = t end end
        function Ctrl:SetVisible(v)      Block.Visible = v end
        function Ctrl:Destroy()          Destroy(Block) end
        Components[#Components + 1] = Ctrl
        return Ctrl
    end


    -- ═══════════════════════════════════════════════════════════════════
    --  TOOLTIP  (NEW — hover on PC, long-press on mobile)
    -- ═══════════════════════════════════════════════════════════════════

    function Options:Tooltip(component, text)
        if not (component and text) then return end

        local TT = Instance.new("Frame")
        SetProperty(TT, {
            Name                   = "Tooltip",
            Size                   = UDim2.new(0, 0, 0, 26),
            AutomaticSize          = Enum.AutomaticSize.X,
            BackgroundColor3       = Theme.TooltipBg,
            BorderSizePixel        = 0,
            ZIndex                 = 100,
            Visible                = false,
            BackgroundTransparency = 1,
            Parent                 = Screen,
        })
        Instance.new("UICorner", TT).CornerRadius = UDim.new(0, 6)

        local TTLabel = Instance.new("TextLabel", TT)
        SetProperty(TTLabel, {
            Text                   = text,
            Font                   = Enum.Font.GothamMedium,
            TextSize               = 12,
            TextColor3             = Theme.TooltipText,
            BackgroundTransparency = 1,
            AutomaticSize          = Enum.AutomaticSize.X,
            Size                   = UDim2.new(0, 0, 1, 0),
            ZIndex                 = 101,
            TextTransparency       = 1,
            BorderSizePixel        = 0,
        })
        local TTPad = Instance.new("UIPadding", TT)
        TTPad.PaddingLeft  = UDim.new(0, 10)
        TTPad.PaddingRight = UDim.new(0, 10)

        local function Show()
            -- Anchor above the component
            local cp = component.AbsolutePosition
            local cs = component.AbsoluteSize
            TT.Position = UDim2.new(0, cp.X + cs.X / 2, 0, cp.Y - 32)
            TT.AnchorPoint = Vector2.new(0.5, 0)
            TT.Visible = true
            Tween(TT, 0.15, { BackgroundTransparency = 0 })
            Tween(TTLabel, 0.15, { TextTransparency = 0 })
        end
        local function Hide()
            Tween(TT, 0.12, { BackgroundTransparency = 1 })
            Tween(TTLabel, 0.12, { TextTransparency = 1 })
            task.delay(0.14, function() TT.Visible = false end)
        end

        if IsMobile then
            -- Long-press: hold finger for 0.5 s
            local HoldStart, HoldTask, ActiveTouch = nil, nil, nil
            WinMaid:Add(Connect(component.InputBegan, function(Inp)
                if Inp.UserInputType ~= Enum.UserInputType.Touch then return end
                ActiveTouch = Inp
                HoldStart = tick()
                HoldTask = task.delay(0.5, function()
                    if HoldStart and tick() - HoldStart >= 0.5 then
                        Show()
                        Buzz(0.3)
                    end
                end)
            end))
            WinMaid:Add(Connect(component.InputEnded, function(Inp)
                if Inp == ActiveTouch then
                    HoldStart = nil
                    if HoldTask then task.cancel(HoldTask); HoldTask = nil end
                    Hide()
                    ActiveTouch = nil
                end
            end))
        else
            WinMaid:Add(Connect(component.MouseEnter, Show))
            WinMaid:Add(Connect(component.MouseLeave, Hide))
        end

        WinMaid:Add(TT)
        return TT
    end


    -- ═══════════════════════════════════════════════════════════════════
    --  CONFIRM DIALOG  (NEW — modal yes/no)
    -- ═══════════════════════════════════════════════════════════════════

    function Options:Confirm(Cfg)
        --[[
            Cfg = {
                Title:       string
                Description: string
                ConfirmText: string?   default "Confirm"
                CancelText:  string?   default "Cancel"
                Callback:    function(confirmed: boolean)
            }
        ]]
        local Modal = Instance.new("Frame")
        SetProperty(Modal, {
            Name             = "ConfirmModal",
            Size             = UDim2.fromScale(1, 1),
            BackgroundColor3 = Color3.new(0, 0, 0),
            BackgroundTransparency = 1,
            BorderSizePixel  = 0,
            ZIndex           = 200,
            Parent           = Screen,
        })
        -- v4: deeper backdrop fade for a real "modal" feel
        Tween(Modal, 0.20, { BackgroundTransparency = 0.45 }, Ease.Smooth)

        local TargetW = IsMobile and 340 or 420
        local TargetH = 200

        local Card = Instance.new("Frame", Modal)
        SetProperty(Card, {
            Size             = UDim2.new(0, TargetW, 0, TargetH),
            Position         = UDim2.fromScale(0.5, 0.5),
            AnchorPoint      = Vector2.new(0.5, 0.5),
            BackgroundColor3 = Theme.Primary,
            BorderSizePixel  = 0,
            ZIndex           = 201,
        })
        Instance.new("UICorner", Card).CornerRadius = UDim.new(0, 12)
        local CardStroke = Instance.new("UIStroke", Card)
        CardStroke.Color        = Theme.Outline
        CardStroke.Thickness    = 1
        CardStroke.Transparency = 0.2

        local CTitle = Instance.new("TextLabel", Card)
        SetProperty(CTitle, {
            Text                   = Cfg.Title or "Confirm",
            Font                   = Enum.Font.GothamBold,
            TextSize               = 17,
            TextColor3             = Theme.Title,
            BackgroundTransparency = 1,
            TextXAlignment         = Enum.TextXAlignment.Left,
            Size                   = UDim2.new(1, -36, 0, 26),
            Position               = UDim2.new(0, 20, 0, 20),
            ZIndex                 = 202,
            BorderSizePixel        = 0,
        })

        local CDesc = Instance.new("TextLabel", Card)
        SetProperty(CDesc, {
            Text                   = Cfg.Description or "",
            Font                   = Enum.Font.GothamMedium,
            TextSize               = 13,
            TextColor3             = Theme.Description,
            BackgroundTransparency = 1,
            TextXAlignment         = Enum.TextXAlignment.Left,
            TextYAlignment         = Enum.TextYAlignment.Top,
            TextWrapped            = true,
            Size                   = UDim2.new(1, -36, 0, 78),
            Position               = UDim2.new(0, 20, 0, 52),
            ZIndex                 = 202,
            BorderSizePixel        = 0,
        })

        local BtnRow = Instance.new("Frame", Card)
        SetProperty(BtnRow, {
            Size                   = UDim2.new(1, -36, 0, 40),
            Position               = UDim2.new(0, 18, 1, -58),
            BackgroundTransparency = 1,
            BorderSizePixel        = 0,
            ZIndex                 = 202,
        })
        local Lay = Instance.new("UIListLayout", BtnRow)
        Lay.FillDirection      = Enum.FillDirection.Horizontal
        Lay.HorizontalAlignment = Enum.HorizontalAlignment.Right
        Lay.Padding            = UDim.new(0, 10)
        Lay.VerticalAlignment  = Enum.VerticalAlignment.Center

        local PanelMaid = Maid.new()

        local function MakeBtn(label, isPrimary)
            local B = Instance.new("TextButton", BtnRow)
            SetProperty(B, {
                Text                   = label,
                Font                   = Enum.Font.GothamSemibold,
                TextSize               = 13,
                TextColor3             = isPrimary and Color3.new(1,1,1) or Theme.Title,
                BackgroundColor3       = isPrimary and Theme.Accent or Theme.Component,
                AutoButtonColor        = false,
                BorderSizePixel        = 0,
                Size                   = UDim2.new(0, 104, 1, 0),
                ZIndex                 = 203,
            })
            Instance.new("UICorner", B).CornerRadius = UDim.new(0, 8)
            Animations:Hover(B, false, PanelMaid, Theme.Accent)
            Animations:Press(B, PanelMaid)
            return B
        end

        local CancelBtn  = MakeBtn(Cfg.CancelText  or "Cancel",  false)
        local ConfirmBtn = MakeBtn(Cfg.ConfirmText or "Confirm", true)

        local function CloseModal(result)
            Tween(Modal, 0.16, { BackgroundTransparency = 1 }, Ease.Snap)
            Tween(Card, 0.16, { Size = UDim2.new(0, TargetW - 30, 0, TargetH - 30) }, Ease.Snap)
            task.delay(0.2, function()
                PanelMaid:Destroy()
                Destroy(Modal)
            end)
            if Cfg.Callback then task.spawn(Cfg.Callback, result) end
        end

        PanelMaid:Add(Connect(CancelBtn.MouseButton1Click,  function() Buzz(0.2); CloseModal(false) end))
        PanelMaid:Add(Connect(ConfirmBtn.MouseButton1Click, function() Buzz(0.35); CloseModal(true)  end))

        -- v4: ESC / outside tap = cancel (modern modal convention)
        PanelMaid:Add(Connect(Modal.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1
               or Input.UserInputType == Enum.UserInputType.Touch then
                local mx, my = Input.Position.X, Input.Position.Y
                local p, s = Card.AbsolutePosition, Card.AbsoluteSize
                local inside = mx >= p.X and mx <= p.X + s.X
                           and my >= p.Y and my <= p.Y + s.Y
                if not inside then
                    CloseModal(false)
                end
            end
        end))

        -- v4: smoother spring-in (Back/Out)
        Card.Size = UDim2.new(0, TargetW - 40, 0, TargetH - 40)
        PresetTween(Card, "Spring", { Size = UDim2.new(0, TargetW, 0, TargetH) })
    end


