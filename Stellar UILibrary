    Options:Tab{cfg} / Options:SetTab(name)
    Options:Notify(cfg) / Confirm(cfg) / Tooltip(c, text)
    Options:SetTheme(name) / SetAccent(color) / SetDensity(d)
    Options:GetConfig() / LoadConfig(t)
    Options:SaveProfile(n) / LoadProfile(n) / ListProfiles()
