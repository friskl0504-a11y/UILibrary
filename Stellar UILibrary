local Animations = {}

function Animations:Open(Window, Transparency, UseCurrentSize)
    local Original   = (UseCurrentSize and Window.Size) or Setup.Size
    local Multiplied = Multiply(Original, 1.06)
    local Shadow     = Window:FindFirstChildOfClass("UIStroke")

    if Shadow then Shadow.Transparency = 1 end
    SetProperty(Window, { Size = Multiplied, GroupTransparency = 1, Visible = true })

    if Shadow then Tween(Shadow, 0.2, { Transparency = 0.55 }) end
    Tween(Window, 0.2, { Size = Original, GroupTransparency = Transparency or 0 },
        Enum.EasingStyle.Back, Enum.EasingDirection.Out)
end

-- v4: ลบ task.wait ออก — ใช้ task.delay แทน ไม่ block thread
function Animations:Close(Window, onDone)
    local Original   = Window.Size
    local Multiplied = Multiply(Original, 1.05)
    local Shadow     = Window:FindFirstChildOfClass("UIStroke")

    if Shadow then Tween(Shadow, 0.16, { Transparency = 1 }) end
    Tween(Window, 0.16, { Size = Multiplied, GroupTransparency = 1 })

    task.delay(0.18, function()
        Window.Size    = Original
        Window.Visible = false
        if onDone then pcall(onDone) end
    end)
end

function Animations:Hover(Component, IsImage, Maid_)
    local base
    local c1 = Connect(Component.InputBegan, function(Input)
        local t = Input.UserInputType
        if t == Enum.UserInputType.MouseMovement or t == Enum.UserInputType.Touch then
            if IsImage then
                Tween(Component, 0.1, { ImageTransparency = 0.28 })
            else
                -- v4: ดึง base color ทุกครั้ง ไม่ stale
                base = Component.BackgroundColor3
                Tween(Component, 0.1, {
                    BackgroundColor3 = base:Lerp(Theme.Accent, 0.07)
                })
            end
        end
    end)
    local c2 = Connect(Component.InputEnded, function(Input)
        local t = Input.UserInputType
        if t == Enum.UserInputType.MouseMovement or t == Enum.UserInputType.Touch then
            if IsImage then
                Tween(Component, 0.1, { ImageTransparency = 0 })
            else
                if base then Tween(Component, 0.12, { BackgroundColor3 = base }) end
            end
        end
    end)
    if Maid_ then Maid_:Add(c1); Maid_:Add(c2) end
end

function Animations:Press(Component, Maid_)
    local c = Connect(Component.MouseButton1Down, function()
        Tween(Component, 0.07, { Size = Multiply(Component.Size, 0.97) })
        task.delay(0.12, function()
            Tween(Component, 0.12, { Size = Multiply(Component.Size, 1/0.97) })
        end)
    end)
    if Maid_ then Maid_:Add(c) end
end

function Animations:Pulse(Component, Maid_)
    local stroke = Component:FindFirstChildOfClass("UIStroke")
    if not stroke then
        stroke = MakeStroke(Component, Theme.Accent, 1.5, 0)
    end
    Tween(stroke, 0.12, { Transparency = 0.3 })
    task.delay(0.35, function()
        Tween(stroke, 0.3, { Transparency = 1 })
    end)
end


-- ═══════════════════════════════════════════════════════════════════
--  Library.CreateWindow
-- ═══════════════════════════════════════════════════════════════════
--[[
    Settings = {
        Title:           string
        Subtitle:        string?
        Icon:            string?         — "rbxassetid://..."
        Size:            UDim2
        Transparency:    number?
        MinimizeKeybind: Enum.KeyCode?
        Blurring:        boolean?
        Theme:           "Dark"|"Light"|"Midnight"|"Mocha"
    }
]]

function Library:CreateWindow(Settings)

    local WinMaid   = Maid.new()
    local WinState  = { DragType = nil, Animating = false }
    local StoredInfo = { Sections = {}, Tabs = {} }

    -- v4: per-window dropdown tracker
    local ActiveDropdown    = nil   -- DropList Frame ที่เปิดอยู่
    local ActiveDropName    = nil   -- ชื่อ dropdown ที่เปิดอยู่

    if Settings.Theme and Themes[Settings.Theme] then
        Theme = Themes[Settings.Theme]
        Setup.ThemeMode = Settings.Theme
    end

    local Window  = Clone(Screen:WaitForChild("Main"))
    local Sidebar = Window:FindFirstChild("Sidebar")
    local Holder  = Window:FindFirstChild("Main")
    local BG      = Window:FindFirstChild("BackgroundShadow")
    local TabList = Sidebar and Sidebar:FindFirstChild("Tab")

    local Examples = {}
    for _, ex in next, Window:GetDescendants() do
        if ex.Name:find("Example") and not Examples[ex.Name] then
            Examples[ex.Name] = ex
        end
    end

    local Options        = {}
    local Opened         = true
    local Maximized      = false
    local BlurEnabled    = false
    local PreMaxPos      = nil
    local ThemeCallbacks = {}
    local ActiveNotifs   = {}
    local TabFrameMap    = {}
    local SubtitleLabel  = nil

    Setup.Transparency = Settings.Transparency or 0
    Setup.Size         = Settings.Size
    Setup.ThemeMode    = Settings.Theme or "Dark"

    if Settings.MinimizeKeybind then
        Setup.Keybind = Settings.MinimizeKeybind
    end


    -- ════════════════════════════════════════════════════════════
    --  v4: Close Active Dropdown (helper ใช้ภายใน)
    -- ════════════════════════════════════════════════════════════

    local function CloseActiveDropdown()
        if not ActiveDropdown then return end
        local dl = ActiveDropdown
        local arrow = dl:FindFirstChild("_Arrow")
        ActiveDropdown = nil
        ActiveDropName = nil
        -- หุบ height → 0
        Tween(dl, 0.18, { Size = UDim2.new(1, 0, 0, 0) }, Enum.EasingStyle.Quart)
        if arrow then Tween(arrow, 0.18, { Rotation = 0 }) end
        task.delay(0.2, function()
            if dl and dl.Parent then
                dl.Visible = false
            end
        end)
    end


    -- ════════════════════════════════════════════════════════════
    --  DRAG SYSTEM
    -- ════════════════════════════════════════════════════════════

    local function MakeDraggable(Canvas, Handle)
        if not Canvas then return end
        Handle = Handle or Canvas
        local Dragging, DragInput, Start, StartPos

        WinMaid:Add(Connect(Handle.InputBegan, function(Input)
            local t = Input.UserInputType
            if (t == Enum.UserInputType.MouseButton1 or t == Enum.UserInputType.Touch)
                and not WinState.DragType then
                Dragging  = true
                Start     = Input.Position
                StartPos  = Canvas.Position
                WinMaid:Add(Connect(Input.Changed, function()
                    if Input.UserInputState == Enum.UserInputState.End then
                        Dragging = false
                    end
                end))
            end
        end))

        WinMaid:Add(Connect(Handle.InputChanged, function(Input)
            local t = Input.UserInputType
            if t == Enum.UserInputType.MouseMovement or t == Enum.UserInputType.Touch then
                DragInput = Input
            end
        end))

        WinMaid:Add(Connect(Services.Input.InputChanged, function(Input)
            if Input == DragInput and Dragging and not WinState.DragType then
                local delta = Input.Position - Start
                Canvas.Position = UDim2.new(
                    StartPos.X.Scale, StartPos.X.Offset + delta.X,
                    StartPos.Y.Scale, StartPos.Y.Offset + delta.Y
                )
            end
        end))
    end


    -- ════════════════════════════════════════════════════════════
    --  RESIZE GRIP
    -- ════════════════════════════════════════════════════════════

    local function AddResizeGrip(Tab, Minimum, Maximum)
        if not Tab then return end
        Minimum = Minimum or Vector2.new(300,  220)
        Maximum = Maximum or Vector2.new(1800, 1200)

        local Grip = Instance.new("Frame")
        SetProperty(Grip, {
            Name                   = "ResizeGrip",
            Size                   = UDim2.new(0, 18, 0, 18),
            Position               = UDim2.new(1, -2, 1, -2),
            AnchorPoint            = Vector2.new(1, 1),
            BackgroundColor3       = Theme.Accent,
            BackgroundTransparency = 0.6,
            ZIndex                 = 20,
            BorderSizePixel        = 0,
            ClipsDescendants       = false,
            Parent                 = Tab,
        })
        MakeCorner(Grip, 4)

        for _, d in ipairs({ {10, 3}, {3, 10}, {10, 10} }) do
            local Dot = Instance.new("Frame")
            SetProperty(Dot, {
                Size             = UDim2.new(0, 2.5, 0, 2.5),
                Position         = UDim2.new(0, d[1], 0, d[2]),
                BackgroundColor3 = Color3.fromRGB(210, 218, 255),
                BorderSizePixel  = 0,
                ZIndex           = 21,
                Parent           = Grip,
            })
            MakeCorner(Dot, 2)
        end

        WinMaid:Add(Connect(Grip.InputBegan, function(I)
            if I.UserInputType == Enum.UserInputType.MouseMovement then
                Tween(Grip, 0.1, { BackgroundTransparency = 0.28 })
            end
        end))
        WinMaid:Add(Connect(Grip.InputEnded, function(I)
            if I.UserInputType == Enum.UserInputType.MouseMovement then
                Tween(Grip, 0.1, { BackgroundTransparency = 0.6 })
            end
        end))

        local Resizing, StartMouse, StartSize, ActiveTouch = false, nil, nil, nil

        local function BeginResize(pos)
            WinState.DragType = "BottomRight"
            Resizing   = true
            StartMouse = pos
            StartSize  = Vector2.new(Tab.AbsoluteSize.X, Tab.AbsoluteSize.Y)
        end
        local function EndResize()
            WinState.DragType = nil
            Resizing = false; StartMouse = nil; StartSize = nil; ActiveTouch = nil
            Tween(Grip, 0.1, { BackgroundTransparency = 0.6 })
        end
        local function DoResize(pos)
            if not (Resizing and StartMouse and StartSize) then return end
            local D = pos - StartMouse
            Tab.Size = UDim2.new(0,
                math.clamp(StartSize.X + D.X, Minimum.X, Maximum.X), 0,
                math.clamp(StartSize.Y + D.Y, Minimum.Y, Maximum.Y))
        end

        WinMaid:Add(Connect(Grip.InputBegan, function(I)
            local t = I.UserInputType
            if t == Enum.UserInputType.MouseButton1 then
                BeginResize(Vector2.new(I.Position.X, I.Position.Y))
                Tween(Grip, 0.08, { BackgroundTransparency = 0.15 })
            elseif t == Enum.UserInputType.Touch then
                ActiveTouch = I
                BeginResize(Vector2.new(I.Position.X, I.Position.Y))
                WinMaid:Add(Connect(I.Changed, function()
                    if I.UserInputState == Enum.UserInputState.End then
                        if Resizing and ActiveTouch == I then EndResize() end
                    elseif Resizing and ActiveTouch == I then
                        DoResize(Vector2.new(I.Position.X, I.Position.Y))
                    end
                end))
            end
        end))
        WinMaid:Add(Connect(Services.Input.InputChanged, function(I)
            if I.UserInputType == Enum.UserInputType.MouseMovement and Resizing then
                DoResize(Vector2.new(I.Position.X, I.Position.Y))
            end
        end))
        WinMaid:Add(Connect(Services.Input.InputEnded, function(I)
            if I.UserInputType == Enum.UserInputType.MouseButton1 and Resizing then
                EndResize()
            end
        end))
    end

    local DragHandle = Window:FindFirstChild("TitleBar") or Window
    MakeDraggable(Window, DragHandle)
    AddResizeGrip(Window, Vector2.new(380, 260), Vector2.new(1800, 1200))


    -- ── Blur ──────────────────────────────────────────────────────
    if Settings.Blurring then
        xpcall(function()
            Blurs[Settings.Title] = Blur.new(Window, 5)
            BlurEnabled = true
        end, function(err)
            warn("[StellarUI v4] Blur init failed: " .. tostring(err))
        end)
    end


    -- ── Titlebar ──────────────────────────────────────────────────
    local TitleBar = Window:FindFirstChild("TitleBar")
    if TitleBar then
        local TL = TitleBar:FindFirstChild("Title")
        local SL = TitleBar:FindFirstChild("Subtitle") or TitleBar:FindFirstChild("Description")
        local IL = TitleBar:FindFirstChild("Icon")

        if TL then TL.Text = Settings.Title    or "Window" end
        if SL then
            SL.Text       = Settings.Subtitle or ""
            SubtitleLabel = SL
        end
        if IL and Settings.Icon then IL.Image = Settings.Icon end

        local ThemeBtn   = TitleBar:FindFirstChild("ThemeSelect")
        if ThemeBtn then
            local ThemeLabel = ThemeBtn:FindFirstChild("Label") or ThemeBtn:FindFirstChild("TextLabel")
            if ThemeLabel then ThemeLabel.Text = Setup.ThemeMode end

            WinMaid:Add(Connect(ThemeBtn.MouseButton1Click, function()
                local order = {"Dark", "Light", "Midnight", "Mocha"}
                local current = Setup.ThemeMode
                local nextIdx = 1
                for i, m in ipairs(order) do
                    if m == current then nextIdx = (i % #order) + 1; break end
                end
                local newMode = order[nextIdx]
                Setup.ThemeMode = newMode
                Theme = Themes[newMode]
                if ThemeLabel then ThemeLabel.Text = newMode end
                Options:SetTheme()
                for _, fn in ipairs(ThemeCallbacks) do task.spawn(fn, newMode, Theme) end
            end))

            Animations:Hover(ThemeBtn, false, WinMaid)
        end
    end


    -- ── Toggle Window  (v4: guard ขณะ animating) ─────────────────
    local function ToggleWindow()
        if WinState.Animating then return end
        if Opened then
            Opened = false
            WinState.Animating = true
            if BlurEnabled and Blurs[Settings.Title] then
                pcall(function() Blurs[Settings.Title].root.Parent = nil end)
            end
            CloseActiveDropdown()
            Animations:Close(Window, function() WinState.Animating = false end)
        else
            Opened = true
            WinState.Animating = true
            Animations:Open(Window, Setup.Transparency)
            task.delay(0.25, function() WinState.Animating = false end)
            if BlurEnabled and Blurs[Settings.Title] then
                pcall(function() Blurs[Settings.Title].root.Parent = workspace.CurrentCamera end)
            end
        end
    end


    -- ── Window Control Buttons ────────────────────────────────────
    local ButtonsFrame = (TitleBar and TitleBar:FindFirstChild("Buttons"))
        or (Sidebar and Sidebar:FindFirstChild("Top") and Sidebar.Top:FindFirstChild("Buttons"))

    if ButtonsFrame then
        for _, Btn in next, ButtonsFrame:GetChildren() do
            if Btn:IsA("TextButton") or Btn:IsA("ImageButton") then
                Animations:Hover(Btn, Btn:IsA("ImageButton"), WinMaid)
                WinMaid:Add(Connect(Btn.MouseButton1Click, function()
                    local n = Btn.Name
                    if n == "Close" then
                        ToggleWindow()
                    elseif n == "Maximize" then
                        if Maximized then
                            Maximized = false
                            Tween(Window, 0.14, { Size = Setup.Size, Position = PreMaxPos })
                        else
                            Maximized  = true
                            PreMaxPos  = Window.Position
                            Tween(Window, 0.14, {
                                Size     = UDim2.fromScale(1, 1),
                                Position = UDim2.fromScale(0.5, 0.5),
                            })
                        end
                    elseif n == "Minimize" then
                        Opened = false
                        Window.Visible = false
                        if BlurEnabled and Blurs[Settings.Title] then
                            pcall(function() Blurs[Settings.Title].root.Parent = nil end)
                        end
                    end
                end))
            end
        end
    end


    -- ── Keybind Toggle ────────────────────────────────────────────
    WinMaid:Add(Connect(Services.Input.InputBegan, function(Input, GameFocused)
        if GameFocused then return end
        if Input == Setup.Keybind or Input.KeyCode == Setup.Keybind then
            ToggleWindow()
        end
    end))


    -- ── Mobile Swipe (v4: velocity-based, improved) ───────────────
    if IsMobile and TabList then
        local SwipeStart, SwipeStartT, SwipeStartY

        WinMaid:Add(Connect(Window.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.Touch then
                SwipeStart  = Input.Position
                SwipeStartT = tick()
                SwipeStartY = Input.Position.Y
            end
        end))

        WinMaid:Add(Connect(Window.InputEnded, function(Input)
            if Input.UserInputType ~= Enum.UserInputType.Touch then return end
            if not (SwipeStart and SwipeStartT) then return end

            local dt    = tick() - SwipeStartT
            local dx    = Input.Position.X - SwipeStart.X
            local absDx = math.abs(dx)
            local absDy = math.abs(Input.Position.Y - SwipeStartY)
            local speed = absDx / math.max(dt, 0.01)

            if dt < 0.4 and absDx > 55 and speed > 190 and absDx > absDy * 1.4 then
                -- ปิด dropdown ที่เปิดอยู่ก่อน swipe
                CloseActiveDropdown()

                local tabs = {}
                for _, Btn in next, TabList:GetChildren() do
                    if Btn:IsA("TextButton") and Btn.Visible then
                        tabs[#tabs + 1] = Btn
                    end
                end
                table.sort(tabs, function(a, b) return a.LayoutOrder < b.LayoutOrder end)

                local activeIdx = 1
                for i, Btn in ipairs(tabs) do
                    local Val = Btn:FindFirstChild("Value")
                    if Val and Val.Value then activeIdx = i; break end
                end

                local newIdx = (dx < 0)
                    and math.min(activeIdx + 1, #tabs)
                    or  math.max(activeIdx - 1, 1)

                if newIdx ~= activeIdx then
                    Options:SetTab(tabs[newIdx].Name)
                end
            end

            SwipeStart = nil; SwipeStartT = nil; SwipeStartY = nil
        end))
    end


    -- ════════════════════════════════════════════════════════════
    --  TAB SYSTEM
    -- ════════════════════════════════════════════════════════════

    function Options:SetTab(Name)
        if not TabList then return end
        CloseActiveDropdown()

        for _, Button in next, TabList:GetChildren() do
            if Button:IsA("TextButton") then
                local isTarget = (Button.Name == Name)
                local Val      = Button:FindFirstChild("Value")
                local Pad      = Button:FindFirstChildOfClass("UIPadding")
                local ICO      = Button:FindFirstChild("ICO")

                if isTarget and not (Val and Val.Value) then
                    if Pad then Tween(Pad, 0.18, { PaddingLeft = UDim.new(0, 22) }) end
                    Tween(Button, 0.18, {
                        BackgroundTransparency = 0.86,
                        BackgroundColor3       = Theme.Accent,
                    })
                    if ICO then Tween(ICO, 0.18, { ImageColor3 = Theme.Accent }) end
                    local TL = Button:FindFirstChild("TextLabel")
                    if TL then Tween(TL, 0.18, { TextColor3 = Theme.TabActive }) end
                    if Val then Val.Value = true end

                elseif not isTarget and (Val and Val.Value) then
                    if Pad then Tween(Pad, 0.18, { PaddingLeft = UDim.new(0, 16) }) end
                    Tween(Button, 0.18, {
                        BackgroundTransparency = 1,
                        BackgroundColor3       = Theme.Component,
                    })
                    if ICO then Tween(ICO, 0.18, { ImageColor3 = Theme.Icon }) end
                    local TL = Button:FindFirstChild("TextLabel")
                    if TL then Tween(TL, 0.18, { TextColor3 = Theme.Tab }) end
                    if Val then Val.Value = false end
                end
            end
        end

        if not Holder then return end
        for _, Main in next, Holder:GetChildren() do
            if Main:IsA("CanvasGroup") then
                local isTarget = (Main.Name == Name)
                local Val      = Main:FindFirstChild("Value")
                local Scroll   = Main:FindFirstChild("ScrollingFrame")
                local Pad      = Scroll and Scroll:FindFirstChild("UIPadding")

                if isTarget and not (Val and Val.Value) then
                    if Val then Val.Value = true end
                    Main.Visible = true
                    Tween(Main, 0.22, { GroupTransparency = 0 })
                    if Pad then Tween(Pad, 0.22, { PaddingTop = UDim.new(0, 8) }) end
                elseif not isTarget and (Val and Val.Value) then
                    if Val then Val.Value = false end
                    Tween(Main, 0.14, { GroupTransparency = 1 })
                    if Pad then Tween(Pad, 0.14, { PaddingTop = UDim.new(0, 18) }) end
                    task.delay(0.18, function() Main.Visible = false end)
                end
            end
        end
    end


    function Options:AddTabSection(Cfg)
        local Example = Examples["SectionExample"]
        if not Example then return end
        local Section = Clone(Example)
        StoredInfo.Sections[Cfg.Name] = Cfg.Order
        SetProperty(Section, {
            Parent      = Example.Parent,
            Text        = Cfg.Name,
            Name        = Cfg.Name,
            LayoutOrder = Cfg.Order,
            Visible     = true,
        })
    end


    function Options:AddTab(Cfg)
        if StoredInfo.Tabs[Cfg.Title] then
            warn("[StellarUI v4] Duplicate tab: " .. Cfg.Title)
            return
        end

        local BtnExample  = Examples["TabButtonExample"]
        local MainExample = Examples["MainExample"]
        if not (BtnExample and MainExample) then return end

        local Main = Clone(MainExample)
        local Tab  = Clone(BtnExample)

        local ICO = Tab:FindFirstChild("ICO")
        if Cfg.Icon and ICO then ICO.Image = Cfg.Icon
        elseif ICO then Destroy(ICO) end

        local TL = Tab:FindFirstChild("TextLabel")
        if TL then TL.Text = Cfg.Title end

        StoredInfo.Tabs[Cfg.Title] = { Tab }

        SetProperty(Main, { Parent = MainExample.Parent, Name = Cfg.Title })
        SetProperty(Tab, {
            Parent      = BtnExample.Parent,
            LayoutOrder = StoredInfo.Sections[Cfg.Section] or (#StoredInfo.Sections + 1),
            Name        = Cfg.Title,
            Visible     = true,
        })

        WinMaid:Add(Connect(Tab.MouseButton1Click, function()
            Options:SetTab(Cfg.Title)
        end))

        local SF = Main:FindFirstChild("ScrollingFrame")
        if SF then
            TabFrameMap[Cfg.Title] = SF
            -- v4: elastic scroll บน mobile
            if IsMobile then
                SF.ElasticScrollingEnabled = true
                SF.ScrollBarThickness = 0
            end
        end

        return SF or Main
    end


    -- ════════════════════════════════════════════════════════════
    --  NOTIFICATIONS  (v4: max 5, mobile top-center stack)
    -- ════════════════════════════════════════════════════════════

    local NOTIF_PADDING = 8

    local NotifTypeColors = {
        success = function() return Theme.Success end,
        warning = function() return Theme.Warning end,
        error   = function() return Theme.Error   end,
        info    = function() return Theme.Info     end,
    }

    local function RepositionNotifs()
        if IsMobile then
            -- v4: mobile → stack จาก top-center
            local baseY = NOTIF_PADDING
            for i = 1, #ActiveNotifs do
                local n = ActiveNotifs[i]
                local h = n.AbsoluteSize.Y > 0 and n.AbsoluteSize.Y or 60
                n.AnchorPoint = Vector2.new(0.5, 0)
                Tween(n, 0.2, {
                    Position = UDim2.new(0.5, 0, 0, baseY)
                })
                baseY = baseY + h + NOTIF_PADDING
            end
        else
            -- desktop → stack จาก bottom-right (เดิม)
            local baseY = -NOTIF_PADDING
            for i = #ActiveNotifs, 1, -1 do
                local n = ActiveNotifs[i]
                local h = n.AbsoluteSize.Y > 0 and n.AbsoluteSize.Y or 60
                Tween(n, 0.2, {
                    Position = UDim2.new(1, -(n.AbsoluteSize.X + 10), 1, baseY - h)
                })
                baseY = baseY - h - NOTIF_PADDING
            end
        end
    end

    function Options:Notify(Cfg)
        --[[
            Cfg = {
                Title:       string
                Description: string
                Duration:    number?   default 3
                Type:        "success"|"warning"|"error"|"info"?
                Icon:        string?   rbxassetid
            }
        ]]
        -- v4: auto-dismiss เก่าสุดถ้าเต็ม NOTIF_MAX
        if #ActiveNotifs >= NOTIF_MAX then
            local oldest = ActiveNotifs[1]
            if oldest then
                table.remove(ActiveNotifs, 1)
                Animations:Close(oldest, function() Destroy(oldest) end)
                RepositionNotifs()
            end
        end

        local Notif = Components and Clone(Components["Notification"])
        if not Notif then return end

        local Title, Desc = Options:GetLabels(Notif)
        local Timer = Notif:FindFirstChild("Timer")

        if Title then Title.Text = Cfg.Title       or "Notification" end
        if Desc  then Desc.Text  = Cfg.Description or ""             end

        Notif.BackgroundColor3 = Theme.Primary
        local NS = Notif:FindFirstChildOfClass("UIStroke")
        if NS then NS.Color = Theme.Outline end

        local typeKey   = Cfg.Type and Cfg.Type:lower()
        local typeColor = typeKey and NotifTypeColors[typeKey] and NotifTypeColors[typeKey]()
                          or Theme.Accent

        local Strip = Instance.new("Frame", Notif)
        SetProperty(Strip, {
            Name             = "TypeStrip",
            Size             = UDim2.new(0, 3, 1, 0),
            Position         = UDim2.new(0, 0, 0, 0),
            BackgroundColor3 = typeColor,
            BorderSizePixel  = 0,
            ZIndex           = Notif.ZIndex + 1,
        })
        MakeCorner(Strip, 2)

        if Title then Title.TextColor3 = typeColor:Lerp(Theme.Title, 0.6) end

        -- v4: mobile → size ใหญ่ขึ้นอ่านง่าย
        if IsMobile then
            Notif.Size = UDim2.new(0, math.min(340, Screen.AbsoluteSize.X - 24), 0, 64)
        end

        local Parent = Screen:FindFirstChild("Frame") or Screen
        SetProperty(Notif, { GroupTransparency = 1, Visible = true, Parent = Parent })

        table.insert(ActiveNotifs, Notif)
        RepositionNotifs()

        task.spawn(function()
            local Duration = Cfg.Duration or 3
            Animations:Open(Notif, Setup.Transparency, true)
            if Timer then Tween(Timer, Duration, { Size = UDim2.new(0, 0, 0, 3) }) end
            task.wait(Duration)
            Animations:Close(Notif)
            task.wait(0.25)
            local idx = table.find(ActiveNotifs, Notif)
            if idx then table.remove(ActiveNotifs, idx) end
            RepositionNotifs()
            task.wait(0.05)
            Destroy(Notif)
        end)
    end


    -- ════════════════════════════════════════════════════════════
    --  HELPER — GetLabels
    -- ════════════════════════════════════════════════════════════

    function Options:GetLabels(Component)
        local Labels = Component:FindFirstChild("Labels")
        if Labels then
            return Labels:FindFirstChild("Title"), Labels:FindFirstChild("Description")
        end
        return Component:FindFirstChild("Title"), Component:FindFirstChild("Description")
    end


    -- ════════════════════════════════════════════════════════════
    --  SECTION HEADER
    -- ════════════════════════════════════════════════════════════

    function Options:AddSection(Cfg)
        local Section = Components and Clone(Components["Section"])
        if not Section then return end
        SetProperty(Section, { Text = Cfg.Name, Parent = Cfg.Tab, Visible = true })
    end


    -- ════════════════════════════════════════════════════════════
    --  DIVIDER  (v4: Label inline ใช้งานได้ถูกต้อง)
    -- ════════════════════════════════════════════════════════════

    function Options:AddDivider(Cfg)
        local Pad     = (Cfg and Cfg.Padding) or 4
        local Wrapper = Instance.new("Frame")
        SetProperty(Wrapper, {
            Name                   = "Divider",
            Size                   = UDim2.new(1, 0, 0, Pad * 2 + 1),
