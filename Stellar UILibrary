--  Easing Presets
--[[
    Modern motion language. Each preset picks a curve appropriate
    to the kind of motion:
        Smooth — generic UI transitions (Cubic/Out)
        Snap   — quick, decisive (Quart/Out)
        Soft   — gentle, eased (Sine/InOut)
        Spring — overshooty arrival (Back/Out)
        Bounce — playful exit (Bounce/Out)
        Linear — for hue/saturation in colour pickers
]]
local Ease = {
    Smooth = TweenInfo.new(0.22, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out),
    Snap   = TweenInfo.new(0.14, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
    Soft   = TweenInfo.new(0.28, Enum.EasingStyle.Sine,  Enum.EasingDirection.InOut),
    Spring = TweenInfo.new(0.32, Enum.EasingStyle.Back,  Enum.EasingDirection.Out),
    Linear = TweenInfo.new(0.15, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut),
    -- Quick taps
    Press  = TweenInfo.new(0.10, Enum.EasingStyle.Quad,  Enum.EasingDirection.Out),
}


