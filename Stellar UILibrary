local function _buildTheme(p)
    -- Fill any missing optional fields from sensible defaults so component
    -- code never has to nil-check theme keys.
    p.Hover       = p.Hover       or p.Secondary
    p.Pressed     = p.Pressed     or p.Primary
    p.AccentLight = p.AccentLight or p.Accent
    p.AccentDark  = p.AccentDark  or p.Accent
    p.FocusRing   = p.FocusRing   or p.Accent
    p.SliderThumb = p.SliderThumb or Color3.new(1, 1, 1)
    p.ToggleKnob  = p.ToggleKnob  or Color3.new(1, 1, 1)
    p.BadgeBg     = p.BadgeBg     or p.Accent
    p.BadgeText   = p.BadgeText   or Color3.new(1, 1, 1)
    -- Code-block "traffic-light" colours stay constant across themes
    p.CodeDotRed     = Color3.fromRGB(255,  95,  87)
    p.CodeDotYellow  = Color3.fromRGB(255, 189,  46)
    p.CodeDotGreen   = Color3.fromRGB( 40, 201,  64)
    return p
end

