    -- ════════════════════════════════════════════════════════════
    --  INPUT  (TextBox)
    -- ════════════════════════════════════════════════════════════

    function Options:AddInput(Cfg)
        --[[
            Cfg = {
                Title: string, Description: string,
                Placeholder: string?, Tab: Instance, Callback: function(string)
            }
            Returns: { Set(str), Get() }
        ]]
        local Input = Components and Clone(Components["Input"])
        if not Input then return {} end

        local Title, Desc = Options:GetLabels(Input)
        local Main    = Input:FindFirstChild("Main")
        local TextBox = Main and Main:FindFirstChild("Input")

        if TextBox then
            if Cfg.Placeholder then TextBox.PlaceholderText = Cfg.Placeholder end

            WinMaid:Add(Connect(Input.MouseButton1Click, function()
                TextBox:CaptureFocus()
            end))

            if IsMobile then
                WinMaid:Add(Connect(Input.InputBegan, function(Inp)
                    if Inp.UserInputType == Enum.UserInputType.Touch then
                        TextBox:CaptureFocus()
                    end
                end))
            end

            WinMaid:Add(Connect(TextBox.Focused, function()
                if Main then
                    Tween(Main, 0.14, {
                        BackgroundColor3 = LerpColor(Theme.Interactable, Theme.Accent, 0.12)
                    })
                end
                local Outline = Input:FindFirstChildOfClass("UIStroke")
                    or (Main and Main:FindFirstChildOfClass("UIStroke"))
                if Outline then Tween(Outline, 0.14, { Color = Theme.Accent }) end
            end))

            WinMaid:Add(Connect(TextBox.FocusLost, function()
                if Main then Tween(Main, 0.14, { BackgroundColor3 = Theme.Interactable }) end
                local Outline = Input:FindFirstChildOfClass("UIStroke")
                    or (Main and Main:FindFirstChildOfClass("UIStroke"))
                if Outline then Tween(Outline, 0.14, { Color = Theme.Outline }) end
                if Cfg.Callback then task.spawn(Cfg.Callback, TextBox.Text) end
            end))
        end

        Animations:Hover(Input, false, WinMaid)
        if Title then Title.Text = Cfg.Title       or "" end
        if Desc  then Desc.Text  = Cfg.Description or "" end
        SetProperty(Input, { Name = Cfg.Title, Parent = Cfg.Tab, Visible = true })

        local Ctrl = {}
        function Ctrl:Set(text) if TextBox then TextBox.Text = text end end
        function Ctrl:Get()     return TextBox and TextBox.Text or "" end
        return Ctrl
    end


    -- ════════════════════════════════════════════════════════════
    --  SLIDER  (v3.0 — unified drag handler + floating value bubble)
    -- ════════════════════════════════════════════════════════════

    function Options:AddSlider(Cfg)
        --[[
            Cfg = {
                Title: string, Description: string,
                MinValue: number?, MaxValue: number,
                Default: number?, AllowDecimals: boolean?, DecimalAmount: number?,
                Tab: Instance, Callback: function(number)
            }
            Returns: { Set(n), Get(), OnChanged(fn) }
        ]]
        local Slider = Components and Clone(Components["Slider"])
        if not Slider then return {} end

        local Title, Desc = Options:GetLabels(Slider)
        local SliderFrame = Slider:FindFirstChild("Slider")
        local Amount = SliderFrame and SliderFrame:FindFirstChild("Main")
                    and SliderFrame.Main:FindFirstChild("Input")
        local Slide = SliderFrame and SliderFrame:FindFirstChild("Slide")
        local Fire  = Slide and Slide:FindFirstChild("Fire")
        local Fill  = Slide and Slide:FindFirstChild("Highlight")

        local MinVal = Cfg.MinValue or 0
        local MaxVal = Cfg.MaxValue or 100
        local Value  = math.clamp(Cfg.Default or MinVal, MinVal, MaxVal)

        local Changed = Signal.new()
        local Active  = false
        local DragConn = nil

        -- v3.0: floating bubble above thumb
        local Bubble, BubbleLbl
        if Slide then
            Bubble = Instance.new("Frame")
            SetProperty(Bubble, {
                Name             = "ValueBubble",
                Size             = UDim2.new(0, 38, 0, 22),
                AnchorPoint      = Vector2.new(0.5, 1),
                Position         = UDim2.new(0, 0, 0, -6),
                BackgroundColor3 = Theme.Accent,
                BorderSizePixel  = 0,
                Visible          = false,
                ZIndex           = 25,
                Parent           = Slide,
            })
            MakeCorner(Bubble, 5)

            BubbleLbl = Instance.new("TextLabel", Bubble)
            SetProperty(BubbleLbl, {
                Size                   = UDim2.fromScale(1, 1),
                Text                   = tostring(Value),
                Font                   = Enum.Font.GothamBold,
                TextSize               = 11,
                TextColor3             = Color3.new(1, 1, 1),
                BackgroundTransparency = 1,
                BorderSizePixel        = 0,
            })

            -- small triangle pointer
            local Tri = Instance.new("Frame", Bubble)
            SetProperty(Tri, {
                Size             = UDim2.new(0, 7, 0, 5),
                Position         = UDim2.new(0.5, 0, 1, 0),
                AnchorPoint      = Vector2.new(0.5, 0),
                BackgroundColor3 = Theme.Accent,
                BorderSizePixel  = 0,
                ZIndex           = 24,
            })
            MakeCorner(Tri, 2)
        end

        local function Round(n)
            if Cfg.AllowDecimals then
                local p = 10 ^ (Cfg.DecimalAmount or 2)
                return math.floor(n * p + 0.5) / p
            end
            return math.round(n)
        end

        local function UpdateFromScale(scale)
            scale = math.clamp(scale, 0, 1)
            Value = Round(MinVal + scale * (MaxVal - MinVal))
            if Amount then Amount.Text = tostring(Value) end
            if Fill   then Fill.Size   = UDim2.fromScale(scale, 1) end
            -- Update bubble position + text
            if Bubble and BubbleLbl then
                Bubble.Position  = UDim2.new(scale, 0, 0, -6)
                BubbleLbl.Text   = tostring(Value)
            end
            if Cfg.Callback then task.spawn(Cfg.Callback, Value) end
            Changed:Fire(Value)
        end

        local function UpdateFromPositionX(posX)
            if not Slide then return end
            local slideX = Slide.AbsolutePosition.X
            local slideW = math.max(Slide.AbsoluteSize.X, 1)
            UpdateFromScale((posX - slideX) / slideW)
        end

        local function SetValue(n)
            n = math.clamp(n, MinVal, MaxVal)
            UpdateFromScale((n - MinVal) / (MaxVal - MinVal))
        end

        local function StopSliding()
            Active = false
            if DragConn then DragConn:Disconnect(); DragConn = nil end
            -- Hide bubble
            if Bubble then Tween(Bubble, 0.1, { Size = UDim2.new(0, 38, 0, 0) })
                task.delay(0.12, function() Bubble.Visible = false; Bubble.Size = UDim2.new(0,38,0,22) end)
            end
        end
        WinMaid:Add(StopSliding)

        -- v3.0: unified drag handler (mouse + touch, one code path)
        local function StartDragging(getX)
            if Active then return end
            Active = true
            -- Show bubble
            if Bubble then
                Bubble.Visible = true
                Bubble.Size    = UDim2.new(0, 38, 0, 0)
                Tween(Bubble, 0.12, { Size = UDim2.new(0, 38, 0, 22) })
            end
            -- Single unified connection
            DragConn = Services.Run.Heartbeat:Connect(function()
                if not Active then StopSliding(); return end
                UpdateFromPositionX(getX())
            end)
        end

        if Fire then
            WinMaid:Add(Connect(Fire.MouseButton1Down, function()
                StartDragging(function() return Player.Mouse.X end)
            end))
            WinMaid:Add(Connect(Fire.InputBegan, function(Inp)
                if Inp.UserInputType == Enum.UserInputType.Touch then
                    local touchRef = Inp
                    StartDragging(function()
                        return touchRef.Position.X
                    end)
                end
            end))
        end

        WinMaid:Add(Connect(Services.Input.InputEnded, function(Inp)
            local t = Inp.UserInputType
            if (t == Enum.UserInputType.MouseButton1 or t == Enum.UserInputType.Touch)
                and Active then
                StopSliding()
            end
        end))

        -- Manual text entry in the value box
        if Amount then
            WinMaid:Add(Connect(Amount.FocusLost, function()
                SetValue(tonumber(Amount.Text) or MinVal)
            end))
        end

        SetValue(Value)
        Animations:Hover(Slider, false, WinMaid)
        if Title then Title.Text = Cfg.Title       or "" end
        if Desc  then Desc.Text  = Cfg.Description or "" end
        SetProperty(Slider, { Name = Cfg.Title, Parent = Cfg.Tab, Visible = true })

        local Ctrl = {}
        function Ctrl:Set(n)        SetValue(n) end
        function Ctrl:Get()         return Value end
        function Ctrl:OnChanged(fn) return Changed:Connect(fn) end
        return Ctrl
    end


    -- ════════════════════════════════════════════════════════════
    --  KEYBIND  (v3.0 — Escape cancels listening)
    -- ════════════════════════════════════════════════════════════

    function Options:AddKeybind(Cfg)
        --[[
            Cfg = {
                Title: string, Description: string,
                Default: Enum.KeyCode?, Tab: Instance, Callback: function(InputObject)
            }
            Returns: { Set(kc), Get(), OnChanged(fn) }
        ]]
        local KBC = Components and Clone(Components["Keybind"])
        if not KBC then return {} end

        local Title, Desc = Options:GetLabels(KBC)
        local Bind = KBC:FindFirstChild("Main") and KBC.Main:FindFirstChild("Options")

        local CurrentKey = Cfg.Default
        local Listening  = false
        local Changed    = Signal.new()

        local MouseTypes = {
            Enum.UserInputType.MouseButton1,
            Enum.UserInputType.MouseButton2,
            Enum.UserInputType.MouseButton3,
        }

        local function FormatKey(Key)
            local t = Key.UserInputType
            if table.find(MouseTypes, t) then
                return tostring(t):gsub("Enum.UserInputType.MouseButton", "MB")
            elseif t == Enum.UserInputType.Keyboard then
                return tostring(Key.KeyCode):gsub("Enum.KeyCode.", "")
            end
            return "?"
        end

        local function SetBind(Key)
            CurrentKey = Key
            if Bind then Bind.Text = FormatKey(Key) end
            Changed:Fire(Key)
        end

        if CurrentKey and Bind then
            if typeof(CurrentKey) == "EnumItem" then
                Bind.Text = tostring(CurrentKey):gsub("Enum.KeyCode.", "")
            end
        end

        local DetectConn

        local function CancelListening()
            Listening = false
            if Bind then Bind.Text = CurrentKey
                and (typeof(CurrentKey) == "EnumItem"
                    and tostring(CurrentKey):gsub("Enum.KeyCode.", "")
                    or FormatKey(CurrentKey))
                or "None"
            end
            if DetectConn then DetectConn:Disconnect(); DetectConn = nil end
        end

        WinMaid:Add(Connect(KBC.MouseButton1Click, function()
            if Listening then return end
            Listening = true
            if Bind then Bind.Text = "..." end

            DetectConn = Connect(Services.Input.InputBegan, function(Key, GameFocused)
                if not Listening or GameFocused then return end
                -- v3.0: Escape cancels
                if Key.KeyCode == Enum.KeyCode.Escape then
                    CancelListening(); return
                end
                Listening = false
                SetBind(Key)
                if Cfg.Callback then task.spawn(Cfg.Callback, Key) end
                if DetectConn then DetectConn:Disconnect(); DetectConn = nil end
            end)
            WinMaid:Add(DetectConn)
        end))

        Animations:Hover(KBC, false, WinMaid)
        if Title then Title.Text = Cfg.Title       or "" end
        if Desc  then Desc.Text  = Cfg.Description or "" end
        SetProperty(KBC, { Name = Cfg.Title, Parent = Cfg.Tab, Visible = true })

        local Ctrl = {}
        function Ctrl:Set(key)      SetBind({ UserInputType = Enum.UserInputType.Keyboard, KeyCode = key }) end
        function Ctrl:Get()         return CurrentKey end
        function Ctrl:OnChanged(fn) return Changed:Connect(fn) end
        return Ctrl
    end


    -- ════════════════════════════════════════════════════════════
    --  DROPDOWN  (v3.0 — search filter when option count > 6)
    -- ════════════════════════════════════════════════════════════

    function Options:AddDropdown(Cfg)
        --[[
            Cfg = {
                Title: string, Description: string,
                Options: { [string]: any }, Default: any?,
                Tab: Instance, Callback: function(value)
            }
            Returns: { Set(value), Get() }
        ]]
        local Dropdown = Components and Clone(Components["Dropdown"])
        if not Dropdown then return {} end

        local Title, Desc  = Options:GetLabels(Dropdown)
        local OptionsLabel = Dropdown:FindFirstChild("Main") and Dropdown.Main:FindFirstChild("Options")

        local CurrentValue = Cfg.Default
        if OptionsLabel and CurrentValue ~= nil then
            for idx, opt in pairs(Cfg.Options) do
                if opt == CurrentValue then
                    OptionsLabel.Text = tostring(idx); break
                end
            end
        end

        -- Count options for search threshold
        local optionCount = 0
        for _ in pairs(Cfg.Options) do optionCount += 1 end

        WinMaid:Add(Connect(Dropdown.MouseButton1Click, function()
            local Example = Clone(Examples["DropdownExample"])
            if not Example then return end

            local CloseButtons = Example:FindFirstChild("Top") and Example.Top:FindFirstChild("Buttons")
            local ScrollFrame  = Example:FindFirstChild("ScrollingFrame") or Example

            -- v3.0: inject search box when many options
            local SearchBox
            if optionCount > 6 then
                local SearchWrapper = Instance.new("Frame")
                SetProperty(SearchWrapper, {
                    Size             = UDim2.new(1, -16, 0, IsMobile and 38 or 30),
                    Position         = UDim2.new(0, 8, 0, 8),
                    BackgroundColor3 = Theme.Interactable,
                    BorderSizePixel  = 0,
                    ZIndex           = 10,
                    Parent           = Example,
                })
                MakeCorner(SearchWrapper, 6)
                MakeStroke(SearchWrapper, Theme.Outline, 1)

                SearchBox = Instance.new("TextBox", SearchWrapper)
                SetProperty(SearchBox, {
                    Size              = UDim2.new(1, -16, 1, 0),
                    Position          = UDim2.new(0, 8, 0, 0),
                    BackgroundTransparency = 1,
                    BorderSizePixel   = 0,
                    Text              = "",
                    PlaceholderText   = "Search…",
                    Font              = Enum.Font.GothamMedium,
                    TextSize          = 12,
                    TextColor3        = Theme.Title,
                    ClearTextOnFocus  = false,
                    ZIndex            = 11,
                })

                -- Push ScrollFrame down
                ScrollFrame.Position = UDim2.new(
                    ScrollFrame.Position.X.Scale,
                    ScrollFrame.Position.X.Offset,
                    ScrollFrame.Position.Y.Scale,
                    ScrollFrame.Position.Y.Offset + (IsMobile and 52 or 44)
                )
                ScrollFrame.Size = UDim2.new(
                    ScrollFrame.Size.X.Scale,
                    ScrollFrame.Size.X.Offset,
                    ScrollFrame.Size.Y.Scale,
                    ScrollFrame.Size.Y.Offset - (IsMobile and 52 or 44)
                )
            end

            if BG then Tween(BG, 0.18, { BackgroundTransparency = 0.5 }) end
            Example.Parent = Window
            Animations:Open(Example, 0, true)

            local function CloseDropdown()
                if BG then Tween(BG, 0.18, { BackgroundTransparency = 1 }) end
                Animations:Close(Example)
                task.delay(0.3, function() Destroy(Example) end)
            end

            if CloseButtons then
                for _, Btn in next, CloseButtons:GetChildren() do
                    if Btn:IsA("TextButton") then
                        Animations:Hover(Btn)
                        Connect(Btn.MouseButton1Click, CloseDropdown)
                    end
                end
            end

            -- Build option buttons
            local BtnInstances = {}
            for Index, Option in next, Cfg.Options do
                local Btn = Clone(Examples["DropdownButtonExample"])
                if not Btn then continue end

                local BTitle, _ = Options:GetLabels(Btn)
                local Selected  = Btn:FindFirstChild("Value")

                if BTitle then BTitle.Text = tostring(Index) end

                if CurrentValue == Option then
                    Btn.BackgroundColor3 = Theme.Interactable
                    if Selected then Selected.Value = true end
                end

                Btn._optionKey = tostring(Index):lower()
                BtnInstances[#BtnInstances + 1] = Btn

                SetProperty(Btn, { Parent = ScrollFrame, Visible = true })
                Animations:Hover(Btn)

                Connect(Btn.MouseButton1Click, function()
                    CurrentValue = Option
                    if OptionsLabel then OptionsLabel.Text = tostring(Index) end
                    if Cfg.Callback then task.spawn(Cfg.Callback, Option) end
                    for _, Other in next, ScrollFrame:GetChildren() do
                        if Other:IsA("TextButton") and Other ~= Btn then
                            Tween(Other, 0.18, { BackgroundColor3 = Theme.Component })
                            local OV = Other:FindFirstChild("Value")
                            if OV then OV.Value = false end
                        end
                    end
                    Tween(Btn, 0.18, { BackgroundColor3 = Theme.Interactable })
                    if Selected then Selected.Value = true end
                    CloseDropdown()
                end)
            end

            -- Wire up search filter
            if SearchBox then
                Connect(SearchBox:GetPropertyChangedSignal("Text"), function()
                    local query = SearchBox.Text:lower()
                    for _, Btn in ipairs(BtnInstances) do
                        Btn.Visible = (query == "" or (Btn._optionKey and Btn._optionKey:find(query, 1, true) ~= nil))
                    end
                end)
            end
        end))

        Animations:Hover(Dropdown, false, WinMaid)
        if Title then Title.Text = Cfg.Title       or "" end
        if Desc  then Desc.Text  = Cfg.Description or "" end
        SetProperty(Dropdown, { Name = Cfg.Title, Parent = Cfg.Tab, Visible = true })

        local Ctrl = {}
        function Ctrl:Get() return CurrentValue end
        function Ctrl:Set(value)
            for idx, opt in pairs(Cfg.Options) do
                if opt == value then
                    CurrentValue = opt
                    if OptionsLabel then OptionsLabel.Text = tostring(idx) end
                    break
                end
            end
        end
        return Ctrl
    end


    -- ════════════════════════════════════════════════════════════
    --  MULTI-DROPDOWN  (v3.0 — search filter + improved UI)
    -- ════════════════════════════════════════════════════════════

    function Options:AddMultiDropdown(Cfg)
        --[[
            Cfg = {
                Title: string, Description: string,
                Options: { [string]: any }, Default: { any }?,
                Tab: Instance, Callback: function(selectedValues: table)
            }
            Returns: { Get(), Set({values}) }
        ]]
        local Dropdown = Components and Clone(Components["Dropdown"])
        if not Dropdown then return {} end

        local Title, Desc  = Options:GetLabels(Dropdown)
        local OptionsLabel = Dropdown:FindFirstChild("Main") and Dropdown.Main:FindFirstChild("Options")

        local Selected = {}
        if Cfg.Default then
            for _, v in ipairs(Cfg.Default) do Selected[v] = true end
        end

        local optionCount = 0
        for _ in pairs(Cfg.Options) do optionCount += 1 end

        local function UpdateLabel()
            if not OptionsLabel then return end
            local count = 0
            for _ in pairs(Selected) do count += 1 end
            OptionsLabel.Text = (count == 0) and "None" or (count .. " selected")
        end
        UpdateLabel()

        WinMaid:Add(Connect(Dropdown.MouseButton1Click, function()
            local Example = Clone(Examples["DropdownExample"])
            if not Example then return end

            local CloseButtons = Example:FindFirstChild("Top") and Example.Top:FindFirstChild("Buttons")
            local ScrollFrame  = Example:FindFirstChild("ScrollingFrame") or Example

            -- Search box for large lists
            local SearchBox
            if optionCount > 6 then
                local SW = Instance.new("Frame")
                SetProperty(SW, {
                    Size             = UDim2.new(1, -16, 0, IsMobile and 38 or 30),
                    Position         = UDim2.new(0, 8, 0, 8),
                    BackgroundColor3 = Theme.Interactable,
                    BorderSizePixel  = 0,
                    ZIndex           = 10,
                    Parent           = Example,
                })
                MakeCorner(SW, 6)
                MakeStroke(SW, Theme.Outline, 1)
                SearchBox = Instance.new("TextBox", SW)
                SetProperty(SearchBox, {
                    Size              = UDim2.new(1, -16, 1, 0),
                    Position          = UDim2.new(0, 8, 0, 0),
                    BackgroundTransparency = 1,
                    BorderSizePixel   = 0,
                    Text              = "",
                    PlaceholderText   = "Search…",
                    Font              = Enum.Font.GothamMedium,
                    TextSize          = 12,
                    TextColor3        = Theme.Title,
                    ClearTextOnFocus  = false,
                    ZIndex            = 11,
                })
                local offset = IsMobile and 52 or 44
                ScrollFrame.Position = UDim2.new(0, 0, 0, offset)
                ScrollFrame.Size     = UDim2.new(1, 0, 1, -offset)
            end

            if BG then Tween(BG, 0.18, { BackgroundTransparency = 0.5 }) end
            Example.Parent = Window
            Animations:Open(Example, 0, true)

            local function CloseDropdown()
                if BG then Tween(BG, 0.18, { BackgroundTransparency = 1 }) end
                Animations:Close(Example)
                task.delay(0.3, function() Destroy(Example) end)
            end

            if CloseButtons then
                for _, Btn in next, CloseButtons:GetChildren() do
                    if Btn:IsA("TextButton") then
                        Animations:Hover(Btn)
                        Connect(Btn.MouseButton1Click, CloseDropdown)
                    end
                end
            end

            local BtnInstances = {}
            for Index, Option in next, Cfg.Options do
                local Btn = Clone(Examples["DropdownButtonExample"])
                if not Btn then continue end

                local BTitle, _ = Options:GetLabels(Btn)
                if BTitle then BTitle.Text = tostring(Index) end

                local Chk = Instance.new("TextLabel", Btn)
                SetProperty(Chk, {
                    Name                   = "CheckMark",
                    Text                   = Selected[Option] and "✓" or "",
                    Font                   = Enum.Font.GothamBold,
                    TextSize               = 13,
                    TextColor3             = Theme.Accent,
                    BackgroundTransparency = 1,
                    Size                   = UDim2.new(0, 20, 1, 0),
                    Position               = UDim2.new(1, -24, 0, 0),
                    AnchorPoint            = Vector2.new(1, 0),
                    ZIndex                 = Btn.ZIndex + 1,
                })

                if Selected[Option] then
                    Btn.BackgroundColor3 = LerpColor(Theme.Component, Theme.Accent, 0.12)
                end

                Btn._optionKey = tostring(Index):lower()
                BtnInstances[#BtnInstances + 1] = Btn

                SetProperty(Btn, { Parent = ScrollFrame, Visible = true })
                Animations:Hover(Btn)

                Connect(Btn.MouseButton1Click, function()
                    Selected[Option] = not Selected[Option]
                    Chk.Text = Selected[Option] and "✓" or ""
                    Tween(Btn, 0.15, {
                        BackgroundColor3 = Selected[Option]
                            and LerpColor(Theme.Component, Theme.Accent, 0.12)
                            or  Theme.Component
                    })
                    UpdateLabel()
                    local arr = {}
                    for v in pairs(Selected) do arr[#arr + 1] = v end
                    if Cfg.Callback then task.spawn(Cfg.Callback, arr) end
                end)
            end

            if SearchBox then
                Connect(SearchBox:GetPropertyChangedSignal("Text"), function()
                    local query = SearchBox.Text:lower()
                    for _, Btn in ipairs(BtnInstances) do
                        Btn.Visible = (query == "" or (Btn._optionKey and Btn._optionKey:find(query, 1, true) ~= nil))
                    end
                end)
            end
        end))

        Animations:Hover(Dropdown, false, WinMaid)
        if Title then Title.Text = Cfg.Title       or "" end
        if Desc  then Desc.Text  = Cfg.Description or "" end
        SetProperty(Dropdown, { Name = Cfg.Title, Parent = Cfg.Tab, Visible = true })

        local Ctrl = {}
        function Ctrl:Get()
            local arr = {}
            for v in pairs(Selected) do arr[#arr + 1] = v end
            return arr
        end
        function Ctrl:Set(values)
            Selected = {}
            for _, v in ipairs(values) do Selected[v] = true end
            UpdateLabel()
        end
        return Ctrl
    end


    -- ════════════════════════════════════════════════════════════
    --  PARAGRAPH
    -- ════════════════════════════════════════════════════════════

    function Options:AddParagraph(Cfg)
        local Para = Components and Clone(Components["Paragraph"])
        if not Para then return {} end
        local Title, Desc = Options:GetLabels(Para)
        if Title then Title.Text = Cfg.Title       or "" end
        if Desc  then Desc.Text  = Cfg.Description or "" end
        SetProperty(Para, { Parent = Cfg.Tab, Visible = true })
        local Ctrl = {}
        function Ctrl:SetTitle(text)       if Title then Title.Text = text end end
        function Ctrl:SetDescription(text) if Desc  then Desc.Text  = text end end
        return Ctrl
    end


    -- ════════════════════════════════════════════════════════════
    --  PROGRESS BAR  (v3.0 — shimmer effect on fill)
    -- ════════════════════════════════════════════════════════════

    function Options:AddProgressBar(Cfg)
        --[[
            Cfg = { Title: string, Tab: Instance, Default: number? (0–1) }
            Returns: { Set(0–1), Get() }
        ]]
        local Wrapper = Instance.new("Frame")
        SetProperty(Wrapper, {
            Name             = "ProgressBar_" .. (Cfg.Title or ""),
            Size             = UDim2.new(1, 0, 0, IsMobile and 56 or 48),
            BackgroundColor3 = Theme.Component,
            BorderSizePixel  = 0,
            Parent           = Cfg.Tab,
            Visible          = true,
        })
        MakeCorner(Wrapper, 8)

        local Row = Instance.new("Frame", Wrapper)
        SetProperty(Row, {
            Name                   = "LabelRow",
            Size                   = UDim2.new(1, -16, 0, 18),
            Position               = UDim2.new(0, 10, 0, 8),
            BackgroundTransparency = 1,
            BorderSizePixel        = 0,
        })

        local TitleLbl = Instance.new("TextLabel", Row)
        SetProperty(TitleLbl, {
            Text                   = Cfg.Title or "",
            Font                   = Enum.Font.GothamSemibold,
            TextSize               = 13,
            TextColor3             = Theme.Title,
            BackgroundTransparency = 1,
            TextXAlignment         = Enum.TextXAlignment.Left,
            Size                   = UDim2.new(0.7, 0, 1, 0),
            BorderSizePixel        = 0,
        })

        local PctLbl = Instance.new("TextLabel", Row)
        SetProperty(PctLbl, {
            Name                   = "Pct",
            Text                   = "0%",
            Font                   = Enum.Font.GothamBold,
            TextSize               = 12,
            TextColor3             = Theme.Accent,
            BackgroundTransparency = 1,
            TextXAlignment         = Enum.TextXAlignment.Right,
            Size                   = UDim2.new(0.3, 0, 1, 0),
            Position               = UDim2.new(0.7, 0, 0, 0),
            BorderSizePixel        = 0,
        })

        local TrackFrame = Instance.new("Frame", Wrapper)
        SetProperty(TrackFrame, {
            Name             = "Track",
            Size             = UDim2.new(1, -20, 0, IsMobile and 8 or 6),
            Position         = UDim2.new(0, 10, 1, -14),
            AnchorPoint      = Vector2.new(0, 1),
            BackgroundColor3 = Theme.ProgressBg,
            BorderSizePixel  = 0,
            ClipsDescendants = true,
        })
        MakeCorner(TrackFrame, 10)

        local FillFrame = Instance.new("Frame", TrackFrame)
        SetProperty(FillFrame, {
            Name             = "Fill",
            Size             = UDim2.fromScale(0, 1),
            BackgroundColor3 = Theme.ProgressFill,
            BorderSizePixel  = 0,
        })
        MakeCorner(FillFrame, 10)

        -- v3.0: subtle shimmer overlay on fill
        local Shimmer = Instance.new("Frame", FillFrame)
        SetProperty(Shimmer, {
            Size             = UDim2.new(0, 40, 1, 0),
            Position         = UDim2.new(-0.5, 0, 0, 0),
            BackgroundColor3 = Color3.new(1, 1, 1),
            BackgroundTransparency = 0.7,
            BorderSizePixel  = 0,
            ZIndex           = FillFrame.ZIndex + 1,
            ClipsDescendants = false,
        })
        MakeCorner(Shimmer, 4)

        local Current = math.clamp(Cfg.Default or 0, 0, 1)

        -- Shimmer loop
        local function RunShimmer()
            while FillFrame and FillFrame.Parent do
                Shimmer.Position = UDim2.new(-0.4, 0, 0, 0)
                Tween(Shimmer, 0.9, { Position = UDim2.new(1.4, 0, 0, 0) })
                task.wait(1.8)
            end
        end
        task.spawn(RunShimmer)

        local function SetProgress(pct)
            pct     = math.clamp(pct, 0, 1)
            Current = pct
            Tween(FillFrame, 0.35, { Size = UDim2.fromScale(pct, 1) })
            PctLbl.Text = math.floor(pct * 100) .. "%"
        end
        SetProgress(Current)

        local Ctrl = {}
        function Ctrl:Set(pct) SetProgress(pct) end
        function Ctrl:Get()    return Current    end
        return Ctrl
    end


    -- ════════════════════════════════════════════════════════════
    --  COLOR PICKER  (v3.0 — alpha slider + RGB/HEX mode toggle)
    -- ════════════════════════════════════════════════════════════

    function Options:AddColorPicker(Cfg)
        --[[
            Cfg = {
                Title: string, Default: Color3?,
                Tab: Instance,
                Callback: function(Color3, alpha: number)  ← alpha is 0–1 (v3.0)
                ShowAlpha: boolean?   (v3.0, default false)
            }
            Returns: { Set(Color3), Get(), SetAlpha(0–1), GetAlpha() }
        ]]

        local ShowAlpha = Cfg.ShowAlpha or false

        -- ── Collapsed row ──────────────────────────────────────────
        local Row = Instance.new("TextButton")
        SetProperty(Row, {
            Name             = "ColorPicker_" .. (Cfg.Title or ""),
            Size             = UDim2.new(1, 0, 0, IsMobile and 50 or 42),
            BackgroundColor3 = Theme.Component,
            BorderSizePixel  = 0,
            Text             = "",
            AutoButtonColor  = false,
            Parent           = Cfg.Tab,
            Visible          = true,
        })
        MakeCorner(Row, 8)
        local RowPad = Instance.new("UIPadding", Row)
        RowPad.PaddingLeft  = UDim.new(0, 12)
        RowPad.PaddingRight = UDim.new(0, 12)

        local RowTitle = Instance.new("TextLabel", Row)
        SetProperty(RowTitle, {
            Text                   = Cfg.Title or "Color",
            Font                   = Enum.Font.GothamSemibold,
            TextSize               = 13,
            TextColor3             = Theme.Title,
            BackgroundTransparency = 1,
            TextXAlignment         = Enum.TextXAlignment.Left,
            Size                   = UDim2.new(1, -60, 1, 0),
            BorderSizePixel        = 0,
        })

        local Swatch = Instance.new("Frame", Row)
        SetProperty(Swatch, {
            Name             = "Swatch",
            Size             = UDim2.new(0, IsMobile and 38 or 30, 0, IsMobile and 24 or 19),
            Position         = UDim2.new(1, 0, 0.5, 0),
            AnchorPoint      = Vector2.new(1, 0.5),
            BorderSizePixel  = 0,
            BackgroundColor3 = Cfg.Default or Color3.fromRGB(112, 135, 255),
        })
        MakeCorner(Swatch, 6)
        MakeStroke(Swatch, Theme.Outline, 1)

        -- ── Expanded picker panel ───────────────────────────────────
        local SV_H    = IsMobile and 130 or 112
        local HUE_H   = IsMobile and 18  or 14
        local ALPHA_H = (ShowAlpha) and (IsMobile and 18 or 14) or 0
        local HEX_H   = IsMobile and 34  or 28
        -- v3.0: mode button row height
        local MODE_H  = 24
        local PANEL_H = 14 + SV_H + 8 + HUE_H + (ShowAlpha and (8 + ALPHA_H) or 0) + 8 + HEX_H + 8 + MODE_H + 8

        local Picker = Instance.new("Frame")
        SetProperty(Picker, {
            Name             = "Picker",
            Size             = UDim2.new(1, 0, 0, 0),
            BackgroundColor3 = Theme.CPBackground,
            BorderSizePixel  = 0,
            ClipsDescendants = true,
            Visible          = false,
            Parent           = Cfg.Tab,
        })
        MakeCorner(Picker, 8)
        MakeStroke(Picker, Theme.CPBorder, 1)

        -- SV canvas
        local SVCanvas = Instance.new("Frame", Picker)
        SetProperty(SVCanvas, {
            Name             = "SVCanvas",
            Size             = UDim2.new(1, -16, 0, SV_H),
            Position         = UDim2.new(0, 8, 0, 8),
            BackgroundColor3 = Color3.fromHSV(0, 1, 1),
            BorderSizePixel  = 0,
            ClipsDescendants = false,
        })
        MakeCorner(SVCanvas, 6)

        local WhiteOverlay = Instance.new("Frame", SVCanvas)
        SetProperty(WhiteOverlay, {
            Size             = UDim2.fromScale(1, 1),
            BackgroundColor3 = Color3.new(1, 1, 1),
            BorderSizePixel  = 0,
            ZIndex           = SVCanvas.ZIndex + 1,
        })
        MakeCorner(WhiteOverlay, 6)
        local WhiteGrad = Instance.new("UIGradient", WhiteOverlay)
        WhiteGrad.Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0),
            NumberSequenceKeypoint.new(1, 1),
        })

        local BlackOverlay = Instance.new("Frame", SVCanvas)
        SetProperty(BlackOverlay, {
            Size             = UDim2.fromScale(1, 1),
            BackgroundColor3 = Color3.new(0, 0, 0),
            BorderSizePixel  = 0,
            ZIndex           = SVCanvas.ZIndex + 2,
        })
        MakeCorner(BlackOverlay, 6)
        local BlackGrad = Instance.new("UIGradient", BlackOverlay)
        BlackGrad.Rotation     = 90
        BlackGrad.Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 1),
            NumberSequenceKeypoint.new(1, 0),
        })

        -- SV thumb
        local SVThumb = Instance.new("Frame", SVCanvas)
        SetProperty(SVThumb, {
            Size             = UDim2.new(0, 13, 0, 13),
            AnchorPoint      = Vector2.new(0.5, 0.5),
            Position         = UDim2.new(1, 0, 0, 0),
            BackgroundColor3 = Color3.new(1, 1, 1),
            BorderSizePixel  = 0,
            ZIndex           = SVCanvas.ZIndex + 5,
        })
        MakeCorner(SVThumb, 10)
        local SVStroke = MakeStroke(SVThumb, Color3.new(0.15, 0.15, 0.15), 1.5)

        -- Hue track
        local HueTrack = Instance.new("Frame", Picker)
        SetProperty(HueTrack, {
            Name             = "HueTrack",
            Size             = UDim2.new(1, -16, 0, HUE_H),
            Position         = UDim2.new(0, 8, 0, 8 + SV_H + 8),
            BackgroundColor3 = Color3.new(1, 0, 0),
            BorderSizePixel  = 0,
            ClipsDescendants = true,
        })
        MakeCorner(HueTrack, 10)
        local HueGrad = Instance.new("UIGradient", HueTrack)
        HueGrad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0/6, Color3.fromHSV(0/6, 1, 1)),
            ColorSequenceKeypoint.new(1/6, Color3.fromHSV(1/6, 1, 1)),
            ColorSequenceKeypoint.new(2/6, Color3.fromHSV(2/6, 1, 1)),
            ColorSequenceKeypoint.new(3/6, Color3.fromHSV(3/6, 1, 1)),
            ColorSequenceKeypoint.new(4/6, Color3.fromHSV(4/6, 1, 1)),
            ColorSequenceKeypoint.new(5/6, Color3.fromHSV(5/6, 1, 1)),
            ColorSequenceKeypoint.new(1,   Color3.fromHSV(1,   1, 1)),
        })

        local HueThumb = Instance.new("Frame", HueTrack)
        SetProperty(HueThumb, {
            Size             = UDim2.new(0, IsMobile and 16 or 12, 1, 4),
            AnchorPoint      = Vector2.new(0.5, 0.5),
            Position         = UDim2.new(0, 0, 0.5, 0),
            BackgroundColor3 = Color3.new(1, 1, 1),
            BorderSizePixel  = 0,
            ZIndex           = HueTrack.ZIndex + 2,
        })
        MakeCorner(HueThumb, 4)
        MakeStroke(HueThumb, Color3.new(0.15, 0.15, 0.15), 1.5)

        -- v3.0: Alpha slider (optional)
        local AlphaTrack, AlphaThumb
        local Alpha = 1

        if ShowAlpha then
            local alphaY = 8 + SV_H + 8 + HUE_H + 8
            AlphaTrack = Instance.new("Frame", Picker)
            SetProperty(AlphaTrack, {
                Name             = "AlphaTrack",
                Size             = UDim2.new(1, -16, 0, ALPHA_H),
                Position         = UDim2.new(0, 8, 0, alphaY),
                BackgroundColor3 = Color3.new(0.8, 0.8, 0.8),
                BorderSizePixel  = 0,
                ClipsDescendants = true,
            })
            MakeCorner(AlphaTrack, 10)

            -- Checkerboard via gradient (approximation)
            local AlphaGrad = Instance.new("UIGradient", AlphaTrack)
            AlphaGrad.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.new(0, 0, 0)),
                ColorSequenceKeypoint.new(1, Color3.new(1, 1, 1)),
            })
            AlphaGrad.Transparency = NumberSequence.new({
                NumberSequenceKeypoint.new(0, 0.8),
                NumberSequenceKeypoint.new(1, 0),
            })

            AlphaThumb = Instance.new("Frame", AlphaTrack)
            SetProperty(AlphaThumb, {
                Size             = UDim2.new(0, IsMobile and 16 or 12, 1, 4),
                AnchorPoint      = Vector2.new(0.5, 0.5),
                Position         = UDim2.new(1, 0, 0.5, 0),
                BackgroundColor3 = Color3.new(1, 1, 1),
                BorderSizePixel  = 0,
                ZIndex           = AlphaTrack.ZIndex + 2,
            })
            MakeCorner(AlphaThumb, 4)
            MakeStroke(AlphaThumb, Color3.new(0.15, 0.15, 0.15), 1.5)
        end

        -- Hex input row
        local hexRowY = 8 + SV_H + 8 + HUE_H + (ShowAlpha and (8 + ALPHA_H) or 0) + 8

        local HexRow = Instance.new("Frame", Picker)
        SetProperty(HexRow, {
            Name             = "HexRow",
            Size             = UDim2.new(1, -16, 0, HEX_H),
            Position         = UDim2.new(0, 8, 0, hexRowY),
            BackgroundColor3 = Theme.CPHexBg,
            BorderSizePixel  = 0,
        })
        MakeCorner(HexRow, 6)

        local HexInput = Instance.new("TextBox", HexRow)
        SetProperty(HexInput, {
            Name              = "HexInput",
            Text              = "",
            PlaceholderText   = "#RRGGBB",
            Font              = Enum.Font.Code,
            TextSize          = 12,
            TextColor3        = Theme.Title,
            BackgroundTransparency = 1,
            Size              = UDim2.new(1, -12, 1, 0),
            Position          = UDim2.new(0, 6, 0, 0),
            ClearTextOnFocus  = false,
            BorderSizePixel   = 0,
        })

        -- v3.0: mode toggle (HEX ↔ RGB display)
        local modeRowY = hexRowY + HEX_H + 8
        local ModeRow  = Instance.new("Frame", Picker)
        SetProperty(ModeRow, {
            Name             = "ModeRow",
            Size             = UDim2.new(1, -16, 0, MODE_H),
            Position         = UDim2.new(0, 8, 0, modeRowY),
            BackgroundTransparency = 1,
            BorderSizePixel  = 0,
        })

        local ModeLabel = Instance.new("TextLabel", ModeRow)
        SetProperty(ModeLabel, {
            Text                   = "HEX",
            Font                   = Enum.Font.GothamMedium,
            TextSize               = 10,
            TextColor3             = Theme.Muted,
            BackgroundTransparency = 1,
            Size                   = UDim2.new(0.5, 0, 1, 0),
            TextXAlignment         = Enum.TextXAlignment.Left,
            BorderSizePixel        = 0,
        })

        local ModeBtn = Instance.new("TextButton", ModeRow)
        SetProperty(ModeBtn, {
            Text             = "⇄ RGB",
            Font             = Enum.Font.GothamMedium,
            TextSize         = 10,
            TextColor3       = Theme.Accent,
            BackgroundColor3 = Theme.Interactable,
            Size             = UDim2.new(0, 52, 0, 18),
            Position         = UDim2.new(1, -52, 0.5, 0),
            AnchorPoint      = Vector2.new(0, 0.5),
            BorderSizePixel  = 0,
        })
        MakeCorner(ModeBtn, 4)

        -- ── HSV state ────────────────────────────────────────────────
        local H, S, V = Color3.toHSV(Cfg.Default or Color3.fromRGB(112, 135, 255))
        local PickerOpen = false
        local VisualDirty = false
        local IsRGBMode   = false

        local function GetC3() return Color3.fromHSV(H, S, V) end

        -- Deferred update (v3.0: single frame cap prevents spam-tween on drag)
        local function UpdateVisuals()
            VisualDirty = false
            local c3 = GetC3()
            Swatch.BackgroundColor3 = c3
            SVCanvas.BackgroundColor3 = Color3.fromHSV(H, 1, 1)
            SVThumb.Position = UDim2.new(S, 0, 1 - V, 0)
            HueThumb.Position = UDim2.new(H, 0, 0.5, 0)
            if AlphaThumb then AlphaThumb.Position = UDim2.new(Alpha, 0, 0.5, 0) end
            if IsRGBMode then
                HexInput.Text = string.format("%d, %d, %d",
                    math.round(c3.R * 255),
                    math.round(c3.G * 255),
                    math.round(c3.B * 255))
            else
                HexInput.Text = Color3ToHex(c3)
            end
            -- Update gradient alpha overlay tint
            if AlphaTrack then
                local ug = AlphaTrack:FindFirstChildOfClass("UIGradient")
                if ug then ug.Color = ColorSequence.new(c3) end
            end
            if Cfg.Callback then task.spawn(Cfg.Callback, c3, Alpha) end
        end

        local function MarkDirty()
            if not VisualDirty then
                VisualDirty = true
                task.defer(UpdateVisuals)
            end
        end

        -- Toggle open/close
        WinMaid:Add(Connect(Row.MouseButton1Click, function()
            PickerOpen = not PickerOpen
            if PickerOpen then
                Picker.Visible = true
                Tween(Picker, 0.2, { Size = UDim2.new(1, 0, 0, PANEL_H) },
                    Enum.EasingStyle.Back, Enum.EasingDirection.Out)
            else
                Tween(Picker, 0.16, { Size = UDim2.new(1, 0, 0, 0) })
                task.delay(0.18, function() Picker.Visible = false end)
            end
        end))

        -- SV drag
        local SVDragging = false
        local function UpdateSV(px, py)
            local ax = SVCanvas.AbsolutePosition.X
            local ay = SVCanvas.AbsolutePosition.Y
            local aw = math.max(SVCanvas.AbsoluteSize.X, 1)
            local ah = math.max(SVCanvas.AbsoluteSize.Y, 1)
            S = math.clamp((px - ax) / aw, 0, 1)
            V = 1 - math.clamp((py - ay) / ah, 0, 1)
            MarkDirty()
        end

        WinMaid:Add(Connect(SVCanvas.InputBegan, function(Inp)
            if Inp.UserInputType == Enum.UserInputType.MouseButton1
                or Inp.UserInputType == Enum.UserInputType.Touch then
                SVDragging = true
                UpdateSV(Inp.Position.X, Inp.Position.Y)
            end
        end))
        WinMaid:Add(Connect(Services.Input.InputChanged, function(Inp)
            if not SVDragging then return end
            if Inp.UserInputType == Enum.UserInputType.MouseMovement
                or Inp.UserInputType == Enum.UserInputType.Touch then
                UpdateSV(Inp.Position.X, Inp.Position.Y)
            end
        end))
        WinMaid:Add(Connect(Services.Input.InputEnded, function(Inp)
            if Inp.UserInputType == Enum.UserInputType.MouseButton1
                or Inp.UserInputType == Enum.UserInputType.Touch then
                SVDragging = false
            end
        end))

        -- Hue drag
        local HueDragging = false
        local function UpdateHue(px)
            local ax = HueTrack.AbsolutePosition.X
            local aw = math.max(HueTrack.AbsoluteSize.X, 1)
            H = math.clamp((px - ax) / aw, 0, 1)
            MarkDirty()
        end
        WinMaid:Add(Connect(HueTrack.InputBegan, function(Inp)
            if Inp.UserInputType == Enum.UserInputType.MouseButton1
                or Inp.UserInputType == Enum.UserInputType.Touch then
                HueDragging = true; UpdateHue(Inp.Position.X)
            end
        end))
        WinMaid:Add(Connect(Services.Input.InputChanged, function(Inp)
            if not HueDragging then return end
            if Inp.UserInputType == Enum.UserInputType.MouseMovement
                or Inp.UserInputType == Enum.UserInputType.Touch then
                UpdateHue(Inp.Position.X)
            end
        end))
        WinMaid:Add(Connect(Services.Input.InputEnded, function(Inp)
            if Inp.UserInputType == Enum.UserInputType.MouseButton1
                or Inp.UserInputType == Enum.UserInputType.Touch then
                HueDragging = false
            end
        end))

        -- v3.0: Alpha drag
        if AlphaTrack then
            local AlphaDragging = false
            local function UpdateAlpha(px)
                local ax = AlphaTrack.AbsolutePosition.X
                local aw = math.max(AlphaTrack.AbsoluteSize.X, 1)
                Alpha = math.clamp((px - ax) / aw, 0, 1)
                MarkDirty()
            end
            WinMaid:Add(Connect(AlphaTrack.InputBegan, function(Inp)
                if Inp.UserInputType == Enum.UserInputType.MouseButton1
                    or Inp.UserInputType == Enum.UserInputType.Touch then
                    AlphaDragging = true; UpdateAlpha(Inp.Position.X)
                end
            end))
            WinMaid:Add(Connect(Services.Input.InputChanged, function(Inp)
                if not AlphaDragging then return end
                if Inp.UserInputType == Enum.UserInputType.MouseMovement
                    or Inp.UserInputType == Enum.UserInputType.Touch then
                    UpdateAlpha(Inp.Position.X)
                end
            end))
            WinMaid:Add(Connect(Services.Input.InputEnded, function(Inp)
                if Inp.UserInputType == Enum.UserInputType.MouseButton1
                    or Inp.UserInputType == Enum.UserInputType.Touch then
                    AlphaDragging = false
                end
            end))
        end

        -- Hex input
        WinMaid:Add(Connect(HexInput.FocusLost, function()
            if IsRGBMode then
                local parts = {}
                for p in HexInput.Text:gmatch("%d+") do parts[#parts + 1] = tonumber(p) end
                if #parts >= 3 then
                    local c3 = Color3.fromRGB(
                        math.clamp(parts[1], 0, 255),
                        math.clamp(parts[2], 0, 255),
                        math.clamp(parts[3], 0, 255))
                    H, S, V = Color3.toHSV(c3)
                    MarkDirty()
                end
            else
                local c3 = HexToColor3(HexInput.Text)
                if c3 then H, S, V = Color3.toHSV(c3); MarkDirty()
                else HexInput.Text = Color3ToHex(GetC3()) end
            end
        end))

        -- v3.0: mode toggle button
        WinMaid:Add(Connect(ModeBtn.MouseButton1Click, function()
            IsRGBMode = not IsRGBMode
            ModeLabel.Text = IsRGBMode and "RGB" or "HEX"
            ModeBtn.Text   = IsRGBMode and "⇄ HEX" or "⇄ RGB"
            HexInput.PlaceholderText = IsRGBMode and "R, G, B" or "#RRGGBB"
            MarkDirty()
        end))

        UpdateVisuals()
        Animations:Hover(Row, false, WinMaid)

        local Ctrl = {}
        function Ctrl:Set(c3) H, S, V = Color3.toHSV(c3); MarkDirty() end
        function Ctrl:Get()   return GetC3() end
        function Ctrl:SetAlpha(a) Alpha = math.clamp(a, 0, 1); MarkDirty() end
        function Ctrl:GetAlpha()  return Alpha end
        return Ctrl
    end


    -- ════════════════════════════════════════════════════════════
    --  CODE BLOCK
    -- ════════════════════════════════════════════════════════════

    function Options:AddCodeBlock(Cfg)
        --[[
            Cfg = { Title: string, Code: string, Tab: Instance, Callback: function()? }
        ]]
        local Template = Components and (Components:FindFirstChild("Code") or Components["Paragraph"])
        if not Template then return end

        local Block   = Clone(Template)
        local Title, Desc = Options:GetLabels(Block)
        local CopyBtn = Block:FindFirstChild("Copy") or Block:FindFirstChild("CopyButton")

        local Dots = Block:FindFirstChild("Dots")
        if Dots then
            local DR = Dots:FindFirstChild("Red")
            local DY = Dots:FindFirstChild("Yellow")
            local DG = Dots:FindFirstChild("Green")
            if DR then DR.BackgroundColor3 = Theme.CodeDotRed    end
            if DY then DY.BackgroundColor3 = Theme.CodeDotYellow end
            if DG then DG.BackgroundColor3 = Theme.CodeDotGreen  end
        end

        if Title then Title.Text = Cfg.Title or "Code" end
        if Desc  then Desc.Text  = Cfg.Code  or ""    end

        if CopyBtn then
            local BtnLabel = CopyBtn:FindFirstChild("TextLabel") or CopyBtn:FindFirstChild("Label")
            WinMaid:Add(Connect(CopyBtn.MouseButton1Click, function()
                pcall(function()
                    if setclipboard then setclipboard(Cfg.Code or "") end
                end)
                if BtnLabel then
                    local Original = BtnLabel.Text
                    BtnLabel.Text = "✓ Copied!"
                    Tween(CopyBtn, 0.08, {
                        BackgroundColor3 = LerpColor(Theme.Component, Theme.Success, 0.3),
                    })
                    task.delay(1.5, function()
                        BtnLabel.Text = Original
                        Tween(CopyBtn, 0.15, { BackgroundColor3 = Theme.Component })
                    end)
                end
                if Cfg.Callback then task.spawn(Cfg.Callback) end
            end))
            Animations:Hover(CopyBtn, false, WinMaid)
        end

        SetProperty(Block, { Parent = Cfg.Tab, Visible = true })
    end


    -- ════════════════════════════════════════════════════════════
    --  SPINNER  (v3.0 new — orbiting dot ring loader)
    -- ════════════════════════════════════════════════════════════

    function Options:AddSpinner(Cfg)
        --[[
            Cfg = {
                Title:  string        — status label text
                Tab:    Instance
                Active: boolean?      — start spinning? (default true)
                Speed:  number?       — degrees/sec (default 280)
            }
            Returns: {
                SetActive(bool)       — start/stop spin
                SetTitle(str)         — update label
                Get()                 — boolean: is spinning
            }
        ]]
        local RING_R   = IsMobile and 20 or 16  -- ring radius px
        local DOT_SIZE = IsMobile and 8  or 6

        local Wrapper = Instance.new("Frame")
        SetProperty(Wrapper, {
            Name             = "Spinner_" .. (Cfg.Title or ""),
            Size             = UDim2.new(1, 0, 0, IsMobile and 70 or 58),
            BackgroundColor3 = Theme.Component,
            BorderSizePixel  = 0,
            Parent           = Cfg.Tab,
            Visible          = true,
        })
        MakeCorner(Wrapper, 8)

        -- Ring (static thin circle)
        local Ring = Instance.new("Frame", Wrapper)
        SetProperty(Ring, {
            Name             = "Ring",
            Size             = UDim2.new(0, RING_R * 2 + 2, 0, RING_R * 2 + 2),
            Position         = UDim2.new(0, IsMobile and 18 or 14, 0.5, 0),
            AnchorPoint      = Vector2.new(0, 0.5),
            BackgroundTransparency = 1,
            BorderSizePixel  = 0,
        })
        -- Ring outline via UIStroke on inner circle
        local RingInner = Instance.new("Frame", Ring)
        SetProperty(RingInner, {
            Size             = UDim2.fromScale(1, 1),
            BackgroundTransparency = 1,
            BorderSizePixel  = 0,
        })
        MakeCorner(RingInner, RING_R + 1)
        local RingStroke = MakeStroke(RingInner, Theme.Outline, 2, 0)

        -- Orbiting dot
        local Dot = Instance.new("Frame", Ring)
        SetProperty(Dot, {
            Name             = "Dot",
            Size             = UDim2.new(0, DOT_SIZE, 0, DOT_SIZE),
            AnchorPoint      = Vector2.new(0.5, 0.5),
            BackgroundColor3 = Theme.SpinnerColor,
            BorderSizePixel  = 0,
            ZIndex           = Ring.ZIndex + 1,
        })
        MakeCorner(Dot, DOT_SIZE)

        -- Trailing dots (fade tail)
        local TRAIL_COUNT = 5
        local Trails = {}
        for i = 1, TRAIL_COUNT do
            local T = Instance.new("Frame", Ring)
            SetProperty(T, {
                Size             = UDim2.new(0, math.max(DOT_SIZE - i, 1), 0, math.max(DOT_SIZE - i, 1)),
                AnchorPoint      = Vector2.new(0.5, 0.5),
                BackgroundColor3 = Theme.SpinnerColor,
                BackgroundTransparency = i * (0.8 / TRAIL_COUNT),
                BorderSizePixel  = 0,
                ZIndex           = Ring.ZIndex + 1,
            })
            MakeCorner(T, DOT_SIZE)
            Trails[i] = T
        end

        -- Label
        local SpinLabel = Instance.new("TextLabel", Wrapper)
        SetProperty(SpinLabel, {
            Text                   = Cfg.Title or "",
            Font                   = Enum.Font.GothamMedium,
            TextSize               = 13,
            TextColor3             = Theme.Description,
            BackgroundTransparency = 1,
            TextXAlignment         = Enum.TextXAlignment.Left,
            Size                   = UDim2.new(1, -(RING_R * 2 + (IsMobile and 42 or 32)), 1, 0),
            Position               = UDim2.new(0, RING_R * 2 + (IsMobile and 42 or 32), 0, 0),
            BorderSizePixel        = 0,
        })

        -- Spin loop
        local spinning = (Cfg.Active ~= false)
        local angle    = 0
        local speed    = Cfg.Speed or 280
        local halfR    = RING_R + 1

        local spinConn = WinMaid:Add(Services.Run.Heartbeat:Connect(function(dt)
            if not spinning then return end
            angle = (angle + dt * speed) % 360
            local rad = math.rad(angle)
            local cx  = halfR
            local cy  = halfR

            Dot.Position = UDim2.new(0, cx + math.cos(rad) * RING_R - DOT_SIZE / 2,
                                      0, cy + math.sin(rad) * RING_R - DOT_SIZE / 2)

            for i, T in ipairs(Trails) do
                local trad = math.rad(angle - i * 18)
                T.Position = UDim2.new(0,
                    cx + math.cos(trad) * RING_R - (DOT_SIZE - i + 1) / 2,
                    0,
                    cy + math.sin(trad) * RING_R - (DOT_SIZE - i + 1) / 2)
            end
        end))

        local Ctrl = {}

        function Ctrl:SetActive(bool)
            spinning = bool
            Dot.Visible = bool
            for _, T in ipairs(Trails) do T.Visible = bool end
        end

        function Ctrl:SetTitle(text)
            SpinLabel.Text = text
        end

        function Ctrl:Get()
            return spinning
        end

        return Ctrl
    end


    -- ════════════════════════════════════════════════════════════
    --  BADGE  (v3.0 new — compact key/value stat pills)
    -- ════════════════════════════════════════════════════════════

    function Options:AddBadge(Cfg)
        --[[
            Cfg = {
                Title:  string             — row title/label
                Items:  { { Key: string, Value: string, Color: Color3? } }
                Tab:    Instance
            }
            Returns: {
                Update({ Key, Value, Color? })    — update all badges
                SetItem(key: string, value: str)  — update single badge value
            }
        ]]
        local Wrapper = Instance.new("Frame")
        SetProperty(Wrapper, {
            Name             = "Badge_" .. (Cfg.Title or ""),
            Size             = UDim2.new(1, 0, 0, IsMobile and 72 or 60),
            BackgroundColor3 = Theme.Component,
            BorderSizePixel  = 0,
            Parent           = Cfg.Tab,
            Visible          = true,
        })
        MakeCorner(Wrapper, 8)

        local TitleLbl = Instance.new("TextLabel", Wrapper)
        SetProperty(TitleLbl, {
            Text                   = Cfg.Title or "",
            Font                   = Enum.Font.GothamSemibold,
            TextSize               = 12,
            TextColor3             = Theme.Description,
            BackgroundTransparency = 1,
            TextXAlignment         = Enum.TextXAlignment.Left,
            Size                   = UDim2.new(1, -24, 0, 16),
            Position               = UDim2.new(0, 12, 0, 8),
            BorderSizePixel        = 0,
        })

        local Row = Instance.new("Frame", Wrapper)
        SetProperty(Row, {
            Name             = "BadgeRow",
            Size             = UDim2.new(1, -24, 0, IsMobile and 34 or 28),
            Position         = UDim2.new(0, 12, 0, 26),
            BackgroundTransparency = 1,
            BorderSizePixel  = 0,
        })

        local Layout = Instance.new("UIListLayout", Row)
        Layout.FillDirection  = Enum.FillDirection.Horizontal
        Layout.Padding        = UDim.new(0, 6)
        Layout.SortOrder      = Enum.SortOrder.LayoutOrder
        Layout.VerticalAlignment = Enum.VerticalAlignment.Center

        local BadgeInstances = {}

        local function MakeBadge(item, order)
            local Pill = Instance.new("Frame", Row)
            SetProperty(Pill, {
                Name             = "Pill_" .. (item.Key or ""),
                Size             = UDim2.new(0, 0, 1, 0),
                AutomaticSize    = Enum.AutomaticSize.X,
                BackgroundColor3 = Theme.BadgeBg,
                BorderSizePixel  = 0,
                LayoutOrder      = order,
            })
            MakeCorner(Pill, 6)

            local PillPad = Instance.new("UIPadding", Pill)
            PillPad.PaddingLeft   = UDim.new(0, 8)
            PillPad.PaddingRight  = UDim.new(0, 8)
            PillPad.PaddingTop    = UDim.new(0, 3)
            PillPad.PaddingBottom = UDim.new(0, 3)

            local PillLayout = Instance.new("UIListLayout", Pill)
            PillLayout.FillDirection = Enum.FillDirection.Horizontal
            PillLayout.Padding       = UDim.new(0, 4)
            PillLayout.VerticalAlignment = Enum.VerticalAlignment.Center

            local KeyLbl = Instance.new("TextLabel", Pill)
            SetProperty(KeyLbl, {
                Text             = item.Key or "",
                Font             = Enum.Font.GothamMedium,
                TextSize         = IsMobile and 12 or 11,
                TextColor3       = Theme.Muted,
                BackgroundTransparency = 1,
                Size             = UDim2.new(0, 0, 1, 0),
                AutomaticSize    = Enum.AutomaticSize.X,
                BorderSizePixel  = 0,
            })

            local ValLbl = Instance.new("TextLabel", Pill)
            SetProperty(ValLbl, {
                Text             = tostring(item.Value or ""),
                Font             = Enum.Font.GothamBold,
                TextSize         = IsMobile and 12 or 11,
                TextColor3       = item.Color or Theme.BadgeText,
                BackgroundTransparency = 1,
                Size             = UDim2.new(0, 0, 1, 0),
                AutomaticSize    = Enum.AutomaticSize.X,
                BorderSizePixel  = 0,
            })

            return { Pill = Pill, Key = item.Key, ValLbl = ValLbl, KeyLbl = KeyLbl }
        end

        for i, item in ipairs(Cfg.Items or {}) do
            BadgeInstances[#BadgeInstances + 1] = MakeBadge(item, i)
        end

        local Ctrl = {}

        function Ctrl:Update(items)
            -- Remove old, recreate
            for _, b in ipairs(BadgeInstances) do Destroy(b.Pill) end
            BadgeInstances = {}
            for i, item in ipairs(items) do
                BadgeInstances[#BadgeInstances + 1] = MakeBadge(item, i)
            end
        end

        function Ctrl:SetItem(key, value)
            for _, b in ipairs(BadgeInstances) do
                if b.Key == key then
                    b.ValLbl.Text = tostring(value)
                    break
                end
            end
        end

        return Ctrl
    end


    -- ════════════════════════════════════════════════════════════
    --  BUTTON GROUP  (v3.0 new — horizontal radio buttons)
    -- ════════════════════════════════════════════════════════════

    function Options:AddButtonGroup(Cfg)
        --[[
            Cfg = {
                Title:    string
                Options:  { string }   — button labels in order
                Default:  string?      — initially active button label
                Tab:      Instance
                Callback: function(label: string)
            }
            Returns: {
                Set(label)  — activate button by label
                Get()       → currently active label
            }
        ]]
        local Wrapper = Instance.new("Frame")
        SetProperty(Wrapper, {
            Name             = "BtnGroup_" .. (Cfg.Title or ""),
            Size             = UDim2.new(1, 0, 0, IsMobile and 72 or 60),
            BackgroundColor3 = Theme.Component,
            BorderSizePixel  = 0,
            Parent           = Cfg.Tab,
            Visible          = true,
        })
        MakeCorner(Wrapper, 8)

        local TitleLbl = Instance.new("TextLabel", Wrapper)
        SetProperty(TitleLbl, {
            Text                   = Cfg.Title or "",
            Font                   = Enum.Font.GothamSemibold,
            TextSize               = 13,
            TextColor3             = Theme.Title,
            BackgroundTransparency = 1,
            TextXAlignment         = Enum.TextXAlignment.Left,
            Size                   = UDim2.new(1, -24, 0, 18),
            Position               = UDim2.new(0, 12, 0, 8),
            BorderSizePixel        = 0,
        })

        local Row = Instance.new("Frame", Wrapper)
        SetProperty(Row, {
            Name                   = "BtnRow",
            Size                   = UDim2.new(1, -24, 0, IsMobile and 32 or 26),
            Position               = UDim2.new(0, 12, 0, 30),
            BackgroundColor3       = Theme.Interactable,
            BorderSizePixel        = 0,
        })
        MakeCorner(Row, 6)

        local Layout = Instance.new("UIListLayout", Row)
        Layout.FillDirection = Enum.FillDirection.Horizontal
        Layout.SortOrder     = Enum.SortOrder.LayoutOrder

        local Active = Cfg.Default
        local Buttons = {}

        local function UpdateButtons()
            for _, b in ipairs(Buttons) do
                local isActive = (b.Label == Active)
                Tween(b.Btn, 0.15, {
                    BackgroundColor3 = isActive and Theme.Accent or Theme.Interactable,
                })
                b.Lbl.TextColor3 = isActive and Color3.new(1, 1, 1) or Theme.Tab
                b.Lbl.Font = isActive and Enum.Font.GothamBold or Enum.Font.GothamMedium
            end
        end

        for i, label in ipairs(Cfg.Options or {}) do
            local Btn = Instance.new("TextButton", Row)
            SetProperty(Btn, {
                Name             = "GBtn_" .. label,
                Size             = UDim2.new(1 / #Cfg.Options, 0, 1, 0),
                BackgroundColor3 = Theme.Interactable,
                BorderSizePixel  = 0,
                Text             = "",
                AutoButtonColor  = false,
                LayoutOrder      = i,
            })
            MakeCorner(Btn, 6)

            local Lbl = Instance.new("TextLabel", Btn)
            SetProperty(Lbl, {
                Text                   = label,
                Font                   = Enum.Font.GothamMedium,
                TextSize               = IsMobile and 13 or 11,
                TextColor3             = Theme.Tab,
                BackgroundTransparency = 1,
                Size                   = UDim2.fromScale(1, 1),
                BorderSizePixel        = 0,
            })

            Buttons[i] = { Btn = Btn, Lbl = Lbl, Label = label }

            WinMaid:Add(Connect(Btn.MouseButton1Click, function()
                if Active == label then return end
                Active = label
                UpdateButtons()
                if Cfg.Callback then task.spawn(Cfg.Callback, label) end
            end))
        end

        -- Set default
        if Active then UpdateButtons()
        elseif #Buttons > 0 then
            Active = Buttons[1].Label
            UpdateButtons()
        end

        local Ctrl = {}
        function Ctrl:Set(label)
            Active = label
            UpdateButtons()
        end
        function Ctrl:Get() return Active end
        return Ctrl
    end


    -- ════════════════════════════════════════════════════════════
    --  THEME ENGINE  (updated rules for all v3.0 components)
    -- ════════════════════════════════════════════════════════════

    local NameRules = {
        ["Paragraph"]       = function(L) if L:IsA("TextButton") then L.BackgroundColor3 = Theme.Component end end,
        ["Title"]           = function(L) if L:IsA("TextLabel")  then L.TextColor3 = Theme.Title          end end,
        ["Description"]     = function(L) if L:IsA("TextLabel")  then L.TextColor3 = Theme.Description    end end,
        ["Section"]         = function(L) if L:IsA("TextLabel")  then L.TextColor3 = Theme.SectionText    end end,
        ["Options"]         = function(L)
            if L:IsA("TextLabel") and L.Parent.Name == "Main" then L.TextColor3 = Theme.Title end
        end,
        ["Notification"]    = function(L)
            if L:IsA("CanvasGroup") then
                L.BackgroundColor3 = Theme.Primary
                local S = L:FindFirstChildOfClass("UIStroke")
                if S then S.Color = Theme.Outline end
            end
        end,
        ["TextLabel"]       = function(L)
            if L:IsA("TextLabel") and L.Parent:FindFirstChild("List") then L.TextColor3 = Theme.Tab end
        end,
        ["Main"]            = function(L)
            if L:IsA("Frame") then
                if L.Parent == Window then
                    L.BackgroundColor3 = Theme.Secondary
                elseif L.Parent:FindFirstChild("Value") then
                    local V = L.Parent.Value
                    if not V.Value then
                        L.BackgroundColor3 = Theme.ToggleOff
                        local C = L:FindFirstChild("Circle")
                        if C then C.BackgroundColor3 = Theme.Primary end
                    end
                else
                    L.BackgroundColor3 = Theme.Interactable
                end
            elseif L:FindFirstChild("Padding") then
                L.TextColor3 = Theme.Title
            end
        end,
        ["Amount"]          = function(L) if L:IsA("Frame") then L.BackgroundColor3 = Theme.Interactable end end,
        ["Slide"]           = function(L) if L:IsA("Frame") then L.BackgroundColor3 = Theme.SliderTrack  end end,
        ["Highlight"]       = function(L) if L:IsA("Frame") then L.BackgroundColor3 = Theme.SliderFill   end end,
        ["Input"]           = function(L)
            if L:IsA("TextLabel") then
                L.TextColor3 = Theme.Title
            elseif L:FindFirstChild("Labels") then
                L.BackgroundColor3 = Theme.Component
            elseif L:IsA("TextBox") and L.Parent.Name == "Main" then
                L.TextColor3 = Theme.Title
            end
        end,
        ["Outline"]         = function(L) if L:IsA("UIStroke")  then L.Color = Theme.Outline end end,
        ["DropdownExample"] = function(L) if L:IsA("Frame")     then L.BackgroundColor3 = Theme.Secondary end end,
        ["Underline"]       = function(L) if L:IsA("Frame")     then L.BackgroundColor3 = Theme.Divider   end end,
        ["Line"]            = function(L) if L:IsA("Frame")     then L.BackgroundColor3 = Theme.Divider   end end,
        ["Track"]           = function(L) if L:IsA("Frame")     then L.BackgroundColor3 = Theme.ProgressBg end end,
        ["Fill"]            = function(L)
            if L:IsA("Frame") and L.Parent and L.Parent.Name == "Track" then
                L.BackgroundColor3 = Theme.ProgressFill
            end
        end,
        ["Picker"]          = function(L)
            if L:IsA("Frame") then
                L.BackgroundColor3 = Theme.CPBackground
                local S = L:FindFirstChildOfClass("UIStroke")
                if S then S.Color = Theme.CPBorder end
            end
        end,
        ["HexRow"]          = function(L) if L:IsA("Frame")    then L.BackgroundColor3 = Theme.CPHexBg end end,
        ["HexInput"]        = function(L) if L:IsA("TextBox")  then L.TextColor3 = Theme.Title end end,
        ["CheckMark"]       = function(L) if L:IsA("TextLabel") then L.TextColor3 = Theme.Accent end end,
        ["Swatch"]          = function(L)
            if L:IsA("Frame") then
                local S = L:FindFirstChildOfClass("UIStroke")
                if S then S.Color = Theme.Outline end
            end
        end,
        -- v3.0 new rules
        ["Ring"]            = function(L)
            if L:IsA("Frame") then
                local inner = L:FindFirstChildOfClass("Frame")
                if inner then
                    local stroke = inner:FindFirstChildOfClass("UIStroke")
                    if stroke then stroke.Color = Theme.Outline end
                end
            end
        end,
        ["Dot"]             = function(L)
            if L:IsA("Frame") then L.BackgroundColor3 = Theme.SpinnerColor end
        end,
        ["BadgeRow"]        = function(L) if L:IsA("Frame") then L.BackgroundTransparency = 1 end end,
        ["TypeStrip"]       = function(L)
            -- Leave notification strips their typed color
        end,
        ["ValueBubble"]     = function(L)
            if L:IsA("Frame") then L.BackgroundColor3 = Theme.Accent end
        end,
    }

    local ClassRules = {
        ["ImageLabel"]     = function(L)
            if L.Image ~= "rbxassetid://6644618143" then L.ImageColor3 = Theme.Icon end
        end,
        ["TextLabel"]      = function(L)
            if L:FindFirstChild("Padding") then L.TextColor3 = Theme.Title end
        end,
        ["TextButton"]     = function(L)
            if L:FindFirstChild("Labels") then L.BackgroundColor3 = Theme.Component end
        end,
        ["ScrollingFrame"] = function(L) L.ScrollBarImageColor3 = Theme.Accent end,
    }

    function Options:SetTheme(NewTheme)
        if NewTheme then Theme = NewTheme end

        Window.BackgroundColor3 = Theme.Primary
        if Holder  then Holder.BackgroundColor3  = Theme.Secondary end
        if Sidebar then Sidebar.BackgroundColor3 = Theme.Sidebar   end

        local WS = Window:FindFirstChildOfClass("UIStroke")
        if WS then WS.Color = Theme.Shadow end

        for _, D in next, Screen:GetDescendants() do
            local nr = NameRules[D.Name]
            local cr = ClassRules[D.ClassName]
            if     nr then pcall(nr, D)
            elseif cr then pcall(cr, D)
            end
        end
    end


    -- ════════════════════════════════════════════════════════════
    --  SETTINGS CONTROL
    -- ════════════════════════════════════════════════════════════

    function Options:SetSetting(Setting, Value)
        if Setting == "Size" then
            Window.Size = Value
            Setup.Size  = Value

        elseif Setting == "Transparency" then
            Window.GroupTransparency = Value
            Setup.Transparency = Value
            for _, D in next, Screen:GetDescendants() do
                if D:IsA("CanvasGroup") and D.Name == "Notification" then
                    D.GroupTransparency = Value
                end
            end

        elseif Setting == "Blur" then
            local stored = Blurs[Settings.Title]
            if Value then
                BlurEnabled = true
                if not stored then
                    pcall(function()
                        Blurs[Settings.Title] = Blur.new(Window, 5)
                    end)
                elseif stored.root and not stored.root.Parent then
                    stored.root.Parent = workspace.CurrentCamera
                end
            else
                if stored and stored.root and stored.root.Parent then
                    stored.root.Parent = nil
                end
                BlurEnabled = false
            end

        elseif Setting == "Theme" then
            local mode = (type(Value) == "string") and Value or nil
            if mode and Themes[mode] then
                Theme = Themes[mode]
                Setup.ThemeMode = mode
                Options:SetTheme()
                for _, fn in ipairs(ThemeCallbacks) do task.spawn(fn, mode, Theme) end
            elseif type(Value) == "table" then
                Options:SetTheme(Value)
            end

        elseif Setting == "Keybind" then
            Setup.Keybind = Value

        else
            warn("[UILib] Unknown setting: " .. tostring(Setting))
        end
    end


    -- ════════════════════════════════════════════════════════════
    --  WINDOW CONTROL API  (+ v3.0 additions)
    -- ════════════════════════════════════════════════════════════

    --- Register a callback invoked whenever the theme changes.
    ---   fn(modeName: string, themeTable: table)
    function Options:OnThemeChanged(fn)
        ThemeCallbacks[#ThemeCallbacks + 1] = fn
    end

    --- Programmatically show or hide the window (animated).
    function Options:SetVisible(visible)
        if visible and not Opened then
            Opened = true
            Animations:Open(Window, Setup.Transparency)
            if BlurEnabled and Blurs[Settings.Title] then
                pcall(function() Blurs[Settings.Title].root.Parent = workspace.CurrentCamera end)
            end
        elseif not visible and Opened then
            Opened = false
            if BlurEnabled and Blurs[Settings.Title] then
                pcall(function() Blurs[Settings.Title].root.Parent = nil end)
            end
            Animations:Close(Window)
        end
    end

    --- Full teardown: disconnects every connection and destroys the window.
    function Options:Destroy()
        WinMaid:Destroy()
        if Blurs[Settings.Title] then
            pcall(function()
                local b = Blurs[Settings.Title]
                if b and b.root then b.root:Destroy() end
            end)
            Blurs[Settings.Title] = nil
        end
        if Window and Window.Parent then
            pcall(function() Window:Destroy() end)
        end
    end

    --- (v3.0) Brief accent pulse on the titlebar — useful for drawing attention.
    function Options:Flash()
        if not TitleBar then return end
        local orig = TitleBar.BackgroundColor3
        Tween(TitleBar, 0.1, { BackgroundColor3 = LerpColor(orig, Theme.Accent, 0.3) })
        task.delay(0.22, function()
            Tween(TitleBar, 0.22, { BackgroundColor3 = orig })
        end)
    end

    --- (v3.0) Update the subtitle label text live.
    function Options:SetSubtitle(text)
        if SubtitleLabel then SubtitleLabel.Text = text end
    end

    --- (v3.0) Returns the current theme name and data table.
    ---   → { name: string, data: table }
    function Options:GetTheme()
        return { name = Setup.ThemeMode, data = Theme }
    end

    --- (v3.0) Returns the ScrollingFrame for a named tab, or nil.
    function Options:GetTab(name)
        return TabFrameMap[name]
    end


    -- ════════════════════════════════════════════════════════════
    --  FINALISE & OPEN
    -- ════════════════════════════════════════════════════════════

    Options:SetTheme()
    SetProperty(Window, { Size = Settings.Size, Visible = true, Parent = Screen })
    Animations:Open(Window, Settings.Transparency or 0)

    return Options
end


return Library
