--  Maid
-- ─────────────────────────────────────────────────────────────────

local Maid = {}
Maid.__index = Maid

function Maid.new()
    return setmetatable({ _tasks = {} }, Maid)
end

function Maid:Add(task_)
    self._tasks[#self._tasks + 1] = task_
    return task_
end

function Maid:Remove(task_)
    for i = #self._tasks, 1, -1 do
        if self._tasks[i] == task_ then
            table.remove(self._tasks, i)
            return
        end
    end
end

function Maid:Destroy()
    for i = #self._tasks, 1, -1 do
        local t  = self._tasks[i]
        local tt = type(t)
        if tt == "function" then
            pcall(t)
        elseif tt == "table" and t.Destroy then
            pcall(function() t:Destroy() end)
        elseif tt == "userdata" then
            if t.Disconnect then
                pcall(function() t:Disconnect() end)
            elseif t.Destroy then
                pcall(function() t:Destroy() end)
            end
        end
        self._tasks[i] = nil
    end
end


-- ─────────────────────────────────────────────────────────────────
--  Signal
-- ─────────────────────────────────────────────────────────────────

local Signal = {}
Signal.__index = Signal

function Signal.new()
    return setmetatable({ _conns = {} }, Signal)
end

function Signal:Connect(fn)
    local conn = { _fn = fn, _sig = self, _active = true }
    self._conns[#self._conns + 1] = conn
    function conn:Disconnect()
        self._active = false
        local list = self._sig._conns
        for i = #list, 1, -1 do
            if list[i] == self then table.remove(list, i); break end
        end
    end
    return conn
end

function Signal:Fire(...)
    local args = { ... }
    for i = #self._conns, 1, -1 do
        local c = self._conns[i]
        if c._active then task.spawn(c._fn, table.unpack(args)) end
    end
end

function Signal:DisconnectAll()
    for _, c in ipairs(self._conns) do c._active = false end
    self._conns = {}
end


-- ─────────────────────────────────────────────────────────────────
--  Utility Functions
-- ─────────────────────────────────────────────────────────────────

local function Clone(obj)       return obj:Clone()                   end
local function Destroy(obj)     pcall(function() obj:Destroy() end)  end
local function Connect(sig, fn) return sig:Connect(fn)               end

local function Tween(obj, speed, props, style, dir)
    local s = style or Enum.EasingStyle.Quart
    local d = dir   or Enum.EasingDirection.Out
    local t = Services.Tween:Create(obj, TweenInfo.new(speed, s, d), props)
    t:Play()
    return t
end

local function SetProperty(obj, props)
    for k, v in next, props do obj[k] = v end
    return obj
end

local function Multiply(value, amount)
    return UDim2.new(
        value.X.Scale  * amount, value.X.Offset * amount,
        value.Y.Scale  * amount, value.Y.Offset * amount
    )
end

local function LerpColor(a, b, t)
    return a:Lerp(b, t)
end

local function ShiftColor(color, factor)
    local f = (Setup.ThemeMode == "Light") and -math.abs(factor) or math.abs(factor)
    return Color3.fromRGB(
        math.clamp((color.R * 255) + f, 0, 255),
        math.clamp((color.G * 255) + f, 0, 255),
        math.clamp((color.B * 255) + f, 0, 255)
    )
end

local function Color3ToHex(c)
    return string.format("#%02X%02X%02X",
        math.round(c.R * 255),
        math.round(c.G * 255),
        math.round(c.B * 255))
end

local function HexToColor3(hex)
    hex = hex:gsub("^#", "")
    if #hex ~= 6 then return nil end
    local r = tonumber(hex:sub(1, 2), 16)
    local g = tonumber(hex:sub(3, 4), 16)
    local b = tonumber(hex:sub(5, 6), 16)
    if not (r and g and b) then return nil end
    return Color3.fromRGB(r, g, b)
end

local function MakeCorner(parent, radius)
    local c = Instance.new("UICorner", parent)
    c.CornerRadius = UDim.new(0, radius or 8)
    return c
end

local function MakeStroke(parent, color, thickness, transparency)
    local s = Instance.new("UIStroke", parent)
    s.Color        = color        or Color3.new(1,1,1)
    s.Thickness    = thickness    or 1
    s.Transparency = transparency or 0
    return s
end

-- v4: ErrorBoundary — ครอบ Add* factory ด้วย pcall ป้องกัน crash
local function ErrorBoundary(name, fn, ...)
    local ok, result = pcall(fn, ...)
    if not ok then
        warn(string.format("[StellarUI v4] %s ล้มเหลว: %s", name, tostring(result)))
        return {}
    end
    return result
end

-- v4: Normalize Options รองรับ array {str} และ dict {[str]=any}
local function NormalizeOptions(raw)
    local list = {}
    if type(raw) ~= "table" then return list end
    -- ตรวจว่าเป็น array (มี key ตัวเลข 1 ขึ้นไป)
    local isArray = (#raw > 0)
    if isArray then
        for _, v in ipairs(raw) do
            list[#list + 1] = { Label = tostring(v), Value = v }
        end
    else
        for k, v in pairs(raw) do
            list[#list + 1] = { Label = tostring(k), Value = v }
        end
        table.sort(list, function(a, b) return a.Label < b.Label end)
    end
    return list
end


