    function Options:AddColorPicker(Cfg)
        if not Cfg.Tab then warn("[UILib] AddColorPicker: missing Cfg.Tab"); return end

        -- Larger on mobile for finger-precision SV picking
        local SV_H    = IsMobile and 160 or 110
        local HUE_H   = IsMobile and 22  or 14
