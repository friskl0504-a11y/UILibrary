    function Options:AddButton(Cfg)
        if not Cfg.Tab then warn("[UILib] AddButton: missing Cfg.Tab"); return end
        local Button = _GlobalComponents and Clone(_GlobalComponents["Button"])
        if not Button then return end

        local Title, Desc = Options:GetLabels(Button)

        -- v4: capture the press position so the ripple originates there
        local lastPressPos = nil
        WinMaid:Add(Connect(Button.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1
               or Input.UserInputType == Enum.UserInputType.Touch then
                lastPressPos = Vector2.new(Input.Position.X, Input.Position.Y)
            end
        end))

        WinMaid:Add(Connect(Button.MouseButton1Click, function()
            -- v4: quick accent flash plus a ripple from the press point
            Tween(Button, 0.08, {
                BackgroundColor3 = LerpColor(Theme.Component, Theme.Accent, 0.22),
            }, Ease.Snap)
            task.delay(0.16, function()
                Tween(Button, 0.20, { BackgroundColor3 = Theme.Component }, Ease.Smooth)
            end)
            Animations:Ripple(Button, lastPressPos, Theme.AccentLight or Theme.Accent)
            Buzz(0.35)
            if Cfg.Callback then task.spawn(Cfg.Callback) end
        end))

        Animations:Hover(Button, false, WinMaid, Theme.Accent)
        Animations:Press(Button, WinMaid)
        if Title then Title.Text = Cfg.Title       or "" end
        if Desc  then Desc.Text  = Cfg.Description or "" end
        SetProperty(Button, { Name = Cfg.Title or "Button", Parent = Cfg.Tab, Visible = true })

        if IsMobile then
            Button.Size = UDim2.new(Button.Size.X.Scale, Button.Size.X.Offset,
                                    Button.Size.Y.Scale, math.max(Button.Size.Y.Offset, 52))
        end

        local Ctrl = {}
        function Ctrl:Set(_)             end
        function Ctrl:Get()              return nil end
        function Ctrl:OnChanged()        end
        function Ctrl:SetLabel(t)        if Title then Title.Text = t end end
        function Ctrl:SetTitle(t)        if Title then Title.Text = t end end
        function Ctrl:SetDescription(t)  if Desc  then Desc.Text  = t end end
        function Ctrl:SetVisible(v)      Button.Visible = v end
        function Ctrl:Destroy()          Destroy(Button) end
        Components[#Components + 1] = Ctrl
        return Ctrl
    end


    -- ═══════════════════════════════════════════════════════════════════
    --  INPUT  (TextBox)
    -- ═══════════════════════════════════════════════════════════════════

    function Options:AddInput(Cfg)
        if not Cfg.Tab then warn("[UILib] AddInput: missing Cfg.Tab"); return end
        local Input = _GlobalComponents and Clone(_GlobalComponents["Input"])
        if not Input then return end

        local Title, Desc = Options:GetLabels(Input)
        local Main    = Input:FindFirstChild("Main")
        local TextBox = Main and Main:FindFirstChild("Input")

        local Listeners = {}

        if TextBox then
            if Cfg.Placeholder then
                TextBox.PlaceholderText = Cfg.Placeholder
            end

            WinMaid:Add(Connect(Input.MouseButton1Click, function()
                TextBox:CaptureFocus()
            end))

            if IsMobile then
                WinMaid:Add(Connect(Input.InputBegan, function(Inp)
                    if Inp.UserInputType == Enum.UserInputType.Touch then
                        TextBox:CaptureFocus()
                    end
                end))
            end

            WinMaid:Add(Connect(TextBox.Focused, function()
                if Main then
                    Tween(Main, 0.14, {
                        BackgroundColor3 = LerpColor(Theme.Interactable, Theme.Accent, 0.12),
                    })
                end
                local Outline = Input:FindFirstChildOfClass("UIStroke")
                    or (Main and Main:FindFirstChildOfClass("UIStroke"))
                if Outline then Tween(Outline, 0.14, { Color = Theme.Accent }) end
            end))

            WinMaid:Add(Connect(TextBox.FocusLost, function()
                if Main then
                    Tween(Main, 0.14, { BackgroundColor3 = Theme.Interactable })
                end
                local Outline = Input:FindFirstChildOfClass("UIStroke")
                    or (Main and Main:FindFirstChildOfClass("UIStroke"))
                if Outline then Tween(Outline, 0.14, { Color = Theme.Outline }) end
                if Cfg.Callback then task.spawn(Cfg.Callback, TextBox.Text) end
                for _, fn in ipairs(Listeners) do task.spawn(fn, TextBox.Text) end
            end))
        end

        Animations:Hover(Input, false, WinMaid, Theme.Accent)
        if Title then Title.Text = Cfg.Title       or "" end
        if Desc  then Desc.Text  = Cfg.Description or "" end
        SetProperty(Input, { Name = Cfg.Title or "Input", Parent = Cfg.Tab, Visible = true })

        if IsMobile then
            Input.Size = UDim2.new(Input.Size.X.Scale, Input.Size.X.Offset,
                                   Input.Size.Y.Scale, math.max(Input.Size.Y.Offset, 60))
        end

        local Ctrl = {}
        function Ctrl:Set(t)             if TextBox then TextBox.Text = t end end
        function Ctrl:Get()              return TextBox and TextBox.Text or "" end
        function Ctrl:OnChanged(fn)      Listeners[#Listeners + 1] = fn end
        function Ctrl:SetTitle(t)        if Title then Title.Text = t end end
        function Ctrl:SetDescription(t)  if Desc  then Desc.Text  = t end end
        function Ctrl:SetVisible(v)      Input.Visible = v end
        function Ctrl:Destroy()          Destroy(Input) end

        RegisterFlag(Cfg.Flag, function() return Ctrl:Get() end, function(v) Ctrl:Set(v) end)

        BindState(Ctrl, Cfg.State)
        Components[#Components + 1] = Ctrl
        return Ctrl
    end


    -- ═══════════════════════════════════════════════════════════════════
    --  SLIDER  (FIXED: tap-anywhere on track; event-driven; clean teardown)
    -- ═══════════════════════════════════════════════════════════════════

    function Options:AddSlider(Cfg)
        if not Cfg.Tab then warn("[UILib] AddSlider: missing Cfg.Tab"); return end
        local Slider = _GlobalComponents and Clone(_GlobalComponents["Slider"])
        if not Slider then return end

        local Title, Desc = Options:GetLabels(Slider)
        local SliderFrame = Slider:FindFirstChild("Slider")
        local Amount = SliderFrame and SliderFrame:FindFirstChild("Main")
                    and SliderFrame.Main:FindFirstChild("Input")
        local Slide = SliderFrame and SliderFrame:FindFirstChild("Slide")
        local Fire  = Slide and Slide:FindFirstChild("Fire")
        local Fill  = Slide and Slide:FindFirstChild("Highlight")

        local MinVal = Cfg.MinValue or 0
        local MaxVal = Cfg.MaxValue or 100
        local Value  = math.clamp(Cfg.Default or MinVal, MinVal, MaxVal)

        local Listeners   = {}
        local Active      = false
        local ActiveTouch = nil

        local function Round(n)
            if Cfg.AllowDecimals then
                local p = 10 ^ (Cfg.DecimalAmount or 2)
                return math.floor(n * p + 0.5) / p
            end
            return math.round(n)
        end

        local function UpdateFromScale(scale)
            scale  = math.clamp(scale, 0, 1)
            Value  = Round(MinVal + scale * (MaxVal - MinVal))
            if Amount then Amount.Text = tostring(Value) end
            if Fill   then Fill.Size   = UDim2.fromScale(scale, 1) end
            if Cfg.Callback then task.spawn(Cfg.Callback, Value) end
            for _, fn in ipairs(Listeners) do task.spawn(fn, Value) end
        end

        local function UpdateFromPositionX(posX)
            if not Slide then return end
            local slideX = Slide.AbsolutePosition.X
            local slideW = math.max(Slide.AbsoluteSize.X, 1)
            UpdateFromScale((posX - slideX) / slideW)
        end

        local function SetValue(n)
            n = math.clamp(n, MinVal, MaxVal)
            UpdateFromScale((n - MinVal) / (MaxVal - MinVal))
        end

        local function StopSliding()
            if Active then
                Buzz(0.2)  -- commit haptic
                -- v4: shrink the thumb back to rest size
                if Fire then
                    PresetTween(Fire, "Spring", {
                        Size = UDim2.new(0, 12, 0, 12),
                    })
                end
            end
            Active = false
            ActiveTouch = nil
        end

        -- Shared InputHub: one global listener instead of per-component
        WinMaid:Add(InputHub:OnChanged(function(Input)
            if not Active then return end
            local t = Input.UserInputType
            if t == Enum.UserInputType.MouseMovement then
                UpdateFromPositionX(Input.Position.X)
            elseif t == Enum.UserInputType.Touch and Input == ActiveTouch then
                UpdateFromPositionX(Input.Position.X)
            end
        end))

        WinMaid:Add(InputHub:OnEnded(function(Input)
            local t = Input.UserInputType
            if Active and (t == Enum.UserInputType.MouseButton1
                           or (t == Enum.UserInputType.Touch and Input == ActiveTouch)) then
                StopSliding()
            end
        end))

        -- Begin slide: TAP ANYWHERE on the track (slide), not just the Fire dot.
        -- This is the big mobile UX win — old behaviour required hitting a tiny circle.
        -- v4: the thumb "lifts" (grows ~20 %) on grab for tactile feedback.
        local function BeginSlide(Input)
            local t = Input.UserInputType
            if t == Enum.UserInputType.MouseButton1 then
                Active = true
                UpdateFromPositionX(Input.Position.X)
            elseif t == Enum.UserInputType.Touch then
                Active = true
                ActiveTouch = Input
                UpdateFromPositionX(Input.Position.X)
            end
            if Active and Fire then
                PresetTween(Fire, "Spring", {
                    Size = UDim2.new(0, 15, 0, 15),
                })
            end
        end

        if Slide then
            WinMaid:Add(Connect(Slide.InputBegan, BeginSlide))
        end
        if Fire then
            -- Fire is now just the visual thumb — still works as a drag handle.
            WinMaid:Add(Connect(Fire.InputBegan, BeginSlide))
        end

        if Amount then
            WinMaid:Add(Connect(Amount.FocusLost, function()
                SetValue(tonumber(Amount.Text) or MinVal)
            end))
        end

        -- Expand the slide's hit-area on mobile (visual unchanged, just larger touch zone)
        if IsMobile and Slide then
            local HitArea = Instance.new("TextButton")
            SetProperty(HitArea, {
                Name                   = "HitArea",
                Size                   = UDim2.new(1, 0, 0, 36),
                Position               = UDim2.new(0, 0, 0.5, 0),
                AnchorPoint            = Vector2.new(0, 0.5),
                BackgroundTransparency = 1,
                Text                   = "",
                AutoButtonColor        = false,
                BorderSizePixel        = 0,
                ZIndex                 = (Slide.ZIndex or 1) - 1,
                Parent                 = Slide,
            })
            WinMaid:Add(Connect(HitArea.InputBegan, BeginSlide))
        end

        SetValue(Value)
        Animations:Hover(Slider, false, WinMaid, Theme.Accent)
        if Title then Title.Text = Cfg.Title       or "" end
        if Desc  then Desc.Text  = Cfg.Description or "" end
        SetProperty(Slider, { Name = Cfg.Title or "Slider", Parent = Cfg.Tab, Visible = true })

        if IsMobile then
            Slider.Size = UDim2.new(Slider.Size.X.Scale, Slider.Size.X.Offset,
                                    Slider.Size.Y.Scale, math.max(Slider.Size.Y.Offset, 68))
        end

        local Ctrl = {}
        function Ctrl:Set(n)             SetValue(n) end
        function Ctrl:Get()              return Value end
        function Ctrl:OnChanged(fn)      Listeners[#Listeners + 1] = fn end
        function Ctrl:SetTitle(t)        if Title then Title.Text = t end end
        function Ctrl:SetDescription(t)  if Desc  then Desc.Text  = t end end
        function Ctrl:SetVisible(v)      Slider.Visible = v end
        function Ctrl:Destroy()          Destroy(Slider) end
        function Ctrl:SetRange(min_, max_)
            MinVal = min_
            MaxVal = max_
            SetValue(math.clamp(Value, MinVal, MaxVal))
        end

        RegisterFlag(Cfg.Flag, function() return Ctrl:Get() end, function(v) Ctrl:Set(v) end)

        BindState(Ctrl, Cfg.State)
        Components[#Components + 1] = Ctrl
        return Ctrl
    end


    -- ═══════════════════════════════════════════════════════════════════
    --  KEYBIND
    -- ═══════════════════════════════════════════════════════════════════

    function Options:AddKeybind(Cfg)
        if not Cfg.Tab then warn("[UILib] AddKeybind: missing Cfg.Tab"); return end
        local KBC = _GlobalComponents and Clone(_GlobalComponents["Keybind"])
        if not KBC then return end

        local Title, Desc = Options:GetLabels(KBC)
        local Bind = KBC:FindFirstChild("Main") and KBC.Main:FindFirstChild("Options")

        local CurrentKey = Cfg.Default
        local Listening  = false
        local Listeners  = {}

        local MouseTypes = {
            Enum.UserInputType.MouseButton1,
            Enum.UserInputType.MouseButton2,
            Enum.UserInputType.MouseButton3,
        }

        local function FormatKey(Key)
            if typeof(Key) == "EnumItem" then
                return tostring(Key):gsub("Enum.KeyCode.", "")
            end
            local t = Key.UserInputType
            if table.find(MouseTypes, t) then
                return tostring(t):gsub("Enum.UserInputType.MouseButton", "MB")
            elseif t == Enum.UserInputType.Keyboard then
                return tostring(Key.KeyCode):gsub("Enum.KeyCode.", "")
            end
            return "?"
        end

        local function SetBind(Key)
            CurrentKey = Key
            if Bind then Bind.Text = FormatKey(Key) end
            for _, fn in ipairs(Listeners) do task.spawn(fn, Key) end
        end

        if CurrentKey and Bind then
            Bind.Text = FormatKey(CurrentKey)
        end

        -- DetectConn is tracked via _detectCleanup (a closure) to avoid the
        -- v2.0 "double disconnect" issue (was both in WinMaid and disconnected
        -- manually).
        local _detectCleanup = nil

        WinMaid:Add(Connect(KBC.MouseButton1Click, function()
            if Listening then return end
            Listening = true
            if Bind then Bind.Text = "..." end

            local conn
            conn = Connect(Services.Input.InputBegan, function(Key, GameFocused)
                if not Listening or GameFocused then return end
                Listening = false
                SetBind(Key)
                if Cfg.Callback then task.spawn(Cfg.Callback, Key) end
                if conn then conn:Disconnect(); conn = nil end
                _detectCleanup = nil
            end)
            _detectCleanup = function()
                if conn then conn:Disconnect(); conn = nil end
            end
        end))

        -- Clean up any pending listener on window destroy
        WinMaid:Add(function()
            if _detectCleanup then _detectCleanup() end
        end)

        Animations:Hover(KBC, false, WinMaid, Theme.Accent)
        if Title then Title.Text = Cfg.Title       or "" end
        if Desc  then Desc.Text  = Cfg.Description or "" end
        SetProperty(KBC, { Name = Cfg.Title or "Keybind", Parent = Cfg.Tab, Visible = true })

        if IsMobile then
            KBC.Size = UDim2.new(KBC.Size.X.Scale, KBC.Size.X.Offset,
                                 KBC.Size.Y.Scale, math.max(KBC.Size.Y.Offset, 56))
        end

        local Ctrl = {}
        function Ctrl:Set(key)
            if typeof(key) == "EnumItem" then
                SetBind(key)
            else
                SetBind(key)
            end
        end
        function Ctrl:Get()              return CurrentKey end
        function Ctrl:OnChanged(fn)      Listeners[#Listeners + 1] = fn end
        function Ctrl:SetTitle(t)        if Title then Title.Text = t end end
        function Ctrl:SetDescription(t)  if Desc  then Desc.Text  = t end end
        function Ctrl:SetVisible(v)      KBC.Visible = v end
        function Ctrl:Destroy()          Destroy(KBC) end

        RegisterFlag(Cfg.Flag,
            function()
                local k = Ctrl:Get()
                if typeof(k) == "EnumItem" then return k.Name end
                return k and (k.KeyCode and k.KeyCode.Name) or nil
            end,
            function(v)
                if type(v) == "string" and Enum.KeyCode[v] then
                    Ctrl:Set(Enum.KeyCode[v])
                end
            end
        )
        BindState(Ctrl, Cfg.State)
        Components[#Components + 1] = Ctrl
        return Ctrl
    end


    -- ═══════════════════════════════════════════════════════════════════
    --  DROPDOWN  (single-select; per-panel Maid prevents leaks)
    -- ═══════════════════════════════════════════════════════════════════

    function Options:AddDropdown(Cfg)
        if not Cfg.Tab then warn("[UILib] AddDropdown: missing Cfg.Tab"); return end
        local Dropdown = _GlobalComponents and Clone(_GlobalComponents["Dropdown"])
        if not Dropdown then return end

        local Title, Desc  = Options:GetLabels(Dropdown)
        local OptionsLabel = Dropdown:FindFirstChild("Main")
            and Dropdown.Main:FindFirstChild("Options")

        local CurrentValue = Cfg.Default
        local CurrentIndex = nil
        local Listeners    = {}

        local function FindIndex(value)
            for idx, opt in pairs(Cfg.Options or {}) do
                if opt == value then return idx end
            end
            return nil
        end

        if OptionsLabel and CurrentValue ~= nil then
            local idx = FindIndex(CurrentValue)
            if idx then
                CurrentIndex = idx
                OptionsLabel.Text = tostring(idx)
            end
        end

        WinMaid:Add(Connect(Dropdown.MouseButton1Click, function()
            local Example = Clone(Examples["DropdownExample"])
            if not Example then return end

            local PanelMaid = Maid.new()

            local CloseButtons = Example:FindFirstChild("Top")
                and Example.Top:FindFirstChild("Buttons")
            local ScrollFrame  = Example:FindFirstChild("ScrollingFrame") or Example

            if BG then Tween(BG, 0.18, { BackgroundTransparency = 0.5 }) end
            Example.Parent = Window
            Animations:Open(Example, 0, Example.Size)

            local function CloseDropdown()
                if BG then Tween(BG, 0.18, { BackgroundTransparency = 1 }) end
                Animations:Close(Example)
                task.delay(0.3, function()
                    PanelMaid:Destroy()
                    Destroy(Example)
                end)
            end

            if CloseButtons then
                for _, Btn in next, CloseButtons:GetChildren() do
                    if Btn:IsA("TextButton") then
                        Animations:Hover(Btn, false, PanelMaid, Theme.Accent)
                        Animations:Press(Btn, PanelMaid)
                        PanelMaid:Add(Connect(Btn.MouseButton1Click, CloseDropdown))
                    end
                end
            end

            for Index, Option in next, Cfg.Options do
                local Btn = Clone(Examples["DropdownButtonExample"])
                if Btn then
                    local BTitle, _ = Options:GetLabels(Btn)
                    local Selected  = Btn:FindFirstChild("Value")

                    if BTitle then BTitle.Text = tostring(Index) end

                    if CurrentValue == Option then
                        Btn.BackgroundColor3 = Theme.Interactable
                        if Selected then Selected.Value = true end
                    end

                    SetProperty(Btn, { Parent = ScrollFrame, Visible = true })
                    Animations:Hover(Btn, false, PanelMaid, Theme.Accent)
                    Animations:Press(Btn, PanelMaid)

                    PanelMaid:Add(Connect(Btn.MouseButton1Click, function()
                        CurrentValue = Option
                        CurrentIndex = Index
                        if OptionsLabel then OptionsLabel.Text = tostring(Index) end
                        if Cfg.Callback then task.spawn(Cfg.Callback, Option, Index) end
                        for _, fn in ipairs(Listeners) do task.spawn(fn, Option, Index) end

                        for _, Other in next, ScrollFrame:GetChildren() do
                            if Other:IsA("TextButton") and Other ~= Btn then
                                Tween(Other, 0.18, { BackgroundColor3 = Theme.Component })
                                local OV = Other:FindFirstChild("Value")
                                if OV then OV.Value = false end
                            end
                        end
                        Tween(Btn, 0.18, { BackgroundColor3 = Theme.Interactable })
                        if Selected then Selected.Value = true end
                        Buzz(0.25)
                        CloseDropdown()
                    end))
                end
            end
        end))

        Animations:Hover(Dropdown, false, WinMaid, Theme.Accent)
        if Title then Title.Text = Cfg.Title       or "" end
        if Desc  then Desc.Text  = Cfg.Description or "" end
        SetProperty(Dropdown, { Name = Cfg.Title or "Dropdown", Parent = Cfg.Tab, Visible = true })

        if IsMobile then
            Dropdown.Size = UDim2.new(Dropdown.Size.X.Scale, Dropdown.Size.X.Offset,
                                      Dropdown.Size.Y.Scale, math.max(Dropdown.Size.Y.Offset, 56))
        end

        local Ctrl = {}
        function Ctrl:Get()             return CurrentValue end
        function Ctrl:Set(value)
            local idx = FindIndex(value)
            if idx then
                CurrentValue = value
                CurrentIndex = idx
                if OptionsLabel then OptionsLabel.Text = tostring(idx) end
                for _, fn in ipairs(Listeners) do task.spawn(fn, value, idx) end
            end
        end
        function Ctrl:OnChanged(fn)     Listeners[#Listeners + 1] = fn end
        function Ctrl:SetTitle(t)       if Title then Title.Text = t end end
        function Ctrl:SetDescription(t) if Desc  then Desc.Text  = t end end
        function Ctrl:SetVisible(v)     Dropdown.Visible = v end
        function Ctrl:Destroy()         Destroy(Dropdown) end

        RegisterFlag(Cfg.Flag,
            function() return CurrentIndex end,   -- save by KEY not VALUE for portability
            function(idx)
                if Cfg.Options and Cfg.Options[idx] ~= nil then
                    Ctrl:Set(Cfg.Options[idx])
                end
            end
        )
        BindState(Ctrl, Cfg.State)
        Components[#Components + 1] = Ctrl
        return Ctrl
    end


    -- ═══════════════════════════════════════════════════════════════════
    --  MULTI-DROPDOWN
    -- ═══════════════════════════════════════════════════════════════════

    function Options:AddMultiDropdown(Cfg)
        if not Cfg.Tab then warn("[UILib] AddMultiDropdown: missing Cfg.Tab"); return end
        local Dropdown = _GlobalComponents and Clone(_GlobalComponents["Dropdown"])
        if not Dropdown then return end

        local Title, Desc  = Options:GetLabels(Dropdown)
        local OptionsLabel = Dropdown:FindFirstChild("Main")
            and Dropdown.Main:FindFirstChild("Options")

        local Selected  = {}
        local Listeners = {}

        if Cfg.Default then
            for _, v in ipairs(Cfg.Default) do Selected[v] = true end
        end

        local function UpdateLabel()
            if not OptionsLabel then return end
            local count = 0
            for _ in pairs(Selected) do count += 1 end
            OptionsLabel.Text = (count == 0) and "None" or (count .. " selected")
        end
        UpdateLabel()

        local function GetArray()
            local arr = {}
            for v in pairs(Selected) do arr[#arr + 1] = v end
            return arr
        end

        WinMaid:Add(Connect(Dropdown.MouseButton1Click, function()
            local Example = Clone(Examples["DropdownExample"])
            if not Example then return end

            local PanelMaid = Maid.new()
            local CloseButtons = Example:FindFirstChild("Top")
                and Example.Top:FindFirstChild("Buttons")
            local ScrollFrame  = Example:FindFirstChild("ScrollingFrame") or Example

            if BG then Tween(BG, 0.18, { BackgroundTransparency = 0.5 }) end
            Example.Parent = Window
            Animations:Open(Example, 0, Example.Size)

            local function CloseDropdown()
                if BG then Tween(BG, 0.18, { BackgroundTransparency = 1 }) end
                Animations:Close(Example)
                task.delay(0.3, function()
                    PanelMaid:Destroy()
                    Destroy(Example)
                end)
            end

            if CloseButtons then
                for _, Btn in next, CloseButtons:GetChildren() do
                    if Btn:IsA("TextButton") then
                        Animations:Hover(Btn, false, PanelMaid, Theme.Accent)
                        Animations:Press(Btn, PanelMaid)
                        PanelMaid:Add(Connect(Btn.MouseButton1Click, CloseDropdown))
                    end
                end
            end

            for Index, Option in next, Cfg.Options do
                local Btn = Clone(Examples["DropdownButtonExample"])
                if Btn then
                    local BTitle, _ = Options:GetLabels(Btn)
                    if BTitle then BTitle.Text = tostring(Index) end

                    local Chk = Instance.new("TextLabel", Btn)
                    SetProperty(Chk, {
                        Name                   = "CheckMark",
                        Text                   = Selected[Option] and "✓" or "",
                        Font                   = Enum.Font.GothamBold,
                        TextSize               = 13,
                        TextColor3             = Theme.Accent,
                        BackgroundTransparency = 1,
                        Size                   = UDim2.new(0, 20, 1, 0),
                        Position               = UDim2.new(1, -24, 0, 0),
                        AnchorPoint            = Vector2.new(1, 0),
                        ZIndex                 = Btn.ZIndex + 1,
                    })

                    if Selected[Option] then
                        Btn.BackgroundColor3 = LerpColor(Theme.Component, Theme.Accent, 0.12)
                    end

                    SetProperty(Btn, { Parent = ScrollFrame, Visible = true })
                    Animations:Hover(Btn, false, PanelMaid, Theme.Accent)
                    Animations:Press(Btn, PanelMaid)

                    PanelMaid:Add(Connect(Btn.MouseButton1Click, function()
                        Selected[Option] = not Selected[Option] or nil
                        Chk.Text = Selected[Option] and "✓" or ""
                        Tween(Btn, 0.15, {
                            BackgroundColor3 = Selected[Option]
                                and LerpColor(Theme.Component, Theme.Accent, 0.12)
                                or  Theme.Component,
                        })
                        UpdateLabel()
                        Buzz(0.2)

                        local arr = GetArray()
                        if Cfg.Callback then task.spawn(Cfg.Callback, arr) end
                        for _, fn in ipairs(Listeners) do task.spawn(fn, arr) end
                    end))
                end
            end
        end))

        Animations:Hover(Dropdown, false, WinMaid, Theme.Accent)
        if Title then Title.Text = Cfg.Title       or "" end
        if Desc  then Desc.Text  = Cfg.Description or "" end
        SetProperty(Dropdown, { Name = Cfg.Title or "MultiDropdown", Parent = Cfg.Tab, Visible = true })

        if IsMobile then
            Dropdown.Size = UDim2.new(Dropdown.Size.X.Scale, Dropdown.Size.X.Offset,
                                      Dropdown.Size.Y.Scale, math.max(Dropdown.Size.Y.Offset, 56))
        end

        local Ctrl = {}
        function Ctrl:Get()             return GetArray() end
        function Ctrl:Set(values)
            Selected = {}
            for _, v in ipairs(values or {}) do Selected[v] = true end
            UpdateLabel()
            local arr = GetArray()
            for _, fn in ipairs(Listeners) do task.spawn(fn, arr) end
        end
        function Ctrl:OnChanged(fn)     Listeners[#Listeners + 1] = fn end
        function Ctrl:SetTitle(t)       if Title then Title.Text = t end end
        function Ctrl:SetDescription(t) if Desc  then Desc.Text  = t end end
        function Ctrl:SetVisible(v)     Dropdown.Visible = v end
        function Ctrl:Destroy()         Destroy(Dropdown) end

        RegisterFlag(Cfg.Flag, function() return Ctrl:Get() end, function(v) Ctrl:Set(v) end)

        BindState(Ctrl, Cfg.State)
        Components[#Components + 1] = Ctrl
        return Ctrl
    end


