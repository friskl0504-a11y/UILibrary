-- ═══════════════════════════════════════════════════
--  SIGNAL  (clean event bus — replaces raw listener tables)
-- ═══════════════════════════════════════════════════
--[[
    Usage:
        local s = Signal.new()
        local conn = s:Connect(function(v) print(v) end)
        s:Once(function(v) print("once:", v) end)
        s:Fire(42)
        conn:Disconnect()
        s:Destroy()
]]

local Signal = {}
Signal.__index = Signal

function Signal.new()
    return setmetatable({ _conns = {}, _dead = false }, Signal)
end

function Signal:Connect(fn)
    assert(type(fn) == "function", "Signal:Connect expects a function")
    local conn = { _fn = fn, _once = false, _signal = self }
    self._conns[conn] = true
    function conn:Disconnect() self._signal._conns[self] = nil end
    return conn
end

function Signal:Once(fn)
    local conn
    conn = self:Connect(function(...)
        conn:Disconnect()
        fn(...)
    end)
    conn._once = true
    return conn
end

function Signal:Fire(...)
    if self._dead then return end
    for conn in next, self._conns do
        task.spawn(conn._fn, ...)
    end
end

function Signal:Destroy()
    self._dead  = true
    self._conns = {}
end


-- ═══════════════════════════════════════════════════
--  MAID  (connection / instance lifecycle manager)
-- ═══════════════════════════════════════════════════

local Maid = {}
Maid.__index = Maid

function Maid.new()
    return setmetatable({ _tasks = {}, _dead = false }, Maid)
end

function Maid:Add(task_)
    if self._dead then
        -- Maid already destroyed; clean up immediately
        local tt = type(task_)
        if tt == "function" then pcall(task_)
        elseif tt == "table"    and task_.Destroy    then pcall(function() task_:Destroy() end)
        elseif tt == "userdata" and task_.Disconnect then pcall(function() task_:Disconnect() end)
        elseif tt == "userdata" and task_.Destroy    then pcall(function() task_:Destroy() end)
        end
        return task_
    end
    self._tasks[#self._tasks + 1] = task_
    return task_
end

function Maid:Child()
    -- Returns a new Maid that is automatically destroyed when this Maid is destroyed
    local child = Maid.new()
    self:Add(child)
    return child
end

function Maid:Destroy()
    if self._dead then return end
    self._dead = true
    for i = #self._tasks, 1, -1 do
        local t  = self._tasks[i]
        local tt = type(t)
        if     tt == "function" then pcall(t)
        elseif tt == "table"    and t.Destroy    then pcall(function() t:Destroy()    end)
        elseif tt == "userdata" and t.Disconnect then pcall(function() t:Disconnect() end)
        elseif tt == "userdata" and t.Destroy    then pcall(function() t:Destroy()    end)
        end
        self._tasks[i] = nil
    end
end


-- ═══════════════════════════════════════════════════
--  COMPONENT REGISTRY  (O(1) theme updates)
-- ═══════════════════════════════════════════════════
--[[
    Components self-register a rule function. On theme change, the registry
    iterates its (short) list of live rules instead of scanning all descendants.

    Usage:
        Registry:Register(function(T)   -- T = new theme table
            myFrame.BackgroundColor3 = T.Component
            myLabel.TextColor3       = T.Title
        end, maid)
    The rule is automatically removed when the maid is destroyed.
]]

local Registry = { _rules = {} }

function Registry:Register(fn, maid_)
    local id = {}
    self._rules[id] = fn
    if maid_ then
        maid_:Add(function() self._rules[id] = nil end)
    end
    -- Immediate apply
    pcall(fn, Theme)
end

function Registry:Apply(newTheme)
    Theme = newTheme
    for _, fn in next, self._rules do pcall(fn, newTheme) end
end


