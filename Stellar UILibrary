    -- ═══════════════════════════════════════════════════════════════════
    --  SECTION  (with optional collapse — NEW in v3.0)
    -- ═══════════════════════════════════════════════════════════════════

    function Options:AddSection(Cfg)
        if not _GlobalComponents then return end
        if not Cfg.Tab then warn("[UILib] AddSection: missing Cfg.Tab"); return end

        local Section = Clone(_GlobalComponents["Section"])
        if not Section then return end
        SetProperty(Section, {
            Text    = Cfg.Name,
            Parent  = Cfg.Tab,
            Visible = true,
        })

        -- Collapsible: returns a control that can hide/show subsequent siblings
        -- whose Name starts with `__SectionChild__<Name>__`. To keep this
        -- backward-compatible, only enabled when Cfg.Collapsible = true.
        local Ctrl = {}
        Ctrl._collapsed = false
        Ctrl._tag = "__SectionChild__" .. tostring(Cfg.Name) .. "__"

        function Ctrl:Tag(component)
            -- Mark a component as belonging to this section.
            if component then component.Name = Ctrl._tag .. component.Name end
        end

        function Ctrl:SetCollapsed(state)
            if Ctrl._collapsed == state then return end
            Ctrl._collapsed = state
            for _, child in next, Cfg.Tab:GetChildren() do
                if child ~= Section and child.Name:find(Ctrl._tag, 1, true) == 1 then
                    child.Visible = not state
                end
            end
        end

        function Ctrl:Destroy() Destroy(Section) end

        if Cfg.Collapsible then
            Section.AutoButtonColor = false
            WinMaid:Add(Connect(Section.MouseButton1Click, function()
                Ctrl:SetCollapsed(not Ctrl._collapsed)
            end))
        end

        return Ctrl
    end


