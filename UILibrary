--// Mobile floating toggle
local function CreateMobileToggle(ScreenGui, OnToggle)
    if not IsMobile or not ScreenGui then return nil end

    local Existing = ScreenGui:FindFirstChild("MobileToggle")
    if Existing then Existing:Destroy() end

    local Btn = Instance.new("TextButton")
    Btn.Name = "MobileToggle"
    Btn.Parent = ScreenGui
    Btn.Size = UDim2.fromOffset(54, 54)
    Btn.AnchorPoint = Vector2.new(1, 1)
    Btn.Position = UDim2.new(1, -14, 1, -24 - SafeAreaInset)
    Btn.BackgroundColor3 = Theme.Accent
    Btn.Text = "UI"
    Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    Btn.TextSize = 16
    Btn.Font = Enum.Font.GothamBold
    Btn.AutoButtonColor = false
    Btn.ZIndex = 999999
    Btn.Visible = true

    local Corner = Instance.new("UICorner")
    Corner.CornerRadius = UDim.new(1, 0)
    Corner.Parent = Btn

    local Stroke = Instance.new("UIStroke")
    Stroke.Color = Theme.Outline
    Stroke.Thickness = 1.2
    Stroke.Transparency = 0.25
    Stroke.Parent = Btn

    local dragging, dragStart, startPos = false, nil, nil

    Btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = Btn.Position
        end
    end)

    Btn.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.Touch then
            local delta = input.Position - dragStart
            Btn.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)

    Services.Input.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    Btn.Activated:Connect(function()
        Tween(Btn, 0.08, { BackgroundColor3 = Theme.AccentGlow })
        task.delay(0.08, function()
            if Btn and Btn.Parent then
                Tween(Btn, 0.15, { BackgroundColor3 = Theme.Accent })
            end
        end)
        if OnToggle then OnToggle() end
    end)

    return Btn
end

