-- ──────────────────────────────────────────────────────────────
--  COMPONENT: Notification (Toast)
-- ──────────────────────────────────────────────────────────────
--[[
    Options (table):
        Title    string
        Message  string
        Variant  string   info|success|danger|warning  ["info"]
        Duration number   seconds, 0 = no auto-dismiss  [3]

    Returns:
        :Dismiss()
--]]
function StellarUI:Notification(opts)
    opts = opts or {}
    local style  = NOTIF_STYLES[opts.Variant or "info"] or NOTIF_STYLES.info
    local dur    = opts.Duration ~= nil and opts.Duration or 3

    local notif = new("Frame", {
        Size             = UDim2.new(1, 0, 0, 60),
        Position         = UDim2.new(0, 0, 0, -66),
        BackgroundColor3 = Theme.Panel2,
        BorderSizePixel  = 0,
        ZIndex           = 90,
    }, self._inner)
    corner(notif, 10)
    new("UIStroke", { Color = style.Color, Thickness = 1, Transparency = 0.35 }, notif)

    local bar = new("Frame", {
        Size             = UDim2.new(0, 3, 1, -16),
        Position         = UDim2.new(0, 0, 0, 8),
        BackgroundColor3 = style.Color,
        BorderSizePixel  = 0,
        ZIndex           = 91,
    }, notif)
    corner(bar, 2)

    new("TextLabel", {
        Size                   = UDim2.new(0, 24, 1, 0),
        Position               = UDim2.new(0, 14, 0, 0),
        Text                   = style.Icon,
        TextColor3             = style.Color,
        TextSize               = 16,
        Font                   = Enum.Font.GothamBold,
        BackgroundTransparency = 1,
        ZIndex                 = 91,
    }, notif)

    new("TextLabel", {
        Size                   = UDim2.new(1, -58, 0, 20),
        Position               = UDim2.new(0, 44, 0, 10),
        Text                   = opts.Title or "Notification",
        TextColor3             = Theme.TxPrimary,
        TextSize               = 13,
        Font                   = Enum.Font.GothamMedium,
        TextXAlignment         = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        ZIndex                 = 91,
    }, notif)

    if opts.Message then
        new("TextLabel", {
            Size                   = UDim2.new(1, -58, 0, 16),
            Position               = UDim2.new(0, 44, 0, 30),
            Text                   = opts.Message,
            TextColor3             = Theme.TxSecond,
            TextSize               = 11,
            Font                   = Enum.Font.Gotham,
            TextXAlignment         = Enum.TextXAlignment.Left,
            BackgroundTransparency = 1,
            ZIndex                 = 91,
        }, notif)
    end

    tween(notif, { Position = UDim2.new(0, 0, 0, 0) }, 0.30, Enum.EasingStyle.Back)

    local dismissed = false
    local function dismiss()
        if dismissed then return end
        dismissed = true
        tween(notif, { Position = UDim2.new(0, 0, 0, -66) }, 0.22)
        task.delay(0.26, function()
            if notif.Parent then notif:Destroy() end
        end)
    end

    local closeBtn = new("TextButton", {
        Size                   = UDim2.new(0, 20, 0, 20),
        Position               = UDim2.new(1, -26, 0, 6),
        Text                   = "x",
        TextColor3             = Theme.TxMuted,
        TextSize               = 12,
        Font                   = Enum.Font.GothamBold,
        BackgroundTransparency = 1,
        ZIndex                 = 92,
    }, notif)
    closeBtn.MouseButton1Click:Connect(dismiss)

    if dur > 0 then
        task.delay(dur, dismiss)
    end

    local comp = {}
    comp.Dismiss = dismiss
    return comp
end

-- ──────────────────────────────────────────────────────────────
--  COMPONENT: NavBar
-- ──────────────────────────────────────────────────────────────
--[[
    Options (table):
        Items    table    { { Id="x", Icon="◇", Label="Name" }, … }
        Mode     string   "side" | "bottom"  ["side"]
        Default  string   initial active item Id

    Returns:
        .OnChanged : Signal<string>
        :SetActive(id: string)
        :Destroy()
--]]
function StellarUI:NavBar(opts)
    opts = opts or {}
    local items  = opts.Items   or {}
    local mode   = opts.Mode    or "side"
    local active = opts.Default or (items[1] and items[1].Id or "")
    local signal = makeSignal()
    local isSide = mode == "side"

    local nav = new("Frame", {
        Size             = isSide and UDim2.new(0, 64, 1, 0)
                                   or UDim2.new(1, 0, 0, 58),
        Position         = isSide and UDim2.new(0, 0, 0, 0)
                                   or UDim2.new(0, 0, 1, -58),
        BackgroundColor3 = Theme.Panel1,
        BorderSizePixel  = 0,
    }, self.Root)

    -- Separator border
    new("Frame", {
        Size             = isSide and UDim2.new(0, 1, 1, 0)
                                   or UDim2.new(1, 0, 0, 1),
        Position         = isSide and UDim2.new(1, -1, 0, 0)
                                   or UDim2.new(0, 0, 0, 0),
        BackgroundColor3 = Theme.Border,
        BackgroundTransparency = 0.45,
        BorderSizePixel  = 0,
    }, nav)

    -- FIX: use a child inner frame so UIListLayout and UIPadding
    --      do not conflict on the same Frame.
    local inner = new("Frame", {
        Size                   = UDim2.new(1, 0, 1, -20),
        Position               = UDim2.new(0, 0, 0, 10),
        BackgroundTransparency = 1,
        BorderSizePixel        = 0,
    }, nav)

    listLayout(inner,
        isSide and Enum.FillDirection.Vertical or Enum.FillDirection.Horizontal,
        4,
        Enum.HorizontalAlignment.Center
    )

    local btnMap = {}  -- [Id] = { frame, icon, label }

    local function refreshNav()
        for id, data in pairs(btnMap) do
            local on = id == active
            tween(data.frame, {
                BackgroundColor3       = on and Theme.AccentDim or Theme.Panel1,
                BackgroundTransparency = on and 0 or 1,
            }, 0.15)
            data.icon.TextColor3  = on and Theme.Accent or Theme.TxSecond
            data.label.TextColor3 = on and Theme.Accent or Theme.TxSecond
        end
    end

    for _, item in ipairs(items) do
        local isOn = item.Id == active

        local itemFrame = new("Frame", {
            Size             = isSide and UDim2.new(0, 50, 0, 50)
                                       or UDim2.new(1 / #items, 0, 1, 0),
            BackgroundColor3 = isOn and Theme.AccentDim or Theme.Panel1,
            BackgroundTransparency = isOn and 0 or 1,
            BorderSizePixel  = 0,
        }, inner)
        corner(itemFrame, 9)

        local iconLbl = new("TextLabel", {
            Size                   = UDim2.new(1, 0, 0, 22),
            Position               = UDim2.new(0, 0, 0, 7),
            Text                   = item.Icon or "o",
            TextColor3             = isOn and Theme.Accent or Theme.TxSecond,
            TextSize               = 16,
            Font                   = Enum.Font.Gotham,
            BackgroundTransparency = 1,
        }, itemFrame)

        local textLbl = new("TextLabel", {
            Size                   = UDim2.new(1, 0, 0, 12),
            Position               = UDim2.new(0, 0, 0, 31),
            Text                   = item.Label or item.Id,
            TextColor3             = isOn and Theme.Accent or Theme.TxSecond,
            TextSize               = 9,
            Font                   = Enum.Font.Gotham,
            BackgroundTransparency = 1,
        }, itemFrame)

        local hit = new("TextButton", {
            Size                   = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Text                   = "",
            ZIndex                 = 5,
        }, itemFrame)

        btnMap[item.Id] = { frame = itemFrame, icon = iconLbl, label = textLbl }

        hit.MouseButton1Click:Connect(function()
            active = item.Id
            refreshNav()
            signal:Fire(active)
        end)
    end

    local comp = {}
    comp.OnChanged = signal
    comp.SetActive = function(_, id)
        active = id
        refreshNav()
    end
    comp.Destroy   = function() nav:Destroy() end
    return comp
end

-- ──────────────────────────────────────────────────────────────
--  CONSTRUCTOR
-- ──────────────────────────────────────────────────────────────
--[[
    StellarUI.new(parent: Instance) -> StellarUIInstance

    `parent` should be a ScreenGui or a Frame.
    All components mount onto an internal scrollable container.

    Properties:
        .Root     Frame    outermost frame
        .Theme    table    design tokens (read/write to retheme)
        .Version  string

    Methods:
        :Toggle(opts)      :Button(opts)       :TextInput(opts)
        :Slider(opts)      :Select(opts)       :CodeBlock(opts)
        :Badge(opts)       :ProgressBar(opts)  :Avatar(opts)
        :Notification(opts):NavBar(opts)       :SectionHeader(opts)
        :Destroy()
--]]
function StellarUI.new(parent)
    assert(
        parent and typeof(parent) == "Instance",
        "[StellarUI] StellarUI.new() requires a valid Instance as parent."
    )

    local self = setmetatable({}, StellarUI)

    -- Root frame
    self.Root = new("Frame", {
        Size             = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = Theme.BG,
        BorderSizePixel  = 0,
    }, parent)

    -- Scrollable viewport
    local scroll = new("ScrollingFrame", {
        Size                       = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency     = 1,
        BorderSizePixel            = 0,
        ScrollBarThickness         = 2,
        ScrollBarImageColor3       = Theme.Accent,
        ScrollBarImageTransparency = 0.5,
        CanvasSize                 = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize        = Enum.AutomaticSize.Y,
        ElasticBehavior            = Enum.ElasticBehavior.WhenScrollable,
    }, self.Root)

    -- FIX: components parent to this inner frame, NOT directly to the
    --      ScrollingFrame, so UIListLayout and UIPadding stay separate.
    local inner = new("Frame", {
        Size                   = UDim2.new(1, -32, 1, 0),
        Position               = UDim2.new(0, 16, 0, 0),
        BackgroundTransparency = 1,
        BorderSizePixel        = 0,
        AutomaticSize          = Enum.AutomaticSize.Y,
    }, scroll)

    listLayout(inner, Enum.FillDirection.Vertical, 6)

    self._inner  = inner
    self.Theme   = Theme
    self.Version = StellarUI.Version

    return self
end

--- Destroy the entire UI hierarchy.
function StellarUI:Destroy()
    if self.Root and self.Root.Parent then
        self.Root:Destroy()
    end
end

return StellarUI
