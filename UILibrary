    -- Toggle
    function Options:AddToggle(Info)
        local Toggle = Clone(Components.Toggle)
        if not Toggle then return end

        local Title, Description = Options:GetLabels(Toggle)
        local On = Toggle.Value
        local Main = Toggle.Main
        local Circle = Main and Main:FindFirstChild("Circle")

        Toggle.Size = UDim2.new(1, 0, 0, math.max(Toggle.Size.Y.Offset, Setup.TouchTargetMin))

        local function Set(Value)
            if Value then
                Tween(Main, 0.18, { BackgroundColor3 = Theme.Accent })
                if Circle then
                    Tween(Circle, 0.18, {
                        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                        Position = UDim2.new(1, -16, 0.5, 0),
                    })
                end
            else
                Tween(Main, 0.18, { BackgroundColor3 = Theme.Interactables })
                if Circle then
                    Tween(Circle, 0.18, {
                        BackgroundColor3 = Theme.Primary,
                        Position = UDim2.new(0, 3, 0.5, 0),
                    })
                end
            end
            if On then On.Value = Value end
        end

        local function HandleTap()
            local Value = not (On and On.Value or false)
            Set(Value)
            if Info.Callback then Info.Callback(Value) end
        end

        Connect(Toggle.MouseButton1Click, HandleTap)
        Connect(Toggle.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.Touch then
                HandleTap()
            end
        end)

        Animations:Component(Toggle)
        Set(Info.Default == true)
        if Title then Title.Text = Info.Title or "Toggle" end
        if Description then Description.Text = Info.Description or "" end
        SetProperty(Toggle, {
            Name = Info.Title or "Toggle",
            Parent = Info.Tab,
            Visible = true,
        })
    end

    -- Keybind
    function Options:AddKeybind(Info)
        local Dropdown = Clone(Components.Keybind)
        if not Dropdown then return end

        local Title, Description = Options:GetLabels(Dropdown)
        local Bind = Dropdown.Main and Dropdown.Main:FindFirstChild("Options")

        local Mouse = {
            Enum.UserInputType.MouseButton1,
            Enum.UserInputType.MouseButton2,
            Enum.UserInputType.MouseButton3,
        }
        local Types = {
            Mouse = "Enum.UserInputType.MouseButton",
            Key = "Enum.KeyCode.",
        }

        local function StartListening()
            local Finished = false
            if Bind then Bind.Text = "..." end

            local Stroke = Dropdown:FindFirstChildOfClass("UIStroke")
            if Stroke then Tween(Stroke, 0.12, { Color = Theme.Accent }) end

            local Detect
            Detect = Connect(game.UserInputService.InputBegan, function(Key, Focused)
                if Finished or Focused then return end
                Finished = true

                local InputType = Key.UserInputType

                if table.find(Mouse, InputType) then
                    if Info.Callback then Info.Callback(Key) end
                    if Bind then Bind.Text = tostring(InputType):gsub(Types.Mouse, "MB") end

                elseif InputType == Enum.UserInputType.Keyboard then
                    if Info.Callback then Info.Callback(Key) end
                    if Bind then Bind.Text = tostring(Key.KeyCode):gsub(Types.Key, "") end

                elseif InputType == Enum.UserInputType.Touch then
                    if Info.Callback then Info.Callback(Key) end
                    if Bind then Bind.Text = "TAP" end
                end

                if Stroke then Tween(Stroke, 0.16, { Color = Theme.Outline }) end
                Detect:Disconnect()
            end)
        end

        Connect(Dropdown.MouseButton1Click, StartListening)
        Connect(Dropdown.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.Touch then
                StartListening()
            end
        end)

        Animations:Component(Dropdown)
        if Title then Title.Text = Info.Title or "Keybind" end
        if Description then Description.Text = Info.Description or "" end
        SetProperty(Dropdown, {
            Name = Info.Title or "Keybind",
            Parent = Info.Tab,
            Visible = true,
        })
    end

    -- Dropdown (bottom-sheet on mobile)
    function Options:AddDropdown(Info)
        local Dropdown = Clone(Components.Dropdown)
        if not Dropdown then return end

        local Title, Description = Options:GetLabels(Dropdown)
        local Text = Dropdown.Main and Dropdown.Main:FindFirstChild("Options")

        local function OpenDropdown()
            local Example = Clone(Examples.DropdownExample)
            if not Example then return end
            local Buttons = Example.Top and Example.Top:FindFirstChild("Buttons")
            if not Buttons then return end

            if IsTouchDevice then
                local sheetHeight = Metrics.IsCompact and 0.76 or 0.70
                Example.AnchorPoint = Vector2.new(0.5, 1)
                Example.Position = UDim2.new(0.5, 0, 1, 50)
                Example.Size = UDim2.new(1, -(Metrics.SafeAreaInset * 2), sheetHeight, 0)
            else
                Example.Position = UDim2.fromScale(0.5, 0.5)
                Example.AnchorPoint = Vector2.new(0.5, 0.5)
            end

            Tween(BG, 0.16, { BackgroundTransparency = 0.25 })
            SetProperty(Example, { Parent = Window })
            Animations:Open(Example, 0, true)

            if IsTouchDevice then
                Tween(Example, 0.22, { Position = UDim2.new(0.5, 0, 1, -(Metrics.SafeAreaInset + 6)) })
            end

            local function CloseDropdown()
                Tween(BG, 0.16, { BackgroundTransparency = 1 })
                if IsTouchDevice then
                    Tween(Example, 0.16, { Position = UDim2.new(0.5, 0, 1, 50) })
                    task.wait(0.18)
                else
                    Animations:Close(Example)
                    task.wait(0.18)
                end
                if Example and Example.Parent then Example:Destroy() end
            end

            for _, Button in next, Buttons:GetChildren() do
                if Button:IsA("TextButton") then
                    Animations:Component(Button, true)
                    Connect(Button.MouseButton1Click, CloseDropdown)
                    Connect(Button.InputBegan, function(Input)
                        if Input.UserInputType == Enum.UserInputType.Touch then
                            CloseDropdown()
                        end
                    end)
                end
            end

            for Index, Option in next, (Info.Options or {}) do
                local Button = Clone(Examples.DropdownButtonExample)
                if not Button then continue end

                local BTitle, BDesc = Options:GetLabels(Button)
                local Selected = Button.Value

                Button.Size = UDim2.new(1, 0, 0, math.max(Button.Size.Y.Offset, Setup.TouchTargetMin + Setup.PaddingY))

                Animations:Component(Button)
                if BTitle then BTitle.Text = tostring(Index) end
                SetProperty(Button, { Parent = Example.ScrollingFrame, Visible = true })
                if BDesc then BDesc:Destroy() end

                local function SelectOption()
                    local NewValue = not (Selected and Selected.Value or false)

                    if NewValue then
                        Tween(Button, 0.16, { BackgroundColor3 = LerpColor(Theme.Interactables, Theme.Accent, 0.24) })
                        if Info.Callback then Info.Callback(Option) end
                        if Text then Text.Text = tostring(Index) end

                        for _, Others in next, Example.ScrollingFrame:GetChildren() do
                            if Others:IsA("TextButton") and Others ~= Button then
                                Others.BackgroundColor3 = Theme.Component
                            end
                        end
                    else
                        Tween(Button, 0.16, { BackgroundColor3 = Theme.Component })
                    end

                    if Selected then Selected.Value = NewValue end
                    CloseDropdown()
                end

                Connect(Button.MouseButton1Click, SelectOption)
                Connect(Button.InputBegan, function(Input)
                    if Input.UserInputType == Enum.UserInputType.Touch then
                        SelectOption()
                    end
                end)
            end
        end

        Connect(Dropdown.MouseButton1Click, OpenDropdown)
        Connect(Dropdown.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.Touch then
                OpenDropdown()
            end
        end)

        Animations:Component(Dropdown)
        if Title then Title.Text = Info.Title or "Dropdown" end
        if Description then Description.Text = Info.Description or "" end
        SetProperty(Dropdown, {
            Name = Info.Title or "Dropdown",
            Parent = Info.Tab,
            Visible = true,
        })
    end

    -- Slider
    function Options:AddSlider(Info)
        local Slider = Clone(Components.Slider)
        if not Slider then return end

        local Title, Desc = Options:GetLabels(Slider)
        local Main = Slider.Slider
        local Amount = Main.Main.Input
        local Slide = Main.Slide
        local Fire = Slide.Fire
        local Fill = Slide.Highlight
        local Circle = Fill.Circle

        local trackHeight = IsTouchDevice and (6 + Setup.ScreenScale) or 4
        local handleSize = IsTouchDevice and math.clamp(math.floor(22 * Setup.ScreenScale), 20, 26) or 14

        Slide.Size = UDim2.new(1, 0, 0, trackHeight)
        Circle.Size = UDim2.new(0, handleSize, 0, handleSize)

        Fill.BackgroundColor3 = Theme.Accent
        Circle.BackgroundColor3 = Theme.AccentGlow

        local MinValue = Info.MinValue or 0
        local MaxValue = Info.MaxValue or 100
        local Active = false
        local ActiveTouch = nil
        local Value = Info.DefaultValue or MinValue
        local LastUpdateTime = 0
        local UpdateThrottle = 0.016

        local function SetNumber(Number)
            if Info.AllowDecimals then
                local Power = 10 ^ (Info.DecimalAmount or 2)
                return math.floor(Number * Power + 0.5) / Power
            else
                return math.round(Number)
            end
        end

        local function UpdateFromX(RawX)
            local now = tick()
            if IsTouchDevice and (now - LastUpdateTime < UpdateThrottle) then return end
            LastUpdateTime = now

            local slidePos = Slide.AbsolutePosition.X
            local slideSize = Slide.AbsoluteSize.X
            local Scale = math.clamp((RawX - slidePos) / slideSize, 0, 1)
            Value = SetNumber(MinValue + Scale * (MaxValue - MinValue))

            Amount.Text = tostring(Value)
            Fill.Size = UDim2.fromScale(Scale, 1)
            Circle.Position = UDim2.new(Scale, -(handleSize / 2), 0.5, 0)

            if Info.Callback then Info.Callback(Value) end
        end

        local function UpdateFromNumber(Number)
            local Clamped = math.clamp(Number, MinValue, MaxValue)
            local Scale = (Clamped - MinValue) / (MaxValue - MinValue)

            Value = SetNumber(Clamped)
            Amount.Text = tostring(Value)
            Fill.Size = UDim2.fromScale(Scale, 1)
            Circle.Position = UDim2.new(Scale, -(handleSize / 2), 0.5, 0)

            if Info.Callback then Info.Callback(Value) end
        end

        Connect(Fire.MouseButton1Down, function()
            Active = true
            ActiveTouch = nil
            UpdateFromX(Player.Mouse.X)
        end)

        Connect(Fire.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.Touch then
                Active = true
                ActiveTouch = Input
                UpdateFromX(Input.Position.X)
            elseif Input.UserInputType == Enum.UserInputType.MouseButton1 then
                Active = true
                ActiveTouch = nil
                UpdateFromX(Player.Mouse.X)
            end
        end)

        Connect(Services.Input.InputChanged, function(Input)
            if not Active then return end

            if Input.UserInputType == Enum.UserInputType.MouseMovement and not IsTouchDevice then
                UpdateFromX(Player.Mouse.X)
            elseif ActiveTouch and Input == ActiveTouch then
                UpdateFromX(Input.Position.X)
            end
        end)

        Connect(Services.Input.InputEnded, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input == ActiveTouch then
                Active = false
                ActiveTouch = nil
            end
        end)

        Connect(Amount.FocusLost, function()
            UpdateFromNumber(tonumber(Amount.Text) or MinValue)
        end)

        Connect(Fire.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.Touch
                or Input.UserInputType == Enum.UserInputType.MouseButton1 then
                Tween(Fill, 0.08, { BackgroundColor3 = Theme.AccentGlow })
            end
        end)

        Connect(Fire.InputEnded, function(Input)
            if Input.UserInputType == Enum.UserInputType.Touch
                or Input.UserInputType == Enum.UserInputType.MouseButton1 then
                Tween(Fill, 0.12, { BackgroundColor3 = Theme.Accent })
            end
        end)

        UpdateFromNumber(Value)

        Animations:Component(Slider)
        if Title then Title.Text = Info.Title or "Slider" end
        if Desc then Desc.Text = Info.Description or "" end
        SetProperty(Slider, {
            Name = Info.Title or "Slider",
            Parent = Info.Tab,
            Visible = true,
        })
    end

