--// Animations [Window]

function Animations:Open(Window, Transparency, UseCurrentSize)
    local Original   = (UseCurrentSize and Window.Size) or Setup.Size
    local Multiplied = Multiply(Original, 0.92)  -- Shrink-in instead of scale-up for mobile feel
    local Shadow     = Window:FindFirstChildOfClass("UIStroke")

    if Shadow then SetProperty(Shadow, { Transparency = 1 }) end
    SetProperty(Window, {
        Size             = Multiplied,
        GroupTransparency = 1,
        Visible          = true,
    })

    if Shadow then Tween(Shadow, 0.3, { Transparency = 0.55 }) end
    TweenSpring(Window, 0.35, {
        Size             = Original,
        GroupTransparency = Transparency or 0,
    })
end

function Animations:Close(Window)
    local Original   = Window.Size
    local Multiplied = Multiply(Original, 0.92)
    local Shadow     = Window:FindFirstChildOfClass("UIStroke")

    if Shadow then Tween(Shadow, 0.2, { Transparency = 1 }) end
    Tween(Window, 0.22, {
        Size             = Multiplied,
        GroupTransparency = 1,
    })

    task.wait(0.25)
    Window.Size    = Original
    Window.Visible = false
end

--// Component hover/press feedback — accent pulse on mobile with throttling
function Animations:Component(Component, Custom)
    if not Component or not Component.Parent then return end
    
    local baseColor = Component.BackgroundColor3
    local lastPressTime = 0
    local pressThrottle = 0.1  -- Prevent rapid re-triggers

    -- Press (InputBegan)
    Connect(Component.InputBegan, function(Input)
        local isValid = Input.UserInputType == Enum.UserInputType.MouseButton1
            or Input.UserInputType == Enum.UserInputType.Touch

        if not isValid then return end
        
        local currentTime = tick()
        if currentTime - lastPressTime < pressThrottle then return end
        lastPressTime = currentTime

        if Custom then
            Tween(Component, 0.15, { Transparency = 0.80 })
        else
            -- On mobile: slight accent tint on press
            local pressColor = IsMobile
                and LerpColor(Theme.Component, Theme.Accent, 0.12)
                or  ColorAdjust(Theme.Component, 8, Setup.ThemeMode)
            Tween(Component, 0.12, { BackgroundColor3 = pressColor })
        end
    end)

    -- Release (InputEnded)
    Connect(Component.InputEnded, function(Input)
        local isValid = Input.UserInputType == Enum.UserInputType.MouseButton1
            or Input.UserInputType == Enum.UserInputType.Touch

        if not isValid then return end

        if Custom then
            Tween(Component, 0.2, { Transparency = 1 })
        else
            Tween(Component, 0.2, { BackgroundColor3 = Theme.Component })
        end
    end)
end

