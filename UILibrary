    --// ============================================================
    --// Input
    --// ============================================================

    function Options:AddInput(Settings)
        local Input   = Clone(Components["Input"])
        if not Input then return end
        
        local Title, Description = Options:GetLabels(Input)
        local TextBox = Input["Main"]["Input"]

        -- Mobile: Larger text box with adaptive padding
        Input.Size = UDim2.new(1, 0, 0, math.max(Input.Size.Y.Offset, Setup.TouchTargetMin + Setup.PaddingY))
        if TextBox then
            TextBox.TextSize = Setup.FontSize
        end

        -- Accent outline on focus
        local Stroke = Input:FindFirstChildOfClass("UIStroke")

        if TextBox then
            Connect(TextBox.Focused, function()
                if Stroke then
                    Tween(Stroke, 0.15, { Color = Theme.Accent, Thickness = 1.5 })
                end
            end)

            Connect(TextBox.FocusLost, function()
                if Stroke then
                    Tween(Stroke, 0.2, { Color = Theme.Outline, Thickness = 1 })
                end
                Settings.Callback(TextBox.Text)
            end)
        end

        Connect(Input.MouseButton1Click, function()
            if TextBox then TextBox:CaptureFocus() end
        end)

        Connect(Input.InputBegan, function(Inp)
            if Inp.UserInputType == Enum.UserInputType.Touch then
                if TextBox then TextBox:CaptureFocus() end
            end
        end)

        Animations:Component(Input)
        if Title then SetProperty(Title, { Text = Settings.Title }) end
        if Description then SetProperty(Description, { Text = Settings.Description }) end
