--  Utility Functions

-- ─────────────────────────────────────────────

local function Clone(obj)   return obj:Clone()   end

local function Destroy(obj) obj:Destroy()         end

local function Connect(sig, fn) return sig:Connect(fn) end



--- Smooth tween helper (defaults to Quart/Out)

local function Tween(obj, speed, props, info)

    local style = (info and info.EasingStyle)     or Enum.EasingStyle.Quart

    local dir   = (info and info.EasingDirection) or Enum.EasingDirection.Out

    Services.Tween:Create(obj, TweenInfo.new(speed, style, dir), props):Play()

end



--- Batch-set object properties

local function SetProperty(obj, props)

    for k, v in next, props do obj[k] = v end

    return obj

end



--- Scale a UDim2 by a factor

local function Multiply(value, amount)

    return UDim2.new(

        value.X.Scale  * amount, value.X.Offset * amount,

        value.Y.Scale  * amount, value.Y.Offset * amount

    )

end



--- Linear interpolation between two Color3

local function LerpColor(a, b, t)

    return Color3.new(

        a.R + (b.R - a.R) * t,

        a.G + (b.G - a.G) * t,

        a.B + (b.B - a.B) * t

    )

end



--- Brighten/darken a Color3 by offset (+ = lighter in Dark, - in Light)

local function ShiftColor(color, factor)

    local mode = Setup.ThemeMode

    local f = (mode == "Light") and -math.abs(factor) or math.abs(factor)

    return Color3.fromRGB(

        math.clamp((color.R * 255) + f, 0, 255),

        math.clamp((color.G * 255) + f, 0, 255),

        math.clamp((color.B * 255) + f, 0, 255)

    )

end



-- ─────────────────────────────────────────────

--  Drag System  (Mouse + Touch)

-- ─────────────────────────────────────────────

local DragType = nil  -- used by resize system



local function MakeDraggable(Canvas, Handle)

    if not Canvas then return end

    Handle = Handle or Canvas



    local Dragging, DragInput, Start, StartPos



    Connect(Handle.InputBegan, function(Input)

        local t = Input.UserInputType

        if (t == Enum.UserInputType.MouseButton1 or t == Enum.UserInputType.Touch) and not DragType then

            Dragging  = true

            Start     = Input.Position

            StartPos  = Canvas.Position



            Connect(Input.Changed, function()

                if Input.UserInputState == Enum.UserInputState.End then

                    Dragging = false

                end

            end)

        end

    end)



    Connect(Handle.InputChanged, function(Input)

        local t = Input.UserInputType

        if t == Enum.UserInputType.MouseMovement or t == Enum.UserInputType.Touch then

            DragInput = Input

        end

    end)



    Connect(Services.Input.InputChanged, function(Input)

        if Input == DragInput and Dragging and not DragType then

            local delta = Input.Position - Start

            Canvas.Position = UDim2.new(

                StartPos.X.Scale, StartPos.X.Offset + delta.X,

                StartPos.Y.Scale, StartPos.Y.Offset + delta.Y

            )

        end

    end)

end



-- ─────────────────────────────────────────────

--  Resize System  (Mouse only — desktop)

-- ─────────────────────────────────────────────

local ResizingModes = {

    TopLeft     = { X = Vector2.new(-1, 0), Y = Vector2.new(0, -1) },

    TopRight    = { X = Vector2.new( 1, 0), Y = Vector2.new(0, -1) },

    BottomLeft  = { X = Vector2.new(-1, 0), Y = Vector2.new(0,  1) },

    BottomRight = { X = Vector2.new( 1, 0), Y = Vector2.new(0,  1) },

}



local function MakeResizable(Tab, Minimum, Maximum)

    if not Tab or not Tab:FindFirstChild("Resize") then return end

    task.spawn(function()

        local MousePos, Size, UIPos



        for _, Handle in next, Tab.Resize:GetChildren() do

            Connect(Handle.InputBegan, function(Input)

                if Input.UserInputType == Enum.UserInputType.MouseButton1 then

                    DragType = Handle

                    MousePos = Vector2.new(Player.Mouse.X, Player.Mouse.Y)

                    Size     = Tab.AbsoluteSize

                    UIPos    = Tab.Position

                end

            end)

            Connect(Handle.InputEnded, function(Input)

                if Input.UserInputType == Enum.UserInputType.MouseButton1 then

                    DragType = nil

                end

            end)

        end



        Connect(Player.Mouse.Move, function()

            if not (DragType and MousePos and Size and UIPos) then return end

            local Mode = ResizingModes[DragType.Name]

            if not Mode then return end



            local Delta   = Vector2.new(Player.Mouse.X, Player.Mouse.Y) - MousePos

            local NewSize = Vector2.new(

                math.clamp(Size.X + Delta.X * Mode.X.X, Minimum.X, Maximum.X),

                math.clamp(Size.Y + Delta.Y * Mode.Y.Y, Minimum.Y, Maximum.Y)

            )

            local AO    = Vector2.new(Tab.AnchorPoint.X * Size.X,    Tab.AnchorPoint.Y * Size.Y)

            local NAO   = Vector2.new(Tab.AnchorPoint.X * NewSize.X, Tab.AnchorPoint.Y * NewSize.Y)

            local DAnchor = NAO - AO



            Tab.Size     = UDim2.new(0, NewSize.X, 0, NewSize.Y)

            Tab.Position = UDim2.new(

                UIPos.X.Scale, UIPos.X.Offset + DAnchor.X * Mode.X.X,

                UIPos.Y.Scale, UIPos.Y.Offset + DAnchor.Y * Mode.Y.Y

            )

        end)

    end)

end



-- ─────────────────────────────────────────────

--  Bottom-Right Resize Grip  (Mouse + Touch)

-- ─────────────────────────────────────────────

--[[

    Creates a small draggable grip at the bottom-right corner of any Frame.

    Dragging it resizes the window. Blocks the drag system while active

    by setting DragType so MakeDraggable ignores movement.



    Parameters:

        Tab     — Frame to resize (the Window)

        Minimum — Vector2   min width/height  (default 280, 200)

        Maximum — Vector2   max width/height  (default 1800, 1200)

]]

local function AddResizeGrip(Tab, Minimum, Maximum)

    if not Tab then return end

    Minimum = Minimum or Vector2.new(280,  200)

    Maximum = Maximum or Vector2.new(1800, 1200)



    -- ── Grip container (pinned bottom-right) ──────────────────────────────

    local Grip = Instance.new("Frame")

    Grip.Name                       = "ResizeGrip"

    Grip.Size                       = UDim2.new(0, 20, 0, 20)

    Grip.Position                   = UDim2.new(1, -2, 1, -2)

    Grip.AnchorPoint                = Vector2.new(1, 1)

    Grip.BackgroundColor3           = Color3.fromRGB(108, 130, 255)

    Grip.BackgroundTransparency     = 0.55

    Grip.ZIndex                     = 20

    Grip.BorderSizePixel            = 0

    Grip.ClipsDescendants           = false

    Grip.Parent                     = Tab



    local GripCorner = Instance.new("UICorner")

    GripCorner.CornerRadius = UDim.new(0, 5)

    GripCorner.Parent       = Grip



    -- ── Three diagonal dots (classic resize indicator) ────────────────────

    --  Arranged like:

    --        · ·

    --      · · ·

    local DotDefs = {

        { X = 11, Y = 3  },

        { X = 3,  Y = 11 },

        { X = 11, Y = 11 },

        { X = 7,  Y = 7  },

        { X = 15, Y = 7  },

        { X = 15, Y = 15 },

    }

    for i = 1, 3 do   -- only use first 3 for a cleaner look

        local D = DotDefs[i]

        local Dot = Instance.new("Frame")

        Dot.Size             = UDim2.new(0, 3, 0, 3)

        Dot.Position         = UDim2.new(0, D.X, 0, D.Y)

        Dot.BackgroundColor3 = Color3.fromRGB(200, 210, 255)

        Dot.BackgroundTransparency = 0

        Dot.BorderSizePixel  = 0

        Dot.ZIndex           = 21

        Instance.new("UICorner", Dot).CornerRadius = UDim.new(1, 0)

        Dot.Parent           = Grip

    end



    -- ── Hover animation ───────────────────────────────────────────────────

    Connect(Grip.InputBegan, function(Input)

        local t = Input.UserInputType

        if t == Enum.UserInputType.MouseMovement then

            Tween(Grip, 0.12, { BackgroundTransparency = 0.25 })

        end

    end)

    Connect(Grip.InputEnded, function(Input)

        local t = Input.UserInputType

        if t == Enum.UserInputType.MouseMovement then

            Tween(Grip, 0.12, { BackgroundTransparency = 0.55 })

        end

    end)



    -- ── Resize state ──────────────────────────────────────────────────────

    local Resizing    = false

    local StartMouse  = nil   -- Vector2 mouse/touch position when drag began

    local StartSize   = nil   -- Vector2 window AbsoluteSize when drag began

    local ActiveTouch = nil   -- the Touch InputObject (mobile only)



    local function BeginResize(pos)

        DragType   = "BottomRight"   -- blocks MakeDraggable while we resize

        Resizing   = true

        StartMouse = pos

        StartSize  = Vector2.new(Tab.AbsoluteSize.X, Tab.AbsoluteSize.Y)

    end



    local function EndResize()

        DragType    = nil

        Resizing    = false

        StartMouse  = nil

        StartSize   = nil

        ActiveTouch = nil

        -- Restore grip look

        Tween(Grip, 0.12, { BackgroundTransparency = 0.55 })

    end



    local function DoResize(currentPos)

        if not (Resizing and StartMouse and StartSize) then return end

        local Delta = currentPos - StartMouse

        local NewW  = math.clamp(StartSize.X + Delta.X, Minimum.X, Maximum.X)

        local NewH  = math.clamp(StartSize.Y + Delta.Y, Minimum.Y, Maximum.Y)

        Tab.Size    = UDim2.new(0, NewW, 0, NewH)

    end



    -- ── Input: Begin ──────────────────────────────────────────────────────

    Connect(Grip.InputBegan, function(Input)

        local t = Input.UserInputType



        if t == Enum.UserInputType.MouseButton1 then

            -- Desktop mouse ------------------------------------------------

            BeginResize(Vector2.new(Input.Position.X, Input.Position.Y))

            Tween(Grip, 0.1, { BackgroundTransparency = 0.15 })



        elseif t == Enum.UserInputType.Touch then

            -- Mobile touch -------------------------------------------------

            ActiveTouch = Input

            BeginResize(Vector2.new(Input.Position.X, Input.Position.Y))

            Tween(Grip, 0.1, { BackgroundTransparency = 0.15 })



            -- Track the touch object directly (more reliable on mobile)

            Connect(Input.Changed, function()

                if Input.UserInputState == Enum.UserInputState.End then

                    if Resizing and ActiveTouch == Input then

                        EndResize()

                    end

                elseif Resizing and ActiveTouch == Input then

                    DoResize(Vector2.new(Input.Position.X, Input.Position.Y))

                end

            end)

        end

    end)



    -- ── Input: Move (desktop mouse via global InputChanged) ───────────────

    Connect(Services.Input.InputChanged, function(Input)

        if Input.UserInputType == Enum.UserInputType.MouseMovement and Resizing then

            DoResize(Vector2.new(Input.Position.X, Input.Position.Y))

        end

    end)



    -- ── Input: End (desktop mouse release) ───────────────────────────────

    Connect(Services.Input.InputEnded, function(Input)

        if Input.UserInputType == Enum.UserInputType.MouseButton1 and Resizing then

            EndResize()

        end

    end)

end



