local function GetViewportSize()
    return (workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize) or Metrics.ScreenSize
end

local function RecomputeMetrics()
    Metrics.ScreenSize = GetViewportSize()
    Metrics.IsLandscape = Metrics.ScreenSize.X > Metrics.ScreenSize.Y
    Metrics.IsCompact = Metrics.ScreenSize.X <= 360
    Metrics.ScreenScale = math.clamp(Metrics.ScreenSize.X / 375, 0.85, 1.35)
    Metrics.SafeAreaInset = IsTouchDevice and (Metrics.IsCompact and 10 or 12) or 0

    Setup.IsLandscape = Metrics.IsLandscape
    Setup.ScreenScale = Metrics.ScreenScale
    Setup.TouchTargetMin = IsTouchDevice and math.clamp(math.floor(48 * Metrics.ScreenScale), 44, 60) or 32
    Setup.FontSize = IsTouchDevice and math.clamp(math.floor(14 + (Metrics.ScreenScale * 1.1)), 14, 17) or 13
    Setup.PaddingX = IsTouchDevice and math.clamp(math.floor(10 * Metrics.ScreenScale), 8, 16) or 10
    Setup.PaddingY = IsTouchDevice and math.clamp(math.floor(8 * Metrics.ScreenScale), 6, 14) or 8
end

RecomputeMetrics()

if Camera then
    Camera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
        RecomputeMetrics()
    end)
end

