-- ──────────────────────────────────────────────────────────────
--  COMPONENT: ProgressBar
-- ──────────────────────────────────────────────────────────────
--[[
    Options (table):
        Label    string
        Value    number   initial value 0–Max      [0]
        Max      number                            [100]
        Variant  string   accent|success|danger|warning ["accent"]

    Returns:
        :GetValue() -> number
        :SetValue(number)
        :Destroy()
--]]
function StellarUI:ProgressBar(opts)
    opts = opts or {}
    local max    = opts.Max or 100
    local color  = PROGRESS_COLORS[opts.Variant or "accent"] or Theme.Accent
    local v      = clamp(opts.Value or 0, 0, max)
    local hasLbl = opts.Label ~= nil

    local wrapper = new("Frame", {
        Size                   = UDim2.new(1, 0, 0, hasLbl and 36 or 14),
        BackgroundTransparency = 1,
        BorderSizePixel        = 0,
    }, self._inner)

    local pctLbl
    if hasLbl then
        new("TextLabel", {
            Size                   = UDim2.new(1, -52, 0, 16),
            Text                   = opts.Label,
            TextColor3             = Theme.TxPrimary,
            TextSize               = 13,
            Font                   = Enum.Font.Gotham,
            TextXAlignment         = Enum.TextXAlignment.Left,
            BackgroundTransparency = 1,
        }, wrapper)
        pctLbl = new("TextLabel", {
            Size                   = UDim2.new(0, 50, 0, 16),
            Position               = UDim2.new(1, -50, 0, 0),
            Text                   = math.round(v / max * 100) .. "%",
            TextColor3             = Theme.TxSecond,
            TextSize               = 11,
            Font                   = Enum.Font.GothamMedium,
            TextXAlignment         = Enum.TextXAlignment.Right,
            BackgroundTransparency = 1,
        }, wrapper)
    end

    local trackY = hasLbl and 22 or 4
    local track  = new("Frame", {
        Size             = UDim2.new(1, 0, 0, 5),
        Position         = UDim2.new(0, 0, 0, trackY),
        BackgroundColor3 = Theme.Panel3,
        BorderSizePixel  = 0,
    }, wrapper)
    corner(track, 3)

    local fill = new("Frame", {
        Size             = UDim2.new(v / max, 0, 1, 0),
        BackgroundColor3 = color,
        BorderSizePixel  = 0,
    }, track)
    corner(fill, 3)

    local comp = {}
    comp.GetValue = function() return v end
    comp.SetValue = function(_, val)
        v = clamp(val, 0, max)
        local pct = v / max
        tween(fill, { Size = UDim2.new(pct, 0, 1, 0) }, 0.30)
        if pctLbl then pctLbl.Text = math.round(pct * 100) .. "%" end
    end
    comp.Destroy  = function() wrapper:Destroy() end
    return comp
end

-- ──────────────────────────────────────────────────────────────
--  COMPONENT: Avatar
-- ──────────────────────────────────────────────────────────────
--[[
    Options (table):
        Name    string   generates initials (e.g. "Alex Ray" → "AR")  ["U"]
        Size    number   pixel size                                    [36]
        Status  string   online|away|busy|offline

    Returns:
        :SetStatus(string)
        :Destroy()
--]]
function StellarUI:Avatar(opts)
    opts = opts or {}
    local sz   = opts.Size or 36
    local name = opts.Name or "User"

    -- FIX: use safe splitStr instead of non-standard :split()
    local parts    = splitStr(name, " ")
    local initials = ""
    for i = 1, math.min(2, #parts) do
        initials = initials .. string.upper(string.sub(parts[i], 1, 1))
    end
    if initials == "" then initials = "U" end

    local frame = new("Frame", {
        Size             = UDim2.new(0, sz, 0, sz),
        BackgroundColor3 = Theme.Accent,
        BorderSizePixel  = 0,
    }, self._inner)
    corner(frame, sz / 2)

    -- Accent → Teal gradient
    new("UIGradient", {
        Color    = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Theme.Accent),
            ColorSequenceKeypoint.new(1, Theme.Teal),
        }),
        Rotation = 135,
    }, frame)

    new("TextLabel", {
        Size                   = UDim2.new(1, 0, 1, 0),
        Text                   = initials,
        TextColor3             = Theme.White,
        TextSize               = math.floor(sz * 0.35),
        Font                   = Enum.Font.GothamBold,
        BackgroundTransparency = 1,
        ZIndex                 = 2,
    }, frame)

    local dotSz = math.floor(sz * 0.28)
    local dotFrame
    if opts.Status then
        dotFrame = new("Frame", {
            Size             = UDim2.new(0, dotSz, 0, dotSz),
            Position         = UDim2.new(1, -dotSz + 1, 1, -dotSz + 1),
            BackgroundColor3 = STATUS_COLORS[opts.Status] or Theme.TxSecond,
            BorderSizePixel  = 0,
            ZIndex           = 3,
        }, frame)
        corner(dotFrame, dotSz / 2)
        new("UIStroke", { Color = Theme.BG, Thickness = 2, Transparency = 0 }, dotFrame)
    end

    local comp = {}
    comp.SetStatus = function(_, s)
        if dotFrame then
            dotFrame.BackgroundColor3 = STATUS_COLORS[s] or Theme.TxSecond
        end
    end
    comp.Destroy   = function() frame:Destroy() end
    return comp
end

