-- ──────────────────────────────────────────────────────────────
--  COMPONENT: Toggle
-- ──────────────────────────────────────────────────────────────
--[[
    Options (table):
        Label    string   display label
        Sub      string   sub-label / description
        Default  bool     initial state            [false]
        Disabled bool     prevent interaction      [false]

    Returns:
        .OnChanged : Signal<bool>
        :GetValue() -> bool
        :SetValue(bool)
        :SetDisabled(bool)
        :Destroy()
--]]
function StellarUI:Toggle(opts)
    opts = opts or {}
    local value    = opts.Default  == true
    local disabled = opts.Disabled == true
    local signal   = makeSignal()

    local row = new("Frame", {
        Size                   = UDim2.new(1, 0, 0, 54),
        BackgroundTransparency = 1,
        BorderSizePixel        = 0,
    }, self._inner)

    -- Bottom divider
    new("Frame", {
        Size             = UDim2.new(1, 0, 0, 1),
        Position         = UDim2.new(0, 0, 1, -1),
        BackgroundColor3 = Theme.Border,
        BackgroundTransparency = 0.70,
        BorderSizePixel  = 0,
    }, row)

    if opts.Label then
        new("TextLabel", {
            Size                   = UDim2.new(1, -60, 0, 18),
            Position               = UDim2.new(0, 0, 0, 10),
            Text                   = opts.Label,
            TextColor3             = disabled and Theme.TxSecond or Theme.TxPrimary,
            TextSize               = 14,
            Font                   = Enum.Font.GothamMedium,
            TextXAlignment         = Enum.TextXAlignment.Left,
            BackgroundTransparency = 1,
        }, row)
    end

    if opts.Sub then
        new("TextLabel", {
            Size                   = UDim2.new(1, -60, 0, 14),
            Position               = UDim2.new(0, 0, 0, 30),
            Text                   = opts.Sub,
            TextColor3             = Theme.TxMuted,
            TextSize               = 11,
            Font                   = Enum.Font.Gotham,
            TextXAlignment         = Enum.TextXAlignment.Left,
            BackgroundTransparency = 1,
        }, row)
    end

    local track = new("Frame", {
        Size             = UDim2.new(0, 44, 0, 24),
        Position         = UDim2.new(1, -44, 0.5, -12),
        BackgroundColor3 = value and Theme.Accent or Theme.Panel2,
        BorderSizePixel  = 0,
    }, row)
    corner(track, 12)

    local trackStroke = new("UIStroke", {
        Color        = value and Theme.Accent or Theme.Border,
        Thickness    = 1,
        Transparency = 0.35,
    }, track)

    local thumb = new("Frame", {
        Size             = UDim2.new(0, 18, 0, 18),
        Position         = value and UDim2.new(0, 22, 0, 2) or UDim2.new(0, 2, 0, 2),
        BackgroundColor3 = value and Theme.White or Theme.TxSecond,
        BorderSizePixel  = 0,
    }, track)
    corner(thumb, 9)

    local thumbGlow = new("UIStroke", {
        Color        = Theme.Accent,
        Thickness    = 2,
        Transparency = value and 0.35 or 1,
    }, thumb)

    local hitbox = new("TextButton", {
        Size                   = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text                   = "",
    }, row)

    local function refresh()
        tween(track, { BackgroundColor3 = value and Theme.Accent or Theme.Panel2 }, 0.18)
        tween(thumb, {
            Position         = value and UDim2.new(0, 22, 0, 2) or UDim2.new(0, 2, 0, 2),
            BackgroundColor3 = value and Theme.White or Theme.TxSecond,
        }, 0.18, Enum.EasingStyle.Back)
        trackStroke.Color    = value and Theme.Accent or Theme.Border
        thumbGlow.Transparency = value and 0.35 or 1
        signal:Fire(value)
    end

    hitbox.MouseButton1Click:Connect(function()
        if disabled then return end
        value = not value
        refresh()
    end)

    local comp = {}
    comp.OnChanged   = signal
    comp.GetValue    = function() return value end
    comp.SetValue    = function(_, v) value = (v == true); refresh() end
    comp.SetDisabled = function(_, v) disabled = (v == true) end
    comp.Destroy     = function() row:Destroy() end
    return comp
end

-- ──────────────────────────────────────────────────────────────
--  COMPONENT: Button
-- ──────────────────────────────────────────────────────────────
--[[
    Options (table):
        Text     string   button label             ["Button"]
        Variant  string   primary|secondary|ghost|danger|success  ["primary"]
        Icon     string   prefix text/emoji
        Size     string   sm|md|lg                 ["md"]
        Disabled bool                              [false]
        Width    number   explicit pixel width

    Returns:
        .OnClick : Signal<>
        :SetText(string)
        :SetDisabled(bool)
        :Destroy()
--]]
function StellarUI:Button(opts)
    opts = opts or {}
    local style    = BUTTON_STYLES[opts.Variant or "primary"] or BUTTON_STYLES.primary
    local sz       = BUTTON_SIZES [opts.Size    or "md"     ] or BUTTON_SIZES.md
    local disabled = opts.Disabled == true
    local signal   = makeSignal()
    local isGhost  = opts.Variant  == "ghost"

    local labelTx = (opts.Icon and (opts.Icon .. "  ") or "") .. (opts.Text or "Button")
    local w = opts.Width or clamp(#labelTx * (sz.FS * 0.62) + sz.PadH * 2, 60, 300)

    local btn = new("TextButton", {
        Size                   = UDim2.new(0, w, 0, sz.H),
        BackgroundColor3       = style.BG,
        BackgroundTransparency = isGhost and 0.92 or 0,
        Text                   = labelTx,
        TextColor3             = disabled and Theme.TxMuted or style.Tx,
        TextSize               = sz.FS,
        Font                   = Enum.Font.GothamMedium,
        AutoButtonColor        = false,
        BorderSizePixel        = 0,
    }, self._inner)
    corner(btn, 7)

    new("UIStroke", {
        Color        = style.Border,
        Thickness    = 1,
        Transparency = disabled and 0.70 or 0.25,
    }, btn)

    if not disabled then
        btn.MouseEnter:Connect(function()
            tween(btn, { BackgroundTransparency = isGhost and 0.75 or 0.12 }, 0.12)
        end)
        btn.MouseLeave:Connect(function()
            tween(btn, { BackgroundTransparency = isGhost and 0.92 or 0 }, 0.15)
        end)
        btn.MouseButton1Down:Connect(function()
            tween(btn, { Size = UDim2.new(0, w * 0.96, 0, sz.H * 0.94) }, 0.08)
        end)
        btn.MouseButton1Up:Connect(function()
            tween(btn, { Size = UDim2.new(0, w, 0, sz.H) }, 0.14, Enum.EasingStyle.Back)
        end)
        btn.MouseButton1Click:Connect(function()
            signal:Fire()
        end)
    end

    local comp = {}
    comp.OnClick     = signal
    comp.SetText     = function(_, t)
        btn.Text = (opts.Icon and (opts.Icon .. "  ") or "") .. t
    end
    comp.SetDisabled = function(_, v)
        disabled = (v == true)
        btn.BackgroundTransparency = disabled and 0.6 or (isGhost and 0.92 or 0)
    end
    comp.Destroy     = function() btn:Destroy() end
    return comp
end

-- ──────────────────────────────────────────────────────────────
--  COMPONENT: TextInput
-- ──────────────────────────────────────────────────────────────
--[[
    Options (table):
        Label        string
        Sub          string
        Placeholder  string
        Icon         string   prefix glyph
        Default      string   initial text
        MaxLength    number
        ClearOnFocus bool

    Returns:
        .OnChanged : Signal<string>
        .OnSubmit  : Signal<string>   fires when Enter is pressed
        :GetValue() -> string
        :SetValue(string)
        :Destroy()
--]]
function StellarUI:TextInput(opts)
    opts = opts or {}
    local value     = opts.Default or ""
    local signal    = makeSignal()
    local submitSig = makeSignal()
    local hasLabel  = opts.Label ~= nil
    local hasSub    = opts.Sub   ~= nil
    local yOff      = hasLabel and (hasSub and 36 or 22) or 0
    local totalH    = yOff + 42

    local wrapper = new("Frame", {
        Size                   = UDim2.new(1, 0, 0, totalH),
        BackgroundTransparency = 1,
        BorderSizePixel        = 0,
    }, self._inner)

    if hasLabel then
        new("TextLabel", {
            Size                   = UDim2.new(1, 0, 0, 18),
            Text                   = opts.Label,
            TextColor3             = Theme.TxPrimary,
            TextSize               = 14,
            Font                   = Enum.Font.GothamMedium,
            TextXAlignment         = Enum.TextXAlignment.Left,
            BackgroundTransparency = 1,
        }, wrapper)
    end
    if hasSub then
        new("TextLabel", {
            Size                   = UDim2.new(1, 0, 0, 14),
            Position               = UDim2.new(0, 0, 0, 18),
            Text                   = opts.Sub,
            TextColor3             = Theme.TxMuted,
            TextSize               = 11,
            Font                   = Enum.Font.Gotham,
            TextXAlignment         = Enum.TextXAlignment.Left,
            BackgroundTransparency = 1,
        }, wrapper)
    end

    local box = new("Frame", {
        Size             = UDim2.new(1, 0, 0, 36),
        Position         = UDim2.new(0, 0, 0, yOff),
        BackgroundColor3 = Theme.Panel2,
        BorderSizePixel  = 0,
    }, wrapper)
    corner(box, 8)

    local stroke = new("UIStroke", {
        Color        = Theme.Border,
        Thickness    = 1,
        Transparency = 0.30,
    }, box)

    local iconPad = 0
    if opts.Icon then
        new("TextLabel", {
            Size                   = UDim2.new(0, 28, 1, 0),
            Position               = UDim2.new(0, 7, 0, 0),
            Text                   = opts.Icon,
            TextColor3             = Theme.TxSecond,
            TextSize               = 14,
            Font                   = Enum.Font.Gotham,
            BackgroundTransparency = 1,
        }, box)
        iconPad = 30
    end

    local tb = new("TextBox", {
        Size                   = UDim2.new(1, -(iconPad + 16), 1, 0),
        Position               = UDim2.new(0, iconPad + 8, 0, 0),
        Text                   = value,
        PlaceholderText        = opts.Placeholder or "",
        PlaceholderColor3      = Theme.TxMuted,
        TextColor3             = Theme.TxPrimary,
        TextSize               = 13,
        Font                   = Enum.Font.Gotham,
        TextXAlignment         = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        BorderSizePixel        = 0,
        ClearTextOnFocus       = opts.ClearOnFocus == true,
    }, box)

    tb.Focused:Connect(function()
        tween(stroke, { Color = Theme.Accent, Transparency = 0 }, 0.15)
        tween(box, { BackgroundColor3 = Theme.Panel3 }, 0.15)
    end)

    tb.FocusLost:Connect(function(didEnter)
        value = tb.Text
        tween(stroke, { Color = Theme.Border, Transparency = 0.30 }, 0.15)
        tween(box, { BackgroundColor3 = Theme.Panel2 }, 0.15)
        if didEnter then submitSig:Fire(value) end
    end)

    tb:GetPropertyChangedSignal("Text"):Connect(function()
        value = tb.Text
        signal:Fire(value)
    end)

    local comp = {}
    comp.OnChanged = signal
    comp.OnSubmit  = submitSig
    comp.GetValue  = function() return value end
    comp.SetValue  = function(_, v)
        tb.Text = tostring(v)
        value   = tb.Text
    end
    comp.Destroy   = function() wrapper:Destroy() end
    return comp
end

-- ──────────────────────────────────────────────────────────────
--  COMPONENT: Slider
-- ──────────────────────────────────────────────────────────────
--[[
    Options (table):
        Label    string
        Sub      string
        Min      number  [0]
        Max      number  [100]
        Default  number  [Min]
        Step     number  [1]
        Unit     string  suffix e.g. "%"

    Returns:
        .OnChanged : Signal<number>
        :GetValue() -> number
        :SetValue(number)
        :Destroy()
--]]
function StellarUI:Slider(opts)
    opts     = opts or {}
    local lo = opts.Min     or 0
    local hi = opts.Max     or 100
    local st = opts.Step    or 1
    local v  = clamp(opts.Default or lo, lo, hi)
    local un = opts.Unit    or ""
    local signal = makeSignal()
    local isDrag = false

    local hasLabel = opts.Label ~= nil
    local hasSub   = opts.Sub   ~= nil
    local totalH   = hasLabel and (hasSub and 72 or 56) or 32

    local wrapper = new("Frame", {
        Size                   = UDim2.new(1, 0, 0, totalH),
        BackgroundTransparency = 1,
        BorderSizePixel        = 0,
    }, self._inner)

    if hasLabel then
        new("TextLabel", {
            Size                   = UDim2.new(1, -60, 0, 18),
            Text                   = opts.Label,
            TextColor3             = Theme.TxPrimary,
            TextSize               = 14,
            Font                   = Enum.Font.GothamMedium,
            TextXAlignment         = Enum.TextXAlignment.Left,
            BackgroundTransparency = 1,
        }, wrapper)
    end
    if hasSub then
        new("TextLabel", {
            Size                   = UDim2.new(1, -60, 0, 14),
            Position               = UDim2.new(0, 0, 0, 20),
            Text                   = opts.Sub,
            TextColor3             = Theme.TxMuted,
            TextSize               = 11,
            Font                   = Enum.Font.Gotham,
            TextXAlignment         = Enum.TextXAlignment.Left,
            BackgroundTransparency = 1,
        }, wrapper)
    end

    local badge = new("TextLabel", {
        Size             = UDim2.new(0, 52, 0, 24),
        Position         = UDim2.new(1, -52, 0, hasLabel and 0 or 4),
        Text             = tostring(v) .. un,
        TextColor3       = Theme.TxPrimary,
        TextSize         = 12,
        Font             = Enum.Font.GothamMedium,
        BackgroundColor3 = Theme.Panel2,
        BorderSizePixel  = 0,
    }, wrapper)
    corner(badge, 6)
    new("UIStroke", { Color = Theme.Border, Thickness = 1, Transparency = 0.30 }, badge)

    local trackY = hasLabel and (hasSub and 50 or 36) or 12

    local trackBG = new("Frame", {
        Size             = UDim2.new(1, 0, 0, 4),
        Position         = UDim2.new(0, 0, 0, trackY),
        BackgroundColor3 = Theme.Panel3,
        BorderSizePixel  = 0,
    }, wrapper)
    corner(trackBG, 2)

    local fill = new("Frame", {
        Size             = UDim2.new((v - lo) / (hi - lo), 0, 1, 0),
        BackgroundColor3 = Theme.Accent,
        BorderSizePixel  = 0,
    }, trackBG)
    corner(fill, 2)

    local thumb = new("Frame", {
        Size             = UDim2.new(0, 16, 0, 16),
        Position         = UDim2.new((v - lo) / (hi - lo), -8, 0, trackY - 6),
        BackgroundColor3 = Theme.Accent,
        BorderSizePixel  = 0,
        ZIndex           = 4,
    }, wrapper)
    corner(thumb, 8)
    new("UIStroke", { Color = Theme.Accent, Thickness = 2, Transparency = 0.45 }, thumb)

    local hitbox = new("TextButton", {
        Size                   = UDim2.new(1, 0, 0, 24),
        Position               = UDim2.new(0, 0, 0, trackY - 10),
        BackgroundTransparency = 1,
        Text                   = "",
        ZIndex                 = 8,
    }, wrapper)

    local function applyValue(pct)
        pct   = clamp(pct, 0, 1)
        local raw     = lo + pct * (hi - lo)
        local stepped = math.round(raw / st) * st
        v             = clamp(stepped, lo, hi)
        local p       = (v - lo) / (hi - lo)
        fill.Size      = UDim2.new(p, 0, 1, 0)
        thumb.Position = UDim2.new(p, -8, 0, trackY - 6)
        badge.Text     = tostring(v) .. un
        signal:Fire(v)
    end

    hitbox.MouseButton1Down:Connect(function(x, _y)
        isDrag = true
        applyValue((x - hitbox.AbsolutePosition.X) / hitbox.AbsoluteSize.X)
    end)

    local moveConn = UserInputService.InputChanged:Connect(function(input)
        if isDrag and input.UserInputType == Enum.UserInputType.MouseMovement then
            applyValue((input.Position.X - hitbox.AbsolutePosition.X) / hitbox.AbsoluteSize.X)
        end
    end)

    local upConn = UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            isDrag = false
        end
    end)

    local comp = {}
    comp.OnChanged = signal
    comp.GetValue  = function() return v end
    comp.SetValue  = function(_, val)
        applyValue((clamp(val, lo, hi) - lo) / (hi - lo))
    end
    comp.Destroy   = function()
        moveConn:Disconnect()
        upConn:Disconnect()
        wrapper:Destroy()
    end
    return comp
end

-- ──────────────────────────────────────────────────────────────
--  COMPONENT: Select (Dropdown)
-- ──────────────────────────────────────────────────────────────
--[[
    Options (table):
        Label    string
        Sub      string
        Options  table    { "A", "B", "C" }
        Default  string   initial selection

    Returns:
        .OnChanged : Signal<string>
        :GetValue() -> string
        :SetValue(string)
        :Destroy()
--]]
function StellarUI:Select(opts)
    opts = opts or {}
    local items    = opts.Options or { "Option 1", "Option 2" }
    local selected = opts.Default or items[1]
    local signal   = makeSignal()
    local isOpen   = false

    local hasLabel = opts.Label ~= nil
    local hasSub   = opts.Sub   ~= nil
    local yOff     = hasLabel and (hasSub and 36 or 22) or 0
    local wrapH    = yOff + 36

    local wrapper = new("Frame", {
        Size                   = UDim2.new(1, 0, 0, wrapH),
        BackgroundTransparency = 1,
        ClipsDescendants       = false,
        BorderSizePixel        = 0,
        ZIndex                 = 10,
    }, self._inner)

    if hasLabel then
        new("TextLabel", {
            Size                   = UDim2.new(1, 0, 0, 18),
            Text                   = opts.Label,
            TextColor3             = Theme.TxPrimary,
            TextSize               = 14,
            Font                   = Enum.Font.GothamMedium,
            TextXAlignment         = Enum.TextXAlignment.Left,
            BackgroundTransparency = 1,
            ZIndex                 = 11,
        }, wrapper)
    end
    if hasSub then
        new("TextLabel", {
            Size                   = UDim2.new(1, 0, 0, 14),
            Position               = UDim2.new(0, 0, 0, 18),
            Text                   = opts.Sub,
            TextColor3             = Theme.TxMuted,
            TextSize               = 11,
            Font                   = Enum.Font.Gotham,
            TextXAlignment         = Enum.TextXAlignment.Left,
            BackgroundTransparency = 1,
            ZIndex                 = 11,
        }, wrapper)
    end

    local display = new("TextButton", {
        Size                   = UDim2.new(1, 0, 0, 34),
        Position               = UDim2.new(0, 0, 0, yOff),
        BackgroundColor3       = Theme.Panel2,
        AutoButtonColor        = false,
        Text                   = "",
        BorderSizePixel        = 0,
        ZIndex                 = 11,
    }, wrapper)
    corner(display, 8)

    local dStroke = new("UIStroke", {
        Color        = Theme.Border,
        Thickness    = 1,
        Transparency = 0.30,
    }, display)

    local valueLabel = new("TextLabel", {
        Size                   = UDim2.new(1, -30, 1, 0),
        Position               = UDim2.new(0, 12, 0, 0),
        Text                   = selected,
        TextColor3             = Theme.TxPrimary,
        TextSize               = 13,
        Font                   = Enum.Font.Gotham,
        TextXAlignment         = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        ZIndex                 = 12,
    }, display)

    local arrow = new("TextLabel", {
        Size                   = UDim2.new(0, 22, 1, 0),
        Position               = UDim2.new(1, -24, 0, 0),
        Text                   = "v",
        TextColor3             = Theme.TxSecond,
        TextSize               = 10,
        Font                   = Enum.Font.GothamBold,
        BackgroundTransparency = 1,
        ZIndex                 = 12,
    }, display)

    local dropH    = #items * 34
    local dropdown = new("Frame", {
        Size             = UDim2.new(1, 0, 0, dropH),
        Position         = UDim2.new(0, 0, 0, yOff + 38),
        BackgroundColor3 = Theme.Panel3,
        Visible          = false,
        BorderSizePixel  = 0,
        ZIndex           = 40,
    }, wrapper)
    corner(dropdown, 8)
    new("UIStroke", { Color = Theme.Border, Thickness = 1, Transparency = 0.25 }, dropdown)

    -- Track each row for color refresh
    local rowMap = {}  -- [optionText] = TextButton

    local function refreshRows()
        for opt, btn in pairs(rowMap) do
            local active = opt == selected
            btn.TextColor3       = active and Theme.Accent or Theme.TxPrimary
            btn.BackgroundColor3 = active and Theme.Panel2  or Theme.Panel3
            btn.Text             = (active and "[v] " or "     ") .. opt
        end
    end

    local function closeDD()
        isOpen           = false
        dropdown.Visible = false
        tween(dStroke, { Color = Theme.Border }, 0.15)
        tween(arrow,   { Rotation = 0 },         0.20)
    end

    local function openDD()
        isOpen           = true
        dropdown.Visible = true
        tween(dStroke, { Color = Theme.Accent }, 0.15)
        tween(arrow,   { Rotation = 180 },        0.20)
    end

    for i, opt in ipairs(items) do
        local isActive = opt == selected
        local row = new("TextButton", {
            Size             = UDim2.new(1, 0, 0, 34),
            Position         = UDim2.new(0, 0, 0, (i - 1) * 34),
            BackgroundColor3 = isActive and Theme.Panel2 or Theme.Panel3,
            Text             = (isActive and "[v] " or "     ") .. opt,
            TextColor3       = isActive and Theme.Accent or Theme.TxPrimary,
            TextSize         = 13,
            Font             = Enum.Font.Gotham,
            TextXAlignment   = Enum.TextXAlignment.Left,
            AutoButtonColor  = false,
            BorderSizePixel  = 0,
            ZIndex           = 41,
        }, dropdown)

        rowMap[opt] = row

        row.MouseEnter:Connect(function()
            if opt ~= selected then
                tween(row, { BackgroundColor3 = Theme.Panel2 }, 0.10)
            end
        end)
        row.MouseLeave:Connect(function()
            if opt ~= selected then
                tween(row, { BackgroundColor3 = Theme.Panel3 }, 0.12)
            end
        end)
        row.MouseButton1Click:Connect(function()
            selected        = opt
            valueLabel.Text = opt
            closeDD()
            refreshRows()
            signal:Fire(selected)
        end)
    end

    display.MouseButton1Click:Connect(function()
        if isOpen then closeDD() else openDD() end
    end)

    local comp = {}
    comp.OnChanged = signal
    comp.GetValue  = function() return selected end
    comp.SetValue  = function(_, v)
        selected        = v
        valueLabel.Text = v
        refreshRows()
    end
    comp.Destroy   = function() wrapper:Destroy() end
    return comp
end

-- ──────────────────────────────────────────────────────────────
--  COMPONENT: CodeBlock
-- ──────────────────────────────────────────────────────────────
--[[
    Options (table):
        Code      string   source code content
        Language  string   language tag label     ["lua"]
        Height    number   body height in pixels  [120]

    Returns:
        :SetCode(string)
        :Destroy()
--]]
function StellarUI:CodeBlock(opts)
    opts = opts or {}
    local code  = opts.Code     or "-- your code here"
    local lang  = opts.Language or "lua"
    local bodyH = opts.Height   or 120

    local wrapper = new("Frame", {
        Size             = UDim2.new(1, 0, 0, bodyH + 34),
        BackgroundColor3 = Theme.Panel1,
        BorderSizePixel  = 0,
    }, self._inner)
    corner(wrapper, 8)
    new("UIStroke", { Color = Theme.Border, Thickness = 1, Transparency = 0.25 }, wrapper)

    -- Header bar
    local header = new("Frame", {
        Size             = UDim2.new(1, 0, 0, 33),
        BackgroundColor3 = Theme.Panel2,
        BorderSizePixel  = 0,
        ZIndex           = 2,
    }, wrapper)
    corner(header, 8)

    -- Traffic-light dots
    local dotColors = {
        Color3.fromRGB(255, 95, 87),
        Color3.fromRGB(255, 189, 46),
        Color3.fromRGB( 40, 200, 64),
    }
    for i, c in ipairs(dotColors) do
        local dot = new("Frame", {
            Size             = UDim2.new(0, 9, 0, 9),
            Position         = UDim2.new(0, 8 + (i - 1) * 14, 0.5, -4),
            BackgroundColor3 = c,
            BorderSizePixel  = 0,
            ZIndex           = 3,
        }, header)
        corner(dot, 5)
    end

    new("TextLabel", {
        Size                   = UDim2.new(0, 60, 1, 0),
        Position               = UDim2.new(0, 52, 0, 0),
        Text                   = lang,
        TextColor3             = Theme.TxSecond,
        TextSize               = 11,
        Font                   = Enum.Font.Code,
        BackgroundTransparency = 1,
        ZIndex                 = 3,
    }, header)

    local copyBtn = new("TextButton", {
        Size             = UDim2.new(0, 58, 0, 22),
        Position         = UDim2.new(1, -64, 0.5, -11),
        Text             = "Copy",
        TextColor3       = Theme.TxSecond,
        TextSize         = 11,
        Font             = Enum.Font.GothamMedium,
        BackgroundColor3 = Theme.Panel1,
        AutoButtonColor  = false,
        BorderSizePixel  = 0,
        ZIndex           = 3,
    }, header)
    corner(copyBtn, 5)
    new("UIStroke", { Color = Theme.Border, Thickness = 1, Transparency = 0.30 }, copyBtn)

    copyBtn.MouseButton1Click:Connect(function()
        copyToClipboard(code)
        copyBtn.Text       = "Copied!"
        copyBtn.TextColor3 = Theme.Teal
        task.delay(2, function()
            if copyBtn.Parent then
                copyBtn.Text       = "Copy"
                copyBtn.TextColor3 = Theme.TxSecond
            end
        end)
    end)

    local codeLabel = new("TextLabel", {
        Size                   = UDim2.new(1, -28, 1, -42),
        Position               = UDim2.new(0, 14, 0, 42),
        Text                   = code,
        TextColor3             = Theme.TxPrimary,
        TextSize               = 12,
        Font                   = Enum.Font.Code,
        TextXAlignment         = Enum.TextXAlignment.Left,
        TextYAlignment         = Enum.TextYAlignment.Top,
        BackgroundTransparency = 1,
        TextWrapped            = true,
        RichText               = false,
        ZIndex                 = 2,
    }, wrapper)

    local comp = {}
    comp.SetCode = function(_, c)
        code           = c
        codeLabel.Text = c
    end
    comp.Destroy = function() wrapper:Destroy() end
    return comp
end

-- ──────────────────────────────────────────────────────────────
--  COMPONENT: Badge
-- ──────────────────────────────────────────────────────────────
--[[
    Options (table):
        Text     string
        Variant  string   default|accent|success|danger|warning ["default"]

    Returns:
        :SetText(string)
        :Destroy()
--]]
function StellarUI:Badge(opts)
    opts = opts or {}
    local style = BADGE_STYLES[opts.Variant or "default"] or BADGE_STYLES.default
    local text  = opts.Text or "Badge"
    local w     = math.max(#text * 7 + 18, 40)

    local frame = new("Frame", {
        Size             = UDim2.new(0, w, 0, 20),
        BackgroundColor3 = style.BG,
        BorderSizePixel  = 0,
    }, self._inner)
    corner(frame, 5)

    local lbl = new("TextLabel", {
        Size                   = UDim2.new(1, 0, 1, 0),
        Text                   = text,
        TextColor3             = style.Tx,
        TextSize               = 11,
        Font                   = Enum.Font.GothamMedium,
