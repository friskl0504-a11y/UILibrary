    -- ════════════════════════════════════════

    --  SLIDER

    -- ════════════════════════════════════════



    function Options:AddSlider(Cfg)

        --[[

            Cfg = {

                Title:         string

                Description:   string

                MinValue:      number?   — default 0

                MaxValue:      number    — required

                Default:       number?   — default = MinValue

                AllowDecimals: boolean?

                DecimalAmount: number?   — decimal places if AllowDecimals

                Tab:           Instance

                Callback:      function(number)

            }

        ]]

        local Slider = Components and Clone(Components["Slider"])

        if not Slider then return end



        local Title, Desc = Options:GetLabels(Slider)

        local Main   = Slider:FindFirstChild("Slider")

        local Amount = Main and Main:FindFirstChild("Main") and Main.Main:FindFirstChild("Input")

        local Slide  = Main and Main:FindFirstChild("Slide")

        local Fire   = Slide and Slide:FindFirstChild("Fire")

        local Fill   = Slide and Slide:FindFirstChild("Highlight")



        local MinVal = Cfg.MinValue or 0

        local MaxVal = Cfg.MaxValue or 100

        local Active = false

        local Value  = Cfg.Default or MinVal



        local function Round(n)

            if Cfg.AllowDecimals then

                local p = 10 ^ (Cfg.DecimalAmount or 2)

                return math.floor(n * p + 0.5) / p

            end

            return math.round(n)

        end



        local function Update(Number)

            local scale

            if Number ~= nil then

                Number = math.clamp(Number, MinVal, MaxVal)

                scale  = (Number - MinVal) / (MaxVal - MinVal)

            else

                local slideX = Slide and Slide.AbsolutePosition.X or 0

                local slideW = Slide and Slide.AbsoluteSize.X     or 1

                -- Support both mouse and touch positions

                local posX = Player.Mouse.X

                scale  = math.clamp((posX - slideX) / slideW, 0, 1)

                Number = MinVal + scale * (MaxVal - MinVal)

            end



            Value = Round(Number)

            if Amount then Amount.Text = tostring(Value) end

            if Fill   then Fill.Size   = UDim2.fromScale(scale, 1) end

            if Cfg.Callback then Cfg.Callback(Value) end

        end



        local function StartSliding()

            Active = true

            repeat task.wait() Update()

            until not Active

        end



        -- Touch drag: track finger position for slider

        local TouchSlideConn

        local function StartTouchSlide(touchInput)

            Active = true

            TouchSlideConn = Connect(Services.Input.InputChanged, function(changedInput)

                if changedInput.UserInputType == Enum.UserInputType.Touch and Active then

                    if Slide then

                        local slideX = Slide.AbsolutePosition.X

                        local slideW = Slide.AbsoluteSize.X or 1

                        local scale  = math.clamp((changedInput.Position.X - slideX) / slideW, 0, 1)

                        local n      = MinVal + scale * (MaxVal - MinVal)

                        Value = Round(n)

                        if Amount then Amount.Text = tostring(Value) end

                        if Fill   then Fill.Size   = UDim2.fromScale(scale, 1) end

                        if Cfg.Callback then Cfg.Callback(Value) end

                    end

                end

            end)

        end



        if Amount then

            Connect(Amount.FocusLost, function()

                Update(tonumber(Amount.Text) or MinVal)

            end)

        end



        if Fire then

            Connect(Fire.MouseButton1Down, StartSliding)

            Connect(Fire.InputBegan, function(Input)

                if Input.UserInputType == Enum.UserInputType.Touch then

                    StartTouchSlide(Input)

                end

            end)

        end



        Connect(Services.Input.InputEnded, function(Input)

            local t = Input.UserInputType

            if t == Enum.UserInputType.MouseButton1 or t == Enum.UserInputType.Touch then

                Active = false

                if TouchSlideConn then

                    TouchSlideConn:Disconnect()

                    TouchSlideConn = nil

                end

            end

        end)



        -- Initialize visual position

        if Fill then Fill.Size = UDim2.fromScale(0, 1) end

        Update(Value)



        Animations:Hover(Slider)

        if Title then Title.Text = Cfg.Title       or "" end

        if Desc  then Desc.Text  = Cfg.Description or "" end

        SetProperty(Slider, { Name = Cfg.Title, Parent = Cfg.Tab, Visible = true })

    end



