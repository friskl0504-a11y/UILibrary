-- ═══════════════════════════════════════════════════════════════
-- Library:CreateWindow
-- ═══════════════════════════════════════════════════════════════

function Library:CreateWindow(Settings)

    -- Optional accent override
    if Settings.AccentColor then
        Theme.Accent     = Settings.AccentColor
        Theme.AccentDark = Color3.new(
            math.max(Settings.AccentColor.R - 0.14, 0),
            math.max(Settings.AccentColor.G - 0.14, 0),
            math.max(Settings.AccentColor.B - 0.14, 0)
        )
    end

    -- Clone window
    local Window  = Screen.Main:Clone()
    local Sidebar = Window:FindFirstChild("Sidebar")
    local Holder  = Window:FindFirstChild("Main")
    local BG      = Window:FindFirstChild("BackgroundShadow")
    local TabList = Sidebar:FindFirstChild("Tab")

    local Options      = {}
    local Examples     = {}
    local Opened       = true
    local Maximized    = false
    local BlurEnabled  = false
    local MobileTogBtn = nil
    local WinConns     = ConnList()    -- connection cleanup for this window

    -- Collect example templates (hidden prototypes)
    for _, ex in ipairs(Window:GetDescendants()) do
        if ex.Name:find("Example") and not Examples[ex.Name] then
            Examples[ex.Name] = ex
        end
    end

    -- Stored tab/section registry
    local StoredSections = {}
    local StoredTabs     = {}

    -- ──────────────────────────────────────────────────────────
    -- Mobile layout
    -- ──────────────────────────────────────────────────────────

    local function ApplyMobileLayout()
        if not IsTouchDevice or not Window.Parent then return end
        RecomputeMetrics()
        local inset = Metrics.Inset

        if Settings.MobileFullscreen or Metrics.VP.X <= 440 then
            Window.Size = UDim2.new(1, -(inset * 2), 1, -(inset * 2))
        else
            local fw = Metrics.IsLand and 0.78 or 0.95
            local fh = Metrics.IsLand and 0.88 or 0.85
            Window.Size = UDim2.fromScale(fw, fh)
        end

        Window.AnchorPoint = Vector2.new(0.5, 0.5)
        Window.Position    = UDim2.fromScale(0.5, Metrics.IsLand and 0.50 or 0.52)
    end

    if IsTouchDevice then
        Settings.Size = nil
        ApplyMobileLayout()
    end

    -- Drag & resize
    MakeDraggable(Window)
    MakeResizable(Window, Vector2.new(420, 280), Vector2.new(math.huge, math.huge))

    Window.Size = Settings.Size or Window.Size

    -- Blur init
    if Settings.Blurring then
        Blurs[Settings.Title] = Blur.new(Window, 5)
        BlurEnabled = true
    end

    -- ──────────────────────────────────────────────────────────
    -- Open / close toggle
    -- ──────────────────────────────────────────────────────────

    local keybind = Settings.MinimizeKeybind or Enum.KeyCode.LeftControl

    local function Close()
        if Opened then
            Opened = false
            Animations.Close(Window)
            if BlurEnabled and Blurs[Settings.Title] then
                Blurs[Settings.Title].root.Parent = nil
            end
            if MobileTogBtn then MobileTogBtn.Text = "≡" end
        else
            Opened = true
            Animations.Open(Window, 0)
            if BlurEnabled and Blurs[Settings.Title] then
                Blurs[Settings.Title].root.Parent = workspace.CurrentCamera
            end
            if MobileTogBtn then MobileTogBtn.Text = "✕" end
        end
    end

    -- ──────────────────────────────────────────────────────────
    -- Title-bar buttons (Close / Maximize / Minimize)
    -- FIX: use unified IsPress handler instead of MouseButton1Click
    -- ──────────────────────────────────────────────────────────

    for _, btn in ipairs(Sidebar.Top.Buttons:GetChildren()) do
        if not btn:IsA("TextButton") then continue end
        local name = btn.Name
        Animations.AddPressEffect(btn, true)

        local act = MakeActivate(function()
            if name == "Close" then
                Close()

            elseif name == "Maximize" then
                if Maximized then
                    Maximized = false
                    Tween(Window, 0.20, { Size = Settings.Size or Window.Size })
                else
                    Maximized = true
                    Tween(Window, 0.20, {
                        Size     = UDim2.fromScale(1, 1),
                        Position = UDim2.fromScale(0.5, 0.5),
                    })
                end

            elseif name == "Minimize" then
                Opened = false
                Window.Visible = false
                if Blurs[Settings.Title] then
                    Blurs[Settings.Title].root.Parent = nil
                end
                if MobileTogBtn then MobileTogBtn.Text = "≡" end
            end
        end, 0.20)

        WinConns.add(btn.InputBegan:Connect(function(input)
            if IsPress(input) then act() end
        end))
    end

    -- Keyboard toggle (desktop)
    WinConns.add(UserInputService.InputBegan:Connect(function(input, focused)
        if focused then return end
        if input.KeyCode == keybind then Close() end
    end))

    -- ──────────────────────────────────────────────────────────
    -- Tab switching
    -- ──────────────────────────────────────────────────────────

    function Options:SetTab(name)
        -- Animate tab buttons
        for _, btn in ipairs(TabList:GetChildren()) do
            if not btn:IsA("TextButton") then continue end
            local isThis = btn.Name == name
            local valObj = btn:FindFirstChild("Value")
            local isOpen = valObj and valObj.Value or false
            local pad    = btn:FindFirstChildOfClass("UIPadding")

            if isThis and not isOpen then
                if valObj then valObj.Value = true end
                if pad then Tween(pad, 0.20, { PaddingLeft = UDim.new(0, 24) }) end
                Tween(btn, 0.20, {
                    BackgroundTransparency = 0.82,
                    BackgroundColor3       = Theme.Accent,
                    Size                   = UDim2.new(1, -14, 0, Metrics.Touch),
                })
            elseif not isThis and isOpen then
                if valObj then valObj.Value = false end
                if pad then Tween(pad, 0.20, { PaddingLeft = UDim.new(0, 18) }) end
                Tween(btn, 0.20, {
                    BackgroundTransparency = 1,
                    BackgroundColor3       = Theme.Component,
                    Size                   = UDim2.new(1, -44, 0, Metrics.Touch),
                })
            end
        end

        -- Show/hide content panels
        for _, panel in ipairs(Holder:GetChildren()) do
            if not panel:IsA("CanvasGroup") then continue end
            local isThis = panel.Name == name
            local valObj = panel:FindFirstChild("Value")
            local isOpen = valObj and valObj.Value or false

            if isThis and not isOpen then
                if valObj then valObj.Value = true end
                panel.Visible = true
                Tween(panel, 0.22, { GroupTransparency = 0 })
            elseif not isThis and isOpen then
                if valObj then valObj.Value = false end
                Tween(panel, 0.16, { GroupTransparency = 1 })
                task.delay(0.18, function()
                    if panel and panel.Parent then panel.Visible = false end
                end)
            end
        end
    end

    -- ──────────────────────────────────────────────────────────
    -- AddTabSection
    -- ──────────────────────────────────────────────────────────

    function Options:AddTabSection(Info)
        local ex = Examples.SectionExample
        if not ex then return end
        local sec = ex:Clone()
        StoredSections[Info.Name] = Info.Order
        SetProps(sec, {
            Parent      = ex.Parent,
            Text        = Info.Name,
            Name        = Info.Name,
            LayoutOrder = Info.Order,
            Visible     = true,
        })
    end

    -- ──────────────────────────────────────────────────────────
    -- AddTab
    -- FIX: single unified activate handler (no double-fire)
    -- ──────────────────────────────────────────────────────────

    function Options:AddTab(Info)
        if StoredTabs[Info.Title] then
            error("[UILib] Duplicate tab: " .. tostring(Info.Title))
        end

        local tabEx  = Examples.TabButtonExample
        local mainEx = Examples.MainExample
        if not tabEx or not mainEx then return end

        local panel = mainEx:Clone()
        local tab   = tabEx:Clone()

        if Info.Icon then
            if tab:FindFirstChild("ICO") then tab.ICO.Image = Info.Icon end
        else
            if tab:FindFirstChild("ICO") then tab.ICO:Destroy() end
        end

        tab.TextLabel.Text = Info.Title
        tab.Size           = UDim2.new(1, -44, 0, Metrics.Touch)

        SetProps(panel, { Parent = mainEx.Parent, Name = Info.Title })
        SetProps(tab, {
            Parent      = tabEx.Parent,
            LayoutOrder = StoredSections[Info.Section] or (#StoredSections + 1),
            Name        = Info.Title,
            Visible     = true,
        })

        StoredTabs[Info.Title] = true

        -- FIX: one activate, one InputBegan — never double-fires
        local act = MakeActivate(function() Options:SetTab(Info.Title) end, 0.20)
        WinConns.add(tab.InputBegan:Connect(function(input)
            if IsPress(input) then act() end
        end))

        return panel:FindFirstChild("ScrollingFrame")
    end

    -- ──────────────────────────────────────────────────────────
    -- Notification system
    -- FIX: corrected position stack math & timing
    -- ──────────────────────────────────────────────────────────

    local NOTIF_H   = IsTouchDevice and 68 or 74
    local NOTIF_GAP = IsTouchDevice and 7  or 9
    local NOTIF_MAX = IsTouchDevice and 3  or 5

    local function RepositionNotifs()
        for i, n in ipairs(ActiveNotifs) do
            if n and n.Parent then
                local yOff = (i - 1) * (NOTIF_H + NOTIF_GAP)
                Tween(n, 0.18, {
                    Position = UDim2.new(
                        1, -(Metrics.PadX + 10),
                        1, -(yOff + NOTIF_H + 14 + Metrics.Inset)
                    )
                })
            end
        end
    end

    function Options:Notify(Info)
        -- Evict oldest when at capacity
        if #ActiveNotifs >= NOTIF_MAX then
            local oldest = table.remove(ActiveNotifs, 1)
            if oldest and oldest.Parent then
                Animations.Close(oldest)
                task.delay(0.28, function()
                    if oldest and oldest.Parent then oldest:Destroy() end
                end)
            end
        end

        local notif = Components.Notification:Clone()
        if not notif then return end

        local labels = notif:FindFirstChild("Labels")
        local titleL = labels and labels:FindFirstChild("Title")
        local descL  = labels and labels:FindFirstChild("Description")
        local timer  = notif:FindFirstChild("Timer")

        if timer then
            local fill = timer:FindFirstChild("Fill")
            if fill then fill.BackgroundColor3 = Theme.Accent end
        end

        if titleL then titleL.Text = Info.Title       or "Notification" end
        if descL  then descL.Text  = Info.Description or "" end

        notif.Position         = UDim2.new(1, 12, 1, -80)
        notif.GroupTransparency = 1
        notif.Visible          = true
        notif.Parent           = Screen.Frame

        table.insert(ActiveNotifs, notif)
        RepositionNotifs()

        local dur = Info.Duration or 3.0

        task.spawn(function()
            xpcall(function()
                Animations.Open(notif, 0, true)

                if timer then
                    timer.Size = UDim2.new(1, 0, 0, 4)
                    Tween(timer, dur, { Size = UDim2.new(0, 0, 0, 4) })
                end

                task.wait(dur)

                -- Remove from stack
                for i, n in ipairs(ActiveNotifs) do
                    if n == notif then table.remove(ActiveNotifs, i); break end
                end
                RepositionNotifs()

                Animations.Close(notif)
                task.delay(0.30, function()
                    if notif and notif.Parent then notif:Destroy() end
                end)

            end, function(err)
                warn("[UILib] Notification error:", err)
            end)
        end)
    end

