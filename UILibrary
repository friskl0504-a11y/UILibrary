function Library:CreateWindow(Settings)
    --[[
    Settings: {
        Title           : string
        Size            : UDim2
        Transparency    : number (0–1)
        MinimizeKeybind : Enum.KeyCode?
        Blurring        : boolean
        Theme           : string ("Dark" | "Light")
        AccentColor     : Color3?   -- override accent
        MobileFullscreen: boolean?  -- force fullscreen on mobile
    }
    ]]

    -- Override accent if provided
    if Settings.AccentColor then
        Theme.Accent     = Settings.AccentColor
        Theme.AccentDark = Color3.new(
            math.max(Settings.AccentColor.R - 0.15, 0),
            math.max(Settings.AccentColor.G - 0.15, 0),
            math.max(Settings.AccentColor.B - 0.15, 0)
        )
    end

    local Window  = Clone(Screen:WaitForChild("Main"))
    local Sidebar = Window:FindFirstChild("Sidebar")
    local Holder  = Window:FindFirstChild("Main")
    local BG      = Window:FindFirstChild("BackgroundShadow")
    local TabList = Sidebar:FindFirstChild("Tab")

    local Options      = {}
    local Examples     = {}
    local Opened       = true
    local Maximized    = false
    local BlurEnabled  = false

    -- Mobile: auto fullscreen or responsive size
    if IsMobile then
        if Settings.MobileFullscreen ~= false then
            -- Full screen with safe area inset
            Settings.Size = UDim2.new(1, -SafeAreaInset * 2, 1, -SafeAreaInset * 2)
            Window.Position = UDim2.fromScale(0.5, 0.5)
            Window.AnchorPoint = Vector2.new(0.5, 0.5)
        else
            -- Responsive size for landscape mode
            if IsLandscape then
                Settings.Size = UDim2.fromScale(0.9, 0.95)
            else
                Settings.Size = UDim2.fromScale(0.95, 0.9)
            end
            Window.Position = UDim2.fromScale(0.5, 0.5)
            Window.AnchorPoint = Vector2.new(0.5, 0.5)
        end
    end

    for _, Example in next, Window:GetDescendants() do
        if Example.Name:find("Example") and not Examples[Example.Name] then
            Examples[Example.Name] = Example
        end
    end

    -- UI setup
    Drag(Window)
    Resizeable(Window, Vector2.new(411, 271), Vector2.new(9e9, 9e9))
    Setup.Transparency = Settings.Transparency or 0
    Setup.Size         = Settings.Size
    Setup.ThemeMode    = Settings.Theme or "Dark"

    if Settings.Blurring then
        Blurs[Settings.Title] = Blur.new(Window, 5)
        BlurEnabled = true
    end

    if Settings.MinimizeKeybind then
        Setup.Keybind = Settings.MinimizeKeybind
    end

    --// Open / Close toggle
    local function Close()
        if Opened then
            if BlurEnabled then Blurs[Settings.Title].root.Parent = nil end
            Opened = false
            Animations:Close(Window)
            Window.Visible = false
        else
            Animations:Open(Window, Setup.Transparency)
            Opened = true
            if BlurEnabled then
                Blurs[Settings.Title].root.Parent = workspace.CurrentCamera
            end
        end
    end

    --// Title-bar buttons
    for _, Button in next, Sidebar.Top.Buttons:GetChildren() do
        if Button:IsA("TextButton") then
            local Name = Button.Name
            Animations:Component(Button, true)

            Connect(Button.MouseButton1Click, function()
                if Name == "Close" then
                    Close()
                elseif Name == "Maximize" then
                    if Maximized then
                        Maximized = false
                        Tween(Window, 0.2, { Size = Setup.Size })
                    else
                        Maximized = true
                        Tween(Window, 0.2, {
                            Size     = UDim2.fromScale(1, 1),
                            Position = UDim2.fromScale(0.5, 0.5)
                        })
                    end
                elseif Name == "Minimize" then
                    Opened = false
                    Window.Visible = false
                    if Blurs[Settings.Title] then
                        Blurs[Settings.Title].root.Parent = nil
                    end
                end
            end)
        end
    end

    --// Keyboard toggle (desktop)
    Services.Input.InputBegan:Connect(function(Input, Focused)
        if (Input == Setup.Keybind or Input.KeyCode == Setup.Keybind) and not Focused then
            Close()
        end
    end)

    --// ============================================================
    --// Tab System
    --// ============================================================

    function Options:SetTab(Name)
        for _, Button in next, TabList:GetChildren() do
            if Button:IsA("TextButton") then
                local IsOpen    = Button.Value
                local SameName  = (Button.Name == Name)
                local Padding   = Button:FindFirstChildOfClass("UIPadding")

                if SameName and not IsOpen.Value then
                    if Padding then
                        Tween(Padding, 0.25, { PaddingLeft = UDim.new(0, 25) })
                    end
                    -- Accent highlight for active tab
                    Tween(Button, 0.25, {
                        BackgroundTransparency = 0.85,
                        BackgroundColor3       = Theme.Accent,
                        Size                   = UDim2.new(1, -15, 0, Setup.TouchTargetMin),
                    })
                    SetProperty(IsOpen, { Value = true })

                elseif not SameName and IsOpen.Value then
                    if Padding then
                        Tween(Padding, 0.25, { PaddingLeft = UDim.new(0, 20) })
                    end
                    Tween(Button, 0.25, {
                        BackgroundTransparency = 1,
                        BackgroundColor3       = Theme.Component,
                        Size                   = UDim2.new(1, -44, 0, Setup.TouchTargetMin),
                    })
                    SetProperty(IsOpen, { Value = false })
                end
            end
        end

        for _, Main in next, Holder:GetChildren() do
            if Main:IsA("CanvasGroup") then
                local IsOpen   = Main.Value
                local SameName = (Main.Name == Name)
                local Scroll   = Main:FindFirstChild("ScrollingFrame")

                if SameName and not IsOpen.Value then
                    IsOpen.Value   = true
                    Main.Visible   = true
                    Tween(Main, 0.28, { GroupTransparency = 0 })
                    if Scroll then
                        Tween(Scroll["UIPadding"], 0.28, { PaddingTop = UDim.new(0, 6) })
                    end

                elseif not SameName and IsOpen.Value then
                    IsOpen.Value = false
                    Tween(Main, 0.18, { GroupTransparency = 1 })
                    if Scroll then
                        Tween(Scroll["UIPadding"], 0.18, { PaddingTop = UDim.new(0, 18) })
                    end
                    task.delay(0.2, function() Main.Visible = false end)
                end
            end
        end
    end

    function Options:AddTabSection(Settings)
        local Example = Examples["SectionExample"]
        local Section = Clone(Example)

        StoredInfo["Sections"][Settings.Name] = Settings.Order
        SetProperty(Section, {
            Parent      = Example.Parent,
            Text        = Settings.Name,
            Name        = Settings.Name,
            LayoutOrder = Settings.Order,
            Visible     = true,
        })
    end

    function Options:AddTab(Settings)
        if StoredInfo["Tabs"][Settings.Title] then
            error("[UI LIB]: A tab with the same name already exists")
        end

        local Example, MainExample = Examples["TabButtonExample"], Examples["MainExample"]
        local Section = StoredInfo["Sections"][Settings.Section]
        local Main    = Clone(MainExample)
        local Tab     = Clone(Example)

        if not Settings.Icon then
            Destroy(Tab["ICO"])
        else
            SetProperty(Tab["ICO"], { Image = Settings.Icon })
        end

        StoredInfo["Tabs"][Settings.Title] = { Tab }
        SetProperty(Tab["TextLabel"], { Text = Settings.Title })

        -- Mobile: Enforce minimum touch target
        Tab.Size = UDim2.new(1, -44, 0, Setup.TouchTargetMin)

        SetProperty(Main, {
            Parent = MainExample.Parent,
            Name   = Settings.Title,
        })

        SetProperty(Tab, {
            Parent      = Example.Parent,
            LayoutOrder = Section or (#StoredInfo["Sections"] + 1),
            Name        = Settings.Title,
            Visible     = true,
        })

        Connect(Tab.MouseButton1Click, function()
            Options:SetTab(Tab.Name)
        end)

        -- Also support touch tap
        Connect(Tab.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.Touch then
                Options:SetTab(Tab.Name)
            end
        end)

        return Main.ScrollingFrame
    end

    --// ============================================================
    --// Notifications — stacked, mobile-aware, memory-efficient
    --// ============================================================

    local NOTIF_HEIGHT = IsMobile and 65 or 70
    local NOTIF_GAP    = IsMobile and 6 or 8
    local NOTIF_MAX    = Setup.MaxNotifications
    local NOTIF_TIMEOUT = 2.5  -- Auto-cleanup timeout

    local function RepositionNotifications()
        for i, notif in ipairs(ActiveNotifications) do
            if notif and notif.Parent then  -- Safety check
                local yOffset = (i - 1) * (NOTIF_HEIGHT + NOTIF_GAP)
                Tween(notif, 0.2, {
                    Position = UDim2.new(1, -Setup.PaddingX - 10, 1, -(yOffset + NOTIF_HEIGHT + 10 + SafeAreaInset))
                })
            end
        end
    end

    function Options:Notify(Settings)
        -- Limit visible notifications
        if #ActiveNotifications >= NOTIF_MAX then
            local oldest = table.remove(ActiveNotifications, 1)
            if oldest and oldest.Parent then
                Animations:Close(oldest)
                task.delay(NOTIF_TIMEOUT, function()
                    if oldest and oldest.Parent then
                        oldest:Destroy()
                    end
                end)
            end
        end

        local Notification = Clone(Components["Notification"])
        if not Notification then return end
        
        local Title, Description = Options:GetLabels(Notification)
        local Timer = Notification["Timer"]

        -- Accent the timer bar
        if Timer and Timer:FindFirstChild("Fill") then
            Timer.Fill.BackgroundColor3 = Theme.Accent
        end

        if Title then SetProperty(Title, { Text = Settings.Title }) end
        if Description then SetProperty(Description, { Text = Settings.Description }) end
        SetProperty(Notification, { Parent = Screen["Frame"] })

        -- Position off-screen right, then slide in
        Notification.Position = UDim2.new(1, 10, 1, -80)
        Notification.Visible = true

        table.insert(ActiveNotifications, Notification)
        RepositionNotifications()

        local Duration = Settings.Duration or 3

        task.spawn(function()
            xpcall(function()
                Animations:Open(Notification, Setup.Transparency, true)
                if Timer then
                    Tween(Timer, Duration, { Size = UDim2.new(0, 0, 0, 4) })
                end
                task.wait(Duration)
                Animations:Close(Notification)
                task.wait(0.35)

                -- Remove from active list
                for i, n in ipairs(ActiveNotifications) do
                    if n == Notification then
                        table.remove(ActiveNotifications, i)
                        break
                    end
                end
                RepositionNotifications()

                task.wait(NOTIF_TIMEOUT)
                if Notification and Notification.Parent then
                    Notification:Destroy()
                end
            end, function(err)
                warn("[UI LIB] Notification error:", err)
            end)
        end)
    end

