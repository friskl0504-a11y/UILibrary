}

local Setup = {
    Keybind = Enum.KeyCode.LeftControl,
    Transparency = 0, -- fully opaque
    ThemeMode = "Dark",
    Size = nil,
    IsMobile = IsMobile,
    IsLandscape = false,
    ScreenScale = 1,

