-- Set multiple properties in one call
local function SetProps(obj, t)
    for k, v in pairs(t) do obj[k] = v end
    return obj
end

-- Color lerp
local function LerpColor(a, b, t)
    return Color3.new(
        a.R + (b.R - a.R) * t,
        a.G + (b.G - a.G) * t,
        a.B + (b.B - a.B) * t
    )
end

-- Scale a UDim2 by a scalar
local function ScaleU2(u, f)
    return UDim2.new(
        u.X.Scale * f, u.X.Offset * f,
        u.Y.Scale * f, u.Y.Offset * f
    )
end

-- Tween wrapper
local function Tween(obj, t, props, style, dir)
    if not obj or not obj.Parent then return end
    local tw = TweenService:Create(
        obj,
        TweenInfo.new(t,
            style or Enum.EasingStyle.Exponential,
            dir   or Enum.EasingDirection.Out
        ),
        props
    )
    tw:Play()
    return tw
end

local function TweenSpring(obj, t, props)
    return Tween(obj, t, props, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
end

--[[
    MakeActivate(callback, debounce?)
    ─────────────────────────────────
    Returns a single function that fires callback once per debounce
    window.  Use ONE connection that handles BOTH MouseButton1 and
    Touch – this is the fix for every double-fire bug.

    Usage:
        local act = MakeActivate(function() ... end)
        component.InputBegan:Connect(function(input)
            if IsPress(input) then act() end
        end)
]]
local function IsPress(input)
    local t = input.UserInputType
    return t == Enum.UserInputType.MouseButton1
        or t == Enum.UserInputType.Touch
end

local function MakeActivate(cb, debounce)
    debounce = debounce or 0.18
    local last = 0
    return function()
        local now = tick()
        if now - last < debounce then return end
        last = now
        task.spawn(cb)
    end
end

-- Connection list (for cleanup)
local function ConnList()
    local list = {}
    return {
        add = function(c) table.insert(list, c); return c end,
        clean = function()
            for _, c in ipairs(list) do
                if c and c.Connected then c:Disconnect() end
            end
            table.clear(list)
        end,
    }
end

