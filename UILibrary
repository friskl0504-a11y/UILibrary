        if TextBox then TextBox.TextSize = Setup.FontSize end

        local Stroke = Input:FindFirstChildOfClass("UIStroke")

        local function ShiftForKeyboard(Active)
            if not IsTouchDevice then return end
            local y = Active and (Metrics.IsLandscape and 0.46 or 0.43) or (Metrics.IsLandscape and 0.50 or 0.53)
            Tween(Window, 0.16, { Position = UDim2.fromScale(0.5, y) })
        end

        if TextBox then
            Connect(TextBox.Focused, function()
                if Stroke then
                    Tween(Stroke, 0.12, { Color = Theme.Accent, Thickness = 1.5 })
