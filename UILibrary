-- ─────────────────────────────────────────────────────────────
-- Metrics  (recomputed on viewport change)
-- ─────────────────────────────────────────────────────────────

local Camera  = workspace.CurrentCamera
local Metrics = {}

local function RecomputeMetrics()
    local vp        = (Camera and Camera.ViewportSize) or Vector2.new(390, 844)
    Metrics.VP      = vp
    Metrics.IsLand  = vp.X > vp.Y
    Metrics.Compact = vp.X <= 390
    Metrics.Scale   = math.clamp(vp.X / 390, 0.80, 1.45)
    Metrics.Inset   = IsTouchDevice and (Metrics.Compact and 10 or 14) or 0
    Metrics.Touch   = IsTouchDevice and math.clamp(math.floor(48 * Metrics.Scale), 44, 62) or 32
    Metrics.Font    = IsTouchDevice and math.clamp(math.floor(14 * Metrics.Scale + 0.5), 13, 17) or 13
    Metrics.PadX    = IsTouchDevice and math.clamp(math.floor(12 * Metrics.Scale + 0.5), 8, 18) or 10
    Metrics.PadY    = IsTouchDevice and math.clamp(math.floor( 8 * Metrics.Scale + 0.5), 6, 12) or 7
end

RecomputeMetrics()
if Camera then
    Camera:GetPropertyChangedSignal("ViewportSize"):Connect(RecomputeMetrics)
end

