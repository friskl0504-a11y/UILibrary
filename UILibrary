-- ============================================================
--  COMPONENT: Notification / Toast
-- ============================================================
--[[
    Options:
        Title   : string
        Message : string
        Variant : "info"|"success"|"danger"|"warning"
        Duration: number   -- seconds before auto-dismiss (default 3)
    Methods:
        :Dismiss()
--]]

local NOTIF_STYLES = {
    info    = { Icon = "ℹ", Color = Theme.Accent  },
    success = { Icon = "✓", Color = Theme.Teal    },
    danger  = { Icon = "✕", Color = Theme.Danger  },
    warning = { Icon = "⚠", Color = Theme.Warning },
}

function StellarUI:Notification(opts)
    opts = opts or {}
    local style    = NOTIF_STYLES[opts.Variant or "info"] or NOTIF_STYLES.info
    local duration = opts.Duration or 3

    local notif = create("Frame", {
        Size             = UDim2.new(1, 0, 0, 60),
        Position         = UDim2.new(0, 0, 0, -64),
        BackgroundColor3 = Theme.Panel2,
        BorderSizePixel  = 0,
        ClipsDescendants = false,
        ZIndex           = 100,
    }, self.Container)
    applyCorner(notif, 10)
    create("UIStroke", { Color = style.Color, Thickness = 1, Transparency = 0.4 }, notif)

    -- Accent bar on left
    create("Frame", {
        Size             = UDim2.new(0, 3, 1, 0),
        BackgroundColor3 = style.Color,
        BorderSizePixel  = 0,
        ZIndex           = 101,
    }, notif)
    local leftBar = notif:GetChildren()[#notif:GetChildren()]
    applyCorner(leftBar, 2)

    -- Icon
    create("TextLabel", {
        Size           = UDim2.new(0, 24, 1, 0),
        Position       = UDim2.new(0, 14, 0, 0),
        Text           = style.Icon,
        TextColor3     = style.Color,
        TextSize       = 18,
        Font           = Enum.Font.GothamBold,
        BackgroundTransparency = 1,
        ZIndex         = 101,
    }, notif)

    -- Title
    create("TextLabel", {
        Size           = UDim2.new(1, -52, 0, 20),
        Position       = UDim2.new(0, 44, 0, 10),
        Text           = opts.Title or "Notification",
        TextColor3     = Theme.TextPrimary,
        TextSize       = 13,
        Font           = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        ZIndex         = 101,
    }, notif)

    -- Message
    if opts.Message then
        create("TextLabel", {
            Size           = UDim2.new(1, -52, 0, 18),
            Position       = UDim2.new(0, 44, 0, 30),
            Text           = opts.Message,
            TextColor3     = Theme.TextSecond,
            TextSize       = 11,
            Font           = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            BackgroundTransparency = 1,
            ZIndex         = 101,
        }, notif)
    end

    -- Slide in
    tween(notif, { Position = UDim2.new(0, 0, 0, 0) }, 0.3, Enum.EasingStyle.Back)

    local function dismiss()
        tween(notif, { Position = UDim2.new(0, 0, 0, -64) }, 0.25)
        task.delay(0.3, function() notif:Destroy() end)
    end

    -- Close button
    local closeBtn = create("TextButton", {
        Size             = UDim2.new(0, 20, 0, 20),
        Position         = UDim2.new(1, -24, 0, 6),
        Text             = "✕",
        TextColor3       = Theme.TextSecond,
        TextSize         = 12,
        Font             = Enum.Font.GothamBold,
        BackgroundTransparency = 1,
        ZIndex           = 102,
    }, notif)
    closeBtn.MouseButton1Click:Connect(dismiss)

    if duration > 0 then
        task.delay(duration, dismiss)
    end

    local comp = {
        Instance = notif,
        Dismiss  = dismiss,
    }
    return comp
end

-- ============================================================
--  NAVBAR (Side or Bottom)
-- ============================================================
--[[
    Options:
        Items  : table   -- { { Id="main", Icon="⊞", Label="Main" }, ... }
        Mode   : string  -- "side" | "bottom"
        Default: string  -- initial active item Id
    Events:
        .OnChanged:Connect(function(id: string) end)
    Methods:
        :SetActive(id: string)
        :Destroy()
--]]

function StellarUI:NavBar(opts)
    opts  = opts or {}
    local items   = opts.Items   or {}
    local mode    = opts.Mode    or "side"
    local active  = opts.Default or (items[1] and items[1].Id or "")
    local signal  = makeSignal()
    local buttons = {}

    local isVertical = mode == "side"
    local navW = isVertical and 68 or 0
    local navH = isVertical and 0  or 58

    local nav = create("Frame", {
        Size             = isVertical
            and UDim2.new(0, navW, 1, 0)
            or  UDim2.new(1, 0, 0, navH),
        Position         = isVertical
            and UDim2.new(0, 0, 0, 0)
            or  UDim2.new(0, 0, 1, -navH),
        BackgroundColor3 = Theme.Panel1,
        BorderSizePixel  = 0,
    }, self.Container)

    -- Separator line
    create("Frame", {
        Size             = isVertical
            and UDim2.new(0, 1, 1, 0)
            or  UDim2.new(1, 0, 0, 1),
        Position         = isVertical
            and UDim2.new(1, -1, 0, 0)
            or  UDim2.new(0, 0, 0, 0),
        BackgroundColor3 = Theme.Border,
        BackgroundTransparency = 0.5,
        BorderSizePixel  = 0,
    }, nav)

    applyListLayout(nav,
        isVertical and Enum.FillDirection.Vertical or Enum.FillDirection.Horizontal,
        isVertical and 4 or 0,
        Enum.HorizontalAlignment.Center
    )
    applyPadding(nav, 10, 0, 10, 0)

    local function refresh()
        for id, btn in pairs(buttons) do
            local isActive = id == active
            tween(btn.frame, {
                BackgroundColor3 = isActive and Theme.AccentDim or Theme.Panel1,
                BackgroundTransparency = isActive and 0 or 1,
            }, 0.15)
            btn.label.TextColor3 = isActive and Theme.Accent or Theme.TextSecond
        end
    end

    for _, item in ipairs(items) do
        local itemFrame = create("Frame", {
            Size             = isVertical
                and UDim2.new(0, 52, 0, 52)
                or  UDim2.new(1/#items, 0, 1, 0),
            BackgroundColor3 = item.Id == active and Theme.AccentDim or Theme.Panel1,
            BackgroundTransparency = item.Id == active and 0 or 1,
            BorderSizePixel  = 0,
        }, nav)
        applyCorner(itemFrame, 9)

        local iconLbl = create("TextLabel", {
            Size           = UDim2.new(1, 0, 0, 22),
            Position       = UDim2.new(0, 0, 0, 8),
            Text           = item.Icon or "◇",
            TextColor3     = item.Id == active and Theme.Accent or Theme.TextSecond,
            TextSize       = 16,
            Font           = Enum.Font.Gotham,
            BackgroundTransparency = 1,
        }, itemFrame)

        local textLbl = create("TextLabel", {
            Name           = "Label",
            Size           = UDim2.new(1, 0, 0, 12),
            Position       = UDim2.new(0, 0, 0, 32),
            Text           = item.Label or item.Id,
            TextColor3     = item.Id == active and Theme.Accent or Theme.TextSecond,
            TextSize       = 9,
            Font           = Enum.Font.Gotham,
            BackgroundTransparency = 1,
        }, itemFrame)

        local hitbox = create("TextButton", {
            Size               = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Text               = "",
            ZIndex             = 5,
        }, itemFrame)

        buttons[item.Id] = { frame = itemFrame, label = textLbl, icon = iconLbl }

        hitbox.MouseButton1Click:Connect(function()
            active = item.Id
            refresh()
            signal:Fire(active)
        end)
    end

    local comp = {
        Instance  = nav,
        OnChanged = signal,
        SetActive = function(_, id)
            active = id
            refresh()
        end,
        Destroy   = function() nav:Destroy() end,
    }
    return comp
end

-- ============================================================
--  CONSTRUCTOR
-- ============================================================

function StellarUI.new(parent)
    local self = setmetatable({}, StellarUI)

    self.Container = create("Frame", {
        Size             = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = Theme.BG,
        BackgroundTransparency = 0,
        BorderSizePixel  = 0,
    }, parent)

    applyListLayout(self.Container, Enum.FillDirection.Vertical, 0)
    applyPadding(self.Container, 0, 16, 16, 16)

    self.Theme = Theme

    return self
end
    return StellarUI
