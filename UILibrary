-- ============================================================
--  COMPONENT: ProgressBar
-- ============================================================
--[[
    Options:
        Label   : string
        Value   : number   (0–100)
        Max     : number   (default 100)
        Variant : "accent"|"success"|"danger"|"warning"
    Methods:
        :SetValue(number)
        :GetValue() -> number
        :Destroy()
--]]

local PROGRESS_COLORS = {
    accent  = Theme.Accent,
    success = Theme.Teal,
    danger  = Theme.Danger,
    warning = Theme.Warning,
}

function StellarUI:ProgressBar(opts)
    opts    = opts or {}
    local max   = opts.Max   or 100
    local value = math.clamp(opts.Value or 0, 0, max)
    local color = PROGRESS_COLORS[opts.Variant or "accent"] or Theme.Accent

    local wrapper = create("Frame", {
        Size             = UDim2.new(1, 0, 0, opts.Label and 36 or 14),
        BackgroundTransparency = 1,
        BorderSizePixel  = 0,
    }, self.Container)

    local pctLabel
    if opts.Label then
        create("TextLabel", {
            Size           = UDim2.new(1, -50, 0, 16),
            Text           = opts.Label,
            TextColor3     = Theme.TextPrimary,
            TextSize       = 13,
            Font           = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            BackgroundTransparency = 1,
        }, wrapper)
        pctLabel = create("TextLabel", {
            Size           = UDim2.new(0, 48, 0, 16),
            Position       = UDim2.new(1, -48, 0, 0),
            Text           = math.round(value / max * 100) .. "%",
            TextColor3     = Theme.TextSecond,
            TextSize       = 11,
            Font           = Enum.Font.GothamMedium,
            TextXAlignment = Enum.TextXAlignment.Right,
            BackgroundTransparency = 1,
        }, wrapper)
    end

    local trackY = opts.Label and 22 or 4
    local track = create("Frame", {
        Size             = UDim2.new(1, 0, 0, 5),
        Position         = UDim2.new(0, 0, 0, trackY),
        BackgroundColor3 = Theme.Panel3,
        BorderSizePixel  = 0,
    }, wrapper)
    applyCorner(track, 3)

    local fill = create("Frame", {
        Size             = UDim2.new(value / max, 0, 1, 0),
        BackgroundColor3 = color,
        BorderSizePixel  = 0,
    }, track)
    applyCorner(fill, 3)

    local comp = {
        Instance = wrapper,
        GetValue = function() return value end,
        SetValue = function(_, v)
            value = math.clamp(v, 0, max)
            local pct = value / max
            tween(fill, { Size = UDim2.new(pct, 0, 1, 0) }, 0.3)
            if pctLabel then
                pctLabel.Text = math.round(pct * 100) .. "%"
            end
        end,
        Destroy = function() wrapper:Destroy() end,
    }
    return comp
end

-- ============================================================
--  COMPONENT: Avatar
-- ============================================================
--[[
    Options:
        Name   : string   -- used to generate initials (e.g. "Alex Ray" -> "AR")
        Size   : number   -- pixel size (default 36)
        Status : string   -- "online"|"away"|"busy"|"offline"
    Methods:
        :SetStatus(string)
        :Destroy()
--]]

local STATUS_COLORS = {
    online  = Color3.fromRGB( 34, 197,  94),
    away    = Theme.Warning,
    busy    = Theme.Danger,
    offline = Theme.TextSecond,
}

function StellarUI:Avatar(opts)
    opts = opts or {}
    local name   = opts.Name or "User"
    local sz     = opts.Size or 36

    local parts    = name:split(" ")
    local initials = ""
    for i = 1, math.min(2, #parts) do
        initials = initials .. parts[i]:sub(1, 1):upper()
    end

    local frame = create("Frame", {
        Size             = UDim2.new(0, sz, 0, sz),
        BackgroundColor3 = Theme.Accent,
        BorderSizePixel  = 0,
    }, self.Container)
    applyCorner(frame, sz / 2)

    -- Gradient background
    create("UIGradient", {
        Color   = ColorSequence.new(Theme.Accent, Theme.Teal),
        Rotation = 135,
    }, frame)

    create("TextLabel", {
        Size           = UDim2.new(1, 0, 1, 0),
        Text           = initials,
        TextColor3     = Color3.fromRGB(255,255,255),
        TextSize       = math.floor(sz * 0.34),
        Font           = Enum.Font.GothamBold,
        BackgroundTransparency = 1,
        ZIndex         = 2,
    }, frame)

    -- Status dot
    local dotSz   = math.floor(sz * 0.27)
    local statusDot
    if opts.Status then
        statusDot = create("Frame", {
            Size             = UDim2.new(0, dotSz, 0, dotSz),
            Position         = UDim2.new(1, -dotSz + 1, 1, -dotSz + 1),
            BackgroundColor3 = STATUS_COLORS[opts.Status] or Theme.TextSecond,
            BorderSizePixel  = 2,
            ZIndex           = 3,
        }, frame)
        applyCorner(statusDot, dotSz / 2)
    end

    local comp = {
        Instance  = frame,
        SetStatus = function(_, s)
            if statusDot then
                statusDot.BackgroundColor3 = STATUS_COLORS[s] or Theme.TextSecond
            end
        end,
        Destroy   = function() frame:Destroy() end,
    }
    return comp
end

