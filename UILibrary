--- Create a Roblox Instance and assign properties in one call.
local function new(class, props, parent)
    local inst = Instance.new(class)
    for k, v in pairs(props or {}) do
        inst[k] = v
    end
    if parent then inst.Parent = parent end
    return inst
end

--- Attach a UICorner to `parent`.
local function corner(parent, radius)
    return new("UICorner", { CornerRadius = UDim.new(0, radius or 8) }, parent)
end

--- Attach a UIListLayout to `parent`.
local function listLayout(parent, direction, gap, halign)
    return new("UIListLayout", {
        FillDirection       = direction or Enum.FillDirection.Vertical,
        Padding             = UDim.new(0, gap or 0),
        HorizontalAlignment = halign or Enum.HorizontalAlignment.Left,
        VerticalAlignment   = Enum.VerticalAlignment.Top,
        SortOrder           = Enum.SortOrder.LayoutOrder,
    }, parent)
end

--- Attach a UIPadding to `parent`.
local function padding(parent, t, r, b, l)
    return new("UIPadding", {
        PaddingTop    = UDim.new(0, t or 0),
        PaddingRight  = UDim.new(0, r or 0),
        PaddingBottom = UDim.new(0, b or 0),
        PaddingLeft   = UDim.new(0, l or 0),
    }, parent)
end

--- Lightweight Signal — returned connection has :Disconnect().
local function makeSignal()
    local cbs = {}
    local sig = {}

    function sig:Connect(fn)
        assert(type(fn) == "function", "[StellarUI] Signal:Connect expects a function")
        cbs[fn] = true
        return {
            Disconnect = function()
                cbs[fn] = nil
            end,
        }
    end

    function sig:Fire(...)
        for fn in pairs(cbs) do
            local ok, err = pcall(fn, ...)
            if not ok then
                warn("[StellarUI] Signal callback error:", err)
            end
        end
    end

    function sig:DisconnectAll()
        cbs = {}
    end

    return sig
end

--- Tween helper.
local function tween(inst, goals, duration, style, direction)
    local info = TweenInfo.new(
        duration  or 0.20,
        style     or Enum.EasingStyle.Quint,
        direction or Enum.EasingDirection.Out
    )
    local tw = TweenService:Create(inst, info, goals)
    tw:Play()
    return tw
end

--- Copy text to clipboard (Studio + common executor environments).
local function copyToClipboard(text)
    if RunService:IsStudio() then
        pcall(function()
            game:GetService("StudioService"):CopyToClipboard(text)
        end)
        return
    end
    -- executor fallbacks (setclipboard / toclipboard)
    if setclipboard then
        pcall(setclipboard, text)
    elseif toclipboard then
        pcall(toclipboard, text)
    end
end

--- Safe string split — avoids relying on the non-standard :split() method.
local function splitStr(str, sep)
    local parts   = {}
    local pattern = "([^" .. sep .. "]+)"
    for part in str:gmatch(pattern) do
        parts[#parts + 1] = part
    end
    return parts
end

--- Clamp helper.
local function clamp(n, lo, hi)
    return math.max(lo, math.min(hi, n))
end

