    -- ──────────────────────────────────────────────────────────
    -- Theme system
    -- ──────────────────────────────────────────────────────────

    local function ApplyTheme(newTheme)
        if newTheme then Theme = newTheme end

        Window.BackgroundColor3  = Theme.Primary
        if Holder then Holder.BackgroundColor3 = Theme.Secondary end
        Window.GroupTransparency = 0
        if BG then BG.BackgroundTransparency = 0.20 end

        local ws = Window:FindFirstChildOfClass("UIStroke")
        if ws then ws.Color = Theme.Shadow end

        if MobileTogBtn then
            MobileTogBtn.BackgroundColor3 = Theme.Component
            MobileTogBtn.TextColor3       = Theme.Title
            local s = MobileTogBtn:FindFirstChildOfClass("UIStroke")
            if s then s.Color = Theme.Outline end
        end

        for _, d in ipairs(Screen:GetDescendants()) do
            local n   = d.Name
            local cls = d.ClassName

            if n == "Title" and cls == "TextLabel" then
                d.TextColor3 = Theme.Title
                d.TextSize   = Metrics.Font

            elseif n == "Description" and cls == "TextLabel" then
                d.TextColor3 = Theme.Description
                d.TextSize   = math.max(12, Metrics.Font - 1)

            elseif n == "Section" and cls == "TextLabel" then
                d.TextColor3 = Theme.Accent

            elseif n == "Notification" and cls == "CanvasGroup" then
                d.BackgroundColor3  = Theme.Secondary
                d.GroupTransparency = 0
                local st = d:FindFirstChildOfClass("UIStroke")
                if st then st.Color = Theme.Outline end

            elseif n == "Main" and cls == "Frame" then
                if d.Parent == Window then
                    d.BackgroundColor3 = Theme.Secondary
                else
                    -- Check if it's a toggle track
                    local valObj = d.Parent and d.Parent:FindFirstChild("Value")
                    if valObj and not valObj.Value then
                        d.BackgroundColor3 = Theme.Interactables
                        local circ = d:FindFirstChild("Circle")
                        if circ then circ.BackgroundColor3 = Theme.Primary end
                    else
                        d.BackgroundColor3 = Theme.Interactables
                    end
                end

            elseif n == "Outline" and cls == "UIStroke" then
                d.Color = Theme.Outline

            elseif n == "Highlight" and cls == "Frame"
                and d.Parent and d.Parent.Name == "Slide" then
                d.BackgroundColor3 = Theme.Accent

            elseif cls == "ImageLabel"
                and d.Image ~= "rbxassetid://6644618143" then
                d.ImageColor3 = Theme.Icon

            elseif cls == "ScrollingFrame" then
                d.ScrollBarImageColor3 = Theme.Accent

            elseif cls == "TextButton" and d:FindFirstChild("Labels") then
                d.BackgroundColor3 = Theme.Component
            end
        end
    end

    function Options:SetTheme(Info)
        ApplyTheme(Info)
    end

    -- ──────────────────────────────────────────────────────────
    -- Settings API
    -- ──────────────────────────────────────────────────────────

    function Options:SetSetting(setting, value)
        if setting == "Size" then
            Window.Size  = value
            Settings.Size = value

        elseif setting == "Keybind" then
            keybind = value

        elseif setting == "Accent" then
            Theme.Accent    = value
            Theme.AccentDark = Color3.new(
                math.max(value.R - 0.14, 0),
                math.max(value.G - 0.14, 0),
                math.max(value.B - 0.14, 0)
            )
            ApplyTheme(Theme)

        elseif setting == "Theme" and type(value) == "table" then
            ApplyTheme(value)

        elseif setting == "Blur" then
            local b = Blurs[Settings.Title]
            if value then
                BlurEnabled = true
                if not b then
                    Blurs[Settings.Title] = Blur.new(Window, 5)
                elseif b.root and not b.root.Parent then
                    b.root.Parent = workspace.CurrentCamera
                end
            else
                BlurEnabled = false
                if b and b.root then b.root.Parent = nil end
            end

        else
            warn("[UILib] SetSetting: unknown key '" .. tostring(setting) .. "'")
        end
    end

    -- ──────────────────────────────────────────────────────────
    -- Destroy window + clean all connections
    -- ──────────────────────────────────────────────────────────

    function Options:Destroy()
        WinConns.clean()
        if MobileTogBtn and MobileTogBtn.Parent then
            MobileTogBtn:Destroy()
        end
        if Window and Window.Parent then
            Window:Destroy()
        end
        if Blurs[Settings.Title] and Blurs[Settings.Title].root then
            Blurs[Settings.Title].root:Destroy()
        end
    end

    -- ──────────────────────────────────────────────────────────
    -- Finalize
    -- ──────────────────────────────────────────────────────────

    SetProps(Window, {
        Visible           = true,
        Parent            = Screen,
        GroupTransparency = 0,
    })

    ApplyTheme()
    Animations.Open(Window, 0)

    if IsTouchDevice then
        MobileTogBtn = CreateMobileToggle(Screen, Close)
        if MobileTogBtn then
            MobileTogBtn.Text = Opened and "✕" or "≡"
        end

        -- Re-layout on orientation change
        if Camera then
            WinConns.add(Camera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
                if Window and Window.Parent then
                    ApplyMobileLayout()
                end
            end))
        end
    end

    return Options
end

return Library
