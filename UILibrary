    -- ──────────────────────────────────────────────────────────
    -- Button
    -- FIX: MakeActivate replaces MouseButton1Click + InputBegan:Touch
    -- ──────────────────────────────────────────────────────────

    function Options:AddButton(Info)
        local btn = Components.Button:Clone()
        if not btn then return end

        local titleL, descL = Options:GetLabels(btn)
        btn.Size = UDim2.new(1, 0, 0,
            math.max(btn.Size.Y.Offset, Metrics.Touch + Metrics.PadY))

        local act = MakeActivate(function()
            Tween(btn, 0.08, {
                BackgroundColor3 = LerpColor(Theme.Component, Theme.Accent, 0.30)
            })
            task.delay(0.14, function()
                if btn and btn.Parent then
                    Tween(btn, 0.18, { BackgroundColor3 = Theme.Component })
                end
            end)
            if Info.Callback then Info.Callback() end
        end, 0.16)

        Animations.AddPressEffect(btn)
        btn.InputBegan:Connect(function(input)
            if IsPress(input) then act() end
        end)

        if titleL then titleL.Text = Info.Title       or "Button" end
        if descL  then descL.Text  = Info.Description or "" end
        SetProps(btn, { Name = Info.Title or "Button", Parent = Info.Tab, Visible = true })

        return btn
    end

    -- ──────────────────────────────────────────────────────────
    -- Input (text box)
    -- FIX: single InputBegan for tap-to-focus; no duplicate click handler
    -- ──────────────────────────────────────────────────────────

    function Options:AddInput(Info)
        local inp = Components.Input:Clone()
        if not inp then return end

        local titleL, descL = Options:GetLabels(inp)
        local box    = inp.Main and inp.Main:FindFirstChild("Input")
        local stroke = inp:FindFirstChildOfClass("UIStroke")

        inp.Size = UDim2.new(1, 0, 0,
            math.max(inp.Size.Y.Offset, Metrics.Touch + Metrics.PadY))
        if box then box.TextSize = Metrics.Font end

        -- Shift window up when on-screen keyboard appears
        local function ShiftWindow(active)
            if not IsTouchDevice then return end
            local y = active
                and (Metrics.IsLand and 0.42 or 0.38)
                or  (Metrics.IsLand and 0.50 or 0.52)
            Tween(Window, 0.20, { Position = UDim2.fromScale(0.5, y) })
        end

        if box then
            box.Focused:Connect(function()
                if stroke then Tween(stroke, 0.12, { Color = Theme.Accent, Thickness = 1.8 }) end
                ShiftWindow(true)
            end)
            box.FocusLost:Connect(function()
                if stroke then Tween(stroke, 0.16, { Color = Theme.Outline, Thickness = 1.0 }) end
                ShiftWindow(false)
                if Info.Callback then Info.Callback(box.Text) end
            end)
        end

        -- Single tap-to-focus handler (no MouseButton1Click duplication)
        inp.InputBegan:Connect(function(input)
            if IsPress(input) then
                if box then box:CaptureFocus() end
            end
        end)

        Animations.AddPressEffect(inp)
        if titleL then titleL.Text = Info.Title       or "Input" end
        if descL  then descL.Text  = Info.Description or "" end
        SetProps(inp, { Name = Info.Title or "Input", Parent = Info.Tab, Visible = true })

        return inp
    end

    -- ──────────────────────────────────────────────────────────
    -- Toggle
    -- FIX: MakeActivate prevents double-fire
    -- ──────────────────────────────────────────────────────────

    function Options:AddToggle(Info)
        local tog = Components.Toggle:Clone()
        if not tog then return end

        local titleL, descL = Options:GetLabels(tog)
        local valObj = tog:FindFirstChild("Value")
        local main   = tog:FindFirstChild("Main")
        local circle = main and main:FindFirstChild("Circle")

        tog.Size = UDim2.new(1, 0, 0, math.max(tog.Size.Y.Offset, Metrics.Touch))

        local function Set(val)
            if val then
                Tween(main, 0.20, { BackgroundColor3 = Theme.Accent })
                if circle then
                    Tween(circle, 0.20, {
                        BackgroundColor3 = Color3.new(1, 1, 1),
                        Position         = UDim2.new(1, -17, 0.5, 0),
                    })
                end
            else
                Tween(main, 0.20, { BackgroundColor3 = Theme.Interactables })
                if circle then
                    Tween(circle, 0.20, {
                        BackgroundColor3 = Theme.Primary,
                        Position         = UDim2.new(0, 3, 0.5, 0),
                    })
                end
            end
            if valObj then valObj.Value = val end
        end

        local act = MakeActivate(function()
            local newVal = not (valObj and valObj.Value or false)
            Set(newVal)
            if Info.Callback then Info.Callback(newVal) end
        end, 0.16)

        Animations.AddPressEffect(tog)
        tog.InputBegan:Connect(function(input)
            if IsPress(input) then act() end
        end)

        Set(Info.Default == true)
        if titleL then titleL.Text = Info.Title       or "Toggle" end
        if descL  then descL.Text  = Info.Description or "" end
        SetProps(tog, { Name = Info.Title or "Toggle", Parent = Info.Tab, Visible = true })

        return { Set = Set }
    end

    -- ──────────────────────────────────────────────────────────
    -- Keybind
    -- ──────────────────────────────────────────────────────────

    function Options:AddKeybind(Info)
        local kb = Components.Keybind:Clone()
        if not kb then return end

        local titleL, descL = Options:GetLabels(kb)
        local bindLbl = kb.Main and kb.Main:FindFirstChild("Options")
        local stroke  = kb:FindFirstChildOfClass("UIStroke")
        local listening = false

        local function StartListening()
            if listening then return end
            listening = true
            if bindLbl then bindLbl.Text = "…" end
            if stroke then Tween(stroke, 0.12, { Color = Theme.Accent }) end

            local conn
            conn = UserInputService.InputBegan:Connect(function(key, focused)
                if focused then return end
                listening = false
                conn:Disconnect()

                local t    = key.UserInputType
                local disp = "?"

                if     t == Enum.UserInputType.Touch        then disp = "TAP"
                elseif t == Enum.UserInputType.MouseButton1 then disp = "MB1"
                elseif t == Enum.UserInputType.MouseButton2 then disp = "MB2"
                elseif t == Enum.UserInputType.MouseButton3 then disp = "MB3"
                elseif t == Enum.UserInputType.Keyboard     then
                    disp = tostring(key.KeyCode):gsub("Enum%.KeyCode%.", "")
                end

                if bindLbl then bindLbl.Text = disp end
                if stroke  then Tween(stroke, 0.16, { Color = Theme.Outline }) end
                if Info.Callback then Info.Callback(key) end
            end)
        end

        local act = MakeActivate(StartListening, 0.20)
        Animations.AddPressEffect(kb)
        kb.InputBegan:Connect(function(input)
            if IsPress(input) then act() end
        end)

        if titleL then titleL.Text = Info.Title       or "Keybind" end
        if descL  then descL.Text  = Info.Description or "" end
        SetProps(kb, { Name = Info.Title or "Keybind", Parent = Info.Tab, Visible = true })

        return kb
    end

    -- ──────────────────────────────────────────────────────────
    -- Dropdown  (bottom-sheet on mobile)
    -- FIX: SelectOption always selects — was incorrectly toggling
    -- ──────────────────────────────────────────────────────────

    function Options:AddDropdown(Info)
        local dd = Components.Dropdown:Clone()
        if not dd then return end

        local titleL, descL = Options:GetLabels(dd)
        local selLabel  = dd.Main and dd.Main:FindFirstChild("Options")
        local curValue  = Info.Default or nil   -- track current selection

        local function OpenSheet()
            local ex = Examples.DropdownExample
            if not ex then return end
            local sheet   = ex:Clone()
            local buttons = sheet.Top and sheet.Top:FindFirstChild("Buttons")
            if not buttons then return end

            -- Position: bottom-sheet on mobile, centered on desktop
            if IsTouchDevice then
                local h = Metrics.Compact and 0.72 or 0.68
                SetProps(sheet, {
                    AnchorPoint = Vector2.new(0.5, 1),
                    Position    = UDim2.new(0.5, 0, 1, 80),
                    Size        = UDim2.new(1, -(Metrics.Inset * 2), h, 0),
                })
            else
                SetProps(sheet, {
                    AnchorPoint = Vector2.new(0.5, 0.5),
                    Position    = UDim2.fromScale(0.5, 0.5),
                })
            end

            SetProps(sheet, { Parent = Window })
            if BG then Tween(BG, 0.16, { BackgroundTransparency = 0.18 }) end
            Animations.Open(sheet, 0, true)

            if IsTouchDevice then
                task.delay(0.04, function()
                    TweenSpring(sheet, 0.24, {
                        Position = UDim2.new(0.5, 0, 1, -(Metrics.Inset + 4))
                    })
                end)
            end

            local function CloseSheet()
                if BG then Tween(BG, 0.16, { BackgroundTransparency = 1 }) end
                if IsTouchDevice then
                    Tween(sheet, 0.18, { Position = UDim2.new(0.5, 0, 1, 80) })
                    task.delay(0.20, function()
                        if sheet and sheet.Parent then sheet:Destroy() end
                    end)
                else
                    Animations.Close(sheet)
                    task.delay(0.24, function()
                        if sheet and sheet.Parent then sheet:Destroy() end
                    end)
                end
            end

            -- Close button in sheet header
            for _, btn in ipairs(buttons:GetChildren()) do
                if btn:IsA("TextButton") then
                    local a = MakeActivate(CloseSheet, 0.20)
                    btn.InputBegan:Connect(function(input)
                        if IsPress(input) then a() end
                    end)
                end
            end

            -- Build option list
            local scroll = sheet:FindFirstChild("ScrollingFrame")

            for _, option in ipairs(Info.Options or {}) do
                local optBtn = Examples.DropdownButtonExample:Clone()
                if not optBtn then continue end

                local oTitle = optBtn:FindFirstChild("Labels")
                    and optBtn.Labels:FindFirstChild("Title")
                local oDesc  = optBtn:FindFirstChild("Labels")
                    and optBtn.Labels:FindFirstChild("Description")

                optBtn.Size = UDim2.new(1, 0, 0,
                    math.max(optBtn.Size.Y.Offset, Metrics.Touch + Metrics.PadY))

                if oTitle then oTitle.Text = tostring(option) end
                if oDesc  then oDesc:Destroy() end

                -- Pre-highlight the current selection
                if curValue == option then
                    optBtn.BackgroundColor3 =
                        LerpColor(Theme.Interactables, Theme.Accent, 0.30)
                end

                Animations.AddPressEffect(optBtn)
                SetProps(optBtn, { Parent = scroll or sheet, Visible = true })

                -- FIX: always SELECT (not toggle) — was `not current.Value`
                local a = MakeActivate(function()
                    curValue = option
                    if selLabel then selLabel.Text = tostring(option) end

                    -- Deselect all others
                    if scroll then
                        for _, ob in ipairs(scroll:GetChildren()) do
                            if ob:IsA("TextButton") then
                                ob.BackgroundColor3 = Theme.Component
                            end
                        end
                    end
                    optBtn.BackgroundColor3 =
                        LerpColor(Theme.Interactables, Theme.Accent, 0.30)

                    if Info.Callback then Info.Callback(option) end
                    task.delay(0.10, CloseSheet)
                end, 0.18)

                optBtn.InputBegan:Connect(function(input)
                    if IsPress(input) then a() end
                end)
            end
        end

        local act = MakeActivate(OpenSheet, 0.20)
        Animations.AddPressEffect(dd)
        dd.InputBegan:Connect(function(input)
            if IsPress(input) then act() end
        end)

        if titleL then titleL.Text = Info.Title       or "Dropdown" end
        if descL  then descL.Text  = Info.Description or "" end
        SetProps(dd, { Name = Info.Title or "Dropdown", Parent = Info.Tab, Visible = true })

        return dd
    end

    -- ──────────────────────────────────────────────────────────
    -- Slider
    -- FIX: removed duplicate Fire.InputBegan connection
    --      single touchRef tracker for one-finger drag
    --      enlarged hit-area on mobile
    -- ──────────────────────────────────────────────────────────

    function Options:AddSlider(Info)
        local sl = Components.Slider:Clone()
        if not sl then return end

        local titleL, descL = Options:GetLabels(sl)

        local inner  = sl:FindFirstChild("Slider")
        local main   = inner and inner:FindFirstChild("Main")
        local amount = main  and main:FindFirstChild("Input")
        local track  = inner and inner:FindFirstChild("Slide")
        local fill   = track and track:FindFirstChild("Highlight")
        local circle = fill  and fill:FindFirstChild("Circle")
        local fire   = track and track:FindFirstChild("Fire")

        if not (track and fill and circle and fire) then
            warn("[UILib] Slider template missing children")
            return
        end

        local trackH   = IsTouchDevice and (6 + Metrics.Scale) or 4
        local handleSz = IsTouchDevice
            and math.clamp(math.floor(24 * Metrics.Scale), 20, 30) or 14

        track.Size  = UDim2.new(1, 0, 0, trackH)
        circle.Size = UDim2.fromOffset(handleSz, handleSz)

        fill.BackgroundColor3   = Theme.Accent
        circle.BackgroundColor3 = Theme.AccentGlow

        local minVal   = Info.MinValue     or 0
        local maxVal   = Info.MaxValue     or 100
        local value    = Info.DefaultValue or minVal
        local active   = false
        local touchRef = nil   -- track one touch pointer only

        -- Enlarge the invisible "Fire" hit zone on mobile
        if IsTouchDevice then
            local hitH = math.max(44, handleSz + 18)
            fire.Size     = UDim2.new(1, 0, 0, hitH)
            fire.Position = UDim2.new(0, 0, 0.5, -(hitH / 2))
        end

        local function Round(n)
            if Info.AllowDecimals then
                local p = 10 ^ (Info.DecimalAmount or 2)
                return math.floor(n * p + 0.5) / p
            end
            return math.round(n)
        end

        local function ApplyValue(v)
            local clamped = math.clamp(v, minVal, maxVal)
            local scale   = (clamped - minVal) / (maxVal - minVal)
            value = Round(clamped)
            if amount then amount.Text = tostring(value) end
            fill.Size       = UDim2.fromScale(scale, 1)
            circle.Position = UDim2.new(scale, -(handleSz / 2), 0.5, 0)
            if Info.Callback then Info.Callback(value) end
        end

        local function ApplyFromX(rawX)
            local sz = track.AbsoluteSize.X
            if sz <= 0 then return end
            local scale = math.clamp(
                (rawX - track.AbsolutePosition.X) / sz,
                0, 1
            )
            ApplyValue(minVal + scale * (maxVal - minVal))
        end

        -- InputBegan on fire zone (single connection)
        fire.InputBegan:Connect(function(input)
            local t = input.UserInputType
            if t == Enum.UserInputType.MouseButton1 then
                active    = true
                touchRef  = nil
                ApplyFromX(Mouse.X)
                Tween(fill, 0.08, { BackgroundColor3 = Theme.AccentGlow })

            elseif t == Enum.UserInputType.Touch then
                if touchRef then return end   -- ignore extra fingers
                active   = true
                touchRef = input
                ApplyFromX(input.Position.X)
                Tween(fill, 0.08, { BackgroundColor3 = Theme.AccentGlow })
            end
        end)

        -- InputChanged (global)
        UserInputService.InputChanged:Connect(function(input)
            if not active then return end
            local t = input.UserInputType
            if t == Enum.UserInputType.MouseMovement and not touchRef then
                ApplyFromX(Mouse.X)
            elseif touchRef and input == touchRef then
                ApplyFromX(input.Position.X)
            end
        end)

        -- InputEnded (global)
        UserInputService.InputEnded:Connect(function(input)
            local t  = input.UserInputType
            local m  = t == Enum.UserInputType.MouseButton1 and not touchRef
            local tc = input == touchRef
            if m or tc then
                active   = false
                touchRef = nil
                Tween(fill, 0.14, { BackgroundColor3 = Theme.Accent })
            end
        end)

        -- Manual text entry
        if amount then
            amount.FocusLost:Connect(function()
                ApplyValue(tonumber(amount.Text) or value)
            end)
        end

        ApplyValue(value)

        Animations.AddPressEffect(sl)
        if titleL then titleL.Text = Info.Title       or "Slider" end
        if descL  then descL.Text  = Info.Description or "" end
        SetProps(sl, { Name = Info.Title or "Slider", Parent = Info.Tab, Visible = true })

        return { SetValue = ApplyValue }
    end

