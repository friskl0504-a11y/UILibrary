            end)

            Connect(TextBox.FocusLost, function()
                if Stroke then
                    Tween(Stroke, 0.16, { Color = Theme.Outline, Thickness = 1 })
                end
                ShiftForKeyboard(false)
                if Info.Callback then Info.Callback(TextBox.Text) end
            end)
        end

        Connect(Input.MouseButton1Click, function()
            if TextBox then TextBox:CaptureFocus() end
        end)

        Connect(Input.InputBegan, function(Inp)
            if Inp.UserInputType == Enum.UserInputType.Touch then
                if TextBox then TextBox:CaptureFocus() end
            end
        end)

        Animations:Component(Input)
        if Title then Title.Text = Info.Title or "Input" end
        if Description then Description.Text = Info.Description or "" end
        SetProperty(Input, {
            Name = Info.Title or "Input",
            Parent = Info.Tab,
            Visible = true,
