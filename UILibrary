--// Helpers
local function Tween(Object, Speed, Properties, Info)
    if not Object or not Object.Parent then return end
    local Style, Direction
    if Info then
        Style, Direction = Info.EasingStyle, Info.EasingDirection
    else
        Style, Direction = Enum.EasingStyle.Exponential, Enum.EasingDirection.Out
    end
    local AdjustedSpeed = IsMobile and (Speed * 1.1) or Speed
    local tw = Services.Tween:Create(Object, TweenInfo.new(AdjustedSpeed, Style, Direction), Properties)
    if tw then tw:Play() end
    return tw
end

local function TweenSpring(Object, Speed, Properties)
    if not Object or not Object.Parent then return end
    local AdjustedSpeed = IsMobile and (Speed * 1.1) or Speed
    local tw = Services.Tween:Create(
        Object,
        TweenInfo.new(AdjustedSpeed, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        Properties
    )
    if tw then tw:Play() end
    return tw
end

local function SetProperty(Object, Properties)
    for Index, Property in next, Properties do
        Object[Index] = Property
    end
    return Object
end

local function Multiply(Value, Amount)
    return UDim2.new(
        Value.X.Scale * Amount,
        Value.X.Offset * Amount,
        Value.Y.Scale * Amount,
        Value.Y.Offset * Amount
    )
end

local function ColorAdjust(Color, Factor, Mode)
    Mode = Mode or Setup.ThemeMode
    if Mode == "Light" then
        return Color3.fromRGB(
            math.clamp((Color.R * 255) - Factor, 0, 255),
            math.clamp((Color.G * 255) - Factor, 0, 255),
            math.clamp((Color.B * 255) - Factor, 0, 255)
        )
    else
        return Color3.fromRGB(
            math.clamp((Color.R * 255) + Factor, 0, 255),
            math.clamp((Color.G * 255) + Factor, 0, 255),
            math.clamp((Color.B * 255) + Factor, 0, 255)
        )
    end
end

local function LerpColor(c1, c2, t)
    return Color3.new(
        c1.R + (c2.R - c1.R) * t,
        c1.G + (c2.G - c1.G) * t,
        c1.B + (c2.B - c1.B) * t
    )
end

--// Drag
local function Drag(Canvas)
    if not Canvas then return end
    local Dragging, DragInput, Start, StartPos = false, nil, nil, nil
    local LastDragTime = 0
    local DragThrottle = 0.016

    local function Update(inputPosition)
        local currentTime = tick()
        if currentTime - LastDragTime < DragThrottle then return end
        LastDragTime = currentTime

        local delta = inputPosition - Start
        Canvas.Position = UDim2.new(
            StartPos.X.Scale,
            StartPos.X.Offset + delta.X,
            StartPos.Y.Scale,
            StartPos.Y.Offset + delta.Y
        )
    end

    local function ClampToScreen()
        local vp = GetViewportSize()
        local abs = Canvas.AbsolutePosition
        local sz = Canvas.AbsoluteSize

        local minX = Metrics.SafeAreaInset
        local maxX = math.max(minX, vp.X - sz.X - Metrics.SafeAreaInset)
        local minY = Metrics.SafeAreaInset
        local maxY = math.max(minY, vp.Y - sz.Y - Metrics.SafeAreaInset)

        local px = math.clamp(abs.X, minX, maxX)
        local py = math.clamp(abs.Y, minY, maxY)
        Tween(Canvas, 0.15, { Position = UDim2.new(0, px, 0, py) })
    end

    Connect(Canvas.InputBegan, function(Input)
        local isTouch = Input.UserInputType == Enum.UserInputType.Touch
        local isMouse = Input.UserInputType == Enum.UserInputType.MouseButton1
        if (isMouse or isTouch) and not Type then
            Dragging = true
            Start = Input.Position
            StartPos = Canvas.Position

            Connect(Input.Changed, function()
                if Input.UserInputState == Enum.UserInputState.End then
                    Dragging = false
                    ClampToScreen()
                end
            end)
        end
    end)

    Connect(Canvas.InputChanged, function(Input)
        local isMove = Input.UserInputType == Enum.UserInputType.MouseMovement
        local isTouch = Input.UserInputType == Enum.UserInputType.Touch
        if (isMove or isTouch) and not Type then
            DragInput = Input
        end
    end)

    Connect(Services.Input.InputChanged, function(Input)
        if Input == DragInput and Dragging and not Type then
            Update(Input.Position)
        end
    end)
end

--// Resize (desktop only)
local Resizing = {
    TopLeft     = { X = Vector2.new(-1, 0), Y = Vector2.new(0, -1) },
    TopRight    = { X = Vector2.new(1, 0), Y = Vector2.new(0, -1) },
    BottomLeft  = { X = Vector2.new(-1, 0), Y = Vector2.new(0, 1) },
    BottomRight = { X = Vector2.new(1, 0), Y = Vector2.new(0, 1) },
}

local function Resizeable(Tab, Minimum, Maximum)
    if IsMobile then return end

    task.spawn(function()
        local MousePos, Size, UIPos = nil, nil, nil

        if Tab and Tab:FindFirstChild("Resize") then
            local Positions = Tab:FindFirstChild("Resize")
            for _, Types in next, Positions:GetChildren() do
                Connect(Types.InputBegan, function(Input)
                    if Input.UserInputType == Enum.UserInputType.MouseButton1 then
                        Type = Types
                        MousePos = Vector2.new(Player.Mouse.X, Player.Mouse.Y)
                        Size = Tab.AbsoluteSize
                        UIPos = Tab.Position
                    end
                end)

                Connect(Types.InputEnded, function(Input)
                    if Input.UserInputType == Enum.UserInputType.MouseButton1 then
                        Type = nil
                    end
                end)
            end
        end

        local function Resize(Delta)
            if Type and MousePos and Size and UIPos and Tab:FindFirstChild("Resize")[Type.Name] == Type then
                local Mode = Resizing[Type.Name]
                local NewSize = Vector2.new(
                    Size.X + Delta.X * Mode.X.X,
                    Size.Y + Delta.Y * Mode.Y.Y
                )
                NewSize = Vector2.new(
                    math.clamp(NewSize.X, Minimum.X, Maximum.X),
                    math.clamp(NewSize.Y, Minimum.Y, Maximum.Y)
                )

                local AnchorOffset = Vector2.new(Tab.AnchorPoint.X * Size.X, Tab.AnchorPoint.Y * Size.Y)
                local NewAnchorOffset = Vector2.new(Tab.AnchorPoint.X * NewSize.X, Tab.AnchorPoint.Y * NewSize.Y)
                local DeltaAnchor = NewAnchorOffset - AnchorOffset

                Tab.Size = UDim2.new(0, NewSize.X, 0, NewSize.Y)
                Tab.Position = UDim2.new(
                    UIPos.X.Scale,
                    UIPos.X.Offset + DeltaAnchor.X * Mode.X.X,
                    UIPos.Y.Scale,
                    UIPos.Y.Offset + DeltaAnchor.Y * Mode.Y.Y
                )
            end
        end

        Connect(Player.Mouse.Move, function()
            if Type then
                Resize(Vector2.new(Player.Mouse.X, Player.Mouse.Y) - MousePos)
            end
        end)
    end)
end


