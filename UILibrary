--// Mobile floating toggle
local function CreateMobileToggle(ScreenGui, OnToggle)
    if not IsTouchDevice or not ScreenGui then return nil end

    local Existing = ScreenGui:FindFirstChild("MobileToggle")
    if Existing then Existing:Destroy() end

    local Btn = Instance.new("TextButton")
    Btn.Name = "MobileToggle"
    Btn.Parent = ScreenGui
    Btn.Size = UDim2.fromOffset(math.clamp(math.floor(58 * Metrics.ScreenScale), 54, 64), math.clamp(math.floor(58 * Metrics.ScreenScale), 54, 64))
    Btn.AnchorPoint = Vector2.new(1, 1)
    Btn.Position = UDim2.new(1, -(14 + Metrics.SafeAreaInset), 1, -(18 + Metrics.SafeAreaInset))
    Btn.BackgroundColor3 = Theme.Component
    Btn.Text = "≡"
    Btn.TextColor3 = Theme.Title
    Btn.TextSize = 18
    Btn.Font = Enum.Font.GothamBold
    Btn.AutoButtonColor = false
    Btn.ZIndex = 999999
    Btn.Visible = true

    local Corner = Instance.new("UICorner")
    Corner.CornerRadius = UDim.new(1, 0)
    Corner.Parent = Btn

    local Stroke = Instance.new("UIStroke")
    Stroke.Color = Theme.Outline
    Stroke.Thickness = 1.2
    Stroke.Transparency = 0.12
    Stroke.Parent = Btn

    local dragging = false
    local startPos, startInputPos
    local movedDistance = 0
    local dragThreshold = 10

    Btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            movedDistance = 0
            startPos = Btn.Position
            startInputPos = input.Position
        end
    end)

    Btn.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.Touch then
            local delta = input.Position - startInputPos
            movedDistance = math.max(movedDistance, delta.Magnitude)

            local nx = startPos.X.Offset + delta.X
            local ny = startPos.Y.Offset + delta.Y

            local vp = Metrics.ScreenSize
            local bw, bh = Btn.AbsoluteSize.X, Btn.AbsoluteSize.Y
            nx = math.clamp(nx, -(vp.X - bw - 8), -8)
            ny = math.clamp(ny, -(vp.Y - bh - 8), -(8 + Metrics.SafeAreaInset))

            Btn.Position = UDim2.new(1, nx, 1, ny)
        end
    end)

    Services.Input.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch and dragging then
            dragging = false
            if movedDistance < dragThreshold and OnToggle then
                Tween(Btn, 0.08, { BackgroundColor3 = Theme.AccentGlow })
                task.delay(0.08, function()
                    if Btn and Btn.Parent then
                        Tween(Btn, 0.15, { BackgroundColor3 = Theme.Component })
                    end
                end)
                OnToggle()
            end
        end
    end)

    return Btn
end


--// Data tables
local Animations = {}
local Blurs = {}
local Components = Screen:FindFirstChild("Components")
local Library = {}
local StoredInfo = {
    Sections = {},
    Tabs = {},
}

--// Window animations
function Animations:Open(Window, Transparency, UseCurrentSize)
    local Original = (UseCurrentSize and Window.Size) or Setup.Size
    local Multiplied = Multiply(Original, 0.92)
    local Shadow = Window:FindFirstChildOfClass("UIStroke")

    if Shadow then SetProperty(Shadow, { Transparency = 1 }) end
    SetProperty(Window, {
        Size = Multiplied,
        GroupTransparency = 1,
        Visible = true,
    })

    if Shadow then Tween(Shadow, 0.28, { Transparency = 0.45 }) end
    TweenSpring(Window, 0.32, {
        Size = Original,
        GroupTransparency = Transparency or 0,
    })
end

function Animations:Close(Window)
    local Original = Window.Size
    local Multiplied = Multiply(Original, 0.92)
    local Shadow = Window:FindFirstChildOfClass("UIStroke")

    if Shadow then Tween(Shadow, 0.18, { Transparency = 1 }) end
    Tween(Window, 0.18, {
        Size = Multiplied,
        GroupTransparency = 1,
    })

    task.wait(0.2)
    Window.Size = Original
    Window.Visible = false
end

function Animations:Component(Component, Custom)
    if not Component or not Component.Parent then return end
    local lastPressTime = 0
    local pressThrottle = 0.1

    Connect(Component.InputBegan, function(Input)
        local isValid = Input.UserInputType == Enum.UserInputType.MouseButton1
            or Input.UserInputType == Enum.UserInputType.Touch
        if not isValid then return end

        local currentTime = tick()
        if currentTime - lastPressTime < pressThrottle then return end
        lastPressTime = currentTime

        if Custom then
            Tween(Component, 0.12, { Transparency = 0.75 })
        else
            local pressColor = IsMobile and LerpColor(Theme.Component, Theme.Accent, 0.12)
                or ColorAdjust(Theme.Component, 8, Setup.ThemeMode)
            Tween(Component, 0.1, { BackgroundColor3 = pressColor })
        end
    end)

    Connect(Component.InputEnded, function(Input)
        local isValid = Input.UserInputType == Enum.UserInputType.MouseButton1
            or Input.UserInputType == Enum.UserInputType.Touch
        if not isValid then return end

        if Custom then
            Tween(Component, 0.16, { Transparency = 1 })
        else
            Tween(Component, 0.16, { BackgroundColor3 = Theme.Component })
        end
    end)
end

--// Library main
function Library:CreateWindow(Settings)
    if Settings.AccentColor then
        Theme.Accent = Settings.AccentColor
        Theme.AccentDark = Color3.new(
            math.max(Settings.AccentColor.R - 0.15, 0),
            math.max(Settings.AccentColor.G - 0.15, 0),
            math.max(Settings.AccentColor.B - 0.15, 0)
        )
    end

    local Window = Clone(Screen:WaitForChild("Main"))
    local Sidebar = Window:FindFirstChild("Sidebar")
    local Holder = Window:FindFirstChild("Main")
    local BG = Window:FindFirstChild("BackgroundShadow")
    local TabList = Sidebar:FindFirstChild("Tab")

    local Options = {}
    local Examples = {}
    local Opened = true
    local Maximized = false
    local BlurEnabled = false
    local MobileToggleButton

    local function ApplyMobileLayout()
        if not IsTouchDevice or not Window or not Window.Parent then return end
        RecomputeMetrics()

        local inset = Metrics.SafeAreaInset
        if Settings.MobileFullscreen == true or Metrics.ScreenSize.X <= 430 then
            Window.Size = UDim2.new(1, -(inset * 2), 1, -(inset * 2))
        else
            local w = Metrics.IsLandscape and (Metrics.IsCompact and 0.82 or 0.76) or 0.94
            local h = Metrics.IsLandscape and 0.88 or (Metrics.IsCompact and 0.78 or 0.84)
            Window.Size = Settings.Size or UDim2.fromScale(w, h)
        end

        Window.AnchorPoint = Vector2.new(0.5, 0.5)
        Window.Position = UDim2.fromScale(0.5, Metrics.IsLandscape and 0.50 or 0.53)
    end

    if IsTouchDevice then
        Settings.Size = nil
        ApplyMobileLayout()
    end

    for _, Example in next, Window:GetDescendants() do
        if Example.Name:find("Example") and not Examples[Example.Name] then
            Examples[Example.Name] = Example
        end
    end

    Drag(Window)
    Resizeable(Window, Vector2.new(411, 271), Vector2.new(9e9, 9e9))
    Setup.Transparency = 0
    Setup.Size = Settings.Size or Window.Size
    Setup.ThemeMode = Settings.Theme or "Dark"

    if Settings.Blurring then
        Blurs[Settings.Title] = Blur.new(Window, 5)
        BlurEnabled = true
    end

    if Settings.MinimizeKeybind then
        Setup.Keybind = Settings.MinimizeKeybind
    end

    local function Close()
        if Opened then
            if BlurEnabled and Blurs[Settings.Title] then
                Blurs[Settings.Title].root.Parent = nil
            end
            Opened = false
            Animations:Close(Window)
            Window.Visible = false
            if MobileToggleButton then MobileToggleButton.Text = "≡" end
        else
            Animations:Open(Window, 0)
            Opened = true
            if BlurEnabled and Blurs[Settings.Title] then
                Blurs[Settings.Title].root.Parent = workspace.CurrentCamera
            end
            if MobileToggleButton then MobileToggleButton.Text = "×" end
        end
    end

    -- Titlebar buttons
    for _, Button in next, Sidebar.Top.Buttons:GetChildren() do
        if Button:IsA("TextButton") then
            local Name = Button.Name
            Animations:Component(Button, true)

            Connect(Button.MouseButton1Click, function()
                if Name == "Close" then
                    Close()

                elseif Name == "Maximize" then
                    if Maximized then
                        Maximized = false
                        Tween(Window, 0.2, { Size = Setup.Size })
                    else
                        Maximized = true
                        Tween(Window, 0.2, {
                            Size = UDim2.fromScale(1, 1),
                            Position = UDim2.fromScale(0.5, 0.5),
                        })
                    end

                elseif Name == "Minimize" then
                    Opened = false
                    Window.Visible = false
                    if Blurs[Settings.Title] then
                        Blurs[Settings.Title].root.Parent = nil
                    end
                    if MobileToggleButton then MobileToggleButton.Text = "≡" end
                end
            end)
        end
    end

    -- Keyboard toggle (desktop)
    Services.Input.InputBegan:Connect(function(Input, Focused)
        if (Input == Setup.Keybind or Input.KeyCode == Setup.Keybind) and not Focused then
            Close()
        end
    end)

    -- Tabs
    function Options:SetTab(Name)
        for _, Button in next, TabList:GetChildren() do
            if Button:IsA("TextButton") then
                local IsOpen = Button.Value
                local SameName = (Button.Name == Name)
                local Padding = Button:FindFirstChildOfClass("UIPadding")

                if SameName and not IsOpen.Value then
                    if Padding then Tween(Padding, 0.22, { PaddingLeft = UDim.new(0, 25) }) end
                    Tween(Button, 0.22, {
                        BackgroundTransparency = 0.80,
                        BackgroundColor3 = Theme.Accent,
                        Size = UDim2.new(1, -15, 0, Setup.TouchTargetMin),
                    })
                    IsOpen.Value = true

                elseif not SameName and IsOpen.Value then
                    if Padding then Tween(Padding, 0.22, { PaddingLeft = UDim.new(0, 20) }) end
                    Tween(Button, 0.22, {
                        BackgroundTransparency = 1,
                        BackgroundColor3 = Theme.Component,
                        Size = UDim2.new(1, -44, 0, Setup.TouchTargetMin),
                    })
                    IsOpen.Value = false
                end
            end
        end

        for _, Main in next, Holder:GetChildren() do
            if Main:IsA("CanvasGroup") then
                local IsOpen = Main.Value
                local SameName = (Main.Name == Name)
                local Scroll = Main:FindFirstChild("ScrollingFrame")

                if SameName and not IsOpen.Value then
                    IsOpen.Value = true
                    Main.Visible = true
                    Tween(Main, 0.24, { GroupTransparency = 0 })
                    if Scroll and Scroll:FindFirstChild("UIPadding") then
                        Tween(Scroll.UIPadding, 0.24, { PaddingTop = UDim.new(0, 6) })
                    end

                elseif not SameName and IsOpen.Value then
                    IsOpen.Value = false
                    Tween(Main, 0.16, { GroupTransparency = 1 })
                    if Scroll and Scroll:FindFirstChild("UIPadding") then
                        Tween(Scroll.UIPadding, 0.16, { PaddingTop = UDim.new(0, 16) })
                    end
                    task.delay(0.18, function()
                        if Main then Main.Visible = false end
                    end)
                end
            end
        end
    end

    function Options:AddTabSection(Info)
        local Example = Examples.SectionExample
        local Section = Clone(Example)
        StoredInfo.Sections[Info.Name] = Info.Order
        SetProperty(Section, {
            Parent = Example.Parent,
            Text = Info.Name,
            Name = Info.Name,
            LayoutOrder = Info.Order,
            Visible = true,
        })
    end

    function Options:AddTab(Info)
        if StoredInfo.Tabs[Info.Title] then
            error("[UI LIB]: A tab with the same name already exists")
        end

        local Example = Examples.TabButtonExample
        local MainExample = Examples.MainExample
        local SectionOrder = StoredInfo.Sections[Info.Section]
        local Main = Clone(MainExample)
        local Tab = Clone(Example)

        if not Info.Icon then
            Destroy(Tab.ICO)
        else
            Tab.ICO.Image = Info.Icon
        end

        StoredInfo.Tabs[Info.Title] = { Tab }
        Tab.TextLabel.Text = Info.Title
        Tab.Size = UDim2.new(1, -44, 0, Setup.TouchTargetMin)

        SetProperty(Main, {
            Parent = MainExample.Parent,
            Name = Info.Title,
        })

        SetProperty(Tab, {
            Parent = Example.Parent,
            LayoutOrder = SectionOrder or (#StoredInfo.Sections + 1),
            Name = Info.Title,
            Visible = true,
        })

        Connect(Tab.MouseButton1Click, function()
            Options:SetTab(Tab.Name)
        end)

        Connect(Tab.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.Touch then
                Options:SetTab(Tab.Name)
            end
        end)

        return Main.ScrollingFrame
    end

    -- Notifications
    local NOTIF_HEIGHT = IsMobile and 64 or 70
    local NOTIF_GAP = IsMobile and 6 or 8
    local NOTIF_MAX = Setup.MaxNotifications
    local NOTIF_TIMEOUT = 2.0

    local function RepositionNotifications()
        for i, notif in ipairs(ActiveNotifications) do
            if notif and notif.Parent then
                local yOffset = (i - 1) * (NOTIF_HEIGHT + NOTIF_GAP)
                Tween(notif, 0.18, {
                    Position = UDim2.new(1, -Setup.PaddingX - 10, 1, -(yOffset + NOTIF_HEIGHT + 10 + Metrics.SafeAreaInset))
                })
            end
        end
    end

    function Options:Notify(Info)
        if #ActiveNotifications >= NOTIF_MAX then
            local oldest = table.remove(ActiveNotifications, 1)
            if oldest and oldest.Parent then
                Animations:Close(oldest)
                task.delay(NOTIF_TIMEOUT, function()
                    if oldest and oldest.Parent then oldest:Destroy() end
                end)
            end
        end

        local Notification = Clone(Components.Notification)
        if not Notification then return end

        local Title, Description = Options:GetLabels(Notification)
        local Timer = Notification.Timer

        if Timer and Timer:FindFirstChild("Fill") then
            Timer.Fill.BackgroundColor3 = Theme.Accent
        end

        if Title then Title.Text = Info.Title or "Notification" end
        if Description then Description.Text = Info.Description or "" end
        Notification.Parent = Screen.Frame

        Notification.Position = UDim2.new(1, 12, 1, -80)
        Notification.Visible = true
        Notification.GroupTransparency = 0

        table.insert(ActiveNotifications, Notification)
        RepositionNotifications()

        local Duration = Info.Duration or 2.8
        task.spawn(function()
            xpcall(function()
                Animations:Open(Notification, 0, true)
                if Timer then
                    Timer.Size = UDim2.new(1, 0, 0, 4)
                    Tween(Timer, Duration, { Size = UDim2.new(0, 0, 0, 4) })
                end
                task.wait(Duration)
                Animations:Close(Notification)
                task.wait(0.25)

                for i, n in ipairs(ActiveNotifications) do
                    if n == Notification then
                        table.remove(ActiveNotifications, i)
                        break
                    end
                end
                RepositionNotifications()

                task.wait(NOTIF_TIMEOUT)
                if Notification and Notification.Parent then Notification:Destroy() end
            end, function(err)
                warn("[UI LIB] Notification error:", err)
            end)
        end)
    end

