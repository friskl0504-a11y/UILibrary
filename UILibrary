    Panel1      = Color3.fromRGB(13,  13,  28),
    Panel2      = Color3.fromRGB(19,  19,  42),
    Panel3      = Color3.fromRGB(25,  25,  52),

    -- Accent colors
    Accent      = Color3.fromRGB(123, 111, 255),  -- stellar purple
    AccentDim   = Color3.fromRGB( 60,  53, 130),
    Teal        = Color3.fromRGB(  0, 212, 168),  -- stellar teal
    TealDim     = Color3.fromRGB(  0,  90,  72),

    -- Semantic colors
    Danger      = Color3.fromRGB(255,  79, 107),
    Warning     = Color3.fromRGB(251, 191,  36),
    Success     = Color3.fromRGB(  0, 212, 168),

