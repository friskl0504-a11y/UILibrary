-- ─────────────────────────────────────────────────────────────
-- Drag  (window dragging, fixed touch-ID tracking)
-- ─────────────────────────────────────────────────────────────

local function MakeDraggable(canvas)
    if not canvas then return end

    local dragging  = false
    local touchRef  = nil          -- track one specific touch pointer
    local startInp  = Vector2.new()
    local startPos  = UDim2.new()

    -- Clamp window inside the viewport with inset padding
    local function Clamp()
        local vp  = Metrics.VP
        local abs = canvas.AbsolutePosition
        local sz  = canvas.AbsoluteSize
        local pad = Metrics.Inset
        local px  = math.clamp(abs.X, pad, math.max(pad, vp.X - sz.X - pad))
        local py  = math.clamp(abs.Y, pad, math.max(pad, vp.Y - sz.Y - pad))
        Tween(canvas, 0.14, { Position = UDim2.new(0, px, 0, py) })
    end

    local function Move(pos2)
        if not dragging then return end
        local d = pos2 - startInp
        canvas.Position = UDim2.new(
            startPos.X.Scale,  startPos.X.Offset + d.X,
            startPos.Y.Scale,  startPos.Y.Offset + d.Y
        )
    end

    -- InputBegan: begin drag when mouse1 or first touch hits canvas
    canvas.InputBegan:Connect(function(input)
        if dragging then return end
        local t = input.UserInputType
        if t == Enum.UserInputType.Touch then
            if touchRef then return end   -- already tracking another finger
            touchRef = input
        elseif t ~= Enum.UserInputType.MouseButton1 then
            return
        end
        dragging = true
        startInp = Vector2.new(input.Position.X, input.Position.Y)
        startPos = canvas.Position
    end)

    -- InputChanged: move (global so we catch fast swipes outside canvas)
    UserInputService.InputChanged:Connect(function(input)
        if not dragging then return end
        local t = input.UserInputType
        if t == Enum.UserInputType.MouseMovement and not touchRef then
            Move(Vector2.new(input.Position.X, input.Position.Y))
        elseif touchRef and input == touchRef then
            Move(Vector2.new(input.Position.X, input.Position.Y))
        end
    end)

    -- InputEnded: release
    UserInputService.InputEnded:Connect(function(input)
        if not dragging then return end
        local t = input.UserInputType
        local isMouse = t == Enum.UserInputType.MouseButton1 and not touchRef
        local isTouch = input == touchRef
        if isMouse or isTouch then
            dragging = false
            touchRef = nil
            Clamp()
        end
    end)
end

-- ─────────────────────────────────────────────────────────────
-- Resize  (desktop only, own state – no shared global)
-- ─────────────────────────────────────────────────────────────

local ResizeDir = {
    TopLeft     = Vector2.new(-1, -1),
    TopRight    = Vector2.new( 1, -1),
    BottomLeft  = Vector2.new(-1,  1),
    BottomRight = Vector2.new( 1,  1),
}

local function MakeResizable(frame, minSz, maxSz)
    if IsTouchDevice then return end

    local resizing   = false
    local rDir       = nil
    local rStartMse  = Vector2.new()
    local rStartSz   = Vector2.new()
    local rStartPos  = UDim2.new()

    local handles = frame:FindFirstChild("Resize")
    if not handles then return end

    for _, h in ipairs(handles:GetChildren()) do
        h.InputBegan:Connect(function(input)
            if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
            resizing   = true
            rDir       = ResizeDir[h.Name]
            rStartMse  = Vector2.new(Mouse.X, Mouse.Y)
            rStartSz   = frame.AbsoluteSize
            rStartPos  = frame.Position
        end)
        h.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                resizing = false
            end
        end)
    end

    Mouse.Move:Connect(function()
        if not resizing or not rDir then return end
        local delta = Vector2.new(Mouse.X, Mouse.Y) - rStartMse
        local nw    = math.clamp(rStartSz.X + delta.X * rDir.X, minSz.X, maxSz.X)
        local nh    = math.clamp(rStartSz.Y + delta.Y * rDir.Y, minSz.Y, maxSz.Y)

        local px = rStartPos.X.Offset
        local py = rStartPos.Y.Offset
        if rDir.X < 0 then px = px + (rStartSz.X - nw) end
        if rDir.Y < 0 then py = py + (rStartSz.Y - nh) end

        frame.Size     = UDim2.new(0, nw, 0, nh)
        frame.Position = UDim2.new(rStartPos.X.Scale, px, rStartPos.Y.Scale, py)
    end)
end

-- ─────────────────────────────────────────────────────────────
-- Mobile floating toggle  (fixed snap-to-edge + drag/tap)
-- ─────────────────────────────────────────────────────────────

local function CreateMobileToggle(screenGui, onToggle)
    if not IsTouchDevice or not screenGui then return nil end

    local ex = screenGui:FindFirstChild("MobileToggle")
    if ex then ex:Destroy() end

    local bsz = math.clamp(math.floor(54 * Metrics.Scale), 48, 64)
    local pad = Metrics.Inset + 12

    local Btn = Instance.new("TextButton")
    SetProps(Btn, {
        Name            = "MobileToggle",
        Size            = UDim2.fromOffset(bsz, bsz),
        AnchorPoint     = Vector2.new(1, 1),
        Position        = UDim2.new(1, -pad, 1, -pad - 6),
        BackgroundColor3 = Theme.Component,
        Text            = "≡",
        TextColor3      = Theme.Title,
        TextSize        = 22,
        Font            = Enum.Font.GothamBold,
        AutoButtonColor = false,
        ZIndex          = 999998,
        Parent          = screenGui,
    })
    do
        local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(1, 0); c.Parent = Btn
        local s = Instance.new("UIStroke"); s.Color = Theme.Outline; s.Thickness = 1.5; s.Parent = Btn
    end

    -- Drag / tap state
    local THRESH    = 10              -- px before drag recognised
    local touchRef  = nil
    local startAbs  = Vector2.new()   -- Btn.AbsolutePosition when touch began
    local startInp  = Vector2.new()   -- input position when touch began
    local moved     = false

    -- Snap to nearest screen edge on release
    local function SnapToEdge()
        local vp  = Metrics.VP
        local bw  = Btn.AbsoluteSize.X
        local bh  = Btn.AbsoluteSize.Y
        local abs = Btn.AbsolutePosition
        local p   = Metrics.Inset + 10

        -- Determine nearest side (left/right)
        local toRight = (vp.X - abs.X - bw) < abs.X
        local py      = math.clamp(abs.Y, p, vp.Y - bh - p)

        if toRight then
            Btn.AnchorPoint = Vector2.new(1, 0)
            TweenSpring(Btn, 0.22, {
                Position = UDim2.new(1, -p, 0, py)
            })
        else
            Btn.AnchorPoint = Vector2.new(0, 0)
            TweenSpring(Btn, 0.22, {
                Position = UDim2.new(0, p, 0, py)
            })
        end
    end

    Btn.InputBegan:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.Touch then return end
        if touchRef then return end
        touchRef  = input
        moved     = false
        startAbs  = Btn.AbsolutePosition
        startInp  = Vector2.new(input.Position.X, input.Position.Y)
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input ~= touchRef then return end
        local delta = Vector2.new(input.Position.X, input.Position.Y) - startInp
        if delta.Magnitude >= THRESH then moved = true end
        if not moved then return end

        -- Free-drag: use absolute (0,0) anchor for simple offset math
        local vp = Metrics.VP
        local bw = Btn.AbsoluteSize.X
        local bh = Btn.AbsoluteSize.Y
        local p  = Metrics.Inset + 4

        local nx = math.clamp(startAbs.X + delta.X, p, vp.X - bw - p)
        local ny = math.clamp(startAbs.Y + delta.Y, p, vp.Y - bh - p)

        Btn.AnchorPoint = Vector2.new(0, 0)
        Btn.Position    = UDim2.new(0, nx, 0, ny)
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input ~= touchRef then return end
        touchRef = nil

        if not moved then
            -- Tap: flash and toggle
            Tween(Btn, 0.07, { BackgroundColor3 = Theme.Accent })
            task.delay(0.14, function()
                if Btn and Btn.Parent then
                    Tween(Btn, 0.20, { BackgroundColor3 = Theme.Component })
                end
            end)
            if onToggle then onToggle() end
        else
            -- Drag ended: snap
            SnapToEdge()
        end
    end)

    return Btn
end

-- ─────────────────────────────────────────────────────────────
-- Window animations
-- ─────────────────────────────────────────────────────────────

local Animations = {}

function Animations.Open(win, transparency, keepSize)
    local orig = win.Size
    local sm   = ScaleU2(orig, 0.93)
    local shad = win:FindFirstChildOfClass("UIStroke")

    if not keepSize then
        SetProps(win, { Size = sm, GroupTransparency = 1, Visible = true })
    else
        SetProps(win, { GroupTransparency = 1, Visible = true })
    end
    if shad then shad.Transparency = 1 end

    TweenSpring(win, 0.28, { Size = orig, GroupTransparency = transparency or 0 })
    if shad then Tween(shad, 0.26, { Transparency = 0.44 }) end
end

-- FIX: uses task.delay instead of task.wait — doesn't block the caller
function Animations.Close(win)
    local orig = win.Size
    local sm   = ScaleU2(orig, 0.93)
    local shad = win:FindFirstChildOfClass("UIStroke")

    if shad then Tween(shad, 0.14, { Transparency = 1 }) end
    Tween(win, 0.18, { GroupTransparency = 1, Size = sm })

    task.delay(0.22, function()
        if win and win.Parent then
            win.Visible = false
            win.Size    = orig
        end
    end)
end

-- Press feedback (used by all interactive components)
-- FIX: single InputBegan/InputEnded pair — no duplicate handlers
function Animations.AddPressEffect(comp, isGhost)
    if not comp then return end
    local down = false

    comp.InputBegan:Connect(function(input)
        if not IsPress(input) then return end
        if down then return end
        down = true
        if isGhost then
            Tween(comp, 0.10, { BackgroundTransparency = 0.55 })
        else
            Tween(comp, 0.10, {
                BackgroundColor3 = LerpColor(Theme.Component, Theme.Accent, 0.13)
            })
        end
    end)

    comp.InputEnded:Connect(function(input)
        if not IsPress(input) then return end
        if not down then return end
        down = false
        if isGhost then
            Tween(comp, 0.16, { BackgroundTransparency = 1 })
        else
            Tween(comp, 0.16, { BackgroundColor3 = Theme.Component })
        end
    end)
end

