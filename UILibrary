    function Options:AddKeybind(SettingsKeybind)
        local Dropdown = Clone(Components["Keybind"])
        if not Dropdown then return end

        local Title, Description = Options:GetLabels(Dropdown)
        local Bind = Dropdown["Main"] and Dropdown["Main"].Options

        local Mouse = {
            Enum.UserInputType.MouseButton1,
            Enum.UserInputType.MouseButton2,
            Enum.UserInputType.MouseButton3,
        }
        local Types = {
            ["Mouse"] = "Enum.UserInputType.MouseButton",
            ["Key"] = "Enum.KeyCode.",
        }

        local function StartListening()
            local Finished = false
            if Bind then SetProperty(Bind, { Text = "..." }) end

            local Stroke = Dropdown:FindFirstChildOfClass("UIStroke")
            if Stroke then Tween(Stroke, 0.15, { Color = Theme.Accent }) end

            local Detect
            Detect = Connect(game.UserInputService.InputBegan, function(Key, Focused)
                if not Finished and not Focused then
                    Finished = true
                    local InputType = Key.UserInputType

                    if table.find(Mouse, InputType) then
                        SettingsKeybind.Callback(Key)
                        if Bind then
                            SetProperty(Bind, { Text = tostring(InputType):gsub(Types.Mouse, "MB") })
                        end
                    elseif InputType == Enum.UserInputType.Keyboard then
                        SettingsKeybind.Callback(Key)
                        if Bind then
                            SetProperty(Bind, { Text = tostring(Key.KeyCode):gsub(Types.Key, "") })
                        end
                    elseif InputType == Enum.UserInputType.Touch then
                        SettingsKeybind.Callback(Key)
                        if Bind then SetProperty(Bind, { Text = "TAP" }) end
                    end

                    if Stroke then Tween(Stroke, 0.2, { Color = Theme.Outline }) end
                    Detect:Disconnect()
                end
            end)
        end

        Connect(Dropdown.MouseButton1Click, StartListening)
        Connect(Dropdown.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.Touch then StartListening() end
        end)

        Animations:Component(Dropdown)
        if Title then SetProperty(Title, { Text = SettingsKeybind.Title }) end
        if Description then SetProperty(Description, { Text = SettingsKeybind.Description }) end
        SetProperty(Dropdown, {
            Name = SettingsKeybind.Title,
            Parent = SettingsKeybind.Tab,
            Visible = true,
        })
    end

    function Options:AddDropdown(SettingsDropdown)
        local Dropdown = Clone(Components["Dropdown"])
        if not Dropdown then return end

        local Title, Description = Options:GetLabels(Dropdown)
        local Text = Dropdown["Main"] and Dropdown["Main"].Options

        local function OpenDropdown()
            local Example = Clone(Examples["DropdownExample"])
            if not Example then return end
            local Buttons = Example["Top"] and Example["Top"]["Buttons"]
            if not Buttons then return end

            if IsMobile then
                Example.Size = UDim2.new(1, -SafeAreaInset * 2, 1, -SafeAreaInset * 2)
                Example.Position = UDim2.fromScale(0.5, 0.5)
                Example.AnchorPoint = Vector2.new(0.5, 0.5)
            end

            Tween(BG, 0.2, { BackgroundTransparency = 0.5 })
            SetProperty(Example, { Parent = Window })
            Animations:Open(Example, 0, true)

            for _, Button in next, Buttons:GetChildren() do
                if Button:IsA("TextButton") then
                    Animations:Component(Button, true)

                    local function CloseDropdown()
                        Tween(BG, 0.2, { BackgroundTransparency = 1 })
                        Animations:Close(Example)
                        task.wait(2.5)
                        if Example and Example.Parent then Example:Destroy() end
                    end

                    Connect(Button.MouseButton1Click, CloseDropdown)
                    Connect(Button.InputBegan, function(Input)
                        if Input.UserInputType == Enum.UserInputType.Touch then CloseDropdown() end
                    end)
                end
            end

            for Index, Option in next, SettingsDropdown.Options do
                local Button = Clone(Examples["DropdownButtonExample"])
                if not Button then continue end

                local BTitle, BDesc = Options:GetLabels(Button)
                local Selected = Button["Value"]
                Button.Size = UDim2.new(1, 0, 0, math.max(Button.Size.Y.Offset, Setup.TouchTargetMin + Setup.PaddingY))

                Animations:Component(Button)
                if BTitle then SetProperty(BTitle, { Text = Index }) end
                SetProperty(Button, { Parent = Example.ScrollingFrame, Visible = true })
                if BDesc then BDesc:Destroy() end

                local function SelectOption()
                    local NewValue = not (Selected and Selected.Value or false)
                    if NewValue then
                        Tween(Button, 0.2, { BackgroundColor3 = LerpColor(Theme.Interactables, Theme.Accent, 0.25) })
                        SettingsDropdown.Callback(Option)
                        if Text then Text.Text = Index end

                        for _, Others in next, Example.ScrollingFrame:GetChildren() do
                            if Others:IsA("TextButton") and Others ~= Button then
                                Others.BackgroundColor3 = Theme.Component
                            end
                        end
                    else
                        Tween(Button, 0.2, { BackgroundColor3 = Theme.Component })
                    end

                    if Selected then Selected.Value = NewValue end
                    Tween(BG, 0.2, { BackgroundTransparency = 1 })
                    Animations:Close(Example)
                    task.wait(2.5)
                    if Example and Example.Parent then Example:Destroy() end
                end

                Connect(Button.MouseButton1Click, SelectOption)
                Connect(Button.InputBegan, function(Input)
                    if Input.UserInputType == Enum.UserInputType.Touch then SelectOption() end
                end)
            end
        end

        Connect(Dropdown.MouseButton1Click, OpenDropdown)
        Connect(Dropdown.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.Touch then OpenDropdown() end
        end)

        Animations:Component(Dropdown)
        if Title then SetProperty(Title, { Text = SettingsDropdown.Title }) end
        if Description then SetProperty(Description, { Text = SettingsDropdown.Description }) end
        SetProperty(Dropdown, {
            Name = SettingsDropdown.Title,
            Parent = SettingsDropdown.Tab,
            Visible = true,
        })
    end

    function Options:AddSlider(SettingsSlider)
        local Slider = Clone(Components["Slider"])
        if not Slider then return end

        local Title, Desc = Options:GetLabels(Slider)
        local Main = Slider["Slider"]
        local Amount = Main["Main"].Input
        local Slide = Main["Slide"]
        local Fire = Slide["Fire"]
        local Fill = Slide["Highlight"]
        local Circle = Fill["Circle"]

        local trackHeight = IsMobile and (6 + ScreenScale) or 4
        local handleSize = IsMobile and (20 + ScreenScale) or 14

        if Slide then Slide.Size = UDim2.new(1, 0, 0, trackHeight) end
        if Circle then Circle.Size = UDim2.new(0, handleSize, 0, handleSize) end
        if Fill then Fill.BackgroundColor3 = Theme.Accent end
        if Circle then Circle.BackgroundColor3 = Theme.AccentGlow end

        local MinValue = SettingsSlider.MinValue or 0
        local MaxValue = SettingsSlider.MaxValue or 100
        local Active = false
        local Value = SettingsSlider.DefaultValue or MinValue
        local LastUpdateTime = 0
        local UpdateThrottle = 0.016

        local function SetNumber(Number)
            if SettingsSlider.AllowDecimals then
                local Power = 10 ^ (SettingsSlider.DecimalAmount or 2)
                return math.floor(Number * Power + 0.5) / Power
            else
                return math.round(Number)
            end
        end

        local function UpdateFromX(RawX)
            local currentTime = tick()
            if IsMobile and (currentTime - LastUpdateTime < UpdateThrottle) then return end
            LastUpdateTime = currentTime

            if not Slide then return end
            local slidePos = Slide.AbsolutePosition.X
            local slideSize = Slide.AbsoluteSize.X
            local Scale = math.clamp((RawX - slidePos) / slideSize, 0, 1)
            Value = SetNumber(MinValue + Scale * (MaxValue - MinValue))

            if Amount then Amount.Text = tostring(Value) end
            if Fill then Fill.Size = UDim2.fromScale(Scale, 1) end
            if Circle then Circle.Position = UDim2.new(Scale, -(handleSize / 2), 0.5, 0) end

            SettingsSlider.Callback(Value)
        end

        local function UpdateFromNumber(Number)
            local Clamped = math.clamp(Number, MinValue, MaxValue)
            local Scale = (Clamped - MinValue) / (MaxValue - MinValue)

            Value = SetNumber(Clamped)
            if Amount then Amount.Text = tostring(Value) end
            if Fill then Fill.Size = UDim2.fromScale(Scale, 1) end
            if Circle then Circle.Position = UDim2.new(Scale, -(handleSize / 2), 0.5, 0) end
            SettingsSlider.Callback(Value)
        end

        Connect(Fire.MouseButton1Down, function()
            Active = true
            repeat
                task.wait()
                UpdateFromX(Player.Mouse.X)
            until not Active
        end)

        Connect(Fire.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.Touch then
                Active = true
                Connect(Input.Changed, function()
                    if Active then UpdateFromX(Input.Position.X) end
                end)
            end
        end)

        Connect(Services.Input.InputEnded, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1
                or Input.UserInputType == Enum.UserInputType.Touch then
                Active = false
            end
        end)

        Connect(Services.Input.TouchMoved, function(touch)
            if Active then UpdateFromX(touch.Position.X) end
        end)

        if Amount then
            Connect(Amount.FocusLost, function()
                UpdateFromNumber(tonumber(Amount.Text) or MinValue)
            end)
        end

        Connect(Fire.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.Touch
                or Input.UserInputType == Enum.UserInputType.MouseButton1 then
                if Fill then Tween(Fill, 0.08, { BackgroundColor3 = Theme.AccentGlow }) end
            end
        end)

        Connect(Fire.InputEnded, function(Input)
            if Input.UserInputType == Enum.UserInputType.Touch
                or Input.UserInputType == Enum.UserInputType.MouseButton1 then
                if Fill then Tween(Fill, 0.15, { BackgroundColor3 = Theme.Accent }) end
            end
        end)

        UpdateFromNumber(Value)

        Animations:Component(Slider)
        if Title then SetProperty(Title, { Text = SettingsSlider.Title }) end
        if Desc then SetProperty(Desc, { Text = SettingsSlider.Description }) end
        SetProperty(Slider, {
            Name = SettingsSlider.Title,
            Parent = SettingsSlider.Tab,
            Visible = true,
        })
    end

